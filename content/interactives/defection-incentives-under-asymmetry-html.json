{
  "slug": "defection-incentives-under-asymmetry",
  "type": "html",
  "title": "Defection Payoff Crossover",
  "concept": "A cartel member defects when the revenue from full production at the resulting lower market price exceeds the revenue from honoring the quota at the cartel's high price.",
  "interactiveId": "a676fd8e-3cd9-4693-a4a1-13840f3a355b",
  "sourcePieceId": "b4ffbd42-cd10-484e-b92e-3085f2303266",
  "publishedAt": 1777389169221,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Defection Payoff Crossover</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c92727;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .market-status {\n    margin: 18px 0;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .market-status div {\n    margin: 4px 0;\n  }\n  .market-status strong {\n    font-weight: 600;\n  }\n  .decision-panel {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px;\n    margin: 20px 0;\n  }\n  .option {\n    padding: 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    cursor: pointer;\n    transition: all 120ms ease;\n    text-align: center;\n  }\n  .option:hover {\n    border-color: var(--muted);\n    transform: translateY(-1px);\n  }\n  .option.selected {\n    border-color: var(--teal);\n    background: #f0faf9;\n  }\n  .option.best {\n    box-shadow: 0 0 0 2px var(--gold);\n  }\n  .option-title {\n    font-weight: 600;\n    margin-bottom: 8px;\n    font-size: 0.95rem;\n  }\n  .option-detail {\n    font-size: 0.85rem;\n    color: var(--muted);\n    margin: 4px 0;\n  }\n  .option-revenue {\n    font-size: 1.4rem;\n    font-weight: 700;\n    margin: 10px 0 6px;\n    font-variant-numeric: tabular-nums;\n  }\n  .option-label {\n    font-size: 0.75rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n  }\n  .result {\n    margin: 20px 0 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .result strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .decision-panel {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust your production capacity, then choose</h2>\n<p class=\"subhead\">The cartel sets a fixed quota. You decide: honor it or produce at full capacity.</p>\n\n<div class=\"control\">\n  <label for=\"capacity\">Your capacity:</label>\n  <input id=\"capacity\" type=\"range\" min=\"60\" max=\"200\" value=\"100\" step=\"1\" aria-describedby=\"capacity-out\">\n  <output id=\"capacity-out\" for=\"capacity\">100</output>\n</div>\n\n<div class=\"market-status\">\n  <div>Cartel quota (fixed): <strong>100</strong> units</div>\n  <div>Market price if you comply: <strong id=\"price-comply\">$10</strong> per unit</div>\n  <div>Market price if you defect: <strong id=\"price-defect\">$10</strong> per unit</div>\n</div>\n\n<div class=\"decision-panel\">\n  <div class=\"option\" id=\"option-comply\" data-choice=\"comply\" tabindex=\"0\" role=\"button\" aria-pressed=\"false\">\n    <div class=\"option-title\">Honor the quota</div>\n    <div class=\"option-detail\">Produce <span id=\"comply-volume\">100</span> units</div>\n    <div class=\"option-revenue\" id=\"comply-revenue\">1000</div>\n    <div class=\"option-label\">Revenue</div>\n  </div>\n  <div class=\"option\" id=\"option-defect\" data-choice=\"defect\" tabindex=\"0\" role=\"button\" aria-pressed=\"false\">\n    <div class=\"option-title\">Produce at capacity</div>\n    <div class=\"option-detail\">Produce <span id=\"defect-volume\">100</span> units</div>\n    <div class=\"option-revenue\" id=\"defect-revenue\">1000</div>\n    <div class=\"option-label\">Revenue</div>\n  </div>\n</div>\n\n<div class=\"result\" id=\"result\" style=\"display: none;\">\n  Your choice: <strong id=\"choice-made\">—</strong>. Revenue: <strong id=\"revenue-made\">—</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">At this capacity, both options yield the same revenue. The cartel holds.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('capacity');\n    var capOut = document.getElementById('capacity-out');\n    var priceComplyEl = document.getElementById('price-comply');\n    var priceDefectEl = document.getElementById('price-defect');\n    var complyVolumeEl = document.getElementById('comply-volume');\n    var defectVolumeEl = document.getElementById('defect-volume');\n    var complyRevenueEl = document.getElementById('comply-revenue');\n    var defectRevenueEl = document.getElementById('defect-revenue');\n    var optionComply = document.getElementById('option-comply');\n    var optionDefect = document.getElementById('option-defect');\n    var result = document.getElementById('result');\n    var choiceMade = document.getElementById('choice-made');\n    var revenueMade = document.getElementById('revenue-made');\n    var caption = document.getElementById('caption');\n\n    var QUOTA = 100;\n    var BASE_PRICE = 10;\n    var selected = null;\n\n    function marketPrice(totalSupply) {\n      var excessSupply = Math.max(0, totalSupply - 100);\n      var priceDecline = excessSupply * 0.05;\n      return Math.max(2, BASE_PRICE - priceDecline);\n    }\n\n    function update() {\n      var cap = +slider.value;\n      capOut.textContent = cap;\n\n      var complySupply = QUOTA;\n      var defectSupply = cap;\n\n      var priceComply = marketPrice(complySupply);\n      var priceDefect = marketPrice(defectSupply);\n\n      var complyRev = complySupply * priceComply;\n      var defectRev = defectSupply * priceDefect;\n\n      priceComplyEl.textContent = '$' + priceComply.toFixed(2);\n      priceDefectEl.textContent = '$' + priceDefect.toFixed(2);\n\n      complyVolumeEl.textContent = complySupply;\n      defectVolumeEl.textContent = defectSupply;\n\n      complyRevenueEl.textContent = Math.round(complyRev);\n      defectRevenueEl.textContent = Math.round(defectRev);\n\n      optionComply.classList.remove('best');\n      optionDefect.classList.remove('best');\n\n      if (complyRev > defectRev) {\n        optionComply.classList.add('best');\n      } else if (defectRev > complyRev) {\n        optionDefect.classList.add('best');\n      }\n\n      if (selected) {\n        showResult(selected);\n      } else {\n        updateCaption(cap, complyRev, defectRev);\n      }\n    }\n\n    function updateCaption(cap, complyRev, defectRev) {\n      var diff = Math.abs(defectRev - complyRev);\n      if (diff < 10) {\n        caption.textContent = 'At this capacity, both options yield similar revenue. The cartel holds.';\n      } else if (complyRev > defectRev) {\n        if (cap < 90) {\n          caption.textContent = 'Low capacity. Honoring the quota yields more revenue because you cannot gain enough volume to offset price erosion.';\n        } else {\n          caption.textContent = 'Even though you could produce more, the quota pays better. The high price compensates for the lower volume.';\n        }\n      } else {\n        var gap = defectRev - complyRev;\n        if (gap < 100) {\n          caption.textContent = 'Past the crossover. Full production now yields more revenue despite the price drop. Defection becomes attractive.';\n        } else if (gap < 300) {\n          caption.textContent = 'High capacity makes defection profitable. Volume gains outweigh the price collapse from flooding the market.';\n        } else {\n          caption.textContent = 'Capacity so high that even severe price erosion cannot offset volume gains. Defection dominates.';\n        }\n      }\n    }\n\n    function showResult(choice) {\n      var cap = +slider.value;\n      var complySupply = QUOTA;\n      var defectSupply = cap;\n      var priceComply = marketPrice(complySupply);\n      var priceDefect = marketPrice(defectSupply);\n      var complyRev = complySupply * priceComply;\n      var defectRev = defectSupply * priceDefect;\n\n      var rev = choice === 'comply' ? complyRev : defectRev;\n      choiceMade.textContent = choice === 'comply' ? 'Honor the quota' : 'Produce at capacity';\n      revenueMade.textContent = Math.round(rev);\n      result.style.display = 'block';\n\n      if (choice === 'comply' && complyRev >= defectRev) {\n        caption.textContent = 'You chose the higher-revenue path. The cartel holds because compliance pays.';\n      } else if (choice === 'defect' && defectRev >= complyRev) {\n        caption.textContent = 'You chose the higher-revenue path. The cartel breaks because defection pays more.';\n      } else if (choice === 'comply' && complyRev < defectRev) {\n        var loss = Math.round(defectRev - complyRev);\n        caption.textContent = 'You honored the quota, but defection would have earned ' + loss + ' more. Individual sacrifice for collective stability.';\n      } else {\n        var loss = Math.round(complyRev - defectRev);\n        caption.textContent = 'You defected, but compliance would have earned ' + loss + ' more. You left money on the table.';\n      }\n    }\n\n    function choose(choice) {\n      selected = choice;\n      optionComply.classList.remove('selected');\n      optionDefect.classList.remove('selected');\n      optionComply.setAttribute('aria-pressed', 'false');\n      optionDefect.setAttribute('aria-pressed', 'false');\n      if (choice === 'comply') {\n        optionComply.classList.add('selected');\n        optionComply.setAttribute('aria-pressed', 'true');\n      } else {\n        optionDefect.classList.add('selected');\n        optionDefect.setAttribute('aria-pressed', 'true');\n      }\n      showResult(choice);\n    }\n\n    optionComply.addEventListener('click', function () {\n      choose('comply');\n    });\n    optionDefect.addEventListener('click', function () {\n      choose('defect');\n    });\n\n    optionComply.addEventListener('keydown', function (e) {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        choose('comply');\n      }\n    });\n    optionDefect.addEventListener('keydown', function (e) {\n      if (e.key === 'Enter' || e.key === ' ') {\n        e.preventDefault();\n        choose('defect');\n      }\n    });\n\n    slider.addEventListener('input', function () {\n      selected = null;\n      result.style.display = 'none';\n      optionComply.classList.remove('selected');\n      optionDefect.classList.remove('selected');\n      optionComply.setAttribute('aria-pressed', 'false');\n      optionDefect.setAttribute('aria-pressed', 'false');\n      update();\n    });\n\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
