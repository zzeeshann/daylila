  "title": "Trait Frequency Shift",
  "concept": "When a trait improves survival in an environment, individuals carrying it reproduce more—over generations, the trait becomes common in the population.",
  "interactiveId": "c8d37c8a-71e1-4e4f-b994-8d33c44b6882",
  "sourcePieceId": "45fd292c-4e38-4f82-b7af-550faac3aaa4",
  "publishedAt": 1777772112810,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Trait Frequency Shift</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --variant-a: #8b7355;\n    --variant-b: #d4a574;\n    --food-hard: #5a4a3a;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 640px;\n    margin: 0 auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--food-hard);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .simulation {\n    margin: 24px 0;\n    padding: 24px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n  }\n  .generation-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 12px;\n  }\n  .population {\n    display: flex;\n    gap: 6px;\n    margin-bottom: 20px;\n    flex-wrap: wrap;\n    min-height: 100px;\n  }\n  .individual {\n    width: 18px;\n    height: 32px;\n    border-radius: 2px;\n    transition: all 180ms ease-out;\n    position: relative;\n  }\n  .individual.variant-a {\n    background: var(--variant-a);\n  }\n  .individual.variant-b {\n    background: var(--variant-b);\n  }\n  .individual.died {\n    opacity: 0.2;\n  }\n  .stats {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin-top: 20px;\n  }\n  .stat {\n    padding: 10px;\n    background: var(--bg);\n    border-radius: 4px;\n  }\n  .stat-label {\n    font-size: 0.7rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n  }\n  .stat-value {\n    font-size: 1.05rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .legend {\n    display: flex;\n    gap: 20px;\n    margin-bottom: 16px;\n    font-size: 0.85rem;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .legend-box {\n    width: 18px;\n    height: 18px;\n    border-radius: 2px;\n  }\n  .controls {\n    display: flex;\n    gap: 12px;\n    margin-top: 16px;\n  }\n  button {\n    padding: 8px 16px;\n    font-size: 0.9rem;\n    font-weight: 500;\n    border: 1px solid var(--line);\n    background: var(--bg);\n    color: var(--fg);\n    border-radius: 4px;\n    cursor: pointer;\n    transition: all 120ms;\n  }\n  button:hover {\n    background: #fff;\n    border-color: var(--muted);\n  }\n  button:disabled {\n    opacity: 0.4;\n    cursor: not-allowed;\n  }\n  p.caption {\n    margin: 16px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .stats {\n      grid-template-columns: 1fr;\n    }\n    .controls {\n      flex-direction: column;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to set food hardness</h2>\n<p class=\"subhead\">Two variants compete. One handles hard food better. Watch the population shift across generations.</p>\n\n<div class=\"control\">\n  <label for=\"hardness\">Food hardness:</label>\n  <input id=\"hardness\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"hardness-out\">\n  <output id=\"hardness-out\" for=\"hardness\">50</output>\n</div>\n\n<div class=\"simulation\">\n  <div class=\"legend\">\n    <div class=\"legend-item\">\n      <div class=\"legend-box\" style=\"background: var(--variant-a);\"></div>\n      <span>Strong jaw</span>\n    </div>\n    <div class=\"legend-item\">\n      <div class=\"legend-box\" style=\"background: var(--variant-b);\"></div>\n      <span>Weak jaw</span>\n    </div>\n  </div>\n  \n  <div class=\"generation-label\">Generation <span id=\"gen-num\">1</span></div>\n  <div class=\"population\" id=\"population\"></div>\n  \n  <div class=\"stats\">\n    <div class=\"stat\">\n      <div class=\"stat-label\">Strong jaw %</div>\n      <div class=\"stat-value\" id=\"freq-a\">50</div>\n    </div>\n    <div class=\"stat\">\n      <div class=\"stat-label\">Survival rate</div>\n      <div class=\"stat-value\" id=\"survival\">75</div>\n    </div>\n  </div>\n  \n  <div class=\"controls\">\n    <button id=\"step\">Next generation</button>\n    <button id=\"reset\">Reset</button>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Neutral environment. Both variants survive equally.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('hardness');\n    var hardnessOut = document.getElementById('hardness-out');\n    var popEl = document.getElementById('population');\n    var genNum = document.getElementById('gen-num');\n    var freqA = document.getElementById('freq-a');\n    var survivalEl = document.getElementById('survival');\n    var caption = document.getElementById('caption');\n    var stepBtn = document.getElementById('step');\n    var resetBtn = document.getElementById('reset');\n\n    var generation = 1;\n    var population = [];\n    var POPULATION_SIZE = 50;\n\n    function initPopulation() {\n      population = [];\n      for (var i = 0; i < POPULATION_SIZE; i++) {\n        population.push({\n          variant: i < POPULATION_SIZE / 2 ? 'a' : 'b',\n          alive: true\n        });\n      }\n      generation = 1;\n    }\n\n    function render() {\n      popEl.innerHTML = '';\n      for (var i = 0; i < population.length; i++) {\n        var ind = population[i];\n        var div = document.createElement('div');\n        div.className = 'individual variant-' + ind.variant;\n        if (!ind.alive) div.classList.add('died');\n        popEl.appendChild(div);\n      }\n    }\n\n    function updateStats() {\n      var alive = population.filter(function(p) { return p.alive; });\n      var aCount = alive.filter(function(p) { return p.variant === 'a'; }).length;\n      var percent = alive.length > 0 ? Math.round((aCount / alive.length) * 100) : 0;\n      freqA.textContent = percent;\n      \n      var survivalRate = Math.round((alive.length / population.length) * 100);\n      survivalEl.textContent = survivalRate;\n      \n      genNum.textContent = generation;\n    }\n\n    function updateCaption() {\n      var hardness = +slider.value;\n      if (hardness < 30) {\n        caption.textContent = 'Soft food. Both jaw types succeed equally—no selection pressure.';\n      } else if (hardness < 60) {\n        caption.textContent = 'Moderate hardness. Strong jaws gain a slight advantage.';\n      } else if (hardness < 80) {\n        caption.textContent = 'Hard food favours strong jaws. Weak-jaw variants struggle to feed.';\n      } else {\n        caption.textContent = 'Very hard food. Weak jaws fail to access nutrition—strong jaws dominate.';\n      }\n    }\n\n    function step() {\n      var hardness = +slider.value;\n      \n      // Survival phase: individuals with variant 'a' (strong jaw) survive better\n      // when food is harder\n      for (var i = 0; i < population.length; i++) {\n        var ind = population[i];\n        var survivalProb;\n        if (ind.variant === 'a') {\n          // Strong jaw: high survival regardless of hardness\n          survivalProb = 0.95 - (hardness / 100) * 0.15;\n        } else {\n          // Weak jaw: survival drops as hardness increases\n          survivalProb = 0.95 - (hardness / 100) * 0.75;\n        }\n        ind.alive = Math.random() < survivalProb;\n      }\n      \n      render();\n      updateStats();\n      \n      // Short delay before reproduction\n      setTimeout(function() {\n        reproduce();\n      }, 400);\n    }\n\n    function reproduce() {\n      // Survivors reproduce to fill population back to original size\n      var survivors = population.filter(function(p) { return p.alive; });\n      \n      if (survivors.length === 0) {\n        caption.textContent = 'Population extinct. Reset to continue.';\n        stepBtn.disabled = true;\n        return;\n      }\n      \n      var newPop = [];\n      for (var i = 0; i < POPULATION_SIZE; i++) {\n        var parent = survivors[Math.floor(Math.random() * survivors.length)];\n        newPop.push({\n          variant: parent.variant,\n          alive: true\n        });\n      }\n      \n      population = newPop;\n      generation++;\n      render();\n      updateStats();\n      updateCaption();\n    }\n\n    function reset() {\n      initPopulation();\n      render();\n      updateStats();\n      updateCaption();\n      stepBtn.disabled = false;\n    }\n\n    slider.addEventListener('input', function() {\n      hardnessOut.textContent = slider.value;\n      updateCaption();\n    });\n    \n    stepBtn.addEventListener('click', step);\n    resetBtn.addEventListener('click', reset);\n\n    initPopulation();\n    render();\n    updateStats();\n    updateCaption();\n  })();\n</script>\n</body>\n</html>"
  }
}
