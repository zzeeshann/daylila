{
  "slug": "observation-without-authority",
  "type": "html",
  "title": "Signal Threshold Mismatch",
  "concept": "When observed patterns accumulate below the threshold required for institutional action, warnings become documentation without intervention — the gap between detection and authority determines whether early information prevents later events.",
  "interactiveId": "35222b65-0052-4664-bd02-61bdf56eb2d5",
  "sourcePieceId": "871db594-7344-4fcd-bdaf-d410fa29d73c",
  "publishedAt": 1777347625432,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Signal Threshold Mismatch</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --signal: #c9a227;\n    --threshold: #1a6b62;\n    --alert: #d32f2f;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 140px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--signal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3.5ch;\n    text-align: right;\n  }\n  .chart-container {\n    position: relative;\n    width: 100%;\n    height: 280px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 20px;\n    margin-bottom: 16px;\n  }\n  .axis-label {\n    position: absolute;\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n  }\n  .axis-label.y {\n    left: 8px;\n    top: 8px;\n  }\n  .axis-label.x {\n    right: 8px;\n    bottom: 8px;\n  }\n  .chart {\n    position: relative;\n    width: 100%;\n    height: 100%;\n    padding: 30px 30px 30px 10px;\n  }\n  .threshold-line {\n    position: absolute;\n    left: 0;\n    right: 30px;\n    height: 2px;\n    background: var(--threshold);\n    transition: top 180ms ease-out;\n  }\n  .threshold-label {\n    position: absolute;\n    right: 35px;\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: var(--threshold);\n    transform: translateY(-50%);\n    transition: top 180ms ease-out;\n    white-space: nowrap;\n  }\n  .signal-bar {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 30px;\n    background: var(--signal);\n    transition: height 180ms ease-out;\n    border-radius: 2px 2px 0 0;\n  }\n  .gap-indicator {\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 0.7rem;\n    color: var(--muted);\n    transition: top 180ms ease-out, opacity 180ms ease-out;\n  }\n  .status {\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    margin-bottom: 12px;\n  }\n  .status strong {\n    font-weight: 600;\n  }\n  .status.active {\n    background: #e8f5e9;\n    border-color: var(--threshold);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-wrap: wrap;\n    }\n    .control label {\n      min-width: 100%;\n    }\n    .chart-container {\n      height: 240px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust signal strength and action threshold</h2>\n<p class=\"subhead\">Warnings accumulate as signal strength. Intervention requires crossing the threshold.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"signal\">Signal strength:</label>\n    <input id=\"signal\" type=\"range\" min=\"0\" max=\"100\" value=\"45\" aria-describedby=\"signal-out\">\n    <output id=\"signal-out\" for=\"signal\">45</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"threshold\">Action threshold:</label>\n    <input id=\"threshold\" type=\"range\" min=\"0\" max=\"100\" value=\"70\" aria-describedby=\"threshold-out\">\n    <output id=\"threshold-out\" for=\"threshold\">70</output>\n  </div>\n</div>\n\n<div class=\"chart-container\">\n  <span class=\"axis-label y\">Authority</span>\n  <span class=\"axis-label x\">Time</span>\n  <div class=\"chart\">\n    <div class=\"threshold-line\" id=\"threshold-line\"></div>\n    <div class=\"threshold-label\" id=\"threshold-label\">Action threshold</div>\n    <div class=\"signal-bar\" id=\"signal-bar\"></div>\n    <div class=\"gap-indicator\" id=\"gap-indicator\"></div>\n  </div>\n</div>\n\n<div class=\"status\" id=\"status\">\n  <strong id=\"status-label\">Status:</strong> <span id=\"status-text\">Signal detected. No authority to act.</span>\n</div>\n\n<p class=\"caption\" id=\"caption\">Warnings generate signal, but intervention depends on threshold position. The gap between them determines outcome.</p>\n\n<script>\n(function () {\n  var signalSlider = document.getElementById('signal');\n  var thresholdSlider = document.getElementById('threshold');\n  var signalOut = document.getElementById('signal-out');\n  var thresholdOut = document.getElementById('threshold-out');\n  var signalBar = document.getElementById('signal-bar');\n  var thresholdLine = document.getElementById('threshold-line');\n  var thresholdLabel = document.getElementById('threshold-label');\n  var gapIndicator = document.getElementById('gap-indicator');\n  var status = document.getElementById('status');\n  var statusLabel = document.getElementById('status-label');\n  var statusText = document.getElementById('status-text');\n  var caption = document.getElementById('caption');\n\n  function update() {\n    var sig = +signalSlider.value;\n    var thr = +thresholdSlider.value;\n    signalOut.textContent = sig;\n    thresholdOut.textContent = thr;\n\n    var chartHeight = 220;\n    var sigHeight = (sig / 100) * chartHeight;\n    var thrTop = chartHeight - (thr / 100) * chartHeight;\n\n    signalBar.style.height = sigHeight + 'px';\n    thresholdLine.style.top = thrTop + 'px';\n    thresholdLabel.style.top = thrTop + 'px';\n\n    var gap = thr - sig;\n    if (gap > 0) {\n      var gapMid = thrTop + ((chartHeight - thrTop) - sigHeight) / 2;\n      gapIndicator.style.top = gapMid + 'px';\n      gapIndicator.style.opacity = '1';\n      gapIndicator.textContent = '↕ gap: ' + gap;\n      status.classList.remove('active');\n      statusLabel.textContent = 'Status:';\n      if (gap > 40) {\n        statusText.textContent = 'Signal detected. No authority to act.';\n        caption.textContent = 'Warnings generate signal, but intervention depends on threshold position. The gap between them determines outcome.';\n      } else if (gap > 15) {\n        statusText.textContent = 'Signal rising. Still below threshold.';\n        caption.textContent = 'Information accumulates, but legal authority activates only at the threshold — not before.';\n      } else {\n        statusText.textContent = 'Signal near threshold. Authority almost available.';\n        caption.textContent = 'The system can see the pattern forming, but cannot act until signal crosses the line.';\n      }\n    } else {\n      gapIndicator.style.opacity = '0';\n      status.classList.add('active');\n      statusLabel.textContent = 'Status:';\n      statusText.textContent = 'Signal crossed threshold. Authority to intervene activated.';\n      caption.textContent = 'Once signal exceeds the threshold, the institution gains authority to act. Below it, warnings remain documentation.';\n    }\n  }\n\n  signalSlider.addEventListener('input', update);\n  thresholdSlider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
