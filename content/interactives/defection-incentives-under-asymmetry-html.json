{
  "slug": "defection-incentives-under-asymmetry",
  "type": "html",
  "title": "Defection Under Capacity Asymmetry",
  "concept": "A member defects from a coordination agreement when their individual gain from breaking the agreement exceeds their share of the collective benefit — asymmetry in production capacity among members creates this condition for high-capacity members even when the collective would profit from continued coordination.",
  "interactiveId": "742203c7-a3de-4937-8f04-bb14ae3491a7",
  "sourcePieceId": "b4ffbd42-cd10-484e-b92e-3085f2303266",
  "publishedAt": 1777385399101,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Defection Under Capacity Asymmetry</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --comply: #1a6b62;\n    --defect: #c9a227;\n    --alert: #a03030;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    margin-bottom: 24px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 14px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 140px;\n    font-size: 0.9rem;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--comply);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .members {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    margin: 24px 0;\n  }\n  .member {\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    padding: 14px;\n  }\n  .member.defector {\n    border-color: var(--alert);\n    background: #fff5f5;\n  }\n  .member-name {\n    font-weight: 600;\n    font-size: 0.85rem;\n    margin-bottom: 10px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .member-name .badge {\n    font-size: 0.7rem;\n    padding: 2px 6px;\n    border-radius: 3px;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n  .member-name .badge.complies {\n    background: #e6f4f1;\n    color: var(--comply);\n  }\n  .member-name .badge.defects {\n    background: #ffe6e6;\n    color: var(--alert);\n  }\n  .capacity-bar {\n    height: 6px;\n    background: var(--line);\n    border-radius: 3px;\n    margin-bottom: 12px;\n    overflow: hidden;\n  }\n  .capacity-bar .fill {\n    height: 100%;\n    background: var(--muted);\n    transition: width 200ms ease-out;\n  }\n  .payoffs {\n    display: flex;\n    gap: 8px;\n    margin-bottom: 8px;\n  }\n  .payoff {\n    flex: 1;\n    padding: 6px 8px;\n    border-radius: 4px;\n    font-size: 0.8rem;\n    text-align: center;\n    transition: all 200ms ease-out;\n  }\n  .payoff.comply {\n    background: #e6f4f1;\n    border: 1px solid var(--comply);\n  }\n  .payoff.defect {\n    background: #fff9e6;\n    border: 1px solid var(--defect);\n  }\n  .payoff.winner {\n    font-weight: 600;\n    transform: scale(1.05);\n  }\n  .payoff.comply.winner {\n    background: var(--comply);\n    color: #fff;\n  }\n  .payoff.defect.winner {\n    background: var(--alert);\n    color: #fff;\n    border-color: var(--alert);\n  }\n  .payoff-label {\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    color: var(--muted);\n    margin-bottom: 2px;\n  }\n  .payoff-value {\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .decision {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-align: center;\n  }\n  .reading {\n    margin: 20px 0 6px;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 640px) {\n    .members {\n      grid-template-columns: 1fr;\n    }\n    .control {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control label {\n      min-width: 0;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag capacity sliders for each member</h2>\n<p class=\"subhead\">Three members coordinate production. Each can comply (honor quota) or defect (pump at full capacity). Watch individual payoffs shift.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"capA\">Member A capacity:</label>\n    <input id=\"capA\" type=\"range\" min=\"60\" max=\"200\" value=\"100\" step=\"10\" aria-describedby=\"capA-out\">\n    <output id=\"capA-out\" for=\"capA\">100</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"capB\">Member B capacity:</label>\n    <input id=\"capB\" type=\"range\" min=\"60\" max=\"200\" value=\"100\" step=\"10\" aria-describedby=\"capB-out\">\n    <output id=\"capB-out\" for=\"capB\">100</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"capC\">Member C capacity:</label>\n    <input id=\"capC\" type=\"range\" min=\"60\" max=\"200\" value=\"100\" step=\"10\" aria-describedby=\"capC-out\">\n    <output id=\"capC-out\" for=\"capC\">100</output>\n  </div>\n</div>\n\n<div class=\"members\">\n  <div class=\"member\" id=\"memberA\">\n    <div class=\"member-name\">\n      Member A\n      <span class=\"badge complies\" id=\"badgeA\">Complies</span>\n    </div>\n    <div class=\"capacity-bar\">\n      <div class=\"fill\" id=\"barA\"></div>\n    </div>\n    <div class=\"payoffs\">\n      <div class=\"payoff comply\" id=\"payoffA-comply\">\n        <div class=\"payoff-label\">Comply</div>\n        <div class=\"payoff-value\" id=\"valA-comply\">80</div>\n      </div>\n      <div class=\"payoff defect\" id=\"payoffA-defect\">\n        <div class=\"payoff-label\">Defect</div>\n        <div class=\"payoff-value\" id=\"valA-defect\">90</div>\n      </div>\n    </div>\n    <div class=\"decision\" id=\"decisionA\">Stays in agreement</div>\n  </div>\n\n  <div class=\"member\" id=\"memberB\">\n    <div class=\"member-name\">\n      Member B\n      <span class=\"badge complies\" id=\"badgeB\">Complies</span>\n    </div>\n    <div class=\"capacity-bar\">\n      <div class=\"fill\" id=\"barB\"></div>\n    </div>\n    <div class=\"payoffs\">\n      <div class=\"payoff comply\" id=\"payoffB-comply\">\n        <div class=\"payoff-label\">Comply</div>\n        <div class=\"payoff-value\" id=\"valB-comply\">80</div>\n      </div>\n      <div class=\"payoff defect\" id=\"payoffB-defect\">\n        <div class=\"payoff-label\">Defect</div>\n        <div class=\"payoff-value\" id=\"valB-defect\">90</div>\n      </div>\n    </div>\n    <div class=\"decision\" id=\"decisionB\">Stays in agreement</div>\n  </div>\n\n  <div class=\"member\" id=\"memberC\">\n    <div class=\"member-name\">\n      Member C\n      <span class=\"badge complies\" id=\"badgeC\">Complies</span>\n    </div>\n    <div class=\"capacity-bar\">\n      <div class=\"fill\" id=\"barC\"></div>\n    </div>\n    <div class=\"payoffs\">\n      <div class=\"payoff comply\" id=\"payoffC-comply\">\n        <div class=\"payoff-label\">Comply</div>\n        <div class=\"payoff-value\" id=\"valC-comply\">80</div>\n      </div>\n      <div class=\"payoff defect\" id=\"payoffC-defect\">\n        <div class=\"payoff-label\">Defect</div>\n        <div class=\"payoff-value\" id=\"valC-defect\">90</div>\n      </div>\n    </div>\n    <div class=\"decision\" id=\"decisionC\">Stays in agreement</div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Agreement status: <strong id=\"status\">All members comply</strong>\n  <div style=\"margin-top: 8px; font-size: 0.85rem; color: var(--muted);\" id=\"detail\">Coordination holds. Each member gains more from their share of the collective benefit than from independent expansion.</div>\n</div>\n\n<p class=\"caption\" id=\"caption\">When capacity is uniform, compliance is individually rational. Collective discipline beats independent expansion.</p>\n\n<script>\n  (function () {\n    var sliders = {\n      A: document.getElementById('capA'),\n      B: document.getElementById('capB'),\n      C: document.getElementById('capC')\n    };\n    var outputs = {\n      A: document.getElementById('capA-out'),\n      B: document.getElementById('capB-out'),\n      C: document.getElementById('capC-out')\n    };\n    var bars = {\n      A: document.getElementById('barA'),\n      B: document.getElementById('barB'),\n      C: document.getElementById('barC')\n    };\n    var members = {\n      A: document.getElementById('memberA'),\n      B: document.getElementById('memberB'),\n      C: document.getElementById('memberC')\n    };\n    var badges = {\n      A: document.getElementById('badgeA'),\n      B: document.getElementById('badgeB'),\n      C: document.getElementById('badgeC')\n    };\n    var payoffComplies = {\n      A: document.getElementById('payoffA-comply'),\n      B: document.getElementById('payoffB-comply'),\n      C: document.getElementById('payoffC-comply')\n    };\n    var payoffDefects = {\n      A: document.getElementById('payoffA-defect'),\n      B: document.getElementById('payoffB-defect'),\n      C: document.getElementById('payoffC-defect')\n    };\n    var valComplies = {\n      A: document.getElementById('valA-comply'),\n      B: document.getElementById('valB-comply'),\n      C: document.getElementById('valC-comply')\n    };\n    var valDefects = {\n      A: document.getElementById('valA-defect'),\n      B: document.getElementById('valB-defect'),\n      C: document.getElementById('valC-defect')\n    };\n    var decisions = {\n      A: document.getElementById('decisionA'),\n      B: document.getElementById('decisionB'),\n      C: document.getElementById('decisionC')\n    };\n    var status = document.getElementById('status');\n    var detail = document.getElementById('detail');\n    var caption = document.getElementById('caption');\n\n    var BASE_PRICE = 100;\n    var PRICE_DROP_PER_DEFECTOR = 20;\n    var QUOTA = 0.6;\n\n    function update() {\n      var caps = {\n        A: +sliders.A.value,\n        B: +sliders.B.value,\n        C: +sliders.C.value\n      };\n\n      outputs.A.textContent = caps.A;\n      outputs.B.textContent = caps.B;\n      outputs.C.textContent = caps.C;\n\n      var maxCap = Math.max(caps.A, caps.B, caps.C);\n      bars.A.style.width = ((caps.A / maxCap) * 100) + '%';\n      bars.B.style.width = ((caps.B / maxCap) * 100) + '%';\n      bars.C.style.width = ((caps.C / maxCap) * 100) + '%';\n\n      var totalCap = caps.A + caps.B + caps.C;\n      var avgCap = totalCap / 3;\n\n      var defectors = [];\n      var choices = {};\n\n      ['A', 'B', 'C'].forEach(function (m) {\n        var cap = caps[m];\n        var complyRevenue = (BASE_PRICE) * (cap * QUOTA);\n        var complyShare = complyRevenue / 3;\n\n        var defectPrice = BASE_PRICE;\n        var defectRevenue = defectPrice * cap;\n\n        var complyPayoff = Math.round(complyShare);\n        var defectPayoff = Math.round(defectRevenue * 0.85);\n\n        valComplies[m].textContent = complyPayoff;\n        valDefects[m].textContent = defectPayoff;\n\n        var defect = defectPayoff > complyPayoff;\n        choices[m] = { comply: complyPayoff, defect: defectPayoff, defects: defect };\n\n        payoffComplies[m].classList.remove('winner');\n        payoffDefects[m].classList.remove('winner');\n\n        if (defect) {\n          defectors.push(m);\n          payoffDefects[m].classList.add('winner');\n          members[m].classList.add('defector');\n          badges[m].classList.remove('complies');\n          badges[m].classList.add('defects');\n          badges[m].textContent = 'Defects';\n          decisions[m].textContent = 'Leaves agreement';\n        } else {\n          payoffComplies[m].classList.add('winner');\n          members[m].classList.remove('defector');\n          badges[m].classList.remove('defects');\n          badges[m].classList.add('complies');\n          badges[m].textContent = 'Complies';\n          decisions[m].textContent = 'Stays in agreement';\n        }\n      });\n\n      if (defectors.length === 0) {\n        status.textContent = 'All members comply';\n        detail.textContent = 'Coordination holds. Each member gains more from their share of the collective benefit than from independent expansion.';\n        caption.textContent = 'When capacity is uniform, compliance is individually rational. Collective discipline beats independent expansion.';\n      } else if (defectors.length === 1) {\n        var d = defectors[0];\n        status.textContent = 'Member ' + d + ' defects';\n        detail.textContent = 'Member ' + d + ' has high enough capacity that pumping at full volume beats their share of the coordination benefit. They leave.';\n        caption.textContent = 'Asymmetry creates defection. The high-capacity member gains more from independent expansion than from coordination.';\n      } else if (defectors.length === 2) {\n        status.textContent = defectors.join(' and ') + ' defect';\n        detail.textContent = 'Two members find defection individually rational. The agreement collapses.';\n        caption.textContent = 'Multiple defectors signal coordination failure. When most members gain more from breaking the agreement, the cartel ends.';\n      } else {\n        status.textContent = 'All members defect';\n        detail.textContent = 'No member gains from coordination. The agreement collapses entirely.';\n        caption.textContent = 'Total defection. When all members can profit more from independent action, coordination cannot hold.';\n      }\n    }\n\n    sliders.A.addEventListener('input', update);\n    sliders.B.addEventListener('input', update);\n    sliders.C.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
