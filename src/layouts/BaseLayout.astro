---
import '../styles/global.css';
import { AGENT_COUNT } from '../lib/constants';
import { getUser } from '../lib/db';
import { parseSessionCookie } from '../lib/auth';

interface Props {
  title: string;
  description?: string;
  /** "article" for daily pieces, "website" for everything else (default). */
  ogType?: 'website' | 'article';
  /** When set, emits a JSON-LD Article schema (and an AudioObject when
   *  audioUrl is present) plus a BreadcrumbList for Home → Daily → Title.
   *  Daily-piece pages pass this; other pages don't. Self-gating. */
  article?: {
    /** Unix-ms timestamp from MDX frontmatter `publishedAt`. */
    publishedAt: number;
    /** Path or absolute URL to a representative audio file. Daily pieces
     *  pass the "hook" beat (or the first beat if no hook). One
     *  AudioObject per Article in v1; per-beat array deferred. */
    audioUrl?: string;
  };
  /** When set, emits a JSON-LD LearningResource schema. Interactive pages
   *  (/interactives/<slug>/) pass this. Self-gating, parallel to `article`. */
  learningResource?: {
    /** "Quiz" for quizzes, "Interactive simulation" for HTML widgets. */
    resourceType: string;
  };
  /** When set, emits one schema.org ClaimReview JSON-LD block per claim
   *  (Phase H, 2026-04-30). Source data: Director's claimReviews
   *  frontmatter splice from the final round's verified fact-check
   *  claims. Empty array → no JSON-LD emitted. Path A (2026-05-01)
   *  reverted Phase A's per-item object union; this is back to a flat
   *  string array of claim text. Source URLs are surfaced in the
   *  drawer's Facts section via the agent's flat citation harvest, not
   *  in the ClaimReview schema. */
  claimReviews?: string[];
}

const { title, description, ogType = 'website', article, learningResource, claimReviews } = Astro.props;

// Single source of truth for the page description — used by
// <meta name="description">, og:description, and twitter:description.
// Always renders (the conditional emit was dropping the meta tag on
// pages that didn't pass `description`, e.g. /login, /auth/verify,
// admin dashboard).
const metaDescription =
  description ??
  `Educate yourself for humble decisions. Daily teaching, made by ${AGENT_COUNT} agents.`;

const siteOrigin = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();

// Footer admin link — visible only to ADMIN_EMAIL.
//
// Cookie is parsed inline rather than reading `Astro.locals.userId`,
// because middleware only sets `userId` for routes in its serverRoutes
// allowlist (`/api/`, `/account`, `/login`, `/dashboard`, `/auth/`).
// That excludes prerendered pages (correct — no D1 access at build
// time) and SSR pages outside the allowlist (e.g. `/daily/` after
// the 2026-05-02 rebuild). Doing the auth lookup here means the link
// gates correctly wherever BaseLayout is rendered server-side, with
// graceful no-op on prerendered pages where runtime.env is absent.
let isAdmin = false;
try {
  const env = (Astro.locals as any).runtime?.env as Record<string, any> | undefined;
  // Bail before touching `Astro.request.headers` on prerendered pages
  // (Astro logs a build-time warning for that access on pages that
  // run at build time). If runtime.env is absent we're prerendering,
  // and there's no DB to consult anyway.
  if (env?.DB && env?.ADMIN_EMAIL) {
    const cookieHeader = Astro.request.headers.get('cookie');
    const userId = parseSessionCookie(cookieHeader);
    if (userId) {
      const user = await getUser(env.DB, userId);
      isAdmin = !!user?.email && user.email === env.ADMIN_EMAIL;
    }
  }
} catch {
  isAdmin = false;
}
const ogImageUrl = new URL('/og-image.png', siteOrigin).toString();

// Defend against `</script>` injection if a future title or
// description ever contains the literal string. JSON.stringify
// doesn't escape `<` by default.
const escapeForScript = (obj: unknown) =>
  JSON.stringify(obj).replace(/</g, '\\u003c');

// JSON-LD Article schema for daily pieces. Article (not NewsArticle —
// Daylila teaches, doesn't report) per Google's structured-data guide.
// All fields recommended-only per the current docs (no `required`
// fields), but the more we provide the richer the result card.
let articleJsonLd: string | null = null;
let breadcrumbJsonLd: string | null = null;
if (article) {
  const isoPublished = new Date(article.publishedAt).toISOString();
  const audioUrl = article.audioUrl
    ? new URL(article.audioUrl, siteOrigin).toString()
    : null;
  const cleanHeadline = title.replace(/ — Daylila$/, '');
  const schema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: cleanHeadline,
    description: metaDescription,
    datePublished: isoPublished,
    // Pieces are permanent (the hard rule) — modified date is always
    // the publish date. If we ever start editing pieces this needs to
    // become a separate field.
    dateModified: isoPublished,
    image: [ogImageUrl],
    author: {
      '@type': 'Organization',
      name: 'Daylila',
      url: siteOrigin.toString(),
    },
    publisher: {
      '@type': 'Organization',
      name: 'Daylila',
      url: siteOrigin.toString(),
      logo: {
        '@type': 'ImageObject',
        url: ogImageUrl,
        width: 1200,
        height: 630,
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonicalUrl,
    },
  };
  if (audioUrl) {
    schema.associatedMedia = {
      '@type': 'AudioObject',
      contentUrl: audioUrl,
      encodingFormat: 'audio/mpeg',
      name: schema.headline,
      uploadDate: isoPublished,
    };
  }
  articleJsonLd = escapeForScript(schema);

  // BreadcrumbList — Home → Daily → Title. Lets Google render the
  // breadcrumb above the SERP snippet instead of the raw URL.
  const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: new URL('/', siteOrigin).toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Daily',
        item: new URL('/daily/', siteOrigin).toString(),
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: cleanHeadline,
        item: canonicalUrl,
      },
    ],
  };
  breadcrumbJsonLd = escapeForScript(breadcrumbSchema);
}

// JSON-LD ClaimReview blocks (Phase H). One block per verified claim.
// Emitted alongside Article + BreadcrumbList for daily pieces that
// have a non-empty claimReviews frontmatter array. Schema per Google's
// fact-check rich-results documentation. Rating fixed at 5/5 ("True")
// because Director's splice only includes claims with status='verified'
// — unverified/incorrect claims never make it into this list.
let claimReviewJsonLds: string[] = [];
if (article && Array.isArray(claimReviews) && claimReviews.length > 0) {
  const isoPublished = new Date(article.publishedAt).toISOString();
  for (const claimText of claimReviews) {
    if (typeof claimText !== 'string' || claimText.length === 0) continue;
    const schema = {
      '@context': 'https://schema.org',
      '@type': 'ClaimReview',
      datePublished: isoPublished,
      url: `${canonicalUrl}#made`,
      claimReviewed: claimText,
      itemReviewed: {
        '@type': 'Claim',
        appearance: canonicalUrl,
      },
      author: {
        '@type': 'Organization',
        name: 'Daylila',
        url: siteOrigin.toString(),
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: 5,
        bestRating: 5,
        worstRating: 1,
        alternateName: 'True',
      },
    };
    claimReviewJsonLds.push(escapeForScript(schema));
  }
}

// JSON-LD LearningResource for /interactives/<slug>/. Self-gating
// parallel to `article` — interactive pages pass this prop, others
// don't. Quiz-specific schema (acceptedAnswer) deferred; the higher-
// level LearningResource type covers both quiz + html widgets and is
// the right granularity for v1.
let learningResourceJsonLd: string | null = null;
if (learningResource) {
  const lrSchema = {
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: title,
    description: metaDescription,
    url: canonicalUrl,
    learningResourceType: learningResource.resourceType,
    educationalUse: 'self-paced learning',
    isAccessibleForFree: true,
    publisher: {
      '@type': 'Organization',
      name: 'Daylila',
      url: siteOrigin.toString(),
    },
  };
  learningResourceJsonLd = escapeForScript(lrSchema);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <style is:inline>
      /* Beat CSS — inlined to prevent Tailwind purging. Single-scroll
         layout (Area 5) — beats stack as continuous prose. */
      lesson-beat{display:block;padding:1rem 0}
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Icons + manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1A6B62" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Daylila — educate yourself for humble decisions" />
    <meta property="og:site_name" content="Daylila" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    {articleJsonLd && (
      <script type="application/ld+json" set:html={articleJsonLd} />
    )}
    {breadcrumbJsonLd && (
      <script type="application/ld+json" set:html={breadcrumbJsonLd} />
    )}
    {claimReviewJsonLds.map((json) => (
      <script type="application/ld+json" set:html={json} />
    ))}
    {learningResourceJsonLd && (
      <script type="application/ld+json" set:html={learningResourceJsonLd} />
    )}

    <!-- Feed auto-discovery for Feedly / Inoreader / NetNewsWire / etc. -->
    <link rel="alternate" type="application/rss+xml" title="Daylila daily pieces" href="/rss.xml" />

    <!-- Fonts: preconnect first, then load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-zee-bg text-zee-text font-sans flex flex-col">
    <header class="w-full max-w-3xl mx-auto px-6 pt-8 pb-4 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight text-zee-primary hover:opacity-80 transition-opacity">
        daylila
      </a>
      <nav class="flex items-center gap-2 sm:gap-4">
        <a href="/daily/" class="text-xs sm:text-sm text-zee-muted hover:text-zee-primary transition-colors">Daily</a>
        <a href="/library/" class="text-xs sm:text-sm text-zee-muted hover:text-zee-primary transition-colors">Library</a>
        <a href="/account/" class="text-xs sm:text-sm text-zee-muted hover:text-zee-primary transition-colors">Account</a>
      </nav>
    </header>

    <main class="flex-1 w-full max-w-3xl mx-auto px-6 py-6">
      <slot />
    </main>

    <footer class="w-full max-w-3xl mx-auto px-6 pt-12 pb-10 border-t border-zee-border/50 mt-8" data-nosnippet>
      <p class="text-sm italic text-zee-muted text-center">
        Educate yourself for humble decisions.
      </p>
      <p class="text-xs text-zee-muted/70 text-center">
        &copy; 2026 Daylila
      </p>
      {isAdmin && (
        <p class="text-xs text-zee-muted/60 text-center mt-3">
          <a href="/dashboard/admin/" class="hover:text-zee-primary transition-colors">Admin →</a>
        </p>
      )}
    </footer>
  </body>
</html>
