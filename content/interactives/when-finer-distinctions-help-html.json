{
  "slug": "when-finer-distinctions-help",
  "type": "html",
  "title": "Sorting Into Subtypes",
  "concept": "Subdividing a category makes each subgroup more internally similar (improving prediction within the subgroup) but fragments the population into smaller samples (reducing statistical power)—the trade-off is precision against proof.",
  "interactiveId": "03790c17-b385-4f8a-8efd-181230ec1052",
  "sourcePieceId": "086ad49c-c549-4931-9a26-244f319ac3df",
  "publishedAt": 1777607873347,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Sorting Into Subtypes</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --accent: #1a6b62;\n    --warning: #c9a227;\n    --mild: #7fb3ab;\n    --severe: #0d4038;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .scatter {\n    width: 100%;\n    height: 320px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    position: relative;\n    margin-bottom: 16px;\n    overflow: hidden;\n  }\n  .dot {\n    position: absolute;\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: var(--accent);\n    transition: all 300ms ease-out;\n    opacity: 0.7;\n  }\n  .dot.mild { background: var(--mild); }\n  .dot.severe { background: var(--severe); }\n  .axis {\n    position: absolute;\n    color: var(--muted);\n    font-size: 0.7rem;\n  }\n  .axis.x {\n    bottom: 4px;\n    left: 50%;\n    transform: translateX(-50%);\n  }\n  .axis.y {\n    top: 50%;\n    left: 4px;\n    transform: translateY(-50%) rotate(-90deg);\n    transform-origin: center;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--accent);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .metrics {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin-bottom: 16px;\n  }\n  .metric-box {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 12px;\n  }\n  .metric-box.warning {\n    background: #fff9e6;\n    border-color: var(--warning);\n  }\n  .metric-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n  }\n  .metric-value {\n    font-size: 1.4rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .status {\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    margin-bottom: 12px;\n  }\n  p.caption {\n    margin: 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .metrics {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to split the population into subtypes</h2>\n<p class=\"subhead\">120 cases, initially grouped together. Watch them sort into tighter clusters as the category subdivides.</p>\n\n<div class=\"control\">\n  <label for=\"subtypes\">Subtypes:</label>\n  <input id=\"subtypes\" type=\"range\" min=\"1\" max=\"3\" value=\"1\" step=\"1\" aria-describedby=\"subtypes-out\">\n  <output id=\"subtypes-out\" for=\"subtypes\">1</output>\n</div>\n\n<div class=\"scatter\" id=\"scatter\" aria-hidden=\"true\">\n  <span class=\"axis x\">Measurement A</span>\n  <span class=\"axis y\">Measurement B</span>\n</div>\n\n<div class=\"metrics\">\n  <div class=\"metric-box\" id=\"variance-box\">\n    <div class=\"metric-label\">Avg variance</div>\n    <div class=\"metric-value\" id=\"variance\">—</div>\n  </div>\n  <div class=\"metric-box\" id=\"sample-box\">\n    <div class=\"metric-label\">Smallest subtype</div>\n    <div class=\"metric-value\" id=\"sample\">—</div>\n  </div>\n</div>\n\n<div class=\"status\" id=\"status\">—</div>\n<p class=\"caption\" id=\"caption\">—</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('subtypes');\n    var subtypesOut = document.getElementById('subtypes-out');\n    var scatter = document.getElementById('scatter');\n    var varianceEl = document.getElementById('variance');\n    var sampleEl = document.getElementById('sample');\n    var varianceBox = document.getElementById('variance-box');\n    var sampleBox = document.getElementById('sample-box');\n    var status = document.getElementById('status');\n    var caption = document.getElementById('caption');\n\n    var totalCases = 120;\n    var dots = [];\n\n    function seededRandom(seed) {\n      var x = Math.sin(seed++) * 10000;\n      return x - Math.floor(x);\n    }\n\n    function initDots() {\n      for (var i = 0; i < totalCases; i++) {\n        var dot = document.createElement('div');\n        dot.className = 'dot';\n        scatter.appendChild(dot);\n        var seed = i * 137;\n        var x = seededRandom(seed) * 0.7 + 0.15;\n        var y = seededRandom(seed + 1) * 0.7 + 0.15;\n        var cluster = i % 3;\n        dots.push({ el: dot, x: x, y: y, cluster: cluster });\n      }\n    }\n\n    function positionDots(n) {\n      var w = scatter.offsetWidth;\n      var h = scatter.offsetHeight;\n      var centers = [];\n      if (n === 1) {\n        centers = [{ cx: 0.5, cy: 0.5 }];\n      } else if (n === 2) {\n        centers = [{ cx: 0.35, cy: 0.5 }, { cx: 0.65, cy: 0.5 }];\n      } else {\n        centers = [{ cx: 0.3, cy: 0.35 }, { cx: 0.7, cy: 0.35 }, { cx: 0.5, cy: 0.65 }];\n      }\n      for (var i = 0; i < dots.length; i++) {\n        var d = dots[i];\n        var targetCluster = n === 1 ? 0 : (n === 2 ? (d.cluster < 2 ? d.cluster : 0) : d.cluster);\n        var center = centers[targetCluster];\n        var spread = n === 1 ? 0.35 : (n === 2 ? 0.18 : 0.12);\n        var offsetX = (d.x - 0.5) * spread;\n        var offsetY = (d.y - 0.5) * spread;\n        var finalX = (center.cx + offsetX) * w;\n        var finalY = (center.cy + offsetY) * h;\n        d.el.style.left = finalX + 'px';\n        d.el.style.top = finalY + 'px';\n        if (n === 1) {\n          d.el.className = 'dot';\n        } else if (n === 2) {\n          d.el.className = targetCluster === 0 ? 'dot mild' : 'dot severe';\n        } else {\n          d.el.className = targetCluster === 0 ? 'dot mild' : (targetCluster === 1 ? 'dot' : 'dot severe');\n        }\n      }\n    }\n\n    function computeVariance(n) {\n      var spread = n === 1 ? 0.35 : (n === 2 ? 0.18 : 0.12);\n      return Math.round((spread / 0.35) * 100);\n    }\n\n    function computeSmallest(n) {\n      if (n === 1) return totalCases;\n      var sizes = [];\n      for (var i = 0; i < n; i++) {\n        var count = 0;\n        for (var j = 0; j < dots.length; j++) {\n          var cluster = n === 2 ? (dots[j].cluster < 2 ? dots[j].cluster : 0) : dots[j].cluster;\n          if (cluster === i) count++;\n        }\n        sizes.push(count);\n      }\n      return Math.min.apply(null, sizes);\n    }\n\n    function update() {\n      var n = +slider.value;\n      subtypesOut.textContent = n;\n      positionDots(n);\n      var variance = computeVariance(n);\n      var smallest = computeSmallest(n);\n      varianceEl.textContent = variance;\n      sampleEl.textContent = smallest;\n\n      varianceBox.classList.remove('warning');\n      sampleBox.classList.remove('warning');\n\n      if (n === 1) {\n        status.textContent = 'One broad category. Cases are spread wide — high variance.';\n        caption.textContent = 'Prediction is rough because the group is internally diverse. But you have all 120 cases to study.';\n      } else if (n === 2) {\n        status.textContent = 'Two subtypes. Cases sort into tighter clusters — variance drops.';\n        caption.textContent = 'Each subtype is more homogeneous. Predictions improve within each group, but each group now has fewer cases.';\n      } else {\n        sampleBox.classList.add('warning');\n        status.textContent = 'Three subtypes. Clusters are very tight — low variance — but smallest subtype has 40 cases.';\n        caption.textContent = 'High precision per subtype, but statistical power is marginal. Harder to detect real effects or replicate findings.';\n      }\n    }\n\n    initDots();\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
