  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Redundancy and Single-Point Failure</title>\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n  background: #fafafa;\n  padding: 20px;\n  line-height: 1.6;\n}\n\n.container {\n  max-width: 800px;\n  margin: 0 auto;\n  background: white;\n  padding: 32px;\n  border-radius: 8px;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n}\n\nh1 {\n  font-size: 24px;\n  font-weight: 600;\n  margin-bottom: 8px;\n  color: #1a1a1a;\n}\n\n.concept {\n  font-size: 15px;\n  color: #666;\n  margin-bottom: 32px;\n  line-height: 1.5;\n}\n\n.teaching-label {\n  font-size: 14px;\n  font-weight: 500;\n  color: #333;\n  margin-bottom: 20px;\n}\n\n.system-container {\n  display: flex;\n  gap: 40px;\n  margin-bottom: 32px;\n}\n\n.system {\n  flex: 1;\n}\n\n.system-title {\n  font-size: 16px;\n  font-weight: 600;\n  margin-bottom: 12px;\n  color: #1a1a1a;\n}\n\n.network {\n  position: relative;\n  height: 200px;\n  background: #f8f8f8;\n  border-radius: 6px;\n  padding: 20px;\n  margin-bottom: 12px;\n}\n\n.node {\n  position: absolute;\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 12px;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n\n.source {\n  background: #4a90e2;\n  color: white;\n  left: 20px;\n  top: 80px;\n}\n\n.destination {\n  background: #50c878;\n  color: white;\n  right: 20px;\n  top: 80px;\n}\n\n.intermediate {\n  background: #e0e0e0;\n  color: #666;\n  transition: all 0.3s ease;\n}\n\n.intermediate.active {\n  background: #ffa500;\n  color: white;\n}\n\n.intermediate.failed {\n  background: #d32f2f;\n  color: white;\n}\n\n.path {\n  position: absolute;\n  stroke: #ccc;\n  stroke-width: 2;\n  fill: none;\n  transition: all 0.3s ease;\n}\n\n.path.active {\n  stroke: #ffa500;\n  stroke-width: 3;\n}\n\n.path.failed {\n  stroke: #d32f2f;\n  stroke-dasharray: 4;\n}\n\n.controls {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.control-row {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\nlabel {\n  font-size: 14px;\n  color: #555;\n  min-width: 80px;\n}\n\nbutton {\n  padding: 8px 16px;\n  background: #4a90e2;\n  color: white;\n  border: none;\n  border-radius: 4px;\n  font-size: 14px;\n  cursor: pointer;\n  transition: background 0.2s;\n}\n\nbutton:hover {\n  background: #357abd;\n}\n\nbutton:disabled {\n  background: #ccc;\n  cursor: not-allowed;\n}\n\n.status {\n  padding: 12px;\n  background: #f0f0f0;\n  border-radius: 4px;\n  font-size: 14px;\n  color: #333;\n  min-height: 60px;\n}\n\n.status.operational {\n  background: #e8f5e9;\n  color: #2e7d32;\n}\n\n.status.degraded {\n  background: #fff3e0;\n  color: #e65100;\n}\n\n.status.failed {\n  background: #ffebee;\n  color: #c62828;\n}\n\n.explanation {\n  margin-top: 32px;\n  padding: 20px;\n  background: #f8f8f8;\n  border-radius: 6px;\n  font-size: 14px;\n  color: #444;\n  line-height: 1.6;\n}\n\n.explanation strong {\n  color: #1a1a1a;\n}\n\n@media (max-width: 600px) {\n  .system-container {\n    flex-direction: column;\n    gap: 32px;\n  }\n  \n  .container {\n    padding: 20px;\n  }\n}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Redundancy and Single-Point Failure</h1>\n  <p class=\"concept\">A system has redundancy when multiple paths can handle the same load, and has a single point of failure when losing one component stops the whole thing from working—the difference determines whether partial breakage degrades gracefully or collapses completely.</p>\n  \n  <p class=\"teaching-label\">Click \"Break a path\" to see how each system responds when part of it fails.</p>\n  \n  <div class=\"system-container\">\n    <div class=\"system\">\n      <div class=\"system-title\">System with redundancy</div>\n      <div class=\"network\" id=\"redundant-network\">\n        <svg style=\"position: absolute; width: 100%; height: 100%; top: 0; left: 0;\">\n          <path class=\"path\" id=\"red-path-1\" d=\"M 60 100 Q 180 60, 300 100\"/>\n          <path class=\"path\" id=\"red-path-2\" d=\"M 60 100 Q 180 140, 300 100\"/>\n        </svg>\n        <div class=\"node source\">A</div>\n        <div class=\"node intermediate\" id=\"red-node-1\" style=\"left: 160px; top: 40px;\">1</div>\n        <div class=\"node intermediate\" id=\"red-node-2\" style=\"left: 160px; top: 120px;\">2</div>\n        <div class=\"node destination\">B</div>\n      </div>\n      <div class=\"controls\">\n        <div class=\"control-row\">\n          <button id=\"red-break\" onclick=\"breakRedundantPath()\">Break a path</button>\n          <button onclick=\"resetRedundant()\">Reset</button>\n        </div>\n      </div>\n      <div class=\"status operational\" id=\"red-status\">Both paths working. Load flows freely.</div>\n    </div>\n    \n    <div class=\"system\">\n      <div class=\"system-title\">System with single point</div>\n      <div class=\"network\" id=\"single-network\">\n        <svg style=\"position: absolute; width: 100%; height: 100%; top: 0; left: 0;\">\n          <path class=\"path\" id=\"single-path\" d=\"M 60 100 L 180 100 L 300 100\"/>\n        </svg>\n        <div class=\"node source\">A</div>\n        <div class=\"node intermediate\" id=\"single-node\" style=\"left: 160px; top: 80px;\">1</div>\n        <div class=\"node destination\">B</div>\n      </div>\n      <div class=\"controls\">\n        <div class=\"control-row\">\n          <button id=\"single-break\" onclick=\"breakSinglePath()\">Break the path</button>\n          <button onclick=\"resetSingle()\">Reset</button>\n        </div>\n      </div>\n      <div class=\"status operational\" id=\"single-status\">Single path working. Load flows freely.</div>\n    </div>\n  </div>\n  \n  <div class=\"explanation\">\n    <strong>The difference is backup capacity.</strong> The left system has two paths connecting the source to the destination. When one breaks, the other carries the load. Throughput drops, but the system keeps working. The right system has one path. When it breaks, nothing moves. A single-point failure stops everything.\n    <br><br>\n    <strong>Real systems layer redundancy.</strong> Power grids route electricity through parallel lines. The internet sends packets along alternate routes. Water systems have reserve tanks. Each backup reduces the chance that one failure collapses the whole thing.\n    <br><br>\n    <strong>Why not redundancy everywhere?</strong> It costs more. You need extra capacity that sits idle most of the time. The trade-off: pay for backup capacity up front, or accept collapse when the primary fails. Systems that can't afford to stop—hospitals, data centers, flight control—build multiple backups. Systems that tolerate interruption—a single store, a personal website—often don't.\n  </div>\n</div>\n\n<script>\nlet redundantBrokenPath = null;\nlet singleBroken = false;\n\nfunction breakRedundantPath() {\n  if (redundantBrokenPath !== null) return;\n  \n  const choice = Math.random() < 0.5 ? 1 : 2;\n  redundantBrokenPath = choice;\n  \n  const node = document.getElementById(`red-node-${choice}`);\n  const path = document.getElementById(`red-path-${choice}`);\n  const otherPath = document.getElementById(`red-path-${choice === 1 ? 2 : 1}`);\n  const status = document.getElementById('red-status');\n  const btn = document.getElementById('red-break');\n  \n  node.classList.add('failed');\n  path.classList.add('failed');\n  otherPath.classList.add('active');\n  \n  status.className = 'status degraded';\n  status.textContent = `Path ${choice} failed. Remaining path carries the load. System degraded but working.`;\n  btn.disabled = true;\n  \n  if (window.parent) {\n    window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n  }\n}\n\nfunction resetRedundant() {\n  if (redundantBrokenPath === null) return;\n  \n  const node = document.getElementById(`red-node-${redundantBrokenPath}`);\n  const path = document.getElementById(`red-path-${redundantBrokenPath}`);\n  const otherPath = document.getElementById(`red-path-${redundantBrokenPath === 1 ? 2 : 1}`);\n  const status = document.getElementById('red-status');\n  const btn = document.getElementById('red-break');\n  \n  node.classList.remove('failed');\n  path.classList.remove('failed');\n  otherPath.classList.remove('active');\n  \n  status.className = 'status operational';\n  status.textContent = 'Both paths working. Load flows freely.';\n  btn.disabled = false;\n  \n  redundantBrokenPath = null;\n}\n\nfunction breakSinglePath() {\n  if (singleBroken) return;\n  \n  singleBroken = true;\n  \n  const node = document.getElementById('single-node');\n  const path = document.getElementById('single-path');\n  const status = document.getElementById('single-status');\n  const btn = document.getElementById('single-break');\n  \n  node.classList.add('failed');\n  path.classList.add('failed');\n  \n  status.className = 'status failed';\n  status.textContent = 'Path failed. No alternative route. System stopped completely.';\n  btn.disabled = true;\n  \n  if (window.parent) {\n    window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n  }\n}\n\nfunction resetSingle() {\n  if (!singleBroken) return;\n  \n  const node = document.getElementById('single-node');\n  const path = document.getElementById('single-path');\n  const status = document.getElementById('single-status');\n  const btn = document.getElementById('single-break');\n  \n  node.classList.remove('failed');\n  path.classList.remove('failed');\n  \n  status.className = 'status operational';\n  status.textContent = 'Single path working. Load flows freely.';\n  btn.disabled = false;\n  \n  singleBroken = false;\n}\n</script>\n</body>\n</html>"
  }
}
