---
/**
 * "How this was made" — small open affordance + drawer shell.
 *
 * Renders a single-line, icon-led button at the bottom of the page
 * (single-scroll layout, Area 5). Click opens the slide-in drawer;
 * the panel is the same drawer-dialog shape as before. Only the open
 * affordance shrunk — drawer body, fetch, and rendering are all
 * unchanged.
 *
 * Server-renders only the static scaffold:
 *   - the open affordance (small info-icon button)
 *   - the empty drawer with a skeleton
 *
 * Daily piece pages are statically prerendered (no D1 at build time).
 * The full drawer content is fetched client-side from
 * /api/daily/{date}/made by src/interactive/made-drawer.ts on first
 * open — saves one D1 query per page view for readers who never open.
 */

interface Props {
  date: string;
  pieceId: string;
}

const { date, pieceId } = Astro.props;
---

<made-drawer data-date={date} data-piece-id={pieceId}>
  <button
    class="made-open"
    type="button"
    data-made-open
    aria-haspopup="dialog"
    aria-controls={`made-panel-${date}`}
    aria-label="How this was made"
  >
    <svg class="made-open-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.25"/>
      <path d="M8 7v4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      <circle cx="8" cy="5" r="0.75" fill="currentColor"/>
    </svg>
    <span class="made-open-label">How this was made</span>
  </button>

  <div class="made-backdrop" data-made-backdrop aria-hidden="true"></div>

  <aside
    class="made-panel"
    id={`made-panel-${date}`}
    role="dialog"
    aria-modal="true"
    aria-labelledby={`made-panel-title-${date}`}
    hidden
  >
    <header class="made-panel-header">
      <div>
        <h2 class="made-panel-title" id={`made-panel-title-${date}`}>How this was made</h2>
        <p class="made-panel-subtitle">
          The full creation story of this piece — timeline, auditors, rules.
        </p>
      </div>
      <button class="made-close" type="button" data-made-close aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <div class="made-panel-body" data-made-body>
      <div class="made-skeleton" data-made-skeleton>
        <div class="made-skeleton-line"></div>
        <div class="made-skeleton-line"></div>
        <div class="made-skeleton-line"></div>
        <div class="made-skeleton-line"></div>
      </div>
    </div>
  </aside>
</made-drawer>
