{
  "slug": "standing-as-procedural-gate",
  "type": "html",
  "title": "Categorical Gates",
  "concept": "A gatekeeper separates two types of input—abstract objections and concrete injury—by checking which category each claim belongs to, not how strong the objection is.",
  "interactiveId": "1741eaf4-adbe-4e12-bc5e-c7ccaa6df1f7",
  "sourcePieceId": "eabae8c5-70bd-487a-af75-569ae41120e3",
  "publishedAt": 1778810846073,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Categorical Gates</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --red: #c43a31;\n    --green: #2d7a3e;\n    --gold: #c9a227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .keys {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 12px;\n    margin-bottom: 28px;\n  }\n  .key {\n    padding: 16px 12px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    cursor: pointer;\n    transition: all 160ms ease;\n    text-align: center;\n    position: relative;\n  }\n  .key:hover {\n    border-color: var(--muted);\n    transform: translateY(-2px);\n  }\n  .key.selected {\n    border-color: var(--gold);\n    background: #fffbf0;\n  }\n  .key-icon {\n    width: 48px;\n    height: 48px;\n    margin: 0 auto 8px;\n    border-radius: 6px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 1.5rem;\n    background: var(--line);\n  }\n  .key.selected .key-icon {\n    background: var(--gold);\n    color: #fff;\n  }\n  .key-label {\n    font-size: 0.85rem;\n    font-weight: 500;\n    margin: 0;\n  }\n  .lock-container {\n    margin: 32px auto;\n    max-width: 400px;\n  }\n  .lock {\n    width: 120px;\n    height: 140px;\n    margin: 0 auto 20px;\n    background: var(--line);\n    border-radius: 12px;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 300ms ease;\n  }\n  .lock.open {\n    background: rgba(45, 122, 62, 0.15);\n  }\n  .lock.closed {\n    background: rgba(196, 58, 49, 0.15);\n  }\n  .lock-icon {\n    font-size: 3.5rem;\n    transition: all 300ms ease;\n  }\n  .keyhole {\n    position: absolute;\n    bottom: 35px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 12px;\n    height: 24px;\n    background: var(--fg);\n    border-radius: 6px 6px 0 0;\n  }\n  .keyhole::after {\n    content: \"\";\n    position: absolute;\n    top: 12px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 0;\n    height: 0;\n    border-left: 6px solid transparent;\n    border-right: 6px solid transparent;\n    border-top: 12px solid var(--fg);\n  }\n  .outcome {\n    padding: 14px 18px;\n    border-radius: 8px;\n    font-size: 0.9rem;\n    font-weight: 500;\n    text-align: center;\n    transition: all 250ms ease;\n    margin-bottom: 16px;\n  }\n  .outcome.pass {\n    background: rgba(45, 122, 62, 0.1);\n    color: var(--green);\n    border: 2px solid var(--green);\n  }\n  .outcome.fail {\n    background: rgba(196, 58, 49, 0.1);\n    color: var(--red);\n    border: 2px solid var(--red);\n  }\n  .outcome.none {\n    background: var(--line);\n    color: var(--muted);\n    border: 2px solid var(--line);\n  }\n  p.caption {\n    margin: 16px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n    line-height: 1.5;\n    text-align: center;\n  }\n  @media (max-width: 480px) {\n    .keys {\n      grid-template-columns: 1fr 1fr;\n    }\n    .lock {\n      width: 100px;\n      height: 120px;\n    }\n    .lock-icon {\n      font-size: 3rem;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Try each key in the lock</h2>\n<p class=\"subhead\">Four different claims. The lock checks which category each belongs to.</p>\n\n<div class=\"keys\">\n  <div class=\"key\" data-type=\"belief\">\n    <div class=\"key-icon\">💭</div>\n    <p class=\"key-label\">I disagree with the decision</p>\n  </div>\n  <div class=\"key\" data-type=\"sympathy\">\n    <div class=\"key-icon\">🤝</div>\n    <p class=\"key-label\">It affects people I know</p>\n  </div>\n  <div class=\"key\" data-type=\"hassle\">\n    <div class=\"key-icon\">⚙️</div>\n    <p class=\"key-label\">It makes my work more difficult</p>\n  </div>\n  <div class=\"key\" data-type=\"injury\">\n    <div class=\"key-icon\">🎯</div>\n    <p class=\"key-label\">It costs me money directly</p>\n  </div>\n</div>\n\n<div class=\"lock-container\">\n  <div class=\"lock\" id=\"lock\">\n    <div class=\"lock-icon\" id=\"lock-icon\">🔒</div>\n    <div class=\"keyhole\"></div>\n  </div>\n  \n  <div class=\"outcome none\" id=\"outcome\">Pick a key above</div>\n  <p class=\"caption\" id=\"caption\">The lock checks category, not intensity. Disagreement doesn't fit. Direct injury does.</p>\n</div>\n\n<script>\n(function() {\n  var keys = document.querySelectorAll('.key');\n  var lock = document.getElementById('lock');\n  var lockIcon = document.getElementById('lock-icon');\n  var outcome = document.getElementById('outcome');\n  var caption = document.getElementById('caption');\n\n  var states = {\n    belief: {\n      passes: false,\n      outcome: 'Lock stays closed—belief alone doesn\\'t fit',\n      caption: 'The gate separates opinion from injury. Thinking a decision is wrong isn\\'t the same category as being harmed by it.'\n    },\n    sympathy: {\n      passes: false,\n      outcome: 'Lock stays closed—concern for others doesn\\'t fit',\n      caption: 'Caring about how a decision affects someone else puts you in the wrong category. The gate needs harm to you.'\n    },\n    hassle: {\n      passes: false,\n      outcome: 'Lock stays closed—inconvenience doesn\\'t fit',\n      caption: 'Making your routine harder and causing you measurable loss are different categories. The lock checks which bin the claim belongs to.'\n    },\n    injury: {\n      passes: true,\n      outcome: 'Lock opens—direct loss fits the category',\n      caption: 'The claim shows concrete harm to you. That\\'s the category the gate accepts. The lock doesn\\'t measure how much you lost; it checks whether you lost anything at all.'\n    }\n  };\n\n  keys.forEach(function(key) {\n    key.addEventListener('click', function() {\n      keys.forEach(function(k) { k.classList.remove('selected'); });\n      key.classList.add('selected');\n      \n      var type = key.getAttribute('data-type');\n      var state = states[type];\n      \n      if (state.passes) {\n        lock.className = 'lock open';\n        lockIcon.textContent = '🔓';\n        outcome.className = 'outcome pass';\n      } else {\n        lock.className = 'lock closed';\n        lockIcon.textContent = '🔒';\n        outcome.className = 'outcome fail';\n      }\n      \n      outcome.textContent = state.outcome;\n      caption.textContent = state.caption;\n    });\n  });\n})();\n</script>\n</body>\n</html>"
  }
}
