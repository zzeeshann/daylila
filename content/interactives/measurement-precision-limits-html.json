{
  "slug": "measurement-precision-limits",
  "type": "html",
  "title": "Signal Extraction from Noise",
  "concept": "When the thing you're trying to measure is orders of magnitude smaller than the background interference, precision collapses—not because your instruments are bad, but because the signal-to-noise ratio makes the measurement itself fundamentally difficult.",
  "interactiveId": "18613442-a944-4d65-9ed7-11bb1a4ffc7d",
  "sourcePieceId": "376094d7-409c-4433-a244-74da50e043ac",
  "publishedAt": 1778206419597,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Signal Extraction from Noise</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --signal: #1a6b62;\n    --noise: #c9a227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--signal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .visualization {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .bars {\n    display: flex;\n    align-items: flex-end;\n    gap: 20px;\n    height: 200px;\n    margin-bottom: 16px;\n  }\n  .bar-container {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n  }\n  .bar {\n    width: 100%;\n    max-width: 80px;\n    border-radius: 4px 4px 0 0;\n    transition: height 180ms ease-out;\n    position: relative;\n  }\n  .bar.signal {\n    background: var(--signal);\n  }\n  .bar.noise {\n    background: var(--noise);\n  }\n  .bar-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    text-align: center;\n  }\n  .bar-value {\n    font-size: 0.85rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n    text-align: center;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: var(--bg);\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .bars {\n      height: 180px;\n    }\n    .bar {\n      max-width: 60px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to change the noise level</h2>\n<p class=\"subhead\">The signal stays constant. Watch what happens to your ability to measure it.</p>\n\n<div class=\"control\">\n  <label for=\"noise\">Noise:</label>\n  <input id=\"noise\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"noise-out\">\n  <output id=\"noise-out\" for=\"noise\">50×</output>\n</div>\n\n<div class=\"visualization\">\n  <div class=\"bars\">\n    <div class=\"bar-container\">\n      <div class=\"bar signal\" id=\"signal-bar\"></div>\n      <div class=\"bar-value\" id=\"signal-value\">1.0</div>\n      <div class=\"bar-label\">Signal</div>\n    </div>\n    <div class=\"bar-container\">\n      <div class=\"bar noise\" id=\"noise-bar\"></div>\n      <div class=\"bar-value\" id=\"noise-value\">50</div>\n      <div class=\"bar-label\">Noise</div>\n    </div>\n  </div>\n  \n  <div class=\"reading\">\n    Signal-to-noise ratio: <strong id=\"ratio\">1:50</strong>.\n    Effective precision: <strong id=\"precision\">~1 decimal place</strong>.\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">The noise is 50 times larger than the signal. Most of what you measure is interference, not the thing you want.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('noise');\n    var noiseOut = document.getElementById('noise-out');\n    var signalBar = document.getElementById('signal-bar');\n    var noiseBar = document.getElementById('noise-bar');\n    var signalValue = document.getElementById('signal-value');\n    var noiseValue = document.getElementById('noise-value');\n    var ratio = document.getElementById('ratio');\n    var precision = document.getElementById('precision');\n    var caption = document.getElementById('caption');\n\n    var SIGNAL = 1.0;\n    var MAX_HEIGHT = 200;\n\n    function update() {\n      var noiseLevel = +slider.value;\n      noiseOut.textContent = noiseLevel + '×';\n\n      var maxVal = Math.max(SIGNAL, noiseLevel);\n      var signalHeight = (SIGNAL / maxVal) * MAX_HEIGHT;\n      var noiseHeight = (noiseLevel / maxVal) * MAX_HEIGHT;\n\n      signalBar.style.height = signalHeight + 'px';\n      noiseBar.style.height = noiseHeight + 'px';\n\n      signalValue.textContent = SIGNAL.toFixed(1);\n      noiseValue.textContent = noiseLevel;\n\n      if (noiseLevel === 0) {\n        ratio.textContent = 'infinite';\n        precision.textContent = 'perfect';\n        caption.textContent = 'No noise. You can measure the signal as precisely as your instrument allows.';\n      } else {\n        var snr = SIGNAL / noiseLevel;\n        ratio.textContent = '1:' + noiseLevel;\n        \n        var precisionText;\n        if (noiseLevel <= 1) {\n          precisionText = '~3+ decimal places';\n          caption.textContent = 'The noise is comparable to or smaller than the signal. You can measure precisely.';\n        } else if (noiseLevel <= 10) {\n          precisionText = '~2 decimal places';\n          caption.textContent = 'The noise is ' + noiseLevel + ' times larger than the signal. Precision suffers, but measurement is still feasible.';\n        } else if (noiseLevel <= 50) {\n          precisionText = '~1 decimal place';\n          caption.textContent = 'The noise is ' + noiseLevel + ' times larger than the signal. Most of what you measure is interference, not the thing you want.';\n        } else {\n          precisionText = '< 1 decimal place';\n          caption.textContent = 'The noise is ' + noiseLevel + ' times larger than the signal. The signal drowns. Measurement becomes guesswork.';\n        }\n        precision.textContent = precisionText;\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
