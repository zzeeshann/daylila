  "title": "Nested Replacement Cost",
  "concept": "Replacing a deeply embedded component requires first replacing every layer that assumes its presence — cost compounds with depth because each layer must be unwound before the next can be addressed.",
  "interactiveId": "15121716-0bfc-4e95-80de-7dfa3a90b975",
  "sourcePieceId": "c0b08dee-c011-44d7-acc2-78ecc3c2f7a6",
  "publishedAt": 1777476587168,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Nested Replacement Cost</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --warn: #c44569;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 680px;\n    margin: 0 auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 1ch;\n    text-align: right;\n  }\n  .arena {\n    margin: 20px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    min-height: 280px;\n  }\n  .stack {\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n    margin-bottom: 20px;\n  }\n  .layer {\n    display: flex;\n    align-items: center;\n    padding: 10px 12px;\n    background: #f9f9f9;\n    border: 1px solid var(--line);\n    border-bottom: none;\n    position: relative;\n    transition: all 200ms ease;\n  }\n  .layer:last-child {\n    border-bottom: 1px solid var(--line);\n  }\n  .layer-num {\n    width: 32px;\n    height: 32px;\n    border-radius: 50%;\n    background: var(--line);\n    color: var(--muted);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    font-size: 0.85rem;\n    flex-shrink: 0;\n    transition: all 200ms ease;\n  }\n  .layer-label {\n    margin-left: 12px;\n    font-size: 0.85rem;\n    color: var(--muted);\n    transition: color 200ms ease;\n  }\n  .layer.active .layer-num {\n    background: var(--teal);\n    color: #fff;\n  }\n  .layer.active .layer-label {\n    color: var(--fg);\n    font-weight: 500;\n  }\n  .layer.processing {\n    background: #fff3cd;\n  }\n  .layer.processing .layer-num {\n    background: var(--gold);\n    color: #fff;\n  }\n  .layer.done {\n    background: #e8f5e9;\n    opacity: 0.7;\n  }\n  .layer.done .layer-num {\n    background: #2e7d32;\n    color: #fff;\n  }\n  .layer.blocked {\n    background: #ffebee;\n  }\n  .layer.blocked .layer-num {\n    background: var(--warn);\n    color: #fff;\n  }\n  .indent-1 { padding-left: 24px; }\n  .indent-2 { padding-left: 48px; }\n  .indent-3 { padding-left: 72px; }\n  .indent-4 { padding-left: 96px; }\n  .switch-btn {\n    width: 100%;\n    padding: 12px 20px;\n    background: var(--teal);\n    color: #fff;\n    border: none;\n    border-radius: 4px;\n    font-weight: 600;\n    font-size: 0.95rem;\n    cursor: pointer;\n    transition: opacity 200ms ease;\n  }\n  .switch-btn:hover:not(:disabled) {\n    opacity: 0.85;\n  }\n  .switch-btn:disabled {\n    background: var(--line);\n    color: var(--muted);\n    cursor: not-allowed;\n  }\n  .reading {\n    margin: 24px 0 6px;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .metric {\n    display: inline-block;\n    font-variant-numeric: tabular-nums;\n    color: var(--teal);\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    body {\n      padding: 16px;\n    }\n    .indent-1 { padding-left: 16px; }\n    .indent-2 { padding-left: 32px; }\n    .indent-3 { padding-left: 48px; }\n    .indent-4 { padding-left: 64px; }\n  }\n</style>\n</head>\n<body>\n<h2>Add nesting, then attempt replacement</h2>\n<p class=\"subhead\">Each layer assumes the one below. Replacement must unwind from bottom to top.</p>\n\n<div class=\"control\">\n  <label for=\"depth\">Nesting depth:</label>\n  <input id=\"depth\" type=\"range\" min=\"0\" max=\"4\" value=\"0\" step=\"1\" aria-describedby=\"depth-out\">\n  <output id=\"depth-out\" for=\"depth\">0</output>\n</div>\n\n<div class=\"arena\">\n  <div class=\"stack\" id=\"stack\"></div>\n  <button class=\"switch-btn\" id=\"switchBtn\">Replace base component</button>\n</div>\n\n<div class=\"reading\">\n  Total layers: <strong class=\"metric\" id=\"countEl\">0</strong>.\n  Replacement time: <strong class=\"metric\" id=\"timeEl\">instant</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">No dependent layers. Replacement is immediate.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('depth');\n    var depthOut = document.getElementById('depth-out');\n    var stack = document.getElementById('stack');\n    var switchBtn = document.getElementById('switchBtn');\n    var countEl = document.getElementById('countEl');\n    var timeEl = document.getElementById('timeEl');\n    var caption = document.getElementById('caption');\n\n    var layerLabels = [\n      'Base component',\n      'Systems assuming base',\n      'Systems assuming layer above',\n      'Systems assuming layer above',\n      'Systems assuming layer above'\n    ];\n\n    var switching = false;\n\n    function buildStack() {\n      var d = +slider.value;\n      stack.innerHTML = '';\n      \n      for (var i = 0; i <= d; i++) {\n        var div = document.createElement('div');\n        var indentClass = i > 0 ? ' indent-' + Math.min(i, 4) : '';\n        div.className = 'layer' + indentClass + (i === 0 ? ' active' : '');\n        div.innerHTML = '<div class=\"layer-num\">' + i + '</div><div class=\"layer-label\">' + layerLabels[i] + '</div>';\n        stack.appendChild(div);\n      }\n    }\n\n    function updateReadout() {\n      var d = +slider.value;\n      depthOut.textContent = d;\n      countEl.textContent = d;\n      \n      if (d === 0) {\n        timeEl.textContent = 'instant';\n        caption.textContent = 'No dependent layers. Replacement is immediate.';\n      } else if (d === 1) {\n        timeEl.textContent = '2 seconds';\n        caption.textContent = 'One layer depends on the base. That layer must be replaced first, then the base.';\n      } else if (d === 2) {\n        timeEl.textContent = '6 seconds';\n        caption.textContent = 'Two nested layers. Must replace layer 2, then layer 1, then the base — cost compounds.';\n      } else if (d === 3) {\n        timeEl.textContent = '14 seconds';\n        caption.textContent = 'Three nested layers. Each requires unwinding everything above it. Replacement cascades.';\n      } else {\n        timeEl.textContent = '30 seconds';\n        caption.textContent = 'Four nested layers. The base is infrastructure. Replacement requires dismantling the entire stack.';\n      }\n    }\n\n    function doSwitch() {\n      if (switching) return;\n      var d = +slider.value;\n      \n      if (d === 0) {\n        var layers = stack.querySelectorAll('.layer');\n        layers[0].classList.add('processing');\n        setTimeout(function () {\n          layers[0].classList.remove('processing');\n          layers[0].classList.add('done');\n          setTimeout(function () {\n            layers[0].classList.remove('done');\n            layers[0].classList.add('active');\n          }, 300);\n        }, 200);\n        return;\n      }\n\n      switching = true;\n      switchBtn.disabled = true;\n      var layers = stack.querySelectorAll('.layer');\n      \n      for (var i = 1; i <= d; i++) {\n        layers[i].classList.add('blocked');\n      }\n\n      var times = [0, 2000, 6000, 14000, 30000];\n      var layerTimes = [];\n      \n      if (d === 1) {\n        layerTimes = [1000, 1000];\n      } else if (d === 2) {\n        layerTimes = [2000, 2000, 2000];\n      } else if (d === 3) {\n        layerTimes = [4000, 4000, 4000, 2000];\n      } else if (d === 4) {\n        layerTimes = [8000, 8000, 8000, 4000, 2000];\n      }\n\n      var currentLayer = d;\n      var elapsed = 0;\n\n      function processLayer() {\n        if (currentLayer < 0) {\n          switching = false;\n          switchBtn.disabled = false;\n          return;\n        }\n\n        layers[currentLayer].classList.remove('blocked');\n        layers[currentLayer].classList.add('processing');\n\n        setTimeout(function () {\n          layers[currentLayer].classList.remove('processing');\n          layers[currentLayer].classList.add('done');\n          \n          setTimeout(function () {\n            layers[currentLayer].classList.remove('done');\n            if (currentLayer === 0) {\n              layers[currentLayer].classList.add('active');\n            }\n            currentLayer--;\n            processLayer();\n          }, 200);\n        }, layerTimes[currentLayer]);\n      }\n\n      processLayer();\n    }\n\n    slider.addEventListener('input', function () {\n      if (!switching) {\n        buildStack();\n        updateReadout();\n      }\n    });\n\n    switchBtn.addEventListener('click', doSwitch);\n\n    buildStack();\n    updateReadout();\n  })();\n</script>\n</body>\n</html>"
  }
}
