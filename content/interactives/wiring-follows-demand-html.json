  "title": "Wiring Follows Demand",
  "concept": "Neural systems allocate connection density based on behavioral demands—circuits used for high-precision tasks get more wiring, while general-purpose circuits stay sparse.",
  "interactiveId": "30622455-d1b3-4641-b0c5-b5b70e4a072d",
  "sourcePieceId": "f100b863-b6fa-4a48-84ec-190d038c5e96",
  "publishedAt": 1778134716220,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Wiring Follows Demand</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c93a3a;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3.5ch;\n    text-align: right;\n  }\n  .circuit-display {\n    display: flex;\n    gap: 40px;\n    margin: 24px 0;\n    justify-content: center;\n    align-items: flex-start;\n  }\n  .circuit-group {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 12px;\n  }\n  .circuit-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    text-align: center;\n  }\n  .circuit-box {\n    width: 140px;\n    height: 140px;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    background: #fff;\n    position: relative;\n    overflow: hidden;\n  }\n  .neuron {\n    position: absolute;\n    width: 6px;\n    height: 6px;\n    background: var(--teal);\n    border-radius: 50%;\n    opacity: 0;\n    transition: opacity 300ms ease-out;\n  }\n  .neuron.visible {\n    opacity: 1;\n  }\n  .connection {\n    position: absolute;\n    height: 1px;\n    background: var(--gold);\n    transform-origin: left center;\n    opacity: 0;\n    transition: opacity 300ms ease-out;\n  }\n  .connection.visible {\n    opacity: 0.6;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .metric-row {\n    display: flex;\n    justify-content: space-between;\n    margin-bottom: 6px;\n  }\n  .metric-row:last-child {\n    margin-bottom: 0;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 580px) {\n    .circuit-display {\n      flex-direction: column;\n      gap: 30px;\n      align-items: center;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to increase task precision demand</h2>\n<p class=\"subhead\">Two motor circuits start identical. Watch how wiring density changes when one task requires fine control.</p>\n\n<div class=\"control\">\n  <label for=\"precision\">Precision need:</label>\n  <input id=\"precision\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"precision-out\">\n  <output id=\"precision-out\" for=\"precision\">0</output>\n</div>\n\n<div class=\"circuit-display\">\n  <div class=\"circuit-group\">\n    <span class=\"circuit-label\">General-purpose task</span>\n    <div class=\"circuit-box\" id=\"general-box\"></div>\n  </div>\n  <div class=\"circuit-group\">\n    <span class=\"circuit-label\">Precision task</span>\n    <div class=\"circuit-box\" id=\"precision-box\"></div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  <div class=\"metric-row\">\n    <span>General-purpose circuit:</span>\n    <strong id=\"general-count\">12 connections</strong>\n  </div>\n  <div class=\"metric-row\">\n    <span>Precision circuit:</span>\n    <strong id=\"precision-count\">12 connections</strong>\n  </div>\n  <div class=\"metric-row\">\n    <span>Wiring ratio:</span>\n    <strong id=\"ratio\">1.0×</strong>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Both circuits have baseline wiring. No specialization yet.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('precision');\n    var precisionOut = document.getElementById('precision-out');\n    var generalBox = document.getElementById('general-box');\n    var precisionBox = document.getElementById('precision-box');\n    var generalCountEl = document.getElementById('general-count');\n    var precisionCountEl = document.getElementById('precision-count');\n    var ratioEl = document.getElementById('ratio');\n    var caption = document.getElementById('caption');\n\n    var baseNeurons = 12;\n    var baseConnections = 12;\n\n    function randomPos(max) {\n      return Math.floor(Math.random() * max);\n    }\n\n    function createNeurons(container, count) {\n      container.innerHTML = '';\n      var neurons = [];\n      for (var i = 0; i < count; i++) {\n        var neuron = document.createElement('div');\n        neuron.className = 'neuron';\n        var x = randomPos(130);\n        var y = randomPos(130);\n        neuron.style.left = x + 'px';\n        neuron.style.top = y + 'px';\n        container.appendChild(neuron);\n        neurons.push({el: neuron, x: x + 3, y: y + 3});\n      }\n      return neurons;\n    }\n\n    function createConnections(container, neurons, count) {\n      for (var i = 0; i < count; i++) {\n        if (neurons.length < 2) break;\n        var a = neurons[Math.floor(Math.random() * neurons.length)];\n        var b = neurons[Math.floor(Math.random() * neurons.length)];\n        if (a === b) continue;\n\n        var dx = b.x - a.x;\n        var dy = b.y - a.y;\n        var dist = Math.sqrt(dx * dx + dy * dy);\n        var angle = Math.atan2(dy, dx) * (180 / Math.PI);\n\n        var conn = document.createElement('div');\n        conn.className = 'connection';\n        conn.style.left = a.x + 'px';\n        conn.style.top = a.y + 'px';\n        conn.style.width = dist + 'px';\n        conn.style.transform = 'rotate(' + angle + 'deg)';\n        container.appendChild(conn);\n      }\n    }\n\n    function update() {\n      var demand = +slider.value;\n      precisionOut.textContent = demand;\n\n      var generalCount = baseConnections;\n      var precisionCount = baseConnections + Math.floor(demand * 0.5);\n\n      var generalNeurons = createNeurons(generalBox, baseNeurons);\n      createConnections(generalBox, generalNeurons, generalCount);\n\n      var precisionNeurons = createNeurons(precisionBox, baseNeurons + Math.floor(demand * 0.15));\n      createConnections(precisionBox, precisionNeurons, precisionCount);\n\n      setTimeout(function () {\n        var allNeurons = document.querySelectorAll('.neuron');\n        var allConns = document.querySelectorAll('.connection');\n        for (var i = 0; i < allNeurons.length; i++) {\n          allNeurons[i].classList.add('visible');\n        }\n        for (var j = 0; j < allConns.length; j++) {\n          allConns[j].classList.add('visible');\n        }\n      }, 50);\n\n      generalCountEl.textContent = generalCount + ' connections';\n      precisionCountEl.textContent = precisionCount + ' connections';\n      var ratio = (precisionCount / generalCount).toFixed(1);\n      ratioEl.textContent = ratio + '×';\n\n      if (demand === 0) {\n        caption.textContent = 'Both circuits have baseline wiring. No specialization yet.';\n      } else if (demand < 30) {\n        caption.textContent = 'Modest precision needs produce modest expansion. The specialized circuit adds a few connections.';\n      } else if (demand < 70) {\n        caption.textContent = 'Higher precision demands drive clear expansion. More neurons, more connections, more bandwidth for fine control.';\n      } else {\n        caption.textContent = 'Extreme precision needs produce dramatic expansion. The specialized circuit has ' + ratio + '× the wiring of the baseline circuit.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
