  "title": "Costly Proof After Failure",
  "concept": "Low-cost fixes barely register after catastrophic failure — only expensive actions prove the system actually changed.",
  "interactiveId": "67a31e4a-b449-4795-916e-6f3e80241c3d",
  "sourcePieceId": "fd644822-c6c6-4c23-811b-a6cef4e203fc",
  "publishedAt": 1777592388029,
  "voiceScore": 68,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Costly Proof After Failure</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .mode-toggle {\n    display: flex;\n    gap: 8px;\n    margin-bottom: 20px;\n  }\n  .mode-toggle button {\n    flex: 1;\n    padding: 10px 16px;\n    font-size: 0.9rem;\n    font-weight: 500;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    background: #fff;\n    color: var(--fg);\n    cursor: pointer;\n    transition: all 150ms ease-out;\n  }\n  .mode-toggle button:hover {\n    border-color: var(--muted);\n  }\n  .mode-toggle button.active {\n    border-color: var(--teal);\n    background: var(--teal);\n    color: #fff;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin: 20px 0;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 75px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3.5ch;\n    text-align: right;\n  }\n  .chart {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .chart-label {\n    font-size: 0.85rem;\n    color: var(--muted);\n    margin-bottom: 12px;\n  }\n  .chart-canvas {\n    position: relative;\n    height: 140px;\n    border-left: 2px solid var(--line);\n    border-bottom: 2px solid var(--line);\n  }\n  .bar {\n    position: absolute;\n    left: 0;\n    bottom: 0;\n    width: 100%;\n    background: var(--teal);\n    transition: height 250ms ease-out;\n    border-radius: 2px 2px 0 0;\n  }\n  .axis-labels {\n    display: flex;\n    justify-content: space-between;\n    margin-top: 6px;\n    font-size: 0.75rem;\n    color: var(--muted);\n  }\n  .readout {\n    margin: 16px 0;\n    padding: 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    text-align: center;\n  }\n  .readout-label {\n    font-size: 0.85rem;\n    color: var(--muted);\n    margin-bottom: 6px;\n  }\n  .readout-value {\n    font-size: 1.3rem;\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .mode-toggle {\n      flex-direction: column;\n    }\n    .control {\n      flex-wrap: wrap;\n    }\n    .control label {\n      min-width: auto;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Pick a context, then adjust cost</h2>\n<p class=\"subhead\">Watch how the same action registers differently when baseline trust is intact or broken.</p>\n\n<div class=\"mode-toggle\">\n  <button id=\"btn-normal\" class=\"active\">Normal operations</button>\n  <button id=\"btn-broken\">After catastrophe</button>\n</div>\n\n<div class=\"control\">\n  <label for=\"cost\">Action cost:</label>\n  <input id=\"cost\" type=\"range\" min=\"0\" max=\"100\" value=\"30\" aria-describedby=\"cost-out\">\n  <output id=\"cost-out\" for=\"cost\">30</output>\n</div>\n\n<div class=\"chart\">\n  <div class=\"chart-label\">Trust rebuilt</div>\n  <div class=\"chart-canvas\" aria-hidden=\"true\">\n    <div class=\"bar\" id=\"bar\"></div>\n  </div>\n  <div class=\"axis-labels\">\n    <span>Low cost</span>\n    <span>High cost</span>\n  </div>\n</div>\n\n<div class=\"readout\">\n  <div class=\"readout-label\">Trust gained</div>\n  <div class=\"readout-value\" id=\"trust-val\">30%</div>\n</div>\n\n<p class=\"caption\" id=\"caption\">When things work normally, trust tracks cost directly. Low-cost fixes register as real effort.</p>\n\n<script>\n  (function () {\n    var btnNormal = document.getElementById('btn-normal');\n    var btnBroken = document.getElementById('btn-broken');\n    var costSlider = document.getElementById('cost');\n    var costOut = document.getElementById('cost-out');\n    var bar = document.getElementById('bar');\n    var trustVal = document.getElementById('trust-val');\n    var caption = document.getElementById('caption');\n    var isBroken = false;\n\n    function trust(cost, broken) {\n      if (!broken) return cost;\n      var gate = 60;\n      if (cost < gate) {\n        var ratio = cost / gate;\n        return Math.round(ratio * ratio * 10);\n      }\n      var above = cost - gate;\n      var range = 100 - gate;\n      return Math.round(10 + (above / range) * 90);\n    }\n\n    function text(cost, val, broken) {\n      if (!broken) {\n        if (cost < 30) return 'When things work normally, trust tracks cost directly. Low-cost fixes register as real effort.';\n        if (cost < 70) return 'Moderate cost builds moderate trust. The relationship is direct when the system works.';\n        return 'High-cost actions rebuild trust. When things work normally, effort builds credibility directly.';\n      }\n      if (cost < 60) return 'After catastrophic failure, low-cost actions barely register — too cheap to prove anything changed.';\n      if (cost < 80) return 'Crossing the threshold: costly actions start to rebuild trust because they prove something real changed.';\n      return 'High-cost actions rebuild trust because only real change costs this much.';\n    }\n\n    function update() {\n      var c = +costSlider.value;\n      costOut.textContent = c;\n      var t = trust(c, isBroken);\n      bar.style.height = t + '%';\n      trustVal.textContent = t + '%';\n      caption.textContent = text(c, t, isBroken);\n    }\n\n    function setMode(broken) {\n      isBroken = broken;\n      if (broken) {\n        btnBroken.classList.add('active');\n        btnNormal.classList.remove('active');\n      } else {\n        btnNormal.classList.add('active');\n        btnBroken.classList.remove('active');\n      }\n      update();\n    }\n\n    btnNormal.addEventListener('click', function () { setMode(false); });\n    btnBroken.addEventListener('click', function () { setMode(true); });\n    costSlider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
