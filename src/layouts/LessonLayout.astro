---
import BaseLayout from './BaseLayout.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import MadeBy from '../components/MadeBy.astro';
import { auditTier, auditTierLabel } from '../lib/audit-tier';
import { isLowQuality, LOW_QUALITY_NOTE, type InteractiveBundle } from '../lib/interactives';
import { wrapWithResizeProbe } from '../lib/interactive-html';
import '../styles/beats.css';
import '../styles/zita.css';

interface Props {
  title: string;
  estimatedTime: string;
  audioBeats?: Record<string, string>;
  /** Legacy single-clip audio path. Pre-Area-4-style pieces; current
   *  pipeline emits per-beat clips into audioBeats instead. */
  audioSrc?: string;
  beatCount?: number;
  subject?: string;
  date?: string;
  /** daily_pieces.id (UUID) — optional. When present, scopes Zita
   *  observer events (truncation, Claude errors, handler errors) to the
   *  piece via piece_id. Migration 0020 added the column (2026-04-22);
   *  site-worker threading completes the loop in sub-task 3.2. */
  pieceId?: string;
  /** Unix-ms timestamp from MDX frontmatter `publishedAt`. Threads down
   *  to BaseLayout for the JSON-LD Article schema's datePublished /
   *  dateModified fields. */
  publishedAt: number;
  voiceScore?: number;
  qualityFlag?: 'low';
  /** Optional one-line description for social-share meta. */
  description?: string;
  /** Source news article URL — daily_candidates.url spliced by Director
   *  at publish time. Pre-2026-04-22 pieces don't have it (selectedCand-
   *  idateId fix in 6999c5e). Surfaces as a "Source: {newsSource} ↗"
   *  link in the meta line when both fields are present. */
  sourceUrl?: string;
  /** News publication name (e.g. "Reuters") from MDX frontmatter. Used
   *  as the visible label of the source link. */
  newsSource?: string;
  /** Optional interactive(s) bundle for the inline section after the
   *  beats. With Area 5's single-scroll layout, the companion quiz +
   *  HTML interactive embed directly on the daily piece page; the
   *  standalone /interactives/<slug>/ URL still works (essence-not-
   *  reference posture from Area 4). */
  interactiveBundle?: InteractiveBundle | null;
  /** Verified factual claims for ClaimReview JSON-LD render (Phase H,
   *  2026-04-30). Threaded straight to BaseLayout's `claimReviews`
   *  prop. Optional — pre-Phase-H pieces have no field; no JSON-LD
   *  blocks emitted in that case. Path A (2026-05-01) reverted to flat
   *  string array — source URLs surface in the drawer's Facts section
   *  via the agent's flat citation harvest, not in frontmatter. */
  claimReviews?: string[];
}

const {
  title,
  estimatedTime,
  audioBeats,
  audioSrc,
  subject,
  date,
  pieceId,
  publishedAt,
  voiceScore,
  qualityFlag,
  description,
  sourceUrl,
  newsSource,
  interactiveBundle,
  claimReviews,
} = Astro.props;

// Pick a representative audio URL for the JSON-LD AudioObject (v1 emits
// one per Article — array-per-beat is deferred). Prefer legacy
// audioSrc when set; else the "hook" beat (the standard opening beat
// across every piece in this codebase); else the first beat in
// iteration order. Any beat works for SEO purposes — Google just needs
// to see audio is present.
let canonicalAudioUrl: string | undefined;
if (audioSrc) {
  canonicalAudioUrl = audioSrc;
} else if (audioBeats) {
  canonicalAudioUrl = audioBeats['hook'] ?? Object.values(audioBeats)[0];
}
const timeDisplay = String(estimatedTime).includes('min') ? estimatedTime : `${estimatedTime} min`;
// Tier is a quiet, consistent signal shown in the metadata line — same
// visual weight as the date. Every piece shows its tier (not just rough
// ones) so the word doesn't become a warning by absence.
const tier = auditTier(voiceScore, qualityFlag);
const tierLabel = auditTierLabel(tier);

let dateDisplay = '';
if (date) {
  const d = new Date(date);
  if (!Number.isNaN(d.getTime())) {
    dateDisplay = d.toLocaleDateString('en-GB', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  }
}

const primary = interactiveBundle?.primary ?? null;
const quizEntry = interactiveBundle?.quizEntry ?? null;
const htmlEntry = interactiveBundle?.htmlEntry ?? null;
const quizContentJson = interactiveBundle?.quizContentJson ?? null;
const interactiveSlug = primary?.data.slug ?? null;
---

<BaseLayout
  title={`${title} — Daylila`}
  description={description}
  ogType="article"
  article={{ publishedAt, audioUrl: canonicalAudioUrl }}
  claimReviews={claimReviews}
>
  <nav class="text-sm text-zee-muted mb-6" aria-label="Breadcrumb">
    <a href="/daily/" class="hover:text-zee-primary transition-colors">Daily</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-zee-text">Today</span>
  </nav>

  {dateDisplay && (
    <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-3">{dateDisplay}</p>
  )}

  <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-[1.15] tracking-tight">{title}</h1>

  <p class="text-sm text-zee-muted mb-2 flex flex-wrap items-center gap-x-2 gap-y-1">
    <span>{timeDisplay}</span>
    {subject && (
      <>
        <span class="opacity-40" aria-hidden="true">·</span>
        <span>{subject}</span>
      </>
    )}
    {sourceUrl && newsSource && (
      <>
        <span class="opacity-40" aria-hidden="true">·</span>
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-2 hover:underline hover:text-zee-primary transition-colors"
        >
          Source: {newsSource} <span class="text-zee-primary" aria-hidden="true">↗</span>
        </a>
      </>
    )}
    {pieceId && (
      <>
        <span class="opacity-40" aria-hidden="true">·</span>
        <button
          type="button"
          data-save-toggle
          data-piece-id={pieceId}
          data-saved="false"
          aria-pressed="false"
          class="underline-offset-2 hover:underline hover:text-zee-primary transition-colors"
        >
          <span class="text-zee-primary" aria-hidden="true" data-save-glyph>☆</span> <span data-save-label>Save</span>
        </button>
      </>
    )}
  </p>

  {date && pieceId && <MadeBy date={date} pieceId={pieceId} />}

  <div class="mb-8">
    <AudioPlayer audioBeats={audioBeats} pieceTitle={title} />
  </div>

  <article class="prose">
    <slot />
  </article>

  {interactiveBundle && primary && (
    <section
      class="lesson-interactive"
      id="interactive"
      data-lesson-interactive
      data-interactive-slug={interactiveSlug}
    >
      <p class="lesson-interactive-eyebrow">Companion interactive</p>
      <h2 class="lesson-interactive-title">{primary.data.title}</h2>
      {primary.data.concept && (
        <p class="lesson-interactive-concept">{primary.data.concept}</p>
      )}

      {htmlEntry && htmlEntry.data.content.type === 'html' && (
        <div class="lesson-interactive-block">
          <h3 class="lesson-interactive-subhead">Try the model</h3>
          {isLowQuality(htmlEntry) && (
            <p class="lesson-interactive-low">{LOW_QUALITY_NOTE}</p>
          )}
          <interactive-frame
            data-interactive-id={htmlEntry.data.interactiveId}
            data-concept={htmlEntry.data.concept}
          >
            <iframe
              class="interactive-frame-iframe"
              sandbox="allow-scripts"
              loading="lazy"
              referrerpolicy="no-referrer"
              scrolling="no"
              title={htmlEntry.data.concept}
              srcdoc={wrapWithResizeProbe(htmlEntry.data.content.html)}
            ></iframe>
          </interactive-frame>
        </div>
      )}

      {quizEntry && quizEntry.data.content.type === 'quiz' && quizContentJson && (
        <div class="lesson-interactive-block">
          {htmlEntry && (
            <h3 class="lesson-interactive-subhead">Then check the pattern</h3>
          )}
          {isLowQuality(quizEntry) && (
            <p class="lesson-interactive-low">{LOW_QUALITY_NOTE}</p>
          )}
          <quiz-card data-interactive-id={quizEntry.data.interactiveId}>
            <script type="application/json" data-quiz-content set:html={quizContentJson} />
            <noscript>
              <ol class="lesson-interactive-noscript">
                {quizEntry.data.content.questions.map((q) => (
                  <li>
                    <p>{q.question}</p>
                    <ul>
                      {q.options.map((opt) => (
                        <li>{opt}</li>
                      ))}
                    </ul>
                    <p class="lesson-interactive-answer">
                      Answer: {q.options[q.correctIndex]}. {q.explanation}
                    </p>
                  </li>
                ))}
              </ol>
            </noscript>
          </quiz-card>
        </div>
      )}
    </section>
  )}

  <footer class="lesson-finish" data-lesson-finish>
    <div class="lesson-finish-actions">
      <a class="lesson-finish-link" href="/daily/">Read another <span aria-hidden="true">→</span></a>
      <a class="lesson-finish-link" href="/library/">Browse library <span aria-hidden="true">→</span></a>
      <button type="button" class="lesson-finish-share" data-share aria-label="Share this piece">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M11 5L8 2M8 2L5 5M8 2V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3 9V12C3 12.5523 3.44772 13 4 13H12C12.5523 13 13 12.5523 13 12V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Share this piece
      </button>
      <span class="lesson-finish-toast" data-share-toast aria-live="polite" hidden>Link copied</span>
    </div>
  </footer>

  <zita-chat
    course="daily"
    lesson="0"
    piece-date={date}
    piece-id={pieceId}
    title={title}
  />
</BaseLayout>

<script is:inline define:vars={{ shareTitle: title }}>
  // Inline share button handler — Web Share API on mobile (native sheet),
  // clipboard fallback on desktop with a "Link copied" toast.
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const btn = target.closest('[data-share]');
    if (!btn) return;
    e.preventDefault();
    const url = window.location.href;
    const data = { title: shareTitle, url };
    const showToast = () => {
      const toast = document.querySelector('[data-share-toast]');
      if (!(toast instanceof HTMLElement)) return;
      toast.hidden = false;
      setTimeout(() => { toast.hidden = true; }, 2400);
    };
    if (navigator.share) {
      navigator.share(data).catch(() => {
        // User dismissed the share sheet — silent.
      });
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(url).then(showToast).catch(() => {});
    }
  });
</script>

<script is:inline>
  // Save-toggle handler. Piece pages are prerendered, so the SSR HTML
  // can't carry per-user state — fetch the initial saved status on
  // hydration, then handle toggle clicks.
  (() => {
    const btn = document.querySelector('[data-save-toggle]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const pieceId = btn.dataset.pieceId;
    if (!pieceId) return;

    const glyph = btn.querySelector('[data-save-glyph]');
    const label = btn.querySelector('[data-save-label]');
    const setLabel = (saved) => {
      btn.dataset.saved = saved ? 'true' : 'false';
      btn.setAttribute('aria-pressed', saved ? 'true' : 'false');
      if (glyph) glyph.textContent = saved ? '★' : '☆';
      if (label) label.textContent = saved ? 'Saved' : 'Save';
    };

    fetch(`/api/saved/toggle?piece_id=${encodeURIComponent(pieceId)}`)
      .then((r) => r.ok ? r.json() : null)
      .then((j) => { if (j && typeof j.saved === 'boolean') setLabel(j.saved); })
      .catch(() => {});

    btn.addEventListener('click', async () => {
      const wasSaved = btn.dataset.saved === 'true';
      // Optimistic flip — re-flips on error.
      setLabel(!wasSaved);
      try {
        const r = await fetch('/api/saved/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ piece_id: pieceId }),
        });
        if (!r.ok) throw new Error('toggle-failed');
        const j = await r.json();
        if (typeof j.saved === 'boolean') setLabel(j.saved);
      } catch {
        setLabel(wasSaved);
      }
    });
  })();
</script>
