  "title": "Triage Priority Under Constraint",
  "concept": "When multiple needs arrive simultaneously and resources are limited, treating the most urgent cases first means accepting that less-urgent cases wait—priority order determines who gets help now and who gets help later.",
  "interactiveId": "39659c79-e06c-4311-870d-d0e8748463ce",
  "sourcePieceId": "97b506b4-9eab-49bb-a321-5db39790b9cc",
  "publishedAt": 1777602072589,
  "voiceScore": 72,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Triage Priority Under Constraint</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --critical: #d32f2f;\n    --urgent: #f57c00;\n    --stable: #388e3c;\n    --inactive: #bdbdbd;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--critical);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .scene {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 12px;\n    margin: 24px 0;\n  }\n  .case {\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    padding: 12px;\n    background: #fff;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n  .case-label {\n    font-size: 0.75rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n  }\n  .case-status {\n    font-weight: 600;\n    font-size: 0.9rem;\n  }\n  .case-timer {\n    font-variant-numeric: tabular-nums;\n    font-size: 0.85rem;\n    color: var(--muted);\n  }\n  .case.critical { border-color: var(--critical); }\n  .case.urgent { border-color: var(--urgent); }\n  .case.stable { border-color: var(--stable); }\n  .case.treating { background: #fff9e6; }\n  .case.waiting .case-status { color: var(--muted); }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  .legend {\n    display: flex;\n    gap: 16px;\n    margin-bottom: 12px;\n    flex-wrap: wrap;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 0.85rem;\n  }\n  .legend-box {\n    width: 16px;\n    height: 16px;\n    border-radius: 2px;\n  }\n  @media (max-width: 480px) {\n    .scene {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust available responders</h2>\n<p class=\"subhead\">Five cases need attention. Responders treat in priority order until exhausted.</p>\n\n<div class=\"control\">\n  <label for=\"responders\">Responders:</label>\n  <input id=\"responders\" type=\"range\" min=\"1\" max=\"5\" value=\"3\" aria-describedby=\"responders-out\">\n  <output id=\"responders-out\" for=\"responders\">3</output>\n</div>\n\n<div class=\"legend\">\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--critical);\"></div>\n    <span>Critical</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--urgent);\"></div>\n    <span>Urgent</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--stable);\"></div>\n    <span>Stable</span>\n  </div>\n</div>\n\n<div class=\"scene\" id=\"scene\"></div>\n\n<div class=\"reading\">\n  Treating: <strong id=\"treating\">3</strong> cases.\n  Waiting: <strong id=\"waiting\">2</strong> cases.\n</div>\n\n<p class=\"caption\" id=\"caption\">With three responders, the two critical cases and one urgent case get immediate attention. Two stable cases wait.</p>\n\n<script>\n  (function () {\n    var cases = [\n      { id: 1, severity: 3, label: 'Case A', desc: 'Critical' },\n      { id: 2, severity: 3, label: 'Case B', desc: 'Critical' },\n      { id: 3, severity: 2, label: 'Case C', desc: 'Urgent' },\n      { id: 4, severity: 1, label: 'Case D', desc: 'Stable' },\n      { id: 5, severity: 1, label: 'Case E', desc: 'Stable' }\n    ];\n\n    var slider = document.getElementById('responders');\n    var respondersOut = document.getElementById('responders-out');\n    var scene = document.getElementById('scene');\n    var treatingEl = document.getElementById('treating');\n    var waitingEl = document.getElementById('waiting');\n    var caption = document.getElementById('caption');\n\n    function render() {\n      var count = +slider.value;\n      respondersOut.textContent = count;\n\n      scene.innerHTML = '';\n      var treating = 0;\n      var waiting = 0;\n\n      cases.forEach(function (c, idx) {\n        var div = document.createElement('div');\n        div.className = 'case';\n        if (c.severity === 3) div.classList.add('critical');\n        else if (c.severity === 2) div.classList.add('urgent');\n        else div.classList.add('stable');\n\n        var isTreating = idx < count;\n        if (isTreating) {\n          div.classList.add('treating');\n          treating++;\n        } else {\n          div.classList.add('waiting');\n          waiting++;\n        }\n\n        var labelSpan = document.createElement('div');\n        labelSpan.className = 'case-label';\n        labelSpan.textContent = c.label;\n\n        var statusSpan = document.createElement('div');\n        statusSpan.className = 'case-status';\n        statusSpan.textContent = c.desc;\n\n        var timerSpan = document.createElement('div');\n        timerSpan.className = 'case-timer';\n        timerSpan.textContent = isTreating ? 'Treating now' : 'Waiting';\n\n        div.appendChild(labelSpan);\n        div.appendChild(statusSpan);\n        div.appendChild(timerSpan);\n        scene.appendChild(div);\n      });\n\n      treatingEl.textContent = treating;\n      waitingEl.textContent = waiting;\n\n      if (count === 5) {\n        caption.textContent = 'All cases receive immediate attention. No one waits.';\n      } else if (count === 4) {\n        caption.textContent = 'One stable case waits while the other four get treated first.';\n      } else if (count === 3) {\n        caption.textContent = 'With three responders, the two critical cases and one urgent case get immediate attention. Two stable cases wait.';\n      } else if (count === 2) {\n        caption.textContent = 'Only the two critical cases get immediate treatment. Three others wait, including the urgent case.';\n      } else {\n        caption.textContent = 'One responder treats the first critical case. Four cases wait, including one other critical case.';\n      }\n    }\n\n    slider.addEventListener('input', render);\n    render();\n  })();\n</script>\n</body>\n</html>"
  }
}
