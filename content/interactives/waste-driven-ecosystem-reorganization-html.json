  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Nutrient Cascade Rewrite</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #d94f3d;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .stages {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin: 24px 0;\n  }\n  .stage {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 12px 14px;\n    transition: all 220ms ease-out;\n  }\n  .stage-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 8px;\n  }\n  .stage-name {\n    font-size: 0.75rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n  }\n  .stage-level {\n    font-size: 0.85rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .bar {\n    height: 18px;\n    background: var(--line);\n    border-radius: 2px;\n    overflow: hidden;\n    position: relative;\n  }\n  .bar-fill {\n    height: 100%;\n    background: var(--teal);\n    transition: width 220ms ease-out;\n  }\n  .stage.altered .bar-fill {\n    background: var(--red);\n  }\n  .stage.altered {\n    background: #fff5f5;\n    border-color: #f0d0cc;\n  }\n  .arrow {\n    text-align: center;\n    color: var(--muted);\n    font-size: 1.2rem;\n    margin: -8px 0;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control output {\n      text-align: left;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to add nutrient input</h2>\n<p class=\"subhead\">Each change creates the starting condition for the next.</p>\n\n<div class=\"control\">\n  <label for=\"nutrient\">Nutrient load:</label>\n  <input id=\"nutrient\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" step=\"5\" aria-describedby=\"nutrient-out\">\n  <output id=\"nutrient-out\" for=\"nutrient\">0</output>\n</div>\n\n<div class=\"stages\">\n  <div class=\"stage\" id=\"stage-1\">\n    <div class=\"stage-header\">\n      <span class=\"stage-name\">Algae bloom</span>\n      <span class=\"stage-level\" id=\"level-1\">baseline</span>\n    </div>\n    <div class=\"bar\"><div class=\"bar-fill\" id=\"fill-1\"></div></div>\n  </div>\n  <div class=\"arrow\">↓</div>\n  <div class=\"stage\" id=\"stage-2\">\n    <div class=\"stage-header\">\n      <span class=\"stage-name\">Oxygen loss</span>\n      <span class=\"stage-level\" id=\"level-2\">baseline</span>\n    </div>\n    <div class=\"bar\"><div class=\"bar-fill\" id=\"fill-2\"></div></div>\n  </div>\n  <div class=\"arrow\">↓</div>\n  <div class=\"stage\" id=\"stage-3\">\n    <div class=\"stage-header\">\n      <span class=\"stage-name\">Fish die-off</span>\n      <span class=\"stage-level\" id=\"level-3\">baseline</span>\n    </div>\n    <div class=\"bar\"><div class=\"bar-fill\" id=\"fill-3\"></div></div>\n  </div>\n  <div class=\"arrow\">↓</div>\n  <div class=\"stage\" id=\"stage-4\">\n    <div class=\"stage-header\">\n      <span class=\"stage-name\">Predator loss</span>\n      <span class=\"stage-level\" id=\"level-4\">baseline</span>\n    </div>\n    <div class=\"bar\"><div class=\"bar-fill\" id=\"fill-4\"></div></div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Stages changed: <strong id=\"changed-count\">0</strong>.\n  Cascade depth: <strong id=\"depth\">none</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">The system sits stable. Each layer gets what it needs from the one before.</p>\n\n<script>\n(function () {\n  var slider = document.getElementById('nutrient');\n  var nutrientOut = document.getElementById('nutrient-out');\n  var stages = [\n    { el: document.getElementById('stage-1'), fill: document.getElementById('fill-1'), level: document.getElementById('level-1') },\n    { el: document.getElementById('stage-2'), fill: document.getElementById('fill-2'), level: document.getElementById('level-2') },\n    { el: document.getElementById('stage-3'), fill: document.getElementById('fill-3'), level: document.getElementById('level-3') },\n    { el: document.getElementById('stage-4'), fill: document.getElementById('fill-4'), level: document.getElementById('level-4') }\n  ];\n  var changedCount = document.getElementById('changed-count');\n  var depth = document.getElementById('depth');\n  var caption = document.getElementById('caption');\n\n  function update() {\n    var load = +slider.value;\n    nutrientOut.textContent = load;\n    \n    var levels = [load];\n    for (var i = 1; i < 4; i++) {\n      var prev = levels[i - 1];\n      var next = 0;\n      if (prev > 15) {\n        next = prev * 0.85;\n      }\n      levels.push(next);\n    }\n    \n    var changed = 0;\n    for (var i = 0; i < 4; i++) {\n      var v = Math.round(levels[i]);\n      stages[i].fill.style.width = v + '%';\n      if (v === 0) {\n        stages[i].level.textContent = 'baseline';\n        stages[i].el.classList.remove('altered');\n      } else {\n        stages[i].level.textContent = v;\n        stages[i].el.classList.add('altered');\n        changed++;\n      }\n    }\n    \n    changedCount.textContent = changed;\n    \n    if (load === 0) {\n      depth.textContent = 'none';\n      caption.textContent = 'The system sits stable. Each layer gets what it needs from the one before.';\n    } else if (changed === 1) {\n      depth.textContent = '1 stage';\n      caption.textContent = 'Extra nutrients fuel more growth. The rest of the system stays unchanged.';\n    } else if (changed === 2) {\n      depth.textContent = '2 stages';\n      caption.textContent = 'The bloom pulls oxygen out. The first change creates the second.';\n    } else if (changed === 3) {\n      depth.textContent = '3 stages';\n      caption.textContent = 'Low oxygen kills off populations that need it. The damage spreads down the line.';\n    } else {\n      depth.textContent = 'full cascade';\n      caption.textContent = 'Every layer breaks. A flood at the top rewrites everything below.';\n    }\n  }\n\n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
