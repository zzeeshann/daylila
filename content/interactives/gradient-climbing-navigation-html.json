{
  "slug": "gradient-climbing-navigation",
  "type": "html",
  "title": "Slope Detection Between Samples",
  "concept": "Pattern recognition by comparing readings across positions — detecting 'more here than there' reveals direction without mapping the whole field.",
  "interactiveId": "ab7d2bb4-4a25-4251-bdd0-92d5093b440e",
  "sourcePieceId": "ad0c68c2-d745-4cde-b776-faf7feb554d0",
  "publishedAt": 1777428498458,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Slope Detection Between Samples</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --source: #c9a227;\n    --left: #1a6b62;\n    --right: #8b4513;\n    --field-low: #f0ece3;\n    --field-high: #e8d8a8;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .container {\n    max-width: 600px;\n    margin: 0 auto;\n  }\n  .field-container {\n    position: relative;\n    width: 100%;\n    margin: 0 0 16px;\n  }\n  canvas {\n    display: block;\n    width: 100%;\n    height: auto;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .detectors {\n    display: flex;\n    justify-content: center;\n    gap: 80px;\n    margin: 20px 0;\n  }\n  .detector {\n    text-align: center;\n  }\n  .detector-visual {\n    width: 50px;\n    height: 50px;\n    border-radius: 50%;\n    margin: 0 auto 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: white;\n  }\n  .detector.left .detector-visual {\n    background: var(--left);\n  }\n  .detector.right .detector-visual {\n    background: var(--right);\n  }\n  .detector-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n  }\n  .detector-reading {\n    font-size: 0.85rem;\n    font-variant-numeric: tabular-nums;\n  }\n  .comparison {\n    margin: 20px 0;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    text-align: center;\n  }\n  .comparison-label {\n    font-size: 0.85rem;\n    color: var(--muted);\n    margin-bottom: 6px;\n  }\n  .comparison-result {\n    font-size: 1.1rem;\n    font-weight: 600;\n  }\n  .comparison-arrow {\n    font-size: 1.5rem;\n    margin: 8px 0;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin: 20px 0;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--left);\n    min-width: 120px;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .detectors {\n      gap: 40px;\n    }\n    .detector-visual {\n      width: 40px;\n      height: 40px;\n      font-size: 0.95rem;\n    }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n<h2>Drag the pair across the field</h2>\n<p class=\"subhead\">Two detectors sample at different positions. The difference between readings reveals direction.</p>\n\n<div class=\"field-container\">\n  <canvas id=\"canvas\" width=\"500\" height=\"300\" aria-label=\"Concentration field visualization\"></canvas>\n</div>\n\n<div class=\"control\">\n  <label for=\"position\">Position:</label>\n  <input id=\"position\" type=\"range\" min=\"50\" max=\"450\" value=\"150\" aria-describedby=\"position-label\">\n</div>\n\n<div class=\"detectors\">\n  <div class=\"detector left\">\n    <div class=\"detector-label\">Left sensor</div>\n    <div class=\"detector-visual\" id=\"left-value\">0</div>\n    <div class=\"detector-reading\" id=\"left-reading\">—</div>\n  </div>\n  <div class=\"detector right\">\n    <div class=\"detector-label\">Right sensor</div>\n    <div class=\"detector-visual\" id=\"right-value\">0</div>\n    <div class=\"detector-reading\" id=\"right-reading\">—</div>\n  </div>\n</div>\n\n<div class=\"comparison\">\n  <div class=\"comparison-label\">Slope detected:</div>\n  <div class=\"comparison-result\" id=\"slope\">—</div>\n  <div class=\"comparison-arrow\" id=\"arrow\">—</div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Drag the slider. When the right sensor reads higher, the slope points right.</p>\n</div>\n\n<script>\n(function() {\n  var canvas = document.getElementById('canvas');\n  var ctx = canvas.getContext('2d');\n  var slider = document.getElementById('position');\n  var leftValueEl = document.getElementById('left-value');\n  var rightValueEl = document.getElementById('right-value');\n  var leftReadingEl = document.getElementById('left-reading');\n  var rightReadingEl = document.getElementById('right-reading');\n  var slopeEl = document.getElementById('slope');\n  var arrowEl = document.getElementById('arrow');\n  var captionEl = document.getElementById('caption');\n\n  var W = canvas.width;\n  var H = canvas.height;\n  var sourceX = W * 0.75;\n  var sourceY = H * 0.5;\n  var separation = 40;\n\n  function intensity(x, y) {\n    var dx = x - sourceX;\n    var dy = y - sourceY;\n    var d = Math.sqrt(dx * dx + dy * dy);\n    return Math.max(0, 100 - d * 0.4);\n  }\n\n  function drawField() {\n    var imgData = ctx.createImageData(W, H);\n    var data = imgData.data;\n    for (var y = 0; y < H; y++) {\n      for (var x = 0; x < W; x++) {\n        var i = (y * W + x) * 4;\n        var val = intensity(x, y);\n        var t = val / 100;\n        var r = Math.floor(240 + t * (232 - 240));\n        var g = Math.floor(236 + t * (216 - 236));\n        var b = Math.floor(227 + t * (168 - 227));\n        data[i] = r;\n        data[i + 1] = g;\n        data[i + 2] = b;\n        data[i + 3] = 255;\n      }\n    }\n    ctx.putImageData(imgData, 0, 0);\n  }\n\n  function drawSource() {\n    ctx.fillStyle = '#c9a227';\n    ctx.beginPath();\n    ctx.arc(sourceX, sourceY, 10, 0, 2 * Math.PI);\n    ctx.fill();\n  }\n\n  function drawDetectors(centerX) {\n    var leftX = centerX - separation / 2;\n    var rightX = centerX + separation / 2;\n    var y = H / 2;\n    ctx.fillStyle = '#1a6b62';\n    ctx.beginPath();\n    ctx.arc(leftX, y, 8, 0, 2 * Math.PI);\n    ctx.fill();\n    ctx.strokeStyle = '#fff';\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    ctx.fillStyle = '#8b4513';\n    ctx.beginPath();\n    ctx.arc(rightX, y, 8, 0, 2 * Math.PI);\n    ctx.fill();\n    ctx.strokeStyle = '#fff';\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    ctx.strokeStyle = 'rgba(26, 107, 98, 0.4)';\n    ctx.lineWidth = 2;\n    ctx.beginPath();\n    ctx.moveTo(leftX, y);\n    ctx.lineTo(rightX, y);\n    ctx.stroke();\n  }\n\n  function render() {\n    drawField();\n    drawSource();\n    var centerX = +slider.value;\n    drawDetectors(centerX);\n  }\n\n  function update() {\n    var centerX = +slider.value;\n    var leftX = centerX - separation / 2;\n    var rightX = centerX + separation / 2;\n    var y = H / 2;\n    var leftVal = intensity(leftX, y);\n    var rightVal = intensity(rightX, y);\n    var diff = rightVal - leftVal;\n    leftValueEl.textContent = Math.round(leftVal);\n    rightValueEl.textContent = Math.round(rightVal);\n    leftReadingEl.textContent = Math.round(leftVal) + ' units';\n    rightReadingEl.textContent = Math.round(rightVal) + ' units';\n    if (Math.abs(diff) < 2) {\n      slopeEl.textContent = 'Flat';\n      arrowEl.textContent = '—';\n      captionEl.textContent = 'Readings match. No slope detected — the pair sits in uniform concentration.';\n    } else if (diff > 0) {\n      slopeEl.textContent = 'Rising to the right';\n      arrowEl.textContent = '→';\n      if (Math.abs(diff) > 15) {\n        captionEl.textContent = 'Sharp slope. The right sensor reads much higher — direction is clear from a single comparison.';\n      } else {\n        captionEl.textContent = 'Gentle slope. The right sensor reads slightly higher — successive comparisons refine direction.';\n      }\n    } else {\n      slopeEl.textContent = 'Rising to the left';\n      arrowEl.textContent = '←';\n      if (Math.abs(diff) > 15) {\n        captionEl.textContent = 'Sharp slope. The left sensor reads much higher — direction is clear from a single comparison.';\n      } else {\n        captionEl.textContent = 'Gentle slope. The left sensor reads slightly higher — successive comparisons refine direction.';\n      }\n    }\n    render();\n  }\n\n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
