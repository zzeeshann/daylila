---
export const prerender = false;

/**
 * /daily/ — today's editorial timeline.
 *
 * TODAY shows full-sized RunBlocks for runs that published today (UTC),
 * newest first. Each RunBlock = one piece + the candidate set Scanner
 * pulled for that run.
 *
 * THIS WEEK shows the previous 6 days as <details> day-rows; expanded
 * each row reveals compact RunBlocks for that day. Beyond 7 days,
 * readers cross to /library/ via the footer link.
 *
 * Data:
 *   daily_pieces  ←→  daily_candidates  (joined on c.piece_id = p.id)
 *   Content collection used to recover the URL slug + description +
 *   sourceUrl + estimatedTime for each piece (D1 doesn't store these).
 *   Pieces with no matching collection entry are filtered out — that
 *   covers orphan piece_ids from runs Scanner started but never
 *   published, which shouldn't appear on the public Daily page.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import RunBlock from '../../components/RunBlock.astro';
import type { RunPiece, RunCandidate } from '../../components/RunBlock.astro';
import { getCollection } from 'astro:content';
import { deriveSlug } from '../../lib/slug';
import { formatUtcLongDateFromIso } from '../../lib/format';
import { computePieceStats } from '../../lib/piece-stats';

const db = Astro.locals.runtime.env.DB;

const todayUtc = new Date().toISOString().slice(0, 10);
const sevenDaysAgoUtc = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000)
  .toISOString()
  .slice(0, 10);

interface PieceRow {
  piece_id: string;
  date: string;
  headline: string;
  reading_minutes: number | null;
  published_at: number;
  candidate_id: string | null;
  candidate_headline: string | null;
  source: string | null;
  url: string | null;
  candidate_created_at: number | null;
  selected: number | null;
}

const rows = (await db
  .prepare(
    `SELECT
       p.id AS piece_id,
       p.date,
       p.headline,
       p.reading_minutes,
       p.published_at,
       c.id AS candidate_id,
       c.headline AS candidate_headline,
       c.source,
       c.url,
       c.created_at AS candidate_created_at,
       c.selected
     FROM daily_pieces p
     LEFT JOIN daily_candidates c ON c.piece_id = p.id
     WHERE p.date >= ?
     ORDER BY p.published_at DESC, c.selected DESC, c.created_at DESC`,
  )
  .bind(sevenDaysAgoUtc)
  .all<PieceRow>()).results;

// Group by piece_id → { piece, candidates[] }
type Bucket = {
  d1: {
    piece_id: string;
    date: string;
    headline: string;
    reading_minutes: number | null;
    published_at: number;
  };
  candidates: RunCandidate[];
};

const buckets = new Map<string, Bucket>();
for (const r of rows) {
  let b = buckets.get(r.piece_id);
  if (!b) {
    b = {
      d1: {
        piece_id: r.piece_id,
        date: r.date,
        headline: r.headline,
        reading_minutes: r.reading_minutes,
        published_at: r.published_at,
      },
      candidates: [],
    };
    buckets.set(r.piece_id, b);
  }
  if (r.candidate_id && r.candidate_headline) {
    b.candidates.push({
      id: r.candidate_id,
      headline: r.candidate_headline,
      source: r.source ?? '',
      url: r.url,
      createdAt: r.candidate_created_at ?? r.published_at,
      selected: r.selected === 1,
    });
  }
}

// JOIN with content collection for slug/description/estimatedTime.
const collection = await getCollection('dailyPieces');
const collectionByPieceId = new Map<string, (typeof collection)[number]>();
for (const entry of collection) {
  if (entry.data.pieceId) collectionByPieceId.set(entry.data.pieceId, entry);
}

type Run = { piece: RunPiece; candidates: RunCandidate[] };

const runs: Run[] = [];
for (const b of buckets.values()) {
  const entry = collectionByPieceId.get(b.d1.piece_id);
  if (!entry) continue; // orphan piece_id — skip
  // Beat count derived from the published MDX (single source of truth).
  // The previously-used daily_pieces.beat_count column was Curator's brief
  // plan and drifted from what Drafter actually shipped — see PR #0.
  const stats = computePieceStats(entry.body ?? '');
  runs.push({
    piece: {
      pieceId: b.d1.piece_id,
      date: b.d1.date,
      slug: deriveSlug(entry.id),
      headline: b.d1.headline || entry.data.title,
      description: entry.data.description,
      beatCount: stats.beatCount,
      readingMinutes: b.d1.reading_minutes,
      estimatedTime: entry.data.estimatedTime,
      publishedAt: b.d1.published_at || entry.data.publishedAt,
      newsSource: entry.data.newsSource,
      sourceUrl: entry.data.sourceUrl,
    },
    candidates: b.candidates,
  });
}

// Sort newest run first by publishedAt.
runs.sort((a, b) => b.piece.publishedAt - a.piece.publishedAt);

const todayRuns = runs.filter((r) => r.piece.date === todayUtc);
const olderRuns = runs.filter((r) => r.piece.date !== todayUtc);

// Group olderRuns by date, newest day first.
const olderByDate = new Map<string, Run[]>();
for (const r of olderRuns) {
  const arr = olderByDate.get(r.piece.date) ?? [];
  arr.push(r);
  olderByDate.set(r.piece.date, arr);
}
const olderDays = [...olderByDate.entries()].sort(([a], [b]) => b.localeCompare(a));

const todayLabel = formatUtcLongDateFromIso(todayUtc);
---

<BaseLayout
  title="Daily — Daylila"
  description="Today's pieces and the news they came from. The candidate set Scanner pulled for each run, with the picked story marked."
>
  <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight">Daily</h1>
  <p class="text-lg text-zee-muted mb-10">
    Today's pieces and the news they came from.
  </p>

  <section aria-labelledby="daily-today-label" class="mb-12">
    <p
      id="daily-today-label"
      class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4"
    >
      Today · {todayLabel}
    </p>
    {todayRuns.length === 0 ? (
      <p class="text-zee-muted italic py-8">
        Today's first piece will appear here when it publishes.
      </p>
    ) : (
      todayRuns.map((r) => (
        <RunBlock piece={r.piece} candidates={r.candidates} size="hero" />
      ))
    )}
  </section>

  {olderDays.length > 0 && (
    <section aria-labelledby="daily-week-label" class="mb-10">
      <p
        id="daily-week-label"
        class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4"
      >
        This week
      </p>
      <ul class="space-y-2">
        {olderDays.map(([date, dayRuns]) => {
          const dayLabel = formatUtcLongDateFromIso(date);
          const totalCandidates = dayRuns.reduce((s, r) => s + r.candidates.length, 0);
          const headlineSummary = dayRuns
            .map((r) => r.piece.headline)
            .join(' · ');
          return (
            <li>
              <details class="day-row border-b border-zee-border/60">
                <summary class="cursor-pointer select-none py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
                  <span class="flex items-baseline gap-3 min-w-0">
                    <span class="day-row-chevron text-zee-muted shrink-0" aria-hidden="true">▸</span>
                    <span class="flex flex-col min-w-0">
                      <span class="text-sm font-medium text-zee-text">{dayLabel}</span>
                      <span class="text-sm text-zee-muted truncate">{headlineSummary}</span>
                    </span>
                  </span>
                  <span class="text-xs text-zee-muted shrink-0 pl-7 sm:pl-0">
                    {totalCandidates} {totalCandidates === 1 ? 'candidate' : 'candidates'}
                  </span>
                </summary>
                <div class="pl-7 pb-4 pt-2">
                  {dayRuns.map((r) => (
                    <RunBlock piece={r.piece} candidates={r.candidates} size="compact" />
                  ))}
                </div>
              </details>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <p class="text-center mt-16 mb-4">
    <a
      href="/library/"
      class="text-sm text-zee-muted hover:text-zee-primary transition-colors"
    >
      Browse the full library →
    </a>
  </p>
</BaseLayout>

<style>
  .day-row > summary {
    list-style: none;
  }
  .day-row > summary::-webkit-details-marker {
    display: none;
  }
  .day-row > summary > span > .day-row-chevron {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .day-row[open] > summary > span > .day-row-chevron {
    transform: rotate(90deg);
  }
</style>
