{
  "slug": "scaling-constraints-and-structure",
  "type": "html",
  "title": "Bone Load and Body Mass",
  "concept": "As an animal's size increases, its bones must thicken faster than its height grows, because weight scales with volume (cubed) while bone strength scales with cross-sectional area (squared)—this physical constraint reveals why larger creatures have proportionally thicker skeletons.",
  "interactiveId": "0067636f-f386-4cd9-ab23-ade886ce28f9",
  "sourcePieceId": "5f4e05cb-f9f3-4081-b503-17c8e0132d1d",
  "publishedAt": 1778897266087,
  "voiceScore": 95,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Bone Load and Body Mass</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --bone: #d4c4a8;\n    --stress: #c94c4c;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--bone);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .display {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 20px;\n    margin: 24px 0;\n  }\n  .metric {\n    padding: 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .metric-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 6px;\n  }\n  .metric-value {\n    font-size: 1.5rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .metric-unit {\n    font-size: 0.85rem;\n    font-weight: 400;\n    color: var(--muted);\n    margin-left: 4px;\n  }\n  .visual {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    gap: 40px;\n    min-height: 200px;\n  }\n  .bone-stack {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 4px;\n  }\n  .bone-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    margin-bottom: 6px;\n  }\n  .bone {\n    background: var(--bone);\n    border-radius: 4px;\n    transition: all 250ms ease-out;\n    position: relative;\n  }\n  .stress-overlay {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    background: var(--stress);\n    opacity: 0;\n    transition: opacity 250ms ease-out;\n    border-radius: 0 0 4px 4px;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .visual {\n      gap: 20px;\n      flex-wrap: wrap;\n    }\n    .display {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Scale an animal up and watch its bones respond</h2>\n<p class=\"subhead\">Height scales linearly, mass scales with volume (cubed), bone strength scales with area (squared).</p>\n\n<div class=\"control\">\n  <label for=\"height\">Height:</label>\n  <input id=\"height\" type=\"range\" min=\"1\" max=\"5\" step=\"0.1\" value=\"1\" aria-describedby=\"height-out\">\n  <output id=\"height-out\" for=\"height\">1×</output>\n</div>\n\n<div class=\"display\">\n  <div class=\"metric\">\n    <div class=\"metric-label\">Mass</div>\n    <div class=\"metric-value\">\n      <span id=\"mass\">1.0</span><span class=\"metric-unit\">×</span>\n    </div>\n  </div>\n  <div class=\"metric\">\n    <div class=\"metric-label\">Bone strength</div>\n    <div class=\"metric-value\">\n      <span id=\"strength\">1.0</span><span class=\"metric-unit\">×</span>\n    </div>\n  </div>\n  <div class=\"metric\">\n    <div class=\"metric-label\">Stress ratio</div>\n    <div class=\"metric-value\" id=\"ratio-display\">\n      <span id=\"ratio\">1.0</span><span class=\"metric-unit\">×</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"visual\" aria-hidden=\"true\">\n  <div class=\"bone-stack\">\n    <div class=\"bone-label\">Base (1×)</div>\n    <div class=\"bone\" id=\"base-bone\" style=\"width: 20px; height: 80px;\">\n      <div class=\"stress-overlay\" id=\"base-stress\" style=\"height: 0%;\"></div>\n    </div>\n  </div>\n  <div class=\"bone-stack\">\n    <div class=\"bone-label\" id=\"scaled-label\">Scaled (1×)</div>\n    <div class=\"bone\" id=\"scaled-bone\" style=\"width: 20px; height: 80px;\">\n      <div class=\"stress-overlay\" id=\"scaled-stress\" style=\"height: 0%;\"></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Status: <strong id=\"status\">Bones handle the load comfortably.</strong>\n</div>\n\n<p class=\"caption\" id=\"caption\">At the base size, mass and strength match. The skeleton is not under unusual stress.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('height');\n    var heightOut = document.getElementById('height-out');\n    var massEl = document.getElementById('mass');\n    var strengthEl = document.getElementById('strength');\n    var ratioEl = document.getElementById('ratio');\n    var ratioDisplay = document.getElementById('ratio-display');\n    var statusEl = document.getElementById('status');\n    var captionEl = document.getElementById('caption');\n    var scaledLabel = document.getElementById('scaled-label');\n    var scaledBone = document.getElementById('scaled-bone');\n    var scaledStress = document.getElementById('scaled-stress');\n    var baseStress = document.getElementById('base-stress');\n\n    function update() {\n      var h = parseFloat(slider.value);\n      heightOut.textContent = h.toFixed(1) + '×';\n\n      // Mass scales with volume: h^3\n      var mass = Math.pow(h, 3);\n      // Bone strength scales with cross-sectional area: h^2\n      var strength = Math.pow(h, 2);\n      // Stress ratio: mass / strength = h^3 / h^2 = h\n      var ratio = mass / strength;\n\n      massEl.textContent = mass.toFixed(1);\n      strengthEl.textContent = strength.toFixed(1);\n      ratioEl.textContent = ratio.toFixed(1);\n\n      scaledLabel.textContent = 'Scaled (' + h.toFixed(1) + '×)';\n\n      // Visual: scale the bone's height and width proportionally\n      var baseH = 80;\n      var baseW = 20;\n      scaledBone.style.height = (baseH * h) + 'px';\n      // To keep stress constant, width would need to scale as h^1.5\n      // But naive scaling is linear, so width = baseW * h\n      // This makes the bone look thinner relative to its load\n      scaledBone.style.width = (baseW * h) + 'px';\n\n      // Stress overlay: show visually how much of the bone is \"overloaded\"\n      // Ratio > 1 means stress is increasing\n      // Cap the visual at 50% fill for ratio = 5\n      var stressPct = Math.min(((ratio - 1) / 4) * 50, 50);\n      scaledStress.style.height = stressPct + '%';\n      scaledStress.style.opacity = ratio > 1.1 ? '0.3' : '0';\n\n      // Base bone stays constant, no stress\n      baseStress.style.opacity = '0';\n\n      // Status and caption\n      if (ratio < 1.2) {\n        statusEl.textContent = 'Bones handle the load comfortably.';\n        captionEl.textContent = 'At this size, mass and strength stay roughly matched. The skeleton is not under unusual stress.';\n        ratioDisplay.style.color = 'var(--fg)';\n      } else if (ratio < 2.0) {\n        statusEl.textContent = 'Stress is rising. Bones are thicker but not thick enough.';\n        captionEl.textContent = 'Mass is growing faster than bone strength. The skeleton begins to bear more load per unit of bone.';\n        ratioDisplay.style.color = 'var(--stress)';\n      } else if (ratio < 3.5) {\n        statusEl.textContent = 'Bones are severely stressed. Collapse risk increases.';\n        captionEl.textContent = 'Each doubling of height adds eight times the mass but only four times the strength. Bones must thicken much faster than height to keep pace.';\n        ratioDisplay.style.color = 'var(--stress)';\n      } else {\n        statusEl.textContent = 'Bones would fail under this load without redesign.';\n        captionEl.textContent = 'At extreme sizes, bones need to be proportionally much thicker—almost comically thick—to support the animal. Physics sets the limit.';\n        ratioDisplay.style.color = 'var(--stress)';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
