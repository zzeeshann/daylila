  "title": "Friction Collapse and Cascades",
  "concept": "When early adopters cross a behavior threshold, their visibility reduces friction for everyone else—lowering the barrier triggers more crossings, which lower the barrier further, creating a self-reinforcing cascade.",
  "interactiveId": "ed7b4fe2-73fe-49e1-a641-65ea5bbae757",
  "sourcePieceId": "8cda1afc-48fb-4ad3-94d2-1ee3d77e3edc",
  "publishedAt": 1778502916930,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Friction Collapse and Cascades</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c23b22;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .chart-area {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .axis-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 12px;\n  }\n  .bar-container {\n    display: flex;\n    align-items: flex-end;\n    height: 160px;\n    gap: 6px;\n    margin-bottom: 8px;\n    border-bottom: 2px solid var(--line);\n    position: relative;\n  }\n  .person-bar {\n    flex: 1;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    align-items: stretch;\n  }\n  .threshold-marker {\n    width: 100%;\n    background: var(--line);\n    border-radius: 2px 2px 0 0;\n    border-top: 2px solid var(--gold);\n    transition: background 300ms ease-out, border-color 300ms ease-out;\n  }\n  .threshold-marker.crossed {\n    background: var(--teal);\n    border-top-color: var(--teal);\n  }\n  .friction-line {\n    position: absolute;\n    left: 0;\n    right: 0;\n    height: 2px;\n    background: var(--red);\n    opacity: 0.7;\n    pointer-events: none;\n    transition: bottom 300ms ease-out;\n  }\n  .friction-label {\n    position: absolute;\n    right: 4px;\n    top: -20px;\n    font-size: 0.7rem;\n    color: var(--red);\n    font-weight: 600;\n    white-space: nowrap;\n  }\n  .x-labels {\n    display: flex;\n    gap: 6px;\n  }\n  .x-label {\n    flex: 1;\n    text-align: center;\n    font-size: 0.65rem;\n    color: var(--muted);\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-wrap: wrap;\n    }\n    .control input[type=range] {\n      width: 100%;\n    }\n    .x-label {\n      font-size: 0.6rem;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Set the starting friction</h2>\n<p class=\"subhead\">Each person has a personal threshold. Watch friction collapse as early crossers pull others in.</p>\n\n<div class=\"control\">\n  <label for=\"initial-friction\">Starting friction:</label>\n  <input id=\"initial-friction\" type=\"range\" min=\"0\" max=\"100\" value=\"75\" aria-describedby=\"friction-out\">\n  <output id=\"friction-out\" for=\"initial-friction\">75</output>\n</div>\n\n<div class=\"chart-area\">\n  <div class=\"axis-label\">Personal threshold (height) vs. current friction (red line)</div>\n  <div class=\"bar-container\" id=\"bars\">\n    <div class=\"friction-line\" id=\"friction-line\">\n      <span class=\"friction-label\" id=\"friction-label\">Friction: 75</span>\n    </div>\n  </div>\n  <div class=\"x-labels\" id=\"x-labels\"></div>\n</div>\n\n<div class=\"reading\">\n  People who crossed: <strong id=\"crossed-count\">0</strong> out of 12.\n  Friction now: <strong id=\"current-friction\">75</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">High friction. Nobody has crossed yet. The barrier holds everyone back.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('initial-friction');\n    var frictionOut = document.getElementById('friction-out');\n    var crossedCount = document.getElementById('crossed-count');\n    var currentFrictionDisplay = document.getElementById('current-friction');\n    var caption = document.getElementById('caption');\n    var barsContainer = document.getElementById('bars');\n    var xLabelsContainer = document.getElementById('x-labels');\n    var frictionLine = document.getElementById('friction-line');\n    var frictionLabel = document.getElementById('friction-label');\n    var MAX_HEIGHT = 160;\n    var FRICTION_DROP_PER_CROSSER = 6;\n\n    var thresholds = [12, 18, 25, 35, 42, 50, 58, 65, 70, 78, 85, 92];\n    var people = thresholds.map(function (t, i) {\n      return { id: i + 1, threshold: t, crossed: false };\n    });\n\n    people.forEach(function (p) {\n      var bar = document.createElement('div');\n      bar.className = 'person-bar';\n      var marker = document.createElement('div');\n      marker.className = 'threshold-marker';\n      marker.dataset.person = p.id;\n      var heightPx = (p.threshold / 100) * MAX_HEIGHT;\n      marker.style.height = heightPx + 'px';\n      bar.appendChild(marker);\n      barsContainer.appendChild(bar);\n\n      var label = document.createElement('div');\n      label.className = 'x-label';\n      label.textContent = 'P' + p.id;\n      xLabelsContainer.appendChild(label);\n    });\n\n    var markers = document.querySelectorAll('.threshold-marker');\n    var currentFriction = 75;\n    var animationRunning = false;\n\n    function computeFriction(numCrossed) {\n      var baselineFriction = +slider.value;\n      var reduction = numCrossed * FRICTION_DROP_PER_CROSSER;\n      return Math.max(0, baselineFriction - reduction);\n    }\n\n    function updateVisuals(friction, numCrossed) {\n      var frictionPx = (friction / 100) * MAX_HEIGHT;\n      frictionLine.style.bottom = frictionPx + 'px';\n      frictionLabel.textContent = 'Friction: ' + Math.round(friction);\n      crossedCount.textContent = numCrossed;\n      currentFrictionDisplay.textContent = Math.round(friction);\n\n      if (numCrossed === 0) {\n        caption.textContent = 'High friction. Nobody has crossed yet. The barrier holds everyone back.';\n      } else if (numCrossed === 1) {\n        caption.textContent = 'One person crossed. Friction drops slightly—their visibility makes it easier for the next person.';\n      } else if (numCrossed <= 3) {\n        caption.textContent = 'A few early crossers reduce friction for everyone. The barrier is lower now than when it started.';\n      } else if (numCrossed <= 6) {\n        caption.textContent = 'The cascade is underway. Each new crosser drops friction further, pulling more people across.';\n      } else if (numCrossed <= 9) {\n        caption.textContent = 'Friction has collapsed. The behavior is becoming normal—late adopters see it everywhere.';\n      } else {\n        caption.textContent = 'Near-universal adoption. The friction that held everyone back at the start is almost gone.';\n      }\n    }\n\n    function runCascade() {\n      if (animationRunning) return;\n      animationRunning = true;\n\n      var baselineFriction = +slider.value;\n      currentFriction = baselineFriction;\n      people.forEach(function (p) { p.crossed = false; });\n      markers.forEach(function (m) { m.classList.remove('crossed'); });\n\n      var numCrossed = 0;\n      updateVisuals(currentFriction, numCrossed);\n\n      var interval = setInterval(function () {\n        var anyoneNew = false;\n        people.forEach(function (p, idx) {\n          if (!p.crossed && currentFriction <= p.threshold) {\n            p.crossed = true;\n            markers[idx].classList.add('crossed');\n            numCrossed++;\n            anyoneNew = true;\n          }\n        });\n\n        if (anyoneNew) {\n          currentFriction = computeFriction(numCrossed);\n          updateVisuals(currentFriction, numCrossed);\n        } else {\n          clearInterval(interval);\n          animationRunning = false;\n        }\n      }, 400);\n    }\n\n    slider.addEventListener('input', function () {\n      frictionOut.textContent = slider.value;\n    });\n\n    slider.addEventListener('change', function () {\n      runCascade();\n    });\n\n    runCascade();\n  })();\n</script>\n</body>\n</html>"
  }
}
