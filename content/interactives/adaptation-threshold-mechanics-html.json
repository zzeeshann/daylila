    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Intensity Thresholds and Adaptation</title>\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n  background: #fafafa;\n  padding: 20px;\n  line-height: 1.5;\n}\n\n.container {\n  max-width: 700px;\n  margin: 0 auto;\n  background: white;\n  padding: 32px;\n  border-radius: 8px;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n}\n\nh1 {\n  font-size: 24px;\n  font-weight: 600;\n  margin-bottom: 8px;\n  color: #1a1a1a;\n}\n\n.concept {\n  font-size: 15px;\n  color: #666;\n  margin-bottom: 32px;\n  line-height: 1.6;\n}\n\n.teaching-label {\n  font-size: 15px;\n  font-weight: 500;\n  color: #1a1a1a;\n  margin-bottom: 20px;\n}\n\n.interactive-surface {\n  background: #f5f5f5;\n  border-radius: 6px;\n  padding: 24px;\n  margin-bottom: 24px;\n}\n\n.slider-container {\n  margin-bottom: 32px;\n}\n\n.slider-label {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: 12px;\n  font-size: 14px;\n  color: #333;\n}\n\n.slider-value {\n  font-weight: 600;\n  color: #0066cc;\n}\n\ninput[type=\"range\"] {\n  width: 100%;\n  height: 6px;\n  border-radius: 3px;\n  background: #ddd;\n  outline: none;\n  -webkit-appearance: none;\n}\n\ninput[type=\"range\"]::-webkit-slider-thumb {\n  -webkit-appearance: none;\n  appearance: none;\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  background: #0066cc;\n  cursor: pointer;\n  transition: transform 0.1s;\n}\n\ninput[type=\"range\"]::-webkit-slider-thumb:hover {\n  transform: scale(1.15);\n}\n\ninput[type=\"range\"]::-moz-range-thumb {\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  background: #0066cc;\n  cursor: pointer;\n  border: none;\n  transition: transform 0.1s;\n}\n\ninput[type=\"range\"]::-moz-range-thumb:hover {\n  transform: scale(1.15);\n}\n\n.visual-zone {\n  margin-top: 20px;\n}\n\n.zone-bars {\n  display: flex;\n  gap: 8px;\n  margin-bottom: 20px;\n}\n\n.zone-bar {\n  flex: 1;\n  height: 80px;\n  border-radius: 4px;\n  position: relative;\n  overflow: hidden;\n  background: #e0e0e0;\n  transition: all 0.3s ease;\n}\n\n.zone-bar.active {\n  background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);\n  box-shadow: 0 4px 12px rgba(0, 102, 204, 0.3);\n}\n\n.zone-bar-label {\n  position: absolute;\n  bottom: 8px;\n  left: 0;\n  right: 0;\n  text-align: center;\n  font-size: 12px;\n  font-weight: 500;\n  color: #666;\n  transition: color 0.3s;\n}\n\n.zone-bar.active .zone-bar-label {\n  color: white;\n}\n\n.adaptation-meter {\n  background: white;\n  border-radius: 6px;\n  padding: 20px;\n  border: 2px solid #e0e0e0;\n}\n\n.meter-header {\n  font-size: 13px;\n  font-weight: 500;\n  color: #666;\n  margin-bottom: 12px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.meter-row {\n  margin-bottom: 16px;\n}\n\n.meter-row:last-child {\n  margin-bottom: 0;\n}\n\n.meter-label {\n  font-size: 14px;\n  color: #333;\n  margin-bottom: 6px;\n  display: flex;\n  justify-content: space-between;\n}\n\n.meter-status {\n  font-weight: 600;\n  font-size: 13px;\n}\n\n.meter-status.off {\n  color: #999;\n}\n\n.meter-status.on {\n  color: #0066cc;\n}\n\n.meter-bar-container {\n  height: 8px;\n  background: #e0e0e0;\n  border-radius: 4px;\n  overflow: hidden;\n}\n\n.meter-bar-fill {\n  height: 100%;\n  background: linear-gradient(90deg, #0066cc 0%, #0052a3 100%);\n  border-radius: 4px;\n  transition: width 0.4s ease;\n  width: 0;\n}\n\n.explanation {\n  font-size: 15px;\n  color: #333;\n  line-height: 1.7;\n  padding: 20px;\n  background: #f9f9f9;\n  border-radius: 6px;\n  border-left: 3px solid #0066cc;\n}\n\n.explanation strong {\n  color: #1a1a1a;\n}\n\n@media (max-width: 600px) {\n  .container {\n    padding: 20px;\n  }\n  \n  h1 {\n    font-size: 20px;\n  }\n  \n  .zone-bars {\n    flex-direction: column;\n    gap: 12px;\n  }\n  \n  .zone-bar {\n    height: 60px;\n  }\n}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Intensity Thresholds and Adaptation</h1>\n  <p class=\"concept\">Physical systems adapt to demand signals, not time spent—crossing an intensity threshold triggers capacity-building mechanisms that moderate effort below the threshold never activates, regardless of duration.</p>\n  \n  <div class=\"teaching-label\">\n    Drag the slider to see how intensity level determines which adaptation mechanisms activate.\n  </div>\n  \n  <div class=\"interactive-surface\">\n    <div class=\"slider-container\">\n      <div class=\"slider-label\">\n        <span>Effort intensity</span>\n        <span class=\"slider-value\" id=\"intensity-display\">50%</span>\n      </div>\n      <input type=\"range\" id=\"intensity-slider\" min=\"0\" max=\"100\" value=\"50\" step=\"1\">\n    </div>\n    \n    <div class=\"visual-zone\">\n      <div class=\"zone-bars\">\n        <div class=\"zone-bar\" id=\"zone-low\">\n          <div class=\"zone-bar-label\">Low<br>0–60%</div>\n        </div>\n        <div class=\"zone-bar active\" id=\"zone-moderate\">\n          <div class=\"zone-bar-label\">Moderate<br>60–75%</div>\n        </div>\n        <div class=\"zone-bar\" id=\"zone-high\">\n          <div class=\"zone-bar-label\">High<br>75–100%</div>\n        </div>\n      </div>\n      \n      <div class=\"adaptation-meter\">\n        <div class=\"meter-header\">Adaptation mechanisms</div>\n        \n        <div class=\"meter-row\">\n          <div class=\"meter-label\">\n            <span>Calorie burning</span>\n            <span class=\"meter-status on\" id=\"status-calories\">Active</span>\n          </div>\n          <div class=\"meter-bar-container\">\n            <div class=\"meter-bar-fill\" id=\"bar-calories\" style=\"width: 50%\"></div>\n          </div>\n        </div>\n        \n        <div class=\"meter-row\">\n          <div class=\"meter-label\">\n            <span>Baseline endurance</span>\n            <span class=\"meter-status on\" id=\"status-endurance\">Active</span>\n          </div>\n          <div class=\"meter-bar-container\">\n            <div class=\"meter-bar-fill\" id=\"bar-endurance\" style=\"width: 50%\"></div>\n          </div>\n        </div>\n        \n        <div class=\"meter-row\">\n          <div class=\"meter-label\">\n            <span>New energy machinery</span>\n            <span class=\"meter-status off\" id=\"status-machinery\">Off</span>\n          </div>\n          <div class=\"meter-bar-container\">\n            <div class=\"meter-bar-fill\" id=\"bar-machinery\" style=\"width: 0%\"></div>\n          </div>\n        </div>\n        \n        <div class=\"meter-row\">\n          <div class=\"meter-label\">\n            <span>Oxygen delivery growth</span>\n            <span class=\"meter-status off\" id=\"status-oxygen\">Off</span>\n          </div>\n          <div class=\"meter-bar-container\">\n            <div class=\"meter-bar-fill\" id=\"bar-oxygen\" style=\"width: 0%\"></div>\n          </div>\n        </div>\n        \n        <div class=\"meter-row\">\n          <div class=\"meter-label\">\n            <span>Max capacity increase</span>\n            <span class=\"meter-status off\" id=\"status-capacity\">Off</span>\n          </div>\n          <div class=\"meter-bar-container\">\n            <div class=\"meter-bar-fill\" id=\"bar-capacity\" style=\"width: 0%\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"explanation\">\n    <strong>The threshold matters more than the clock.</strong> Below ~75% intensity, your body burns fuel and maintains current capacity. Above that line, you trigger mechanisms that build NEW capacity—cells create energy-processing machinery, muscles add oxygen pathways, maximum throughput increases. Two hours below the threshold keeps you where you are. Fifteen minutes above it tells your system to grow. The adaptation signal is intensity-gated, not time-gated.\n  </div>\n</div>\n\n<script>\nconst slider = document.getElementById('intensity-slider');\nconst display = document.getElementById('intensity-display');\n\nconst zoneLow = document.getElementById('zone-low');\nconst zoneMod = document.getElementById('zone-moderate');\nconst zoneHigh = document.getElementById('zone-high');\n\nconst statusCalories = document.getElementById('status-calories');\nconst statusEndurance = document.getElementById('status-endurance');\nconst statusMachinery = document.getElementById('status-machinery');\nconst statusOxygen = document.getElementById('status-oxygen');\nconst statusCapacity = document.getElementById('status-capacity');\n\nconst barCalories = document.getElementById('bar-calories');\nconst barEndurance = document.getElementById('bar-endurance');\nconst barMachinery = document.getElementById('bar-machinery');\nconst barOxygen = document.getElementById('bar-oxygen');\nconst barCapacity = document.getElementById('bar-capacity');\n\nlet hasInteracted = false;\n\nfunction updateDisplay(value) {\n  const intensity = parseInt(value);\n  display.textContent = intensity + '%';\n  \n  // Update zone highlighting\n  zoneLow.classList.remove('active');\n  zoneMod.classList.remove('active');\n  zoneHigh.classList.remove('active');\n  \n  if (intensity < 60) {\n    zoneLow.classList.add('active');\n  } else if (intensity < 75) {\n    zoneMod.classList.add('active');\n  } else {\n    zoneHigh.classList.add('active');\n  }\n  \n  // Calorie burning scales with intensity\n  barCalories.style.width = Math.min(100, intensity) + '%';\n  statusCalories.textContent = 'Active';\n  statusCalories.className = 'meter-status on';\n  \n  // Endurance active above ~30%, scales moderately\n  if (intensity >= 30) {\n    const enduranceLevel = Math.min(100, (intensity - 30) * 1.2);\n    barEndurance.style.width = enduranceLevel + '%';\n    statusEndurance.textContent = 'Active';\n    statusEndurance.className = 'meter-status on';\n  } else {\n    barEndurance.style.width = '0%';\n    statusEndurance.textContent = 'Off';\n    statusEndurance.className = 'meter-status off';\n  }\n  \n  // Threshold-gated mechanisms activate sharply at 75%\n  const threshold = 75;\n  \n  if (intensity >= threshold) {\n    const aboveThreshold = intensity - threshold;\n    const scaledLevel = Math.min(100, aboveThreshold * 4); // Scales 0-100 over 25 point range\n    \n    barMachinery.style.width = scaledLevel + '%';\n    statusMachinery.textContent = 'Active';\n    statusMachinery.className = 'meter-status on';\n    \n    barOxygen.style.width = scaledLevel + '%';\n    statusOxygen.textContent = 'Active';\n    statusOxygen.className = 'meter-status on';\n    \n    barCapacity.style.width = scaledLevel + '%';\n    statusCapacity.textContent = 'Active';\n    statusCapacity.className = 'meter-status on';\n  } else {\n    barMachinery.style.width = '0%';\n    statusMachinery.textContent = 'Off';\n    statusMachinery.className = 'meter-status off';\n    \n    barOxygen.style.width = '0%';\n    statusOxygen.textContent = 'Off';\n    statusOxygen.className = 'meter-status off';\n    \n    barCapacity.style.width = '0%';\n    statusCapacity.textContent = 'Off';\n    statusCapacity.className = 'meter-status off';\n  }\n  \n  // Report engagement on first real interaction\n  if (!hasInteracted && intensity !== 50) {\n    hasInteracted = true;\n    try {\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n    } catch (e) {\n      // Silently fail if parent context unavailable\n    }\n  }\n}\n\nslider.addEventListener('input', (e) => {\n  updateDisplay(e.target.value);\n});\n\n// Initialize\nupdateDisplay(slider.value);\n</script>\n</body>\n</html>"
  }
}
