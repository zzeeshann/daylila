{
  "slug": "supply-bottleneck-leverage",
  "type": "html",
  "title": "Capacity Binds Flow",
  "concept": "When transformation happens at one point between many sources and many destinations, the width of that point—not the number of sources or destinations—sets how much moves through the system.",
  "interactiveId": "14d8b886-9efc-4621-a51b-80628db76b76",
  "sourcePieceId": "070caa7e-bde8-4a71-be10-f73479a0f46d",
  "publishedAt": 1778659155335,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Capacity Binds Flow</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --inactive: #e5e0d6;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 140px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .flow-system {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    gap: 28px;\n    align-items: center;\n    margin: 28px 0 20px;\n  }\n  .node-group {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .node-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n    text-align: center;\n  }\n  .nodes {\n    display: flex;\n    flex-direction: column;\n    gap: 7px;\n  }\n  .node {\n    height: 22px;\n    background: var(--gold);\n    border-radius: 4px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: var(--fg);\n    transition: background 140ms ease-out, opacity 140ms ease-out;\n  }\n  .node.blocked {\n    background: var(--inactive);\n    opacity: 0.5;\n  }\n  .converter {\n    width: 80px;\n    height: 110px;\n    background: var(--teal);\n    border-radius: 6px;\n    position: relative;\n    overflow: hidden;\n  }\n  .converter-fill {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    background: linear-gradient(180deg, rgba(26,107,98,0.15) 0%, rgba(26,107,98,0.05) 100%);\n    transition: height 200ms ease-out;\n  }\n  .converter-label {\n    position: absolute;\n    bottom: 6px;\n    left: 0;\n    right: 0;\n    text-align: center;\n    font-size: 0.7rem;\n    color: rgba(255,255,255,0.85);\n    font-weight: 500;\n  }\n  .reading {\n    margin: 20px 0 8px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 520px) {\n    .flow-system {\n      grid-template-columns: 1fr;\n      grid-template-rows: auto auto auto;\n      gap: 18px;\n    }\n    .converter {\n      margin: 0 auto;\n      width: 110px;\n      height: 70px;\n    }\n    .converter-fill {\n      bottom: auto;\n      top: 0;\n      left: 0;\n      right: auto;\n      width: 50%;\n      height: 100%;\n      transition: width 200ms ease-out;\n    }\n    .converter-label {\n      bottom: auto;\n      top: 50%;\n      transform: translateY(-50%);\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to change transformation width</h2>\n<p class=\"subhead\">Seven sources feed into one step, then split to four destinations.</p>\n\n<div class=\"control\">\n  <label for=\"width\">Width:</label>\n  <input id=\"width\" type=\"range\" min=\"10\" max=\"100\" value=\"100\" step=\"5\" aria-describedby=\"width-out\">\n  <output id=\"width-out\" for=\"width\">100</output>\n</div>\n\n<div class=\"flow-system\" aria-hidden=\"true\">\n  <div class=\"node-group\">\n    <span class=\"node-label\">Origins</span>\n    <div class=\"nodes\">\n      <div class=\"node\">α</div>\n      <div class=\"node\">β</div>\n      <div class=\"node\">γ</div>\n      <div class=\"node\">δ</div>\n      <div class=\"node\">ε</div>\n      <div class=\"node\">ζ</div>\n      <div class=\"node\">η</div>\n    </div>\n  </div>\n  <div class=\"converter\" id=\"converter\">\n    <div class=\"converter-fill\" id=\"converter-fill\"></div>\n    <span class=\"converter-label\">Transform</span>\n  </div>\n  <div class=\"node-group\">\n    <span class=\"node-label\">Destinations</span>\n    <div class=\"nodes\">\n      <div class=\"node\" data-dest=\"1\">1</div>\n      <div class=\"node\" data-dest=\"2\">2</div>\n      <div class=\"node\" data-dest=\"3\">3</div>\n      <div class=\"node\" data-dest=\"4\">4</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Flow rate: <strong id=\"flow-rate\">100</strong>%.<br>\n  What limits it: <strong id=\"limiter\">nothing—width matches need</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">The transformation step is wide enough for full flow. All destinations receive.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('width');\n    var widthOut = document.getElementById('width-out');\n    var flowRate = document.getElementById('flow-rate');\n    var limiter = document.getElementById('limiter');\n    var caption = document.getElementById('caption');\n    var converterFill = document.getElementById('converter-fill');\n    var destinations = document.querySelectorAll('[data-dest]');\n\n    // How many destinations can be reached at each width level\n    function reachable(w) {\n      if (w >= 90) return 4;\n      if (w >= 60) return 3;\n      if (w >= 35) return 2;\n      return 1;\n    }\n\n    function update() {\n      var w = +slider.value;\n      widthOut.textContent = w;\n      flowRate.textContent = w;\n\n      // Visual: fill height tracks width on desktop, fill width on mobile\n      var fillPct = w;\n      converterFill.style.height = fillPct + '%';\n      converterFill.style.width = fillPct + '%';\n\n      // Mark destinations as blocked when width constrains them\n      var reach = reachable(w);\n      for (var i = 0; i < destinations.length; i++) {\n        if (i < reach) {\n          destinations[i].classList.remove('blocked');\n        } else {\n          destinations[i].classList.add('blocked');\n        }\n      }\n\n      // Update reading\n      if (w === 100) {\n        limiter.textContent = 'nothing—width matches need';\n        caption.textContent = 'The transformation step is wide enough for full flow. All destinations receive.';\n      } else if (w >= 90) {\n        limiter.textContent = 'a narrow margin';\n        caption.textContent = 'Width is just shy of full capacity. Four destinations still reachable, but the system has little slack.';\n      } else if (w >= 60) {\n        limiter.textContent = 'the transformation step';\n        caption.textContent = 'Width constrains flow to three destinations. One goes dark because the middle can\\'t handle more.';\n      } else if (w >= 35) {\n        limiter.textContent = 'the transformation step, significantly';\n        caption.textContent = 'A narrow middle cuts access to half the destinations. Origins remain, but flow stops at the constraint.';\n      } else {\n        limiter.textContent = 'the transformation step, severely';\n        caption.textContent = 'Minimal width means three destinations go unreached. Seven origins feed one narrow point that reaches one destination.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
