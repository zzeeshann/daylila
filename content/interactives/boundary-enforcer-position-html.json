  "title": "Nested Boundaries and Blast Radius",
  "concept": "When boundaries nest inside each other, a breach at an inner layer compromises everything outside it, while a breach at an outer layer stays contained to that layer alone.",
  "interactiveId": "edc1ec3e-19b3-4b3a-b7f9-8a316d9e8d74",
  "sourcePieceId": "99b4187f-7a66-4a1b-be9c-5d406017c1f2",
  "publishedAt": 1777595181598,
  "voiceScore": 78,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Nested Boundaries and Blast Radius</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --outer: #8fa39a;\n    --middle: #5a7a6f;\n    --inner: #2d5a4f;\n    --fail: #c94d3a;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control select {\n    flex: 1;\n    padding: 8px 12px;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    background: #fff;\n    font-size: 0.9rem;\n    font-family: inherit;\n    min-width: 180px;\n  }\n  .nest {\n    margin: 0 auto 20px;\n    max-width: 480px;\n    position: relative;\n  }\n  .layer {\n    border: 3px solid;\n    border-radius: 8px;\n    padding: 20px;\n    position: relative;\n    transition: all 220ms ease-out;\n  }\n  .layer-outer {\n    border-color: var(--outer);\n    background: rgba(143, 163, 154, 0.15);\n  }\n  .layer-middle {\n    border-color: var(--middle);\n    background: rgba(90, 122, 111, 0.2);\n    margin-top: 16px;\n  }\n  .layer-inner {\n    border-color: var(--inner);\n    background: rgba(45, 90, 79, 0.25);\n    margin-top: 16px;\n  }\n  .layer.compromised {\n    border-color: var(--fail);\n    background: rgba(201, 77, 58, 0.25);\n    animation: pulse 600ms ease-out;\n  }\n  @keyframes pulse {\n    0%, 100% { transform: scale(1); }\n    50% { transform: scale(1.02); }\n  }\n  .layer-label {\n    font-weight: 600;\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n  }\n  .layer-desc {\n    font-size: 0.8rem;\n    color: var(--muted);\n  }\n  .reading {\n    margin: 20px 0 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-direction: column;\n      align-items: flex-start;\n    }\n    .control select {\n      width: 100%;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Pick which layer fails</h2>\n<p class=\"subhead\">Three boundaries nest inside each other. Watch how the compromise spreads based on depth.</p>\n\n<div class=\"control\">\n  <label for=\"breach-select\">Breach:</label>\n  <select id=\"breach-select\" aria-describedby=\"status\">\n    <option value=\"none\">— None (all layers intact) —</option>\n    <option value=\"outer\">Outer layer</option>\n    <option value=\"middle\">Middle layer</option>\n    <option value=\"inner\">Inner layer</option>\n  </select>\n</div>\n\n<div class=\"nest\" role=\"img\" aria-label=\"Nested boundary visualization\">\n  <div class=\"layer layer-outer\" id=\"outer\">\n    <div class=\"layer-label\">Outer Layer</div>\n    <div class=\"layer-desc\">Public perimeter — anyone can enter</div>\n    <div class=\"layer layer-middle\" id=\"middle\">\n      <div class=\"layer-label\">Middle Layer</div>\n      <div class=\"layer-desc\">Restricted — requires credentials</div>\n      <div class=\"layer layer-inner\" id=\"inner\">\n        <div class=\"layer-label\">Inner Layer</div>\n        <div class=\"layer-desc\">Critical controls — highest trust required</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\" id=\"status\">\n  Compromised layers: <strong id=\"count\">0</strong>.\n  Blast radius: <strong id=\"radius\">none</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">All boundaries hold. Each layer enforces its own rules independently.</p>\n\n<script>\n  (function () {\n    var select = document.getElementById('breach-select');\n    var outer = document.getElementById('outer');\n    var middle = document.getElementById('middle');\n    var inner = document.getElementById('inner');\n    var count = document.getElementById('count');\n    var radius = document.getElementById('radius');\n    var caption = document.getElementById('caption');\n\n    function clearAll() {\n      outer.classList.remove('compromised');\n      middle.classList.remove('compromised');\n      inner.classList.remove('compromised');\n    }\n\n    function update() {\n      var choice = select.value;\n      clearAll();\n\n      if (choice === 'none') {\n        count.textContent = '0';\n        radius.textContent = 'none';\n        caption.textContent = 'All boundaries hold. Each layer enforces its own rules independently.';\n      } else if (choice === 'outer') {\n        outer.classList.add('compromised');\n        count.textContent = '1';\n        radius.textContent = 'outer layer only';\n        caption.textContent = 'A breach at the outermost boundary stays contained. The inner layers remain protected because they enforce their own separate rules.';\n      } else if (choice === 'middle') {\n        outer.classList.add('compromised');\n        middle.classList.add('compromised');\n        count.textContent = '2';\n        radius.textContent = 'middle + outer';\n        caption.textContent = 'A breach in the middle layer cascades outward. The outer layer depended on the middle one enforcing access rules, so it inherits the compromise. The inner layer still holds.';\n      } else if (choice === 'inner') {\n        outer.classList.add('compromised');\n        middle.classList.add('compromised');\n        inner.classList.add('compromised');\n        count.textContent = '3';\n        radius.textContent = 'entire system';\n        caption.textContent = 'A breach at the innermost layer cascades through everything outside it. The middle and outer layers trust the inner one to enforce the deepest rules — when it fails, all boundaries collapse.';\n      }\n    }\n\n    select.addEventListener('change', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
