{
  "slug": "removing-redundancy-creates-fragility",
  "type": "html",
  "title": "Pre-Commitment Under Uncertainty",
  "concept": "When you don't know what shock will hit, you must choose between efficient operation now and survival margin later—once the shock arrives, the choice is already made.",
  "interactiveId": "d5bc93f0-7ec8-4ab6-84e2-316294077d16",
  "sourcePieceId": "afdfb4e4-aa19-4cbc-9192-7ac66bc94d78",
  "publishedAt": 1777600760467,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pre-Commitment Under Uncertainty</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --primary: #1a6b62;\n    --warn: #c9a227;\n    --fail: #b83c3c;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 600px;\n    margin: 0 auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 24px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .phase {\n    margin-bottom: 24px;\n    padding: 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n  }\n  .phase-label {\n    font-size: 0.8rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 12px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 16px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--primary);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .stats {\n    display: flex;\n    gap: 16px;\n    margin-top: 12px;\n  }\n  .stat {\n    flex: 1;\n  }\n  .stat-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    margin-bottom: 4px;\n  }\n  .stat-value {\n    font-size: 1.3rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .stat-value.positive {\n    color: var(--primary);\n  }\n  .stat-value.negative {\n    color: var(--fail);\n  }\n  button {\n    width: 100%;\n    padding: 14px;\n    font-size: 1rem;\n    font-weight: 600;\n    color: #fff;\n    background: var(--primary);\n    border: none;\n    border-radius: 6px;\n    cursor: pointer;\n    transition: background 180ms;\n  }\n  button:hover {\n    background: #145550;\n  }\n  button:disabled {\n    background: var(--muted);\n    cursor: not-allowed;\n  }\n  .outcome {\n    margin-top: 20px;\n    padding: 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.95rem;\n    display: none;\n  }\n  .outcome.visible {\n    display: block;\n  }\n  .outcome.survive {\n    border-color: var(--primary);\n    background: #e8f5f0;\n  }\n  .outcome.fail {\n    border-color: var(--fail);\n    background: #ffebee;\n  }\n  .outcome strong {\n    font-weight: 600;\n    display: block;\n    margin-bottom: 8px;\n  }\n  .outcome-detail {\n    color: var(--muted);\n    font-size: 0.875rem;\n    margin-top: 8px;\n  }\n  .history {\n    margin-top: 24px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    display: none;\n  }\n  .history.visible {\n    display: block;\n  }\n  .history-label {\n    font-size: 0.8rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n  }\n  .history-list {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n  .history-item {\n    font-size: 0.85rem;\n    padding: 6px 8px;\n    background: var(--bg);\n    border-radius: 4px;\n  }\n  .history-item.survived {\n    color: var(--primary);\n  }\n  .history-item.failed {\n    color: var(--fail);\n  }\n  p.caption {\n    margin: 16px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    body {\n      padding: 16px;\n    }\n    .stats {\n      flex-direction: column;\n      gap: 12px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Choose your buffer before the shock hits</h2>\n<p class=\"subhead\">A system needs 10 working parts. You decide how much spare capacity to carry. Then a random shock tests your choice.</p>\n\n<div class=\"phase\">\n  <div class=\"phase-label\">Before the shock</div>\n  <div class=\"control\">\n    <label for=\"buffer\">Spare parts:</label>\n    <input id=\"buffer\" type=\"range\" min=\"0\" max=\"10\" value=\"2\" step=\"1\" aria-describedby=\"buffer-out\">\n    <output id=\"buffer-out\" for=\"buffer\">2</output>\n  </div>\n  <div class=\"stats\">\n    <div class=\"stat\">\n      <div class=\"stat-label\">Daily output</div>\n      <div class=\"stat-value positive\" id=\"output\">83 units</div>\n    </div>\n    <div class=\"stat\">\n      <div class=\"stat-label\">Daily cost</div>\n      <div class=\"stat-value negative\" id=\"cost\">12</div>\n    </div>\n  </div>\n</div>\n\n<button id=\"test-btn\">Test System</button>\n\n<div class=\"outcome\" id=\"outcome\">\n  <strong id=\"outcome-result\">System survives.</strong>\n  <div id=\"outcome-body\">Shock removed 3 parts. You had 12 total, lost 3, have 9 remaining. Need 10 minimum. Short by 1.</div>\n  <div class=\"outcome-detail\" id=\"outcome-detail\">You chose 2 spare parts. A shock of 3 hit.</div>\n</div>\n\n<div class=\"history\" id=\"history\">\n  <div class=\"history-label\">Previous runs</div>\n  <div class=\"history-list\" id=\"history-list\"></div>\n</div>\n\n<p class=\"caption\" id=\"caption\">You're carrying 2 spare parts. Each spare part costs resources but increases survival margin.</p>\n\n<script>\n(function () {\n  var bufferSlider = document.getElementById('buffer');\n  var bufferOut = document.getElementById('buffer-out');\n  var outputEl = document.getElementById('output');\n  var costEl = document.getElementById('cost');\n  var testBtn = document.getElementById('test-btn');\n  var outcomeEl = document.getElementById('outcome');\n  var outcomeResult = document.getElementById('outcome-result');\n  var outcomeBody = document.getElementById('outcome-body');\n  var outcomeDetail = document.getElementById('outcome-detail');\n  var caption = document.getElementById('caption');\n  var historyEl = document.getElementById('history');\n  var historyList = document.getElementById('history-list');\n\n  var REQUIRED = 10;\n  var MAX_OUTPUT = 100;\n  var COST_PER_PART = 1;\n  var runs = [];\n  var hasInteracted = false;\n\n  function updateBeforeShock() {\n    var buffer = +bufferSlider.value;\n    var total = REQUIRED + buffer;\n    var output = Math.round((REQUIRED / total) * MAX_OUTPUT);\n    var cost = total * COST_PER_PART;\n\n    bufferOut.textContent = buffer;\n    outputEl.textContent = output + ' units';\n    costEl.textContent = cost;\n\n    if (buffer === 0) {\n      caption.textContent = \"You're running lean—no spare capacity. Maximum output, but any failure breaks the system.\";\n    } else if (buffer <= 3) {\n      caption.textContent = \"You're carrying \" + buffer + \" spare parts. Each spare costs resources but increases survival margin.\";\n    } else if (buffer <= 6) {\n      caption.textContent = \"Moderate redundancy. Daily output drops to \" + output + \" units, but you can absorb moderate shocks.\";\n    } else {\n      caption.textContent = \"Heavy redundancy. Output falls to \" + output + \" units—\" + buffer + \" parts sit idle until disaster strikes.\";\n    }\n  }\n\n  function runTest() {\n    var buffer = +bufferSlider.value;\n    var total = REQUIRED + buffer;\n    var shock = Math.floor(Math.random() * 8) + 1;\n    var remaining = total - shock;\n    var survives = remaining >= REQUIRED;\n\n    outcomeEl.className = 'outcome visible ' + (survives ? 'survive' : 'fail');\n\n    if (survives) {\n      var margin = remaining - REQUIRED;\n      outcomeResult.textContent = 'System survives.';\n      if (margin === 0) {\n        outcomeBody.textContent = 'Shock removed ' + shock + ' parts. You had ' + total + ' total, lost ' + shock + ', have ' + remaining + ' remaining. Need ' + REQUIRED + ' minimum. Survived by exactly zero margin.';\n      } else {\n        outcomeBody.textContent = 'Shock removed ' + shock + ' parts. You had ' + total + ' total, lost ' + shock + ', have ' + remaining + ' remaining. Need ' + REQUIRED + ' minimum. Margin: ' + margin + '.';\n      }\n    } else {\n      var shortfall = REQUIRED - remaining;\n      outcomeResult.textContent = 'System fails.';\n      outcomeBody.textContent = 'Shock removed ' + shock + ' parts. You had ' + total + ' total, lost ' + shock + ', have ' + remaining + ' remaining. Need ' + REQUIRED + ' minimum. Short by ' + shortfall + '.';\n    }\n\n    outcomeDetail.textContent = 'You chose ' + buffer + ' spare parts. A shock of ' + shock + ' hit.';\n\n    runs.push({\n      buffer: buffer,\n      shock: shock,\n      survived: survives\n    });\n\n    if (runs.length > 0) {\n      historyEl.className = 'history visible';\n      var item = document.createElement('div');\n      item.className = 'history-item ' + (survives ? 'survived' : 'failed');\n      item.textContent = 'Buffer ' + buffer + ', shock ' + shock + ': ' + (survives ? 'survived' : 'failed');\n      historyList.insertBefore(item, historyList.firstChild);\n      if (historyList.children.length > 5) {\n        historyList.removeChild(historyList.lastChild);\n      }\n    }\n\n    if (!hasInteracted) {\n      hasInteracted = true;\n      if (window.parent && window.parent !== window) {\n        window.parent.postMessage({ type: 'interactive_engagement', event: 'manipulated' }, '*');\n      }\n    }\n  }\n\n  bufferSlider.addEventListener('input', updateBeforeShock);\n  testBtn.addEventListener('click', runTest);\n  updateBeforeShock();\n})();\n</script>\n</body>\n</html>"
  }
}
