{
  "slug": "function-invisible-to-direct-test",
  "type": "html",
  "title": "Inference from Indirect Evidence",
  "concept": "When you cannot observe the variable you need directly, you infer from correlates—but changing which correlate you measure shifts what you conclude, even when all correlates are accurate.",
  "interactiveId": "c493e389-91f5-4a73-95ad-b25df3aa8004",
  "sourcePieceId": "a204d497-fbcd-480d-ba91-3b1549d534c3",
  "publishedAt": 1777817459646,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Inference from Indirect Evidence</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c94227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 160px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .visualization {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .hidden-box {\n    padding: 16px;\n    background: var(--bg);\n    border: 2px dashed var(--muted);\n    border-radius: 4px;\n    margin-bottom: 20px;\n    text-align: center;\n  }\n  .hidden-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 6px;\n  }\n  .hidden-value {\n    font-size: 1.4rem;\n    font-weight: 600;\n    color: var(--muted);\n  }\n  .unavailable {\n    font-size: 0.8rem;\n    color: var(--red);\n    margin-top: 4px;\n  }\n  .correlates {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .correlate {\n    padding: 12px;\n    background: var(--bg);\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    text-align: center;\n  }\n  .correlate-name {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n  }\n  .correlate-value {\n    font-size: 1.3rem;\n    font-weight: 600;\n    color: var(--gold);\n    margin-bottom: 6px;\n  }\n  .correlate-relation {\n    font-size: 0.75rem;\n    color: var(--muted);\n    line-height: 1.3;\n  }\n  .inference-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px;\n  }\n  .inference {\n    padding: 12px;\n    background: #e8f5f3;\n    border-left: 3px solid var(--teal);\n    border-radius: 3px;\n  }\n  .inference-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 6px;\n  }\n  .inference-value {\n    font-size: 1.3rem;\n    font-weight: 600;\n    margin-bottom: 6px;\n  }\n  .inference-error {\n    font-size: 0.8rem;\n    color: var(--red);\n    font-weight: 500;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 600px) {\n    .correlates {\n      grid-template-columns: 1fr;\n    }\n    .inference-grid {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to change the hidden variable</h2>\n<p class=\"subhead\">Three correlates track it through different relationships. Each one gives you a different inference.</p>\n\n<div class=\"control\">\n  <label for=\"hidden\">Hidden:</label>\n  <input id=\"hidden\" type=\"range\" min=\"10\" max=\"90\" value=\"50\" aria-describedby=\"hidden-out\">\n  <output id=\"hidden-out\" for=\"hidden\">50</output>\n</div>\n\n<div class=\"visualization\">\n  <div class=\"hidden-box\">\n    <div class=\"hidden-label\">True Value (cannot measure directly)</div>\n    <div class=\"hidden-value\" id=\"true-display\">50</div>\n    <div class=\"unavailable\">Observable only through correlates</div>\n  </div>\n\n  <div class=\"correlates\">\n    <div class=\"correlate\">\n      <div class=\"correlate-name\">Correlate A</div>\n      <div class=\"correlate-value\" id=\"corr-a\">45</div>\n      <div class=\"correlate-relation\">Tracks below</div>\n    </div>\n    <div class=\"correlate\">\n      <div class=\"correlate-name\">Correlate B</div>\n      <div class=\"correlate-value\" id=\"corr-b\">75</div>\n      <div class=\"correlate-relation\">Tracks amplified</div>\n    </div>\n    <div class=\"correlate\">\n      <div class=\"correlate-name\">Correlate C</div>\n      <div class=\"correlate-value\" id=\"corr-c\">30</div>\n      <div class=\"correlate-relation\">Tracks inverted</div>\n    </div>\n  </div>\n\n  <div class=\"inference-grid\">\n    <div class=\"inference\">\n      <div class=\"inference-label\">If you measure A</div>\n      <div class=\"inference-value\" id=\"infer-a\">45</div>\n      <div class=\"inference-error\" id=\"error-a\">Error: -5</div>\n    </div>\n    <div class=\"inference\">\n      <div class=\"inference-label\">If you measure B</div>\n      <div class=\"inference-value\" id=\"infer-b\">50</div>\n      <div class=\"inference-error\" id=\"error-b\">Error: 0</div>\n    </div>\n    <div class=\"inference\">\n      <div class=\"inference-label\">If you measure C</div>\n      <div class=\"inference-value\" id=\"infer-c\">70</div>\n      <div class=\"inference-error\" id=\"error-c\">Error: +20</div>\n    </div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">All three correlates are accurate, but each suggests a different conclusion. Your inference depends on which one you choose to measure.</p>\n\n<script>\n(function () {\n  var slider = document.getElementById('hidden');\n  var hiddenOut = document.getElementById('hidden-out');\n  var trueDisplay = document.getElementById('true-display');\n  var corrAEl = document.getElementById('corr-a');\n  var corrBEl = document.getElementById('corr-b');\n  var corrCEl = document.getElementById('corr-c');\n  var inferAEl = document.getElementById('infer-a');\n  var inferBEl = document.getElementById('infer-b');\n  var inferCEl = document.getElementById('infer-c');\n  var errorAEl = document.getElementById('error-a');\n  var errorBEl = document.getElementById('error-b');\n  var errorCEl = document.getElementById('error-c');\n  var captionEl = document.getElementById('caption');\n\n  function formatError(val) {\n    return (val >= 0 ? '+' : '') + val;\n  }\n\n  function update() {\n    var hidden = +slider.value;\n    hiddenOut.textContent = hidden;\n    trueDisplay.textContent = hidden;\n\n    var corrA = Math.round(hidden * 0.9);\n    var corrB = Math.round(hidden * 1.5);\n    var corrC = Math.round(100 - hidden);\n\n    corrAEl.textContent = corrA;\n    corrBEl.textContent = corrB;\n    corrCEl.textContent = corrC;\n\n    var inferA = corrA;\n    var inferB = Math.round(corrB / 1.5);\n    var inferC = 100 - corrC;\n\n    inferAEl.textContent = inferA;\n    inferBEl.textContent = inferB;\n    inferCEl.textContent = inferC;\n\n    var errorA = inferA - hidden;\n    var errorB = inferB - hidden;\n    var errorC = inferC - hidden;\n\n    errorAEl.textContent = 'Error: ' + formatError(errorA);\n    errorBEl.textContent = 'Error: ' + formatError(errorB);\n    errorCEl.textContent = 'Error: ' + formatError(errorC);\n\n    var totalError = Math.abs(errorA) + Math.abs(errorB) + Math.abs(errorC);\n    if (totalError === 0) {\n      captionEl.textContent = 'At this value, all three correlates produce the same inference. Measurement choice does not matter here.';\n    } else if (totalError < 20) {\n      captionEl.textContent = 'All three correlates are accurate, but each suggests a slightly different conclusion. Small divergence.';\n    } else if (totalError < 50) {\n      captionEl.textContent = 'All three correlates are accurate, but each suggests a different conclusion. Measurement choice shapes inference.';\n    } else {\n      captionEl.textContent = 'All three correlates are accurate, but each suggests a very different conclusion. Which one you measure determines what you conclude.';\n    }\n  }\n\n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
