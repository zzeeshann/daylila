  "title": "Prepared Recognition",
  "concept": "Unexpected patterns become visible when you have the mental tools to recognize them—the same data looks like noise without the right reference frame and reveals structure with it.",
  "interactiveId": "b8e58367-9f6e-43e0-84b1-b4204065c2cd",
  "sourcePieceId": "45921a12-0156-478f-b8ab-7d9534f87439",
  "publishedAt": 1778076449848,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Prepared Recognition</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --grid: rgba(26, 107, 98, 0.15);\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .canvas {\n    width: 100%;\n    max-width: 600px;\n    height: 320px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    margin: 24px auto;\n    position: relative;\n    overflow: hidden;\n  }\n  svg {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n  }\n  .grid-line {\n    stroke: var(--grid);\n    stroke-width: 1;\n    opacity: 0;\n    transition: opacity 300ms ease-out;\n  }\n  .grid-line.visible {\n    opacity: 1;\n  }\n  .reference-line {\n    stroke: var(--teal);\n    stroke-width: 2;\n    stroke-dasharray: 4 4;\n    opacity: 0;\n    transition: opacity 300ms ease-out;\n  }\n  .reference-line.visible {\n    opacity: 0.4;\n  }\n  .datapoint {\n    fill: var(--gold);\n    opacity: 0.6;\n    transition: fill 300ms ease-out, opacity 300ms ease-out, r 300ms ease-out;\n  }\n  .datapoint.pattern {\n    fill: var(--teal);\n    opacity: 1;\n  }\n  .axis-label {\n    fill: var(--muted);\n    font-size: 11px;\n    opacity: 0;\n    transition: opacity 300ms ease-out;\n  }\n  .axis-label.visible {\n    opacity: 1;\n  }\n  .reading {\n    margin: 18px auto 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    max-width: 600px;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px auto 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n    max-width: 600px;\n  }\n  .legend {\n    display: flex;\n    gap: 20px;\n    margin: 12px auto 0;\n    font-size: 0.85rem;\n    max-width: 600px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-dot {\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n  }\n  .legend-dot.noise { background: var(--gold); opacity: 0.6; }\n  .legend-dot.signal { background: var(--teal); }\n  @media (max-width: 480px) {\n    .canvas {\n      height: 280px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Add tools that make patterns visible</h2>\n<p class=\"subhead\">Same data. Different capacity to recognize the structure hiding in it.</p>\n\n<div class=\"control\">\n  <label for=\"tools\">Tools:</label>\n  <input id=\"tools\" type=\"range\" min=\"0\" max=\"3\" value=\"0\" step=\"1\" aria-describedby=\"tools-out\">\n  <output id=\"tools-out\" for=\"tools\">0</output>\n</div>\n\n<div class=\"canvas\" id=\"canvas\" role=\"img\" aria-label=\"Data visualization showing how reference tools reveal hidden patterns\"></div>\n\n<div class=\"legend\">\n  <div class=\"legend-item\">\n    <div class=\"legend-dot noise\"></div>\n    <span>Noise</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-dot signal\"></div>\n    <span>Pattern</span>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Pattern points recognized: <strong id=\"recognized\">0</strong> of 18.\n</div>\n\n<p class=\"caption\" id=\"caption\">Without tools, every point looks the same. The pattern is invisible.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('tools');\n    var toolsOut = document.getElementById('tools-out');\n    var recognized = document.getElementById('recognized');\n    var caption = document.getElementById('caption');\n    var canvas = document.getElementById('canvas');\n\n    var width = 600;\n    var height = 320;\n    var padding = 40;\n\n    // Generate data: 18 points following y = 0.5x + 30 with jitter, plus 40 noise points\n    var patternPoints = [];\n    var noisePoints = [];\n    \n    for (var i = 0; i < 18; i++) {\n      var x = padding + i * (width - 2 * padding) / 17;\n      var y = height - (0.5 * x + 30 + (Math.random() - 0.5) * 20);\n      patternPoints.push({ x: x, y: y, id: i });\n    }\n\n    for (var j = 0; j < 40; j++) {\n      noisePoints.push({\n        x: padding + Math.random() * (width - 2 * padding),\n        y: padding + Math.random() * (height - 2 * padding),\n        id: 'noise-' + j\n      });\n    }\n\n    // Create SVG\n    var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');\n    svg.setAttribute('viewBox', '0 0 ' + width + ' ' + height);\n    canvas.appendChild(svg);\n\n    // Grid lines (tool level 1)\n    var gridGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n    gridGroup.setAttribute('class', 'grid');\n    for (var gx = padding; gx <= width - padding; gx += (width - 2 * padding) / 5) {\n      var vline = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n      vline.setAttribute('class', 'grid-line');\n      vline.setAttribute('x1', gx);\n      vline.setAttribute('x2', gx);\n      vline.setAttribute('y1', padding);\n      vline.setAttribute('y2', height - padding);\n      gridGroup.appendChild(vline);\n    }\n    for (var gy = padding; gy <= height - padding; gy += (height - 2 * padding) / 4) {\n      var hline = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n      hline.setAttribute('class', 'grid-line');\n      hline.setAttribute('x1', padding);\n      hline.setAttribute('x2', width - padding);\n      hline.setAttribute('y1', gy);\n      hline.setAttribute('y2', gy);\n      gridGroup.appendChild(hline);\n    }\n    svg.appendChild(gridGroup);\n\n    // Reference line (tool level 2) - a faint diagonal showing the expected slope\n    var refLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n    refLine.setAttribute('class', 'reference-line');\n    refLine.setAttribute('x1', padding);\n    refLine.setAttribute('y1', height - (0.5 * padding + 30));\n    refLine.setAttribute('x2', width - padding);\n    refLine.setAttribute('y2', height - (0.5 * (width - padding) + 30));\n    svg.appendChild(refLine);\n\n    // Axis labels (tool level 3)\n    var xLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n    xLabel.setAttribute('class', 'axis-label');\n    xLabel.setAttribute('x', width / 2);\n    xLabel.setAttribute('y', height - 10);\n    xLabel.setAttribute('text-anchor', 'middle');\n    xLabel.textContent = 'Variable A';\n    svg.appendChild(xLabel);\n\n    var yLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n    yLabel.setAttribute('class', 'axis-label');\n    yLabel.setAttribute('x', 15);\n    yLabel.setAttribute('y', height / 2);\n    yLabel.setAttribute('text-anchor', 'middle');\n    yLabel.setAttribute('transform', 'rotate(-90 15 ' + (height / 2) + ')');\n    yLabel.textContent = 'Variable B';\n    svg.appendChild(yLabel);\n\n    // Render noise points\n    noisePoints.forEach(function (pt) {\n      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('class', 'datapoint');\n      circle.setAttribute('cx', pt.x);\n      circle.setAttribute('cy', pt.y);\n      circle.setAttribute('r', 4);\n      svg.appendChild(circle);\n    });\n\n    // Render pattern points\n    var patternCircles = [];\n    patternPoints.forEach(function (pt) {\n      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('class', 'datapoint');\n      circle.setAttribute('data-pattern', 'true');\n      circle.setAttribute('cx', pt.x);\n      circle.setAttribute('cy', pt.y);\n      circle.setAttribute('r', 4);\n      patternCircles.push(circle);\n      svg.appendChild(circle);\n    });\n\n    function update() {\n      var toolLevel = +slider.value;\n      toolsOut.textContent = toolLevel;\n\n      // Tool 0: no aids\n      // Tool 1: grid appears (spatial reference)\n      // Tool 2: reference line appears (comparison template)\n      // Tool 3: axis labels appear (vocabulary to describe what you see)\n\n      var gridLines = svg.querySelectorAll('.grid-line');\n      var numRecognized = 0;\n\n      if (toolLevel >= 1) {\n        gridLines.forEach(function (line) { line.classList.add('visible'); });\n        numRecognized = 6; // Grid lets you see ~1/3 of the pattern\n      } else {\n        gridLines.forEach(function (line) { line.classList.remove('visible'); });\n      }\n\n      if (toolLevel >= 2) {\n        refLine.classList.add('visible');\n        numRecognized = 12; // Reference line lets you match ~2/3\n      } else {\n        refLine.classList.remove('visible');\n      }\n\n      if (toolLevel >= 3) {\n        xLabel.classList.add('visible');\n        yLabel.classList.add('visible');\n        numRecognized = 18; // Full vocabulary lets you see it all\n      } else {\n        xLabel.classList.remove('visible');\n        yLabel.classList.remove('visible');\n      }\n\n      // Highlight recognized pattern points\n      patternCircles.forEach(function (circle, idx) {\n        if (idx < numRecognized) {\n          circle.classList.add('pattern');\n          circle.setAttribute('r', 5);\n        } else {\n          circle.classList.remove('pattern');\n          circle.setAttribute('r', 4);\n        }\n      });\n\n      recognized.textContent = numRecognized;\n\n      if (toolLevel === 0) {\n        caption.textContent = 'Without tools, every point looks the same. The pattern is invisible.';\n      } else if (toolLevel === 1) {\n        caption.textContent = 'A grid gives you spatial reference. Now you can see a few points line up vertically—enough to suspect something.';\n      } else if (toolLevel === 2) {\n        caption.textContent = 'A reference line gives you a comparison template. Now you can match points against an expected slope—most of the pattern appears.';\n      } else {\n        caption.textContent = 'Axis labels give you vocabulary to describe what you see. Now the pattern is fully legible—you can name the relationship.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
