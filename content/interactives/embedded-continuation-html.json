{
  "slug": "embedded-continuation",
  "type": "html",
  "title": "Default Infrastructure Lock-In",
  "concept": "A system persists when switching requires replacing not just the primary component but every adjacent layer that assumes its presence — infrastructure builds dependencies, dependencies build procedures, and replacement means addressing all simultaneously.",
  "interactiveId": "8e95aeec-1bf4-4610-aec8-94cff841dec2",
  "sourcePieceId": "c0b08dee-c011-44d7-acc2-78ecc3c2f7a6",
  "publishedAt": 1777471849433,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Default Infrastructure Lock-In</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --core: #2563eb;\n    --adjacent: #7c3aed;\n    --procedure: #dc2626;\n    --alt: #16a34a;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 28px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 110px;\n  }\n  .control input[type=checkbox] {\n    width: 20px;\n    height: 20px;\n    accent-color: var(--core);\n    cursor: pointer;\n  }\n  .visual {\n    margin: 28px 0;\n    display: flex;\n    gap: 32px;\n    align-items: flex-end;\n  }\n  .system {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n  .system-label {\n    font-size: 0.8rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    color: var(--muted);\n    margin-bottom: 8px;\n    text-align: center;\n  }\n  .layer {\n    height: 0;\n    border-radius: 4px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.8rem;\n    font-weight: 500;\n    color: #fff;\n    overflow: hidden;\n    transition: height 200ms ease-out, opacity 200ms;\n    opacity: 0;\n  }\n  .layer.visible {\n    opacity: 1;\n  }\n  .layer.core { background: var(--core); }\n  .layer.adjacent { background: var(--adjacent); }\n  .layer.procedure { background: var(--procedure); }\n  .cost-bar {\n    margin: 24px 0 12px;\n    padding: 16px 18px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n  }\n  .cost-label {\n    font-size: 0.85rem;\n    color: var(--muted);\n    margin-bottom: 8px;\n  }\n  .cost-value {\n    font-size: 1.3rem;\n    font-weight: 700;\n    color: var(--core);\n    font-variant-numeric: tabular-nums;\n  }\n  .cost-bar.high {\n    border-color: var(--procedure);\n  }\n  .cost-bar.high .cost-value {\n    color: var(--procedure);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 560px) {\n    .visual {\n      flex-direction: column;\n      gap: 24px;\n      align-items: stretch;\n    }\n    .system {\n      min-height: 180px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Toggle each layer to see replacement cost</h2>\n<p class=\"subhead\">The current system sits on the left. Each layer you enable adds dependencies that must be replaced when switching.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"adjacent\">Adjacent systems:</label>\n    <input type=\"checkbox\" id=\"adjacent\" aria-describedby=\"caption\">\n  </div>\n  <div class=\"control\">\n    <label for=\"procedure\">Procedures:</label>\n    <input type=\"checkbox\" id=\"procedure\" aria-describedby=\"caption\">\n  </div>\n</div>\n\n<div class=\"visual\" role=\"img\" aria-label=\"Two systems showing layers that must be replaced when switching\">\n  <div class=\"system\">\n    <span class=\"system-label\">Current System</span>\n    <div class=\"layer core visible\" id=\"current-core\" style=\"height: 50px;\">Core</div>\n    <div class=\"layer adjacent\" id=\"current-adjacent\">Adjacent</div>\n    <div class=\"layer procedure\" id=\"current-procedure\">Procedures</div>\n  </div>\n  <div class=\"system\">\n    <span class=\"system-label\">Alternative</span>\n    <div class=\"layer core visible\" id=\"alt-core\" style=\"height: 50px;\">Core</div>\n    <div class=\"layer adjacent\" id=\"alt-adjacent\">Adjacent</div>\n    <div class=\"layer procedure\" id=\"alt-procedure\">Procedures</div>\n  </div>\n</div>\n\n<div class=\"cost-bar\" id=\"cost-bar\">\n  <div class=\"cost-label\">Replacement cost (layers to rebuild):</div>\n  <div class=\"cost-value\" id=\"cost-value\">1</div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Only the core must be replaced. Cost is minimal.</p>\n\n<script>\n  (function () {\n    var adjacentCheck = document.getElementById('adjacent');\n    var procedureCheck = document.getElementById('procedure');\n    var currentAdjacent = document.getElementById('current-adjacent');\n    var currentProcedure = document.getElementById('current-procedure');\n    var altAdjacent = document.getElementById('alt-adjacent');\n    var altProcedure = document.getElementById('alt-procedure');\n    var costValue = document.getElementById('cost-value');\n    var costBar = document.getElementById('cost-bar');\n    var caption = document.getElementById('caption');\n\n    function update() {\n      var hasAdjacent = adjacentCheck.checked;\n      var hasProcedure = procedureCheck.checked;\n\n      var layers = 1;\n\n      if (hasAdjacent) {\n        currentAdjacent.style.height = '44px';\n        currentAdjacent.classList.add('visible');\n        altAdjacent.style.height = '44px';\n        altAdjacent.classList.add('visible');\n        layers++;\n      } else {\n        currentAdjacent.style.height = '0';\n        currentAdjacent.classList.remove('visible');\n        altAdjacent.style.height = '0';\n        altAdjacent.classList.remove('visible');\n      }\n\n      if (hasProcedure) {\n        currentProcedure.style.height = '38px';\n        currentProcedure.classList.add('visible');\n        altProcedure.style.height = '38px';\n        altProcedure.classList.add('visible');\n        layers++;\n      } else {\n        currentProcedure.style.height = '0';\n        currentProcedure.classList.remove('visible');\n        altProcedure.style.height = '0';\n        altProcedure.classList.remove('visible');\n      }\n\n      costValue.textContent = layers;\n\n      if (layers === 3) {\n        costBar.classList.add('high');\n        caption.textContent = 'All three layers require simultaneous replacement. The alternative must reproduce the entire stack to be viable.';\n      } else if (layers === 2) {\n        costBar.classList.remove('high');\n        caption.textContent = 'Adjacent systems assume the core exists. Switching means rebuilding both the core and everything that depends on it.';\n      } else {\n        costBar.classList.remove('high');\n        caption.textContent = 'Only the core must be replaced. Cost is minimal.';\n      }\n    }\n\n    adjacentCheck.addEventListener('change', update);\n    procedureCheck.addEventListener('change', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
