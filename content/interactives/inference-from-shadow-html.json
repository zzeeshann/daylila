{
  "slug": "inference-from-shadow",
  "type": "html",
  "title": "Shadow Reveals Structure",
  "concept": "When you cannot observe something directly, measuring what it removes from a known source—which wavelengths it absorbs, which signals it blocks—turns absence into readable evidence of composition and form.",
  "interactiveId": "32321ea0-d8a2-4453-9a3a-565b026b51bc",
  "sourcePieceId": "f64aeef7-dff4-40dd-a35c-a8e331f44164",
  "publishedAt": 1778962936656,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Shadow Reveals Structure</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --accent: #1a6b62;\n    --surface: #fff;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .workspace {\n    background: var(--surface);\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 20px;\n    margin-bottom: 20px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--accent);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .spectrum-display {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n  }\n  .spectrum-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .spectrum-label {\n    font-size: 0.8rem;\n    font-weight: 500;\n    min-width: 80px;\n    color: var(--muted);\n  }\n  .spectrum-bar-container {\n    flex: 1;\n    height: 32px;\n    background: var(--line);\n    border-radius: 4px;\n    position: relative;\n    overflow: hidden;\n  }\n  .spectrum-bar {\n    height: 100%;\n    transition: width 250ms ease-out;\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    padding-right: 8px;\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: rgba(0, 0, 0, 0.7);\n  }\n  .inference-panel {\n    margin-top: 20px;\n    padding: 14px;\n    background: rgba(0, 0, 0, 0.03);\n    border-radius: 4px;\n    min-height: 80px;\n  }\n  .inference-title {\n    font-size: 0.85rem;\n    font-weight: 600;\n    margin-bottom: 8px;\n    color: var(--fg);\n  }\n  .inference-body {\n    font-size: 0.85rem;\n    color: var(--muted);\n    line-height: 1.6;\n  }\n  .inference-body strong {\n    color: var(--fg);\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .spectrum-row {\n      flex-direction: column;\n      align-items: stretch;\n      gap: 6px;\n    }\n    .spectrum-label {\n      min-width: 0;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Select which wavelength band to measure</h2>\n<p class=\"subhead\">A bright source emits across the spectrum. Hidden material absorbs specific wavelengths. What can you learn?</p>\n\n<div class=\"control\">\n  <label for=\"wavelength\">Band:</label>\n  <input id=\"wavelength\" type=\"range\" min=\"380\" max=\"700\" value=\"380\" step=\"40\" aria-describedby=\"wavelength-out\">\n  <output id=\"wavelength-out\" for=\"wavelength\">380 nm</output>\n</div>\n\n<div class=\"workspace\">\n  <div class=\"spectrum-display\">\n    <div class=\"spectrum-row\">\n      <span class=\"spectrum-label\">Source output:</span>\n      <div class=\"spectrum-bar-container\">\n        <div class=\"spectrum-bar\" id=\"source-bar\" style=\"width: 100%;\">100%</div>\n      </div>\n    </div>\n    <div class=\"spectrum-row\">\n      <span class=\"spectrum-label\">Received:</span>\n      <div class=\"spectrum-bar-container\">\n        <div class=\"spectrum-bar\" id=\"received-bar\" style=\"width: 0%;\"></div>\n      </div>\n    </div>\n    <div class=\"spectrum-row\">\n      <span class=\"spectrum-label\">Absorbed:</span>\n      <div class=\"spectrum-bar-container\">\n        <div class=\"spectrum-bar\" id=\"absorbed-bar\" style=\"width: 0%; background: #c9a227;\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"inference-panel\">\n    <div class=\"inference-title\">What the absorption tells you:</div>\n    <div class=\"inference-body\" id=\"inference-text\">Select a wavelength to measure.</div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">The source emits at full strength. Move the slider to measure different wavelengths.</p>\n\n<script>\n(function () {\n  var slider = document.getElementById('wavelength');\n  var wavelengthOut = document.getElementById('wavelength-out');\n  var sourceBar = document.getElementById('source-bar');\n  var receivedBar = document.getElementById('received-bar');\n  var absorbedBar = document.getElementById('absorbed-bar');\n  var inferenceText = document.getElementById('inference-text');\n  var caption = document.getElementById('caption');\n\n  // Absorption profile: different materials absorb different wavelengths.\n  // This hidden structure has three components that preferentially absorb\n  // different bands, creating a fingerprint.\n  var absorptionProfile = {\n    380: { abs: 85, material: 'Material A', reason: 'strongly absorbs violet-blue' },\n    420: { abs: 75, material: 'Material A', reason: 'moderately absorbs blue' },\n    460: { abs: 20, material: 'transparent in cyan', reason: 'passes through with minimal loss' },\n    500: { abs: 15, material: 'transparent in green', reason: 'passes through with minimal loss' },\n    540: { abs: 60, material: 'Material B', reason: 'moderately absorbs yellow-green' },\n    580: { abs: 70, material: 'Material B', reason: 'strongly absorbs yellow' },\n    620: { abs: 25, material: 'weakly absorbing in orange', reason: 'some loss' },\n    660: { abs: 90, material: 'Material C', reason: 'strongly absorbs red' },\n    700: { abs: 80, material: 'Material C', reason: 'strongly absorbs deep red' }\n  };\n\n  var colorMap = {\n    380: { color: '#8b00ff', name: 'Violet' },\n    420: { color: '#4169e1', name: 'Blue' },\n    460: { color: '#00bfff', name: 'Cyan' },\n    500: { color: '#00ff00', name: 'Green' },\n    540: { color: '#9acd32', name: 'Yellow-green' },\n    580: { color: '#ffd700', name: 'Yellow' },\n    620: { color: '#ff8c00', name: 'Orange' },\n    660: { color: '#ff4500', name: 'Red' },\n    700: { color: '#8b0000', name: 'Deep red' }\n  };\n\n  function update() {\n    var wl = +slider.value;\n    var profile = absorptionProfile[wl];\n    var colorInfo = colorMap[wl];\n\n    wavelengthOut.textContent = wl + ' nm';\n\n    var absPercent = profile.abs;\n    var recPercent = 100 - absPercent;\n\n    sourceBar.style.background = colorInfo.color;\n    receivedBar.style.background = colorInfo.color;\n    absorbedBar.style.background = '#c9a227';\n\n    receivedBar.style.width = recPercent + '%';\n    receivedBar.textContent = recPercent + '%';\n    absorbedBar.style.width = absPercent + '%';\n    absorbedBar.textContent = absPercent + '%';\n\n    // Inference text: explain what this absorption depth means\n    if (absPercent >= 70) {\n      inferenceText.innerHTML = '<strong>' + colorInfo.name + ' (' + wl + ' nm)</strong> is heavily absorbed (' + absPercent + '%). The hidden material contains <strong>' + profile.material + '</strong>, which ' + profile.reason + '. High absorption at this wavelength is a signature.';\n    } else if (absPercent >= 40) {\n      inferenceText.innerHTML = '<strong>' + colorInfo.name + ' (' + wl + ' nm)</strong> is moderately absorbed (' + absPercent + '%). The material contains <strong>' + profile.material + '</strong>, which ' + profile.reason + '.';\n    } else {\n      inferenceText.innerHTML = '<strong>' + colorInfo.name + ' (' + wl + ' nm)</strong> passes through with little loss (' + absPercent + '% absorbed). The material is <strong>' + profile.material + '</strong>—it does not interact strongly at this wavelength.';\n    }\n\n    // Caption updates\n    if (absPercent >= 70) {\n      caption.textContent = 'Deep absorption at ' + wl + ' nm reveals material that blocks this wavelength. Measuring across bands builds a fingerprint.';\n    } else if (absPercent >= 40) {\n      caption.textContent = 'Moderate absorption at ' + wl + ' nm shows partial blocking. Different wavelengths teach different things about composition.';\n    } else {\n      caption.textContent = 'Low absorption at ' + wl + ' nm—this wavelength passes through. The material is transparent here, opaque elsewhere.';\n    }\n  }\n\n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
