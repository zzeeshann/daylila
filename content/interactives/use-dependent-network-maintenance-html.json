{
  "slug": "use-dependent-network-maintenance",
  "type": "html",
  "title": "Synaptic Pruning and Rewiring",
  "concept": "Your brain prunes unused connections and builds new ones in response to activity—the balance between loss and growth determines whether capacity expands or shrinks over time.",
  "interactiveId": "65fa90bc-0963-4f6a-b1fd-9205caee53c7",
  "sourcePieceId": "9536b2c6-35aa-461c-9748-68ad2a73685e",
  "publishedAt": 1778510615841,
  "voiceScore": 94,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Synaptic Pruning and Rewiring</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --prune: #c94d4d;\n    --build: #4d9c4d;\n    --neutral: #d4d0c6;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .control-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .control-row label {\n    font-weight: 500;\n    min-width: 120px;\n    flex-shrink: 0;\n  }\n  .control-row input[type=range] {\n    flex: 1;\n    accent-color: var(--fg);\n    min-width: 100px;\n  }\n  .control-row output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3.5ch;\n    text-align: right;\n  }\n  .network {\n    margin: 24px 0;\n    padding: 24px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 280px;\n    position: relative;\n  }\n  .synapses {\n    display: grid;\n    grid-template-columns: repeat(8, 1fr);\n    gap: 8px;\n    max-width: 400px;\n    width: 100%;\n  }\n  .synapse {\n    aspect-ratio: 1;\n    border-radius: 50%;\n    transition: background-color 300ms ease-out, opacity 300ms ease-out;\n    border: 2px solid var(--line);\n  }\n  .synapse.active {\n    background: var(--build);\n    opacity: 1;\n  }\n  .synapse.pruned {\n    background: var(--neutral);\n    opacity: 0.3;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading-row {\n    display: flex;\n    justify-content: space-between;\n    margin: 6px 0;\n  }\n  .reading-row:first-child {\n    margin-top: 0;\n  }\n  .reading-row:last-child {\n    margin-bottom: 0;\n  }\n  .reading-row strong {\n    font-weight: 600;\n  }\n  .stat-label {\n    color: var(--muted);\n  }\n  .stat-value {\n    font-variant-numeric: tabular-nums;\n  }\n  .stat-value.positive {\n    color: var(--build);\n  }\n  .stat-value.negative {\n    color: var(--prune);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .synapses {\n      grid-template-columns: repeat(6, 1fr);\n    }\n    .control-row {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control-row label {\n      min-width: 0;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust activity to shift the balance</h2>\n<p class=\"subhead\">Unused connections prune over time. New activity builds replacements. Net change determines capacity.</p>\n\n<div class=\"controls\">\n  <div class=\"control-row\">\n    <label for=\"novel\">Novel activity:</label>\n    <input id=\"novel\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"novel-out\">\n    <output id=\"novel-out\" for=\"novel\">50</output>\n  </div>\n  <div class=\"control-row\">\n    <label for=\"routine\">Routine use:</label>\n    <input id=\"routine\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"routine-out\">\n    <output id=\"routine-out\" for=\"routine\">50</output>\n  </div>\n</div>\n\n<div class=\"network\">\n  <div class=\"synapses\" id=\"synapses\" aria-hidden=\"true\"></div>\n</div>\n\n<div class=\"reading\">\n  <div class=\"reading-row\">\n    <span class=\"stat-label\">Active connections:</span>\n    <span class=\"stat-value\" id=\"active\">32</span>\n  </div>\n  <div class=\"reading-row\">\n    <span class=\"stat-label\">Net change per cycle:</span>\n    <strong class=\"stat-value\" id=\"net-change\">0</strong>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Pruning and building are balanced. Capacity holds steady.</p>\n\n<script>\n  (function () {\n    var novelSlider = document.getElementById('novel');\n    var routineSlider = document.getElementById('routine');\n    var novelOut = document.getElementById('novel-out');\n    var routineOut = document.getElementById('routine-out');\n    var activeSpan = document.getElementById('active');\n    var netChangeSpan = document.getElementById('net-change');\n    var caption = document.getElementById('caption');\n    var synapsesContainer = document.getElementById('synapses');\n\n    var totalSynapses = 64;\n    var synapseElements = [];\n    var activeCount = 32;\n\n    // Initialize synapse grid\n    for (var i = 0; i < totalSynapses; i++) {\n      var synapse = document.createElement('div');\n      synapse.className = 'synapse';\n      if (i < activeCount) {\n        synapse.classList.add('active');\n      } else {\n        synapse.classList.add('pruned');\n      }\n      synapsesContainer.appendChild(synapse);\n      synapseElements.push(synapse);\n    }\n\n    function update() {\n      var novel = +novelSlider.value;\n      var routine = +routineSlider.value;\n      \n      novelOut.textContent = novel;\n      routineOut.textContent = routine;\n\n      // Novel activity builds new connections (rate proportional to novel)\n      // Routine use maintains existing but doesn't build new\n      // Low routine means more pruning of unused connections\n      var buildRate = novel / 10;\n      var pruneRate = (100 - routine) / 10;\n      var netChange = Math.round(buildRate - pruneRate);\n\n      // Update active count (bounded by 0 and totalSynapses)\n      activeCount = Math.max(0, Math.min(totalSynapses, activeCount + netChange));\n\n      // Update visual state\n      for (var i = 0; i < totalSynapses; i++) {\n        if (i < activeCount) {\n          synapseElements[i].classList.remove('pruned');\n          synapseElements[i].classList.add('active');\n        } else {\n          synapseElements[i].classList.remove('active');\n          synapseElements[i].classList.add('pruned');\n        }\n      }\n\n      activeSpan.textContent = activeCount;\n      netChangeSpan.textContent = (netChange > 0 ? '+' : '') + netChange;\n      netChangeSpan.className = 'stat-value';\n      if (netChange > 0) {\n        netChangeSpan.classList.add('positive');\n      } else if (netChange < 0) {\n        netChangeSpan.classList.add('negative');\n      }\n\n      // Update caption based on net change\n      if (netChange > 3) {\n        caption.textContent = 'Building outpaces pruning. Capacity expands as new connections form faster than old ones disappear.';\n      } else if (netChange > 0) {\n        caption.textContent = 'Building slightly exceeds pruning. Capacity grows, but slowly.';\n      } else if (netChange === 0) {\n        caption.textContent = 'Pruning and building are balanced. Capacity holds steady.';\n      } else if (netChange > -3) {\n        caption.textContent = 'Pruning slightly exceeds building. Capacity shrinks, but slowly.';\n      } else {\n        caption.textContent = 'Pruning outpaces building. Capacity contracts as connections disappear faster than new ones form.';\n      }\n    }\n\n    novelSlider.addEventListener('input', update);\n    routineSlider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
