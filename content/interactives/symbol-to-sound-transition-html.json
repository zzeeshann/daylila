{
  "slug": "symbol-to-sound-transition",
  "type": "html",
  "title": "Symbol-to-Sound Mapping",
  "concept": "A writing system encodes speech when symbols stop representing objects directly and instead represent the sounds in spoken words—a conceptual leap that requires training your brain to ignore meaning and hear sound.",
  "interactiveId": "de6ab4cb-839d-42c2-854f-e675d2ee2ac4",
  "sourcePieceId": "d0504385-5ffc-4dde-9dcc-8b3b3d1ae73f",
  "publishedAt": 1778307300644,
  "voiceScore": 88,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Symbol-to-Sound Mapping</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 640px;\n    margin: 0 auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .mode-toggle {\n    display: flex;\n    gap: 8px;\n    margin-bottom: 24px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n    padding: 4px;\n  }\n  .mode-toggle button {\n    flex: 1;\n    padding: 10px 16px;\n    border: none;\n    background: transparent;\n    color: var(--muted);\n    font-weight: 500;\n    border-radius: 6px;\n    cursor: pointer;\n    transition: all 120ms;\n    font-size: 0.9rem;\n  }\n  .mode-toggle button.active {\n    background: var(--teal);\n    color: #fff;\n  }\n  .symbol-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 12px;\n    margin-bottom: 24px;\n  }\n  .symbol-card {\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    padding: 20px 12px;\n    text-align: center;\n    cursor: pointer;\n    transition: all 180ms ease-out;\n    user-select: none;\n  }\n  .symbol-card:hover {\n    border-color: var(--gold);\n    transform: translateY(-2px);\n  }\n  .symbol-card.selected {\n    border-color: var(--teal);\n    background: #f0f8f7;\n  }\n  .symbol-glyph {\n    font-size: 2.5rem;\n    margin-bottom: 8px;\n    display: block;\n  }\n  .symbol-label {\n    font-size: 0.85rem;\n    font-weight: 600;\n    color: var(--fg);\n    display: block;\n    margin-bottom: 4px;\n  }\n  .symbol-sublabel {\n    font-size: 0.75rem;\n    color: var(--muted);\n    display: block;\n  }\n  .reading-area {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n    padding: 16px;\n    min-height: 80px;\n    margin-bottom: 16px;\n  }\n  .reading-area .label {\n    font-size: 0.75rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n    margin-bottom: 8px;\n  }\n  .reading-area .output {\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: var(--fg);\n    min-height: 1.5em;\n  }\n  .reading-area .output.empty {\n    color: var(--muted);\n    font-style: italic;\n    font-weight: 400;\n  }\n  .reset-btn {\n    display: block;\n    width: 100%;\n    padding: 10px;\n    background: transparent;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    color: var(--muted);\n    font-size: 0.85rem;\n    cursor: pointer;\n    margin-bottom: 16px;\n    transition: all 120ms;\n  }\n  .reset-btn:hover {\n    border-color: var(--gold);\n    color: var(--fg);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n    line-height: 1.6;\n  }\n  @media (max-width: 480px) {\n    .symbol-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Tap symbols to build a sequence</h2>\n<p class=\"subhead\">The same marks can represent objects or sounds—switch modes to see the difference.</p>\n\n<div class=\"mode-toggle\">\n  <button id=\"mode-object\" class=\"active\">Object Mode</button>\n  <button id=\"mode-sound\">Sound Mode</button>\n</div>\n\n<div class=\"symbol-grid\">\n  <div class=\"symbol-card\" data-object=\"ox\" data-sound=\"a\">\n    <span class=\"symbol-glyph\">🐂</span>\n    <span class=\"symbol-label\" data-label-object=\"Ox\" data-label-sound=\"A\">Ox</span>\n    <span class=\"symbol-sublabel\" data-sublabel-object=\"\" data-sublabel-sound=\"first sound\"></span>\n  </div>\n  <div class=\"symbol-card\" data-object=\"house\" data-sound=\"b\">\n    <span class=\"symbol-glyph\">🏠</span>\n    <span class=\"symbol-label\" data-label-object=\"House\" data-label-sound=\"B\">House</span>\n    <span class=\"symbol-sublabel\" data-sublabel-object=\"\" data-sublabel-sound=\"house sound\"></span>\n  </div>\n  <div class=\"symbol-card\" data-object=\"water\" data-sound=\"m\">\n    <span class=\"symbol-glyph\">💧</span>\n    <span class=\"symbol-label\" data-label-object=\"Water\" data-label-sound=\"M\">Water</span>\n    <span class=\"symbol-sublabel\" data-sublabel-object=\"\" data-sublabel-sound=\"water sound\"></span>\n  </div>\n  <div class=\"symbol-card\" data-object=\"sun\" data-sound=\"s\">\n    <span class=\"symbol-glyph\">☀️</span>\n    <span class=\"symbol-label\" data-label-object=\"Sun\" data-label-sound=\"S\">Sun</span>\n    <span class=\"symbol-sublabel\" data-sublabel-object=\"\" data-sublabel-sound=\"sun sound\"></span>\n  </div>\n  <div class=\"symbol-card\" data-object=\"eye\" data-sound=\"i\">\n    <span class=\"symbol-glyph\">👁️</span>\n    <span class=\"symbol-label\" data-label-object=\"Eye\" data-label-sound=\"I\">Eye</span>\n    <span class=\"symbol-sublabel\" data-sublabel-object=\"\" data-sublabel-sound=\"eye sound\"></span>\n  </div>\n  <div class=\"symbol-card\" data-object=\"tree\" data-sound=\"t\">\n    <span class=\"symbol-glyph\">🌳</span>\n    <span class=\"symbol-label\" data-label-object=\"Tree\" data-label-sound=\"T\">Tree</span>\n    <span class=\"symbol-sublabel\" data-sublabel-object=\"\" data-sublabel-sound=\"tree sound\"></span>\n  </div>\n</div>\n\n<div class=\"reading-area\">\n  <div class=\"label\" id=\"reading-label\">Objects selected:</div>\n  <div class=\"output empty\" id=\"reading-output\">No symbols selected yet.</div>\n</div>\n\n<button class=\"reset-btn\" id=\"reset-btn\">Clear sequence</button>\n\n<p class=\"caption\" id=\"caption\">\nIn object mode, each symbol means the thing it pictures. A list of symbols is a list of things.\n</p>\n\n<script>\n(function() {\n  var mode = 'object';\n  var sequence = [];\n  \n  var modeObjectBtn = document.getElementById('mode-object');\n  var modeSoundBtn = document.getElementById('mode-sound');\n  var cards = document.querySelectorAll('.symbol-card');\n  var readingLabel = document.getElementById('reading-label');\n  var readingOutput = document.getElementById('reading-output');\n  var resetBtn = document.getElementById('reset-btn');\n  var caption = document.getElementById('caption');\n  \n  var captions = {\n    object: {\n      empty: 'In object mode, each symbol means the thing it pictures. A list of symbols is a list of things.',\n      one: 'One symbol, one object. No room for grammar or names yet.',\n      multi: 'Multiple symbols make a list of objects. This works for inventory, but not for speech.'\n    },\n    sound: {\n      empty: 'In sound mode, the same symbols represent sounds from spoken words. Now you can spell.',\n      one: 'One sound. Combine sounds to build words.',\n      multi: 'Sounds combine into syllables and words. The symbols no longer mean the objects they picture—they encode speech.'\n    }\n  };\n  \n  function updateMode(newMode) {\n    mode = newMode;\n    sequence = [];\n    \n    if (mode === 'object') {\n      modeObjectBtn.classList.add('active');\n      modeSoundBtn.classList.remove('active');\n      readingLabel.textContent = 'Objects selected:';\n    } else {\n      modeSoundBtn.classList.add('active');\n      modeObjectBtn.classList.remove('active');\n      readingLabel.textContent = 'Sounds combined:';\n    }\n    \n    cards.forEach(function(card) {\n      card.classList.remove('selected');\n      var label = card.querySelector('.symbol-label');\n      var sublabel = card.querySelector('.symbol-sublabel');\n      \n      if (mode === 'object') {\n        label.textContent = label.getAttribute('data-label-object');\n        sublabel.textContent = sublabel.getAttribute('data-sublabel-object');\n      } else {\n        label.textContent = label.getAttribute('data-label-sound');\n        sublabel.textContent = sublabel.getAttribute('data-sublabel-sound');\n      }\n    });\n    \n    updateReading();\n  }\n  \n  function updateReading() {\n    if (sequence.length === 0) {\n      readingOutput.classList.add('empty');\n      readingOutput.textContent = 'No symbols selected yet.';\n      caption.textContent = captions[mode].empty;\n      return;\n    }\n    \n    readingOutput.classList.remove('empty');\n    \n    if (mode === 'object') {\n      readingOutput.textContent = sequence.join(', ');\n      caption.textContent = sequence.length === 1 ? captions.object.one : captions.object.multi;\n    } else {\n      var soundStr = sequence.join('-');\n      readingOutput.textContent = soundStr.toUpperCase();\n      caption.textContent = sequence.length === 1 ? captions.sound.one : captions.sound.multi;\n    }\n  }\n  \n  modeObjectBtn.addEventListener('click', function() { updateMode('object'); });\n  modeSoundBtn.addEventListener('click', function() { updateMode('sound'); });\n  \n  cards.forEach(function(card) {\n    card.addEventListener('click', function() {\n      var val = mode === 'object' \n        ? card.getAttribute('data-object') \n        : card.getAttribute('data-sound');\n      \n      sequence.push(val);\n      card.classList.add('selected');\n      updateReading();\n      \n      setTimeout(function() {\n        card.classList.remove('selected');\n      }, 300);\n    });\n  });\n  \n  resetBtn.addEventListener('click', function() {\n    sequence = [];\n    cards.forEach(function(c) { c.classList.remove('selected'); });\n    updateReading();\n  });\n  \n  updateMode('object');\n})();\n</script>\n</body>\n</html>"
  }
}
