{
  "slug": "adding-requirements-through-practice",
  "type": "html",
  "title": "Interpretation as Addition",
  "concept": "A written rule can stay identical while its operational effect narrows through added requirements that emerge from applying the rule to new situations—each new hurdle leaves the text unchanged but makes the outcome harder to reach.",
  "interactiveId": "a86baeb4-30dd-41c7-acdf-e3a9df2cb441",
  "sourcePieceId": "2fb4bb9e-1918-4a84-8e80-ad1974b8bcf4",
  "publishedAt": 1777550352216,
  "voiceScore": 72,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Interpretation as Addition</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c92727;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2ch;\n    text-align: right;\n  }\n  .rule-display {\n    margin: 20px 0;\n    padding: 14px 16px;\n    background: #fff;\n    border: 2px solid var(--teal);\n    border-radius: 6px;\n    font-size: 0.95rem;\n    font-weight: 500;\n  }\n  .tests-container {\n    margin: 24px 0;\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .test-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 10px;\n    padding: 10px;\n    background: var(--bg);\n    border-radius: 4px;\n    font-size: 0.875rem;\n  }\n  .test-number {\n    font-weight: 600;\n    color: var(--muted);\n    min-width: 24px;\n  }\n  .test-label {\n    flex: 1;\n  }\n  .test-status {\n    font-weight: 600;\n    min-width: 60px;\n    text-align: right;\n  }\n  .test-status.pass { color: var(--teal); }\n  .test-status.fail { color: var(--red); }\n  .test-status.inactive { color: var(--muted); opacity: 0.5; }\n  .outcome {\n    margin: 18px 0 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.95rem;\n  }\n  .outcome.success {\n    border-color: var(--teal);\n    background: #f0f8f7;\n  }\n  .outcome.failure {\n    border-color: var(--red);\n    background: #fdf5f5;\n  }\n  .outcome strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-wrap: wrap;\n    }\n    .control label {\n      width: 100%;\n      margin-bottom: 4px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Add requirements without rewriting the rule</h2>\n<p class=\"subhead\">The written text stays fixed. Each added test makes passage harder.</p>\n\n<div class=\"control\">\n  <label for=\"requirements\">Active requirements:</label>\n  <input id=\"requirements\" type=\"range\" min=\"1\" max=\"4\" value=\"1\" aria-describedby=\"req-out\">\n  <output id=\"req-out\" for=\"requirements\">1</output>\n</div>\n\n<div class=\"rule-display\">\n  Rule: \"Access granted when score exceeds 50.\"\n</div>\n\n<div class=\"control\">\n  <label for=\"score\">Applicant score:</label>\n  <input id=\"score\" type=\"range\" min=\"0\" max=\"100\" value=\"75\" aria-describedby=\"score-out\">\n  <output id=\"score-out\" for=\"score\">75</output>\n</div>\n\n<div class=\"tests-container\" aria-live=\"polite\">\n  <div class=\"test-row\" data-test=\"1\">\n    <span class=\"test-number\">1</span>\n    <span class=\"test-label\">Score above 50</span>\n    <span class=\"test-status\" id=\"test1-status\">PASS</span>\n  </div>\n  <div class=\"test-row\" data-test=\"2\">\n    <span class=\"test-number\">2</span>\n    <span class=\"test-label\">Score above 60</span>\n    <span class=\"test-status inactive\" id=\"test2-status\">—</span>\n  </div>\n  <div class=\"test-row\" data-test=\"3\">\n    <span class=\"test-number\">3</span>\n    <span class=\"test-label\">Score above 70</span>\n    <span class=\"test-status inactive\" id=\"test3-status\">—</span>\n  </div>\n  <div class=\"test-row\" data-test=\"4\">\n    <span class=\"test-number\">4</span>\n    <span class=\"test-label\">Score above 80</span>\n    <span class=\"test-status inactive\" id=\"test4-status\">—</span>\n  </div>\n</div>\n\n<div class=\"outcome\" id=\"outcome\">\n  Result: <strong id=\"result-text\">Granted</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">One test. The rule operates as written.</p>\n\n<script>\n  (function () {\n    var reqSlider = document.getElementById('requirements');\n    var scoreSlider = document.getElementById('score');\n    var reqOut = document.getElementById('req-out');\n    var scoreOut = document.getElementById('score-out');\n    var outcome = document.getElementById('outcome');\n    var resultText = document.getElementById('result-text');\n    var caption = document.getElementById('caption');\n\n    var tests = [\n      { id: 1, threshold: 50 },\n      { id: 2, threshold: 60 },\n      { id: 3, threshold: 70 },\n      { id: 4, threshold: 80 }\n    ];\n\n    function update() {\n      var score = +scoreSlider.value;\n      var activeCount = +reqSlider.value;\n      scoreOut.textContent = score;\n      reqOut.textContent = activeCount;\n\n      var allPass = true;\n      for (var i = 0; i < tests.length; i++) {\n        var test = tests[i];\n        var statusEl = document.getElementById('test' + test.id + '-status');\n        if (i < activeCount) {\n          var pass = score > test.threshold;\n          statusEl.textContent = pass ? 'PASS' : 'FAIL';\n          statusEl.className = 'test-status ' + (pass ? 'pass' : 'fail');\n          if (!pass) allPass = false;\n        } else {\n          statusEl.textContent = '—';\n          statusEl.className = 'test-status inactive';\n        }\n      }\n\n      if (allPass) {\n        outcome.className = 'outcome success';\n        resultText.textContent = 'Granted';\n      } else {\n        outcome.className = 'outcome failure';\n        resultText.textContent = 'Denied';\n      }\n\n      if (activeCount === 1) {\n        caption.textContent = 'One test. The rule operates as written.';\n      } else if (activeCount === 2) {\n        caption.textContent = 'Two tests. Same text, but passing now requires clearing both hurdles.';\n      } else if (activeCount === 3) {\n        caption.textContent = 'Three tests. Each added requirement narrows who qualifies without touching the original rule.';\n      } else {\n        caption.textContent = 'Four tests. The text is unchanged, but access has shrunk to a fraction of the original scope.';\n      }\n    }\n\n    reqSlider.addEventListener('input', update);\n    scoreSlider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
