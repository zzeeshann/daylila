{
  "slug": "identity-loss-through-transformation",
  "type": "html",
  "title": "Mixing and Traceability",
  "concept": "Homogeneous mixing erases individual input identity; the degree of blending determines whether origin remains detectable.",
  "interactiveId": "6af76d1d-5a06-4bfe-a4f3-912e5f9a69be",
  "sourcePieceId": "9280146e-16ad-4c7a-977a-1900dc9b3324",
  "publishedAt": 1777201763192,
  "voiceScore": 95,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Mixing and Traceability</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --clean: #1a6b62;\n    --contaminated: #c43a31;\n    --trace: #c9a227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 140px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--trace);\n    min-width: 160px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2.5ch;\n    text-align: right;\n  }\n  .pipeline {\n    display: grid;\n    grid-template-columns: 140px 1fr 140px;\n    gap: 20px;\n    align-items: center;\n    margin: 28px 0;\n    min-height: 180px;\n  }\n  .stage {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .stage-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n    text-align: center;\n  }\n  .inputs {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n  .input-stream {\n    height: 20px;\n    border-radius: 3px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.65rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    transition: all 200ms ease;\n    position: relative;\n  }\n  .input-stream.clean {\n    background: var(--clean);\n    color: white;\n  }\n  .input-stream.contaminated {\n    background: var(--contaminated);\n    color: white;\n  }\n  .tracer-dot {\n    position: absolute;\n    left: 6px;\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: var(--trace);\n    border: 1.5px solid white;\n    opacity: 0;\n    transition: opacity 200ms ease;\n  }\n  .input-stream.tracer .tracer-dot {\n    opacity: 1;\n  }\n  .mixer-box {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n  }\n  .mixer-visual {\n    width: 100%;\n    height: 120px;\n    border-radius: 6px;\n    position: relative;\n    overflow: hidden;\n    background: var(--line);\n  }\n  .stream-layer {\n    position: absolute;\n    width: 100%;\n    transition: all 300ms ease-out;\n  }\n  .stream-layer.s0 { background: var(--clean); }\n  .stream-layer.s1 { background: var(--clean); }\n  .stream-layer.s2 { background: var(--clean); }\n  .stream-layer.s3 { background: var(--contaminated); }\n  .stream-layer.s4 { background: var(--contaminated); }\n  .tracer-marker {\n    position: absolute;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    background: var(--trace);\n    border: 2px solid white;\n    box-shadow: 0 0 8px rgba(201, 162, 39, 0.6);\n    transition: all 300ms ease-out;\n  }\n  .output-container {\n    height: 100px;\n    border-radius: 6px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    transition: background-color 300ms ease;\n    gap: 6px;\n    position: relative;\n  }\n  .output-label {\n    font-size: 1rem;\n    color: white;\n  }\n  .output-tracer {\n    width: 14px;\n    height: 14px;\n    border-radius: 50%;\n    background: var(--trace);\n    border: 2.5px solid white;\n    opacity: 0;\n    transition: opacity 300ms ease;\n  }\n  .output-tracer.visible {\n    opacity: 1;\n  }\n  .reading {\n    margin: 20px 0 6px;\n    padding: 14px 18px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: baseline;\n  }\n  .reading-row + .reading-row {\n    margin-top: 8px;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 640px) {\n    .control {\n      flex-direction: column;\n      align-items: flex-start;\n    }\n    .control label {\n      min-width: 0;\n    }\n    input[type=range] {\n      width: 100%;\n    }\n    .pipeline {\n      grid-template-columns: 1fr;\n      grid-template-rows: auto auto auto;\n      gap: 18px;\n    }\n    .stage-label {\n      text-align: left;\n    }\n    .mixer-visual {\n      height: 100px;\n    }\n    .output-container {\n      height: 80px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to increase mixing intensity</h2>\n<p class=\"subhead\">Five streams enter — three clean, two contaminated. One clean stream carries a tracer.</p>\n\n<div class=\"control\">\n  <label for=\"mixing\">Mixing intensity:</label>\n  <input id=\"mixing\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"mixing-out\">\n  <output id=\"mixing-out\" for=\"mixing\">0</output>\n</div>\n\n<div class=\"pipeline\">\n  <div class=\"stage\">\n    <span class=\"stage-label\">Inputs</span>\n    <div class=\"inputs\" id=\"inputs\">\n      <div class=\"input-stream clean tracer\" data-idx=\"0\">\n        <div class=\"tracer-dot\"></div>\n        <span>Clean</span>\n      </div>\n      <div class=\"input-stream clean\" data-idx=\"1\">Clean</div>\n      <div class=\"input-stream clean\" data-idx=\"2\">Clean</div>\n      <div class=\"input-stream contaminated\" data-idx=\"3\">Contaminated</div>\n      <div class=\"input-stream contaminated\" data-idx=\"4\">Contaminated</div>\n    </div>\n  </div>\n  \n  <div class=\"stage\">\n    <span class=\"stage-label\">Mixing point</span>\n    <div class=\"mixer-box\">\n      <div class=\"mixer-visual\" id=\"mixer\">\n        <div class=\"stream-layer s0\" id=\"layer0\"></div>\n        <div class=\"stream-layer s1\" id=\"layer1\"></div>\n        <div class=\"stream-layer s2\" id=\"layer2\"></div>\n        <div class=\"stream-layer s3\" id=\"layer3\"></div>\n        <div class=\"stream-layer s4\" id=\"layer4\"></div>\n        <div class=\"tracer-marker\" id=\"tracer\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"stage\">\n    <span class=\"stage-label\">Output</span>\n    <div class=\"output-container\" id=\"output\">\n      <span class=\"output-label\" id=\"output-label\">Distinct</span>\n      <div class=\"output-tracer\" id=\"output-tracer\"></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  <div class=\"reading-row\">\n    <span>Tracer visibility:</span>\n    <strong id=\"tracer-status\">Detectable</strong>\n  </div>\n  <div class=\"reading-row\">\n    <span>Input identity:</span>\n    <strong id=\"identity-status\">Preserved</strong>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">At zero mixing, streams remain separate. The tracer is identifiable in its origin stream. Each input retains distinct identity.</p>\n\n<script>\n(function () {\n  var slider = document.getElementById('mixing');\n  var mixingOut = document.getElementById('mixing-out');\n  var mixer = document.getElementById('mixer');\n  var layers = [\n    document.getElementById('layer0'),\n    document.getElementById('layer1'),\n    document.getElementById('layer2'),\n    document.getElementById('layer3'),\n    document.getElementById('layer4')\n  ];\n  var tracer = document.getElementById('tracer');\n  var output = document.getElementById('output');\n  var outputLabel = document.getElementById('output-label');\n  var outputTracer = document.getElementById('output-tracer');\n  var tracerStatus = document.getElementById('tracer-status');\n  var identityStatus = document.getElementById('identity-status');\n  var caption = document.getElementById('caption');\n  \n  function update() {\n    var intensity = +slider.value;\n    mixingOut.textContent = intensity;\n    \n    var normalized = intensity / 100;\n    var layerHeight = 120 / 5;\n    \n    for (var i = 0; i < 5; i++) {\n      var baseTop = i * layerHeight;\n      var spread = normalized * 60;\n      var newTop = baseTop - spread / 2 + (Math.random() - 0.5) * spread * 0.6;\n      var newHeight = layerHeight * (1 + normalized * 0.8);\n      layers[i].style.top = newTop + 'px';\n      layers[i].style.height = newHeight + 'px';\n      layers[i].style.opacity = String(1 - normalized * 0.3);\n    }\n    \n    var tracerBaseY = 0 * layerHeight + layerHeight / 2;\n    var tracerSpread = normalized * 50;\n    var tracerY = tracerBaseY + (Math.random() - 0.5) * tracerSpread;\n    var tracerX = 10 + normalized * 70 + (Math.random() - 0.5) * normalized * 40;\n    tracer.style.left = tracerX + '%';\n    tracer.style.top = tracerY + 'px';\n    tracer.style.opacity = String(1 - normalized * 0.7);\n    \n    var cleanRatio = 0.6;\n    var r = Math.round(26 + (196 - 26) * (1 - cleanRatio));\n    var g = Math.round(107 + (67 - 107) * (1 - cleanRatio));\n    var b = Math.round(98 + (49 - 98) * (1 - cleanRatio));\n    var blendR = Math.round(r + (139 - r) * normalized);\n    var blendG = Math.round(g + (115 - g) * normalized);\n    var blendB = Math.round(b + (85 - b) * normalized);\n    output.style.background = 'rgb(' + blendR + ',' + blendG + ',' + blendB + ')';\n    \n    if (intensity === 0) {\n      outputLabel.textContent = 'Distinct';\n      outputTracer.classList.add('visible');\n      tracerStatus.textContent = 'Detectable';\n      identityStatus.textContent = 'Preserved';\n      caption.textContent = 'At zero mixing, streams remain separate. The tracer is identifiable in its origin stream. Each input retains distinct identity.';\n    } else if (intensity <= 25) {\n      outputLabel.textContent = 'Layered';\n      outputTracer.classList.add('visible');\n      tracerStatus.textContent = 'Mostly detectable';\n      identityStatus.textContent = 'Partially preserved';\n      caption.textContent = 'Light mixing produces layers. The tracer is still visible but beginning to diffuse. Individual streams are distinguishable but boundaries blur.';\n    } else if (intensity <= 50) {\n      outputLabel.textContent = 'Blending';\n      outputTracer.style.opacity = '0.4';\n      tracerStatus.textContent = 'Fading';\n      identityStatus.textContent = 'Degrading';\n      caption.textContent = 'Moderate mixing erodes separation. The tracer disperses across the volume. Origin becomes probabilistic rather than certain.';\n    } else if (intensity <= 75) {\n      outputLabel.textContent = 'Homogenizing';\n      outputTracer.classList.remove('visible');\n      tracerStatus.textContent = 'Undetectable';\n      identityStatus.textContent = 'Lost';\n      caption.textContent = 'Heavy mixing approaches homogeneity. The tracer cannot be located. Downstream sees a single composite with no individual stream identity.';\n    } else {\n      outputLabel.textContent = 'Homogeneous';\n      outputTracer.classList.remove('visible');\n      tracerStatus.textContent = 'Undetectable';\n      identityStatus.textContent = 'Erased';\n      caption.textContent = 'Full mixing produces a uniform blend. The tracer is statistically distributed. No test can determine which input contributed the contaminated fraction.';\n    }\n  }\n  \n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
