{
  "slug": "momentum-transfer-in-gravity-assists",
  "type": "html",
  "title": "Velocity Change Without Fuel",
  "concept": "A moving object can change another object's speed and direction through gravity alone if the second object passes close enough—no fuel burned, just momentum transferred from the larger mass to the smaller one.",
  "interactiveId": "07f8f62d-0074-4c91-8561-0175949270a5",
  "sourcePieceId": "5cb63863-58b8-451e-9e0b-e2db5e373509",
  "publishedAt": 1778363426586,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Velocity Change Without Fuel</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --planet: #c9a227;\n    --craft: #1a6b62;\n    --path: #d4a574;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--craft);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .stage {\n    margin: 24px 0;\n    position: relative;\n    height: 280px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    overflow: hidden;\n  }\n  svg {\n    display: block;\n    width: 100%;\n    height: 100%;\n  }\n  .planet-body {\n    fill: var(--planet);\n  }\n  .craft-dot {\n    fill: var(--craft);\n  }\n  .approach-path {\n    stroke: var(--path);\n    stroke-width: 2;\n    fill: none;\n    stroke-dasharray: 4 3;\n    opacity: 0.6;\n  }\n  .exit-path {\n    stroke: var(--craft);\n    stroke-width: 2;\n    fill: none;\n  }\n  .velocity-arrow {\n    stroke: var(--craft);\n    stroke-width: 2;\n    fill: var(--craft);\n  }\n  .planet-arrow {\n    stroke: var(--planet);\n    stroke-width: 2;\n    fill: var(--planet);\n    opacity: 0.5;\n  }\n  .label-text {\n    font-size: 12px;\n    fill: var(--muted);\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .speed-compare {\n    display: flex;\n    gap: 20px;\n    margin-top: 8px;\n  }\n  .speed-bar {\n    flex: 1;\n  }\n  .speed-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n  }\n  .bar-track {\n    height: 24px;\n    background: var(--line);\n    border-radius: 3px;\n    overflow: hidden;\n    position: relative;\n  }\n  .bar-fill {\n    height: 100%;\n    background: var(--craft);\n    transition: width 200ms ease-out;\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    padding-right: 6px;\n    color: #fff;\n    font-size: 0.8rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .stage {\n      height: 240px;\n    }\n    .speed-compare {\n      flex-direction: column;\n      gap: 12px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust the flyby distance</h2>\n<p class=\"subhead\">A small object passes a large moving object. Watch how close approach changes the exit speed.</p>\n\n<div class=\"control\">\n  <label for=\"distance\">Distance:</label>\n  <input id=\"distance\" type=\"range\" min=\"1\" max=\"10\" value=\"3\" step=\"0.5\" aria-describedby=\"distance-out\">\n  <output id=\"distance-out\" for=\"distance\">3.0</output>\n</div>\n\n<div class=\"stage\" role=\"img\" aria-label=\"Gravity assist visualization\">\n  <svg id=\"viz\" viewBox=\"0 0 600 280\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n      <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"10\" refX=\"9\" refY=\"3\" orient=\"auto\">\n        <polygon points=\"0 0, 10 3, 0 6\" fill=\"var(--craft)\" />\n      </marker>\n      <marker id=\"arrowhead-planet\" markerWidth=\"10\" markerHeight=\"10\" refX=\"9\" refY=\"3\" orient=\"auto\">\n        <polygon points=\"0 0, 10 3, 0 6\" fill=\"var(--planet)\" opacity=\"0.5\" />\n      </marker>\n    </defs>\n    \n    <!-- Planet -->\n    <circle id=\"planet\" class=\"planet-body\" cx=\"300\" cy=\"140\" r=\"40\" />\n    \n    <!-- Planet velocity arrow (rightward, showing orbital motion) -->\n    <line class=\"planet-arrow\" x1=\"300\" y1=\"90\" x2=\"380\" y2=\"90\" marker-end=\"url(#arrowhead-planet)\" />\n    <text class=\"label-text\" x=\"340\" y=\"82\" text-anchor=\"middle\">planet motion</text>\n    \n    <!-- Approach path (dashed curve from left) -->\n    <path id=\"approach\" class=\"approach-path\" d=\"\" />\n    \n    <!-- Exit path (solid curve to right) -->\n    <path id=\"exit\" class=\"exit-path\" d=\"\" />\n    \n    <!-- Craft dot -->\n    <circle id=\"craft\" class=\"craft-dot\" cx=\"0\" cy=\"0\" r=\"6\" />\n    \n    <!-- Velocity arrows -->\n    <line id=\"vel-approach\" class=\"velocity-arrow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"0\" marker-end=\"url(#arrowhead)\" style=\"display:none;\" />\n    <line id=\"vel-exit\" class=\"velocity-arrow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"0\" marker-end=\"url(#arrowhead)\" style=\"display:none;\" />\n    \n    <text id=\"label-approach\" class=\"label-text\" x=\"0\" y=\"0\" text-anchor=\"middle\" style=\"display:none;\">approach</text>\n    <text id=\"label-exit\" class=\"label-text\" x=\"0\" y=\"0\" text-anchor=\"middle\" style=\"display:none;\">exit</text>\n  </svg>\n</div>\n\n<div class=\"reading\">\n  <div>Closest approach: <strong id=\"closest\">3.0</strong> planetary radii.</div>\n  <div class=\"speed-compare\">\n    <div class=\"speed-bar\">\n      <div class=\"speed-label\">Speed before</div>\n      <div class=\"bar-track\">\n        <div id=\"speed-before\" class=\"bar-fill\">15</div>\n      </div>\n    </div>\n    <div class=\"speed-bar\">\n      <div class=\"speed-label\">Speed after</div>\n      <div class=\"bar-track\">\n        <div id=\"speed-after\" class=\"bar-fill\">22</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">The closer you pass, the more speed you gain. The planet's motion becomes yours.</p>\n\n<script>\n(function () {\n  var slider = document.getElementById('distance');\n  var distOut = document.getElementById('distance-out');\n  var closest = document.getElementById('closest');\n  var speedBefore = document.getElementById('speed-before');\n  var speedAfter = document.getElementById('speed-after');\n  var caption = document.getElementById('caption');\n  var approach = document.getElementById('approach');\n  var exit = document.getElementById('exit');\n  var craft = document.getElementById('craft');\n  var velApproach = document.getElementById('vel-approach');\n  var velExit = document.getElementById('vel-exit');\n  var labelApproach = document.getElementById('label-approach');\n  var labelExit = document.getElementById('label-exit');\n  \n  var planetX = 300;\n  var planetY = 140;\n  var planetR = 40;\n  \n  function calculateGain(distRadii) {\n    // Simplified model: closer flyby = more velocity gain\n    // At distance 1 (grazing), gain ~50%. At distance 10, gain ~5%.\n    var maxGain = 0.5;\n    var minGain = 0.05;\n    var normalized = (distRadii - 1) / 9;\n    return maxGain - (maxGain - minGain) * normalized;\n  }\n  \n  function update() {\n    var dist = parseFloat(slider.value);\n    distOut.textContent = dist.toFixed(1);\n    closest.textContent = dist.toFixed(1);\n    \n    var initialSpeed = 15;\n    var gain = calculateGain(dist);\n    var finalSpeed = Math.round(initialSpeed * (1 + gain));\n    \n    speedBefore.textContent = initialSpeed;\n    speedBefore.style.width = (initialSpeed / 30 * 100) + '%';\n    \n    speedAfter.textContent = finalSpeed;\n    speedAfter.style.width = (finalSpeed / 30 * 100) + '%';\n    \n    // Draw paths\n    var closestDist = dist * planetR;\n    var approachY = planetY - closestDist;\n    var exitY = planetY + (closestDist * 0.6); // Exit path bends down less\n    \n    // Approach: smooth curve from left, passing above planet\n    var approachPath = 'M 50 ' + approachY + ' Q 200 ' + (approachY - 10) + ' ' + (planetX - closestDist) + ' ' + planetY;\n    approach.setAttribute('d', approachPath);\n    \n    // Exit: curve from closest point to right, angled downward slightly\n    var exitPath = 'M ' + (planetX + closestDist) + ' ' + planetY + ' Q 400 ' + (planetY + 20) + ' 550 ' + exitY;\n    exit.setAttribute('d', exitPath);\n    \n    // Position craft at approach point\n    craft.setAttribute('cx', 50);\n    craft.setAttribute('cy', approachY);\n    \n    // Velocity arrows (show at approach and exit positions)\n    velApproach.setAttribute('x1', 50);\n    velApproach.setAttribute('y1', approachY);\n    velApproach.setAttribute('x2', 50 + 40);\n    velApproach.setAttribute('y2', approachY);\n    velApproach.style.display = 'block';\n    \n    velExit.setAttribute('x1', 550);\n    velExit.setAttribute('y1', exitY);\n    velExit.setAttribute('x2', 550 + 60);\n    velExit.setAttribute('y2', exitY);\n    velExit.style.display = 'block';\n    \n    labelApproach.setAttribute('x', 70);\n    labelApproach.setAttribute('y', approachY - 12);\n    labelApproach.style.display = 'block';\n    \n    labelExit.setAttribute('x', 580);\n    labelExit.setAttribute('y', exitY - 12);\n    labelExit.style.display = 'block';\n    \n    // Update caption\n    if (dist <= 2) {\n      caption.textContent = 'A very close pass. Maximum momentum transfer from the planet to the smaller object.';\n    } else if (dist <= 5) {\n      caption.textContent = 'The closer you pass, the more speed you gain. The planet\\'s motion becomes yours.';\n    } else {\n      caption.textContent = 'Far flyby. Gravity bends the path but transfers little momentum.';\n    }\n  }\n  \n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
