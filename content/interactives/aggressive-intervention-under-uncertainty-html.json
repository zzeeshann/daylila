{
  "slug": "aggressive-intervention-under-uncertainty",
  "type": "html",
  "title": "Elimination as Signal",
  "concept": "When a system cannot distinguish between multiple causes cheaply, removing one component entirely forces the ambiguity to resolve—if the problem persists after removal, the eliminated component was not the cause; if the problem stops, it was.",
  "interactiveId": "02c91a62-3651-4db3-94ea-e2c6062834d0",
  "sourcePieceId": "b77e8406-a000-46ef-8989-dde9bb48a8b4",
  "publishedAt": 1777731219774,
  "voiceScore": 68,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Elimination as Signal</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #d65d3f;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .scenario {\n    margin: 0 0 20px;\n    padding: 14px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .scenario strong {\n    font-weight: 600;\n  }\n  .priors {\n    display: flex;\n    gap: 12px;\n    margin: 8px 0 0;\n    font-size: 0.85rem;\n  }\n  .prior-item {\n    color: var(--muted);\n  }\n  .actions {\n    display: flex;\n    gap: 12px;\n    margin: 24px 0 20px;\n  }\n  .action-btn {\n    flex: 1;\n    padding: 12px 16px;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    background: #fff;\n    cursor: pointer;\n    font-size: 0.9rem;\n    font-weight: 500;\n    transition: all 150ms ease;\n  }\n  .action-btn:hover:not(:disabled) {\n    border-color: var(--teal);\n  }\n  .action-btn:disabled {\n    cursor: not-allowed;\n    opacity: 0.4;\n  }\n  .action-btn.low-cost {\n    border-color: var(--gold);\n  }\n  .action-btn.high-cost {\n    border-color: var(--red);\n  }\n  .cost-label {\n    display: block;\n    font-size: 0.75rem;\n    color: var(--muted);\n    margin-top: 4px;\n  }\n  .outcome {\n    margin: 20px 0 0;\n    padding: 14px 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    min-height: 60px;\n  }\n  .outcome.resolved {\n    border-color: var(--teal);\n  }\n  .outcome.failed {\n    border-color: var(--gold);\n  }\n  .outcome.definitive {\n    border-color: var(--red);\n  }\n  .outcome-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 6px;\n  }\n  .outcome-text {\n    font-size: 0.9rem;\n    line-height: 1.5;\n  }\n  .outcome-text strong {\n    font-weight: 600;\n  }\n  .state-box {\n    margin: 16px 0 0;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.85rem;\n  }\n  .state-box strong {\n    font-weight: 600;\n  }\n  .reset {\n    margin: 16px 0 0;\n    padding: 8px 14px;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    background: var(--bg);\n    cursor: pointer;\n    font-size: 0.85rem;\n    color: var(--muted);\n  }\n  .reset:hover {\n    color: var(--fg);\n    border-color: var(--fg);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .actions {\n      flex-direction: column;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Pick an action</h2>\n<p class=\"subhead\">A persistent problem appears. Two components could be the cause. You choose what to try.</p>\n\n<div class=\"scenario\">\n  <strong>Problem:</strong> output keeps failing.<br>\n  <strong>Suspects:</strong> Component X (happens often) or Component Y (happens rarely).\n  <div class=\"priors\">\n    <span class=\"prior-item\">X fails in 70% of similar cases</span>\n    <span class=\"prior-item\">Y fails in 30% of similar cases</span>\n  </div>\n</div>\n\n<div class=\"actions\" id=\"actions\">\n  <button class=\"action-btn low-cost\" id=\"btn-treat\">\n    Treat X\n    <span class=\"cost-label\">Cheap. Targets the usual cause.</span>\n  </button>\n  <button class=\"action-btn high-cost\" id=\"btn-remove\">\n    Remove X\n    <span class=\"cost-label\">Expensive. Takes X out of the picture.</span>\n  </button>\n</div>\n\n<div class=\"outcome\" id=\"outcome\" style=\"display: none;\">\n  <div class=\"outcome-label\" id=\"outcome-label\">Result</div>\n  <div class=\"outcome-text\" id=\"outcome-text\"></div>\n</div>\n\n<div class=\"state-box\" id=\"state-box\" style=\"display: none;\">\n  <strong id=\"state-text\"></strong>\n</div>\n\n<button class=\"reset\" id=\"reset\" style=\"display: none;\">Try again</button>\n\n<p class=\"caption\" id=\"caption\">Treating the likely cause first costs less when it works. Removal is always there if treatment fails.</p>\n\n<script>\n  (function () {\n    var btnTreat = document.getElementById('btn-treat');\n    var btnRemove = document.getElementById('btn-remove');\n    var outcome = document.getElementById('outcome');\n    var outcomeLabel = document.getElementById('outcome-label');\n    var outcomeText = document.getElementById('outcome-text');\n    var stateBox = document.getElementById('state-box');\n    var stateText = document.getElementById('state-text');\n    var reset = document.getElementById('reset');\n    var caption = document.getElementById('caption');\n    var actions = document.getElementById('actions');\n\n    var treatmentAttempted = false;\n\n    function disableActions() {\n      btnTreat.disabled = true;\n      btnRemove.disabled = true;\n    }\n\n    function showOutcome(label, text, className, stateLine) {\n      outcome.style.display = 'block';\n      outcome.className = 'outcome ' + className;\n      outcomeLabel.textContent = label;\n      outcomeText.innerHTML = text;\n      stateBox.style.display = 'block';\n      stateText.textContent = stateLine;\n      reset.style.display = 'block';\n    }\n\n    function tryTreatment() {\n      disableActions();\n      treatmentAttempted = true;\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n      \n      var roll = Math.random();\n      if (roll < 0.40) {\n        showOutcome(\n          'Problem solved',\n          '<strong>Output restored.</strong> X was the cause. Treatment worked.',\n          'resolved',\n          'Treated X. Problem gone. Paid less.'\n        );\n        caption.textContent = 'When X is the cause and treatment works, you solve the problem cheaply. The bet paid off.';\n      } else {\n        showOutcome(\n          'Problem still there',\n          '<strong>Output still failing.</strong> Treatment didn't fix it. Either X wasn't the cause or the treatment wasn't enough.',\n          'failed',\n          'Treated X. Problem still there.'\n        );\n        caption.textContent = 'Treatment failed. You still don't know if X was the cause or if the treatment just wasn't strong enough. You can remove X to find out.';\n        \n        btnRemove.disabled = false;\n        var costLabel = btnRemove.querySelector('.cost-label');\n        if (costLabel) costLabel.textContent = 'Expensive. Eliminates X completely.';\n      }\n    }\n\n    function tryRemoval() {\n      disableActions();\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n      \n      if (treatmentAttempted) {\n        var roll = Math.random();\n        if (roll < 0.50) {\n          showOutcome(\n            'Problem solved',\n            '<strong>Output restored.</strong> X is gone and the problem stopped. X was the cause.',\n            'definitive',\n            'Removed X. Problem solved. X was it.'\n          );\n          caption.textContent = 'Removing X after treatment failed solved it. X was the cause — treatment just wasn't strong enough. Paid more, but got clarity.';\n        } else {\n          showOutcome(\n            'Problem still there',\n            '<strong>Output still failing.</strong> X is gone but the problem continues. X wasn't the cause. Y must be.',\n            'definitive',\n            'Removed X. Problem still there. Y is the cause.'\n          );\n          caption.textContent = 'X is gone. The problem didn't stop. That tells you X wasn't the cause. Y is the only thing left. Removal forced the answer.';\n        }\n      } else {\n        var roll = Math.random();\n        if (roll < 0.70) {\n          showOutcome(\n            'Problem solved',\n            '<strong>Output restored.</strong> X is gone and the problem stopped. X was the cause.',\n            'definitive',\n            'Removed X first. Problem solved. Paid more.'\n          );\n          caption.textContent = 'Removing X worked, but you paid the high cost right away. Treatment might have worked for less — you skipped that step.';\n        } else {\n          showOutcome(\n            'Problem still there',\n            '<strong>Output still failing.</strong> X is gone but the problem continues. X wasn't the cause. Y must be.',\n            'definitive',\n            'Removed X first. Problem still there. Y is the cause.'\n          );\n          caption.textContent = 'X is gone. The problem didn't stop. That tells you X wasn't the cause. Y is the only thing left. You got the answer, but paid the high cost upfront.';\n        }\n      }\n    }\n\n    function resetScenario() {\n      treatmentAttempted = false;\n      btnTreat.disabled = false;\n      btnRemove.disabled = false;\n      btnTreat.textContent = 'Treat X';\n      btnRemove.textContent = 'Remove X';\n      var costLabels = actions.querySelectorAll('.cost-label');\n      if (costLabels[0]) costLabels[0].textContent = 'Cheap. Targets the usual cause.';\n      if (costLabels[1]) costLabels[1].textContent = 'Expensive. Takes X out of the picture.';\n      outcome.style.display = 'none';\n      stateBox.style.display = 'none';\n      reset.style.display = 'none';\n      caption.textContent = 'Treating the likely cause first costs less when it works. Removal is always there if treatment fails.';\n    }\n\n    btnTreat.addEventListener('click', tryTreatment);\n    btnRemove.addEventListener('click', tryRemoval);\n    reset.addEventListener('click', resetScenario);\n  })();\n</script>\n</body>\n</html>"
  }
}
