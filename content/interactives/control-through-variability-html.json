{
  "slug": "control-through-variability",
  "type": "html",
  "title": "Dual-Signal Regulation",
  "concept": "Two opposing control signals running simultaneously produce moment-to-moment variation — the size of that variation reveals whether both controllers are working.",
  "interactiveId": "ec5c24ac-ba13-44eb-986f-fc37eae89721",
  "sourcePieceId": "d3f724bd-5933-40a2-b078-0a317d05425b",
  "publishedAt": 1778163020939,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Dual-Signal Regulation</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --red: #c92727;\n    --blue: #274bc9;\n    --purple: #8b4bc9;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .control label {\n    font-weight: 500;\n    min-width: 100px;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    min-width: 120px;\n  }\n  .control input[type=range].speed-up {\n    accent-color: var(--red);\n  }\n  .control input[type=range].slow-down {\n    accent-color: var(--blue);\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3.5ch;\n    text-align: right;\n  }\n  .output-display {\n    margin: 24px 0;\n  }\n  .pulse-track {\n    height: 120px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    position: relative;\n    overflow: hidden;\n    margin-bottom: 16px;\n  }\n  .pulse-bar {\n    position: absolute;\n    width: 3px;\n    height: 100%;\n    background: var(--purple);\n    opacity: 0.7;\n    transition: left 50ms linear;\n  }\n  .baseline {\n    position: absolute;\n    top: 50%;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: var(--line);\n    transform: translateY(-0.5px);\n  }\n  .reading {\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading-row {\n    display: flex;\n    justify-content: space-between;\n    margin-bottom: 8px;\n  }\n  .reading-row:last-child {\n    margin-bottom: 0;\n  }\n  .reading-row strong {\n    font-weight: 600;\n  }\n  .variance-value {\n    font-size: 1.1rem;\n    font-weight: 700;\n    color: var(--purple);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control label {\n      min-width: 0;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust both control signals</h2>\n<p class=\"subhead\">Two opposing forces run at the same time. Their push and pull creates variation in the output.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"speed-up\">Speed-up signal:</label>\n    <input id=\"speed-up\" class=\"speed-up\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"speed-up-out\">\n    <output id=\"speed-up-out\" for=\"speed-up\">50</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"slow-down\">Slow-down signal:</label>\n    <input id=\"slow-down\" class=\"slow-down\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"slow-down-out\">\n    <output id=\"slow-down-out\" for=\"slow-down\">50</output>\n  </div>\n</div>\n\n<div class=\"output-display\">\n  <div class=\"pulse-track\" aria-hidden=\"true\">\n    <div class=\"baseline\"></div>\n    <canvas id=\"pulse-canvas\" width=\"800\" height=\"120\"></canvas>\n  </div>\n  \n  <div class=\"reading\">\n    <div class=\"reading-row\">\n      <span>Current output:</span>\n      <strong id=\"current-rate\">50</strong>\n    </div>\n    <div class=\"reading-row\">\n      <span>Variation (range):</span>\n      <strong class=\"variance-value\" id=\"variance\">0</strong>\n    </div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">When both signals are off, there's no variation. Move the sliders.</p>\n\n<script>\n(function() {\n  var speedUpSlider = document.getElementById('speed-up');\n  var slowDownSlider = document.getElementById('slow-down');\n  var speedUpOut = document.getElementById('speed-up-out');\n  var slowDownOut = document.getElementById('slow-down-out');\n  var currentRate = document.getElementById('current-rate');\n  var varianceDisplay = document.getElementById('variance');\n  var caption = document.getElementById('caption');\n  var canvas = document.getElementById('pulse-canvas');\n  var ctx = canvas.getContext('2d');\n  \n  var history = [];\n  var maxHistory = 100;\n  var time = 0;\n  \n  function getRate() {\n    var speedUp = +speedUpSlider.value;\n    var slowDown = +slowDownSlider.value;\n    \n    // Base output is difference between the two signals\n    var base = speedUp - slowDown + 50;\n    \n    // Add oscillation when both are active - simulates moment-to-moment\n    // competition between the two controllers\n    var bothActive = Math.min(speedUp, slowDown) / 100;\n    var oscillation = Math.sin(time * 0.3) * 20 * bothActive;\n    \n    return Math.max(0, Math.min(100, base + oscillation));\n  }\n  \n  function getVariance() {\n    if (history.length < 2) return 0;\n    var min = Math.min.apply(null, history);\n    var max = Math.max.apply(null, history);\n    return Math.round(max - min);\n  }\n  \n  function updateCaption(speedUp, slowDown, variance) {\n    var bothActive = Math.min(speedUp, slowDown);\n    var eitherActive = Math.max(speedUp, slowDown);\n    \n    if (eitherActive < 10) {\n      caption.textContent = \"When both signals are off, there's no variation. Move the sliders.\";\n    } else if (bothActive < 10) {\n      caption.textContent = \"Only one signal is active. Output moves, but stays steady — no back-and-forth.\";\n    } else if (bothActive < 30) {\n      caption.textContent = \"Both signals are weak. Small variation appears — the system is responding, but barely.\";\n    } else if (bothActive < 60) {\n      caption.textContent = \"Both signals are active. Output swings as they compete — this is what healthy variation looks like.\";\n    } else {\n      caption.textContent = \"Both signals are strong. Large swings show both controllers working hard in opposite directions.\";\n    }\n  }\n  \n  function drawHistory() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n    \n    if (history.length < 2) return;\n    \n    ctx.strokeStyle = '#8b4bc9';\n    ctx.lineWidth = 2;\n    ctx.beginPath();\n    \n    var step = canvas.width / maxHistory;\n    for (var i = 0; i < history.length; i++) {\n      var x = i * step;\n      var y = canvas.height - (history[i] / 100 * canvas.height);\n      if (i === 0) {\n        ctx.moveTo(x, y);\n      } else {\n        ctx.lineTo(x, y);\n      }\n    }\n    ctx.stroke();\n  }\n  \n  function update() {\n    var speedUp = +speedUpSlider.value;\n    var slowDown = +slowDownSlider.value;\n    \n    speedUpOut.textContent = speedUp;\n    slowDownOut.textContent = slowDown;\n    \n    var rate = getRate();\n    currentRate.textContent = Math.round(rate);\n    \n    history.push(rate);\n    if (history.length > maxHistory) {\n      history.shift();\n    }\n    \n    var variance = getVariance();\n    varianceDisplay.textContent = variance;\n    \n    drawHistory();\n    updateCaption(speedUp, slowDown, variance);\n    \n    time++;\n  }\n  \n  // Animate continuously to show oscillation\n  function animate() {\n    update();\n    requestAnimationFrame(animate);\n  }\n  \n  speedUpSlider.addEventListener('input', function() {\n    history = []; // Reset history on manual change\n  });\n  slowDownSlider.addEventListener('input', function() {\n    history = [];\n  });\n  \n  // Resize canvas to match container\n  function resizeCanvas() {\n    var container = canvas.parentElement;\n    var rect = container.getBoundingClientRect();\n    canvas.width = rect.width - 2; // Account for border\n    canvas.style.width = (rect.width - 2) + 'px';\n  }\n  \n  window.addEventListener('resize', resizeCanvas);\n  resizeCanvas();\n  \n  animate();\n})();\n</script>\n</body>\n</html>"
  }
}
