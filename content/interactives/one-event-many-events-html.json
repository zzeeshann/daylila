{
  "slug": "one-event-many-events",
  "type": "html",
  "title": "One Event Versus Many Events",
  "concept": "One path builds a link over many tries; the other builds it in a single moment—the difference is timing, not outcome.",
  "interactiveId": "db133175-1a35-4292-9827-c764605acc9f",
  "sourcePieceId": "4151bae5-320c-437d-ad38-b2bb7d003b67",
  "publishedAt": 1777644565606,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>One Event Versus Many Events</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 18px;\n    margin-bottom: 24px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 90px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .paths {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin: 24px 0 20px;\n  }\n  .path {\n    border: 1px solid var(--line);\n    border-radius: 8px;\n    padding: 16px;\n    background: white;\n  }\n  .path-title {\n    font-weight: 600;\n    margin-bottom: 12px;\n    font-size: 0.9rem;\n  }\n  .viz {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 16px;\n  }\n  .node {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    background: var(--line);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: var(--muted);\n  }\n  .link {\n    flex: 1;\n    height: 6px;\n    background: var(--line);\n    border-radius: 3px;\n    position: relative;\n    overflow: hidden;\n  }\n  .link-fill {\n    height: 100%;\n    background: var(--gold);\n    width: 0%;\n    transition: width 250ms ease-out;\n  }\n  .metrics {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    font-size: 0.85rem;\n  }\n  .metric-row {\n    display: flex;\n    justify-content: space-between;\n  }\n  .metric-label {\n    color: var(--muted);\n  }\n  .metric-value {\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .reading {\n    margin: 18px 0 8px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 12px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 560px) {\n    .paths {\n      grid-template-columns: 1fr;\n    }\n    .control label {\n      min-width: 80px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Watch two paths reach the same outcome</h2>\n<p class=\"subhead\">One builds strength across many tries. The other builds it in a single moment.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"reps\">Repetitions:</label>\n    <input id=\"reps\" type=\"range\" min=\"1\" max=\"20\" value=\"1\" step=\"1\" aria-describedby=\"reps-out\">\n    <output id=\"reps-out\" for=\"reps\">1</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"intensity\">Event strength:</label>\n    <input id=\"intensity\" type=\"range\" min=\"0\" max=\"100\" value=\"30\" aria-describedby=\"intensity-out\">\n    <output id=\"intensity-out\" for=\"intensity\">30</output>\n  </div>\n</div>\n\n<div class=\"paths\">\n  <div class=\"path\">\n    <div class=\"path-title\">Slow path</div>\n    <div class=\"viz\">\n      <div class=\"node\">A</div>\n      <div class=\"link\"><div class=\"link-fill\" id=\"slow-fill\"></div></div>\n      <div class=\"node\">B</div>\n    </div>\n    <div class=\"metrics\">\n      <div class=\"metric-row\">\n        <span class=\"metric-label\">Strength:</span>\n        <span class=\"metric-value\" id=\"slow-strength\">0%</span>\n      </div>\n      <div class=\"metric-row\">\n        <span class=\"metric-label\">Complete:</span>\n        <span class=\"metric-value\" id=\"slow-status\">No</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"path\">\n    <div class=\"path-title\">Fast path</div>\n    <div class=\"viz\">\n      <div class=\"node\">C</div>\n      <div class=\"link\"><div class=\"link-fill\" id=\"fast-fill\"></div></div>\n      <div class=\"node\">D</div>\n    </div>\n    <div class=\"metrics\">\n      <div class=\"metric-row\">\n        <span class=\"metric-label\">Strength:</span>\n        <span class=\"metric-value\" id=\"fast-strength\">0%</span>\n      </div>\n      <div class=\"metric-row\">\n        <span class=\"metric-label\">Complete:</span>\n        <span class=\"metric-value\" id=\"fast-status\">No</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  <strong id=\"summary\">Adjust both sliders to see how each path responds.</strong>\n</div>\n\n<p class=\"caption\" id=\"caption\">The slow path needs many tries at any strength. The fast path needs one strong try.</p>\n\n<script>\n(function () {\n  var repsSlider = document.getElementById('reps');\n  var repsOut = document.getElementById('reps-out');\n  var intensitySlider = document.getElementById('intensity');\n  var intensityOut = document.getElementById('intensity-out');\n  \n  var slowFill = document.getElementById('slow-fill');\n  var slowStrength = document.getElementById('slow-strength');\n  var slowStatus = document.getElementById('slow-status');\n  \n  var fastFill = document.getElementById('fast-fill');\n  var fastStrength = document.getElementById('fast-strength');\n  var fastStatus = document.getElementById('fast-status');\n  \n  var summary = document.getElementById('summary');\n  var caption = document.getElementById('caption');\n\n  var lastReps = 1;\n  var lastIntensity = 30;\n  var hasEngaged = false;\n\n  function update() {\n    var reps = +repsSlider.value;\n    var intensity = +intensitySlider.value;\n    repsOut.textContent = reps;\n    intensityOut.textContent = intensity;\n\n    var slowStr = Math.min(100, reps * 5);\n    var fastStr = 0;\n    if (intensity >= 70) {\n      fastStr = Math.min(100, (intensity - 70) * 3.33);\n    }\n\n    slowFill.style.width = slowStr + '%';\n    slowStrength.textContent = Math.round(slowStr) + '%';\n    slowStatus.textContent = slowStr >= 100 ? 'Yes' : 'No';\n\n    fastFill.style.width = fastStr + '%';\n    fastStrength.textContent = Math.round(fastStr) + '%';\n    fastStatus.textContent = fastStr >= 100 ? 'Yes' : 'No';\n\n    var slowComplete = slowStr >= 100;\n    var fastComplete = fastStr >= 100;\n\n    if (slowComplete && fastComplete) {\n      summary.textContent = 'Both paths complete. Same outcome, different timing.';\n      caption.textContent = 'Many weak tries or one strong try — both build a lasting link.';\n    } else if (slowComplete && !fastComplete) {\n      summary.textContent = 'The slow path completes. The fast path needs a stronger event.';\n      caption.textContent = 'Repetition alone is enough to form a link, even without intensity.';\n    } else if (!slowComplete && fastComplete) {\n      summary.textContent = 'The fast path completes. The slow path needs more tries.';\n      caption.textContent = 'One strong event forms a link without repetition.';\n    } else if (reps === 1 && intensity < 70) {\n      summary.textContent = 'One weak event does not complete either path.';\n      caption.textContent = 'A single routine event is not enough for either way to finish.';\n    } else if (reps > 1 && intensity < 70) {\n      summary.textContent = 'The slow path builds. The fast path stays dormant.';\n      caption.textContent = 'Many weak tries accumulate on the slow path. The fast path needs strength.';\n    } else if (reps === 1 && intensity >= 70) {\n      summary.textContent = 'The fast path responds to the strong event. The slow path needs more tries.';\n      caption.textContent = 'A single strong event activates the fast path but not the slow one.';\n    } else {\n      summary.textContent = 'Both paths are building but neither is complete yet.';\n      caption.textContent = 'The slow path benefits from repetition. The fast path needs more strength.';\n    }\n\n    if (!hasEngaged && (Math.abs(reps - lastReps) > 0 || Math.abs(intensity - lastIntensity) > 5)) {\n      hasEngaged = true;\n      if (window.parent) {\n        window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n      }\n    }\n    lastReps = reps;\n    lastIntensity = intensity;\n  }\n\n  repsSlider.addEventListener('input', update);\n  intensitySlider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
