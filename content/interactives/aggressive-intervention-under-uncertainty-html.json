{
  "slug": "aggressive-intervention-under-uncertainty",
  "type": "html",
  "title": "Elimination Under Uncertainty",
  "concept": "When a diagnostic system checks the likeliest causes and finds no match, removing the most-suspected source forces clarity—even if the real cause lies elsewhere.",
  "interactiveId": "d5dae3cb-6edb-4887-b813-9748c6382c06",
  "sourcePieceId": "b77e8406-a000-46ef-8989-dde9bb48a8b4",
  "publishedAt": 1777732808529,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Elimination Under Uncertainty</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c92727;\n    --green: #27c942;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .sources {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));\n    gap: 12px;\n    margin: 20px 0;\n  }\n  .source {\n    aspect-ratio: 1;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    background: #fff;\n    cursor: pointer;\n    transition: all 150ms;\n    position: relative;\n  }\n  .source:hover:not(.checked):not(.removed) {\n    border-color: var(--teal);\n    background: #f9f9f9;\n  }\n  .source.checked {\n    background: #f0f0f0;\n    border-color: var(--muted);\n    cursor: default;\n  }\n  .source.removed {\n    background: var(--red);\n    border-color: var(--red);\n    color: #fff;\n    cursor: default;\n  }\n  .source.actual {\n    background: var(--green);\n    border-color: var(--green);\n    color: #fff;\n  }\n  .source-label {\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    margin-bottom: 2px;\n    opacity: 0.7;\n  }\n  .source.removed .source-label,\n  .source.actual .source-label {\n    opacity: 0.9;\n  }\n  .source-prob {\n    font-size: 1.3rem;\n    font-weight: 600;\n  }\n  .timer-bar {\n    margin: 20px 0 12px;\n    height: 32px;\n    background: var(--line);\n    border-radius: 4px;\n    overflow: hidden;\n    position: relative;\n  }\n  .timer-fill {\n    height: 100%;\n    background: var(--teal);\n    transition: width 1000ms linear;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #fff;\n    font-weight: 600;\n    font-size: 0.85rem;\n  }\n  .actions {\n    display: flex;\n    gap: 12px;\n    margin: 16px 0;\n  }\n  button {\n    flex: 1;\n    padding: 12px 18px;\n    font-size: 0.95rem;\n    font-weight: 600;\n    border: 2px solid var(--red);\n    background: var(--red);\n    color: #fff;\n    border-radius: 6px;\n    cursor: pointer;\n    transition: all 150ms;\n  }\n  button:hover:not(:disabled) {\n    background: #a82020;\n    border-color: #a82020;\n  }\n  button:disabled {\n    opacity: 0.4;\n    cursor: not-allowed;\n  }\n  .status {\n    margin: 14px 0 0;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .status.success {\n    border-color: var(--green);\n    background: #f0fdf4;\n  }\n  .status.failure {\n    border-color: var(--red);\n    background: #fef2f2;\n  }\n  .reading {\n    margin: 12px 0;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.875rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .sources {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Check sources or remove the likeliest suspect</h2>\n<p class=\"subhead\">One source causes the signal. Probabilities guide suspicion.</p>\n\n<div class=\"sources\" id=\"sources\"></div>\n\n<div class=\"timer-bar\">\n  <div class=\"timer-fill\" id=\"timer-fill\">10s remaining</div>\n</div>\n\n<div class=\"reading\">\n  Checked: <strong id=\"checked-count\">0</strong> of 5.\n  <span id=\"suspect-label\" style=\"display:none;\">Primary suspect: <strong id=\"suspect-name\"></strong>.</span>\n</div>\n\n<div class=\"actions\">\n  <button id=\"remove-btn\" disabled>Remove Primary Suspect</button>\n</div>\n\n<div id=\"status\" class=\"status\" style=\"display:none;\"></div>\n\n<p class=\"caption\" id=\"caption\">Check sources to narrow the search. If time runs out, the system removes the most-suspected source to force an answer.</p>\n\n<script>\n(function () {\n  var sourcesEl = document.getElementById('sources');\n  var timerFill = document.getElementById('timer-fill');\n  var checkedCount = document.getElementById('checked-count');\n  var suspectLabel = document.getElementById('suspect-label');\n  var suspectName = document.getElementById('suspect-name');\n  var removeBtn = document.getElementById('remove-btn');\n  var statusEl = document.getElementById('status');\n  var caption = document.getElementById('caption');\n\n  var sources = [\n    { id: 'A', prob: 60, label: 'Source A' },\n    { id: 'B', prob: 15, label: 'Source B' },\n    { id: 'C', prob: 10, label: 'Source C' },\n    { id: 'D', prob: 10, label: 'Source D' },\n    { id: 'E', prob: 5, label: 'Source E' }\n  ];\n  var actualIndex = -1;\n  var checkedIndices = [];\n  var timeRemaining = 10;\n  var gameOver = false;\n  var timerId = null;\n  var removed = false;\n\n  function init() {\n    var roll = Math.random() * 100;\n    var cumulative = 0;\n    actualIndex = -1;\n    for (var i = 0; i < sources.length; i++) {\n      cumulative += sources[i].prob;\n      if (roll < cumulative) {\n        actualIndex = i;\n        break;\n      }\n    }\n    if (actualIndex === -1) actualIndex = 0;\n\n    checkedIndices = [];\n    timeRemaining = 10;\n    gameOver = false;\n    removed = false;\n\n    render();\n    updateReadout();\n    statusEl.style.display = 'none';\n    removeBtn.disabled = true;\n    caption.textContent = 'Check sources to narrow the search. If time runs out, the system removes the most-suspected source to force an answer.';\n\n    if (timerId) clearInterval(timerId);\n    timerId = setInterval(tick, 1000);\n  }\n\n  function render() {\n    sourcesEl.innerHTML = '';\n    for (var i = 0; i < sources.length; i++) {\n      var div = document.createElement('div');\n      div.className = 'source';\n      div.dataset.index = i;\n      if (checkedIndices.indexOf(i) !== -1) {\n        div.classList.add('checked');\n      }\n      if (removed && i === 0) {\n        div.classList.add('removed');\n      }\n      if (gameOver && i === actualIndex) {\n        div.classList.add('actual');\n      }\n      var marker = (i === 0) ? ' ★' : '';\n      div.innerHTML = '<div class=\"source-label\">' + sources[i].label + marker + '</div>' +\n                      '<div class=\"source-prob\">' + sources[i].prob + '%</div>';\n      if (!gameOver && checkedIndices.indexOf(i) === -1 && !removed) {\n        div.addEventListener('click', function () {\n          checkSource(+this.dataset.index);\n        });\n      }\n      sourcesEl.appendChild(div);\n    }\n    timerFill.style.width = (timeRemaining / 10 * 100) + '%';\n    timerFill.textContent = timeRemaining + 's remaining';\n  }\n\n  function tick() {\n    if (gameOver) return;\n    timeRemaining -= 1;\n    timerFill.style.width = (timeRemaining / 10 * 100) + '%';\n    timerFill.textContent = timeRemaining + 's remaining';\n    if (timeRemaining <= 0) {\n      endGame('timeout');\n    }\n  }\n\n  function checkSource(index) {\n    if (gameOver || checkedIndices.indexOf(index) !== -1) return;\n    checkedIndices.push(index);\n    if (index === actualIndex) {\n      endGame('found');\n    } else {\n      render();\n      updateReadout();\n      if (checkedIndices.length === 1) {\n        caption.textContent = 'First check ruled out. The cause remains hidden.';\n      } else if (checkedIndices.length === 2) {\n        caption.textContent = 'Two sources checked without a match. Time continues to pass.';\n        removeBtn.disabled = false;\n      } else {\n        caption.textContent = 'Multiple checks completed. The actual cause has not appeared yet.';\n        removeBtn.disabled = false;\n      }\n    }\n  }\n\n  function removeSuspected() {\n    if (gameOver || removed) return;\n    removed = true;\n    clearInterval(timerId);\n    render();\n    if (actualIndex === 0) {\n      endGame('removed-correct');\n    } else {\n      endGame('removed-wrong');\n    }\n  }\n\n  function endGame(outcome) {\n    gameOver = true;\n    clearInterval(timerId);\n    render();\n    var msg = '';\n    var success = false;\n    if (outcome === 'found') {\n      msg = 'The actual cause was identified through checking. Source ' + sources[actualIndex].id + ' confirmed as the source.';\n      success = true;\n    } else if (outcome === 'timeout') {\n      msg = 'Time ran out before the cause was found. The actual source was ' + sources[actualIndex].id + '. The system never identified it through checking.';\n    } else if (outcome === 'removed-correct') {\n      msg = 'Removal targeted the actual cause. The problem resolved because the suspected source was correct.';\n      success = true;\n    } else if (outcome === 'removed-wrong') {\n      msg = 'Removal targeted the wrong source. The actual cause was ' + sources[actualIndex].id + '. Removal forced an answer but did not solve the underlying problem.';\n    }\n    statusEl.textContent = msg;\n    statusEl.className = success ? 'status success' : 'status failure';\n    statusEl.style.display = 'block';\n    removeBtn.disabled = true;\n    caption.textContent = 'Reload to run again. The actual cause changes each time.';\n  }\n\n  function updateReadout() {\n    checkedCount.textContent = checkedIndices.length;\n    if (checkedIndices.length >= 2) {\n      suspectLabel.style.display = 'inline';\n      suspectName.textContent = sources[0].label;\n    } else {\n      suspectLabel.style.display = 'none';\n    }\n  }\n\n  removeBtn.addEventListener('click', removeSuspected);\n\n  init();\n})();\n</script>\n</body>\n</html>"
  }
}
