{
  "slug": "substitution-cost-in-tuned-systems",
  "type": "html",
  "title": "Slack Under Substitution",
  "concept": "When a system has many positions optimized for one component, substituting similar-but-not-identical replacements degrades performance globally because the system's tolerances are finite—it survives the first few swaps by burning slack, but each swap compounds the misfit until the slack runs out.",
  "interactiveId": "2717273a-c8e6-4a49-9ff6-d6798e561b6a",
  "sourcePieceId": "c6cc7d96-9ad5-4622-9666-912fbf9df3f1",
  "publishedAt": 1777605374084,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Slack Under Substitution</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --original: #1a6b62;\n    --substitute: #c9a227;\n    --warn: #d64545;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--substitute);\n    min-width: 140px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .system {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n  }\n  .positions {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(12px, 1fr));\n    gap: 4px;\n    margin-bottom: 16px;\n    max-width: 100%;\n  }\n  .position {\n    width: 12px;\n    height: 12px;\n    border-radius: 2px;\n    background: var(--original);\n    transition: background 150ms ease-out;\n  }\n  .position.substituted {\n    background: var(--substitute);\n  }\n  .output-bar {\n    margin-top: 16px;\n    padding-top: 16px;\n    border-top: 1px solid var(--line);\n  }\n  .bar-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n  }\n  .bar-track {\n    height: 28px;\n    background: var(--line);\n    border-radius: 4px;\n    position: relative;\n    overflow: hidden;\n  }\n  .bar-fill {\n    height: 100%;\n    background: var(--original);\n    transition: width 300ms cubic-bezier(0.4, 0, 0.2, 1), background 300ms ease-out;\n    display: flex;\n    align-items: center;\n    justify-content: flex-end;\n    padding-right: 8px;\n    font-size: 0.85rem;\n    font-weight: 600;\n    color: #fff;\n    font-variant-numeric: tabular-nums;\n  }\n  .bar-fill.degraded {\n    background: var(--warn);\n  }\n  .metrics {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin: 20px 0;\n  }\n  .metric {\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .metric-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 6px;\n  }\n  .metric-value {\n    font-size: 1.4rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  .metric-value.warn {\n    color: var(--warn);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  .legend {\n    display: flex;\n    gap: 18px;\n    margin-bottom: 16px;\n    font-size: 0.85rem;\n    flex-wrap: wrap;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-box {\n    width: 14px;\n    height: 14px;\n    border-radius: 2px;\n  }\n  .legend-box.original {\n    background: var(--original);\n  }\n  .legend-box.substitute {\n    background: var(--substitute);\n  }\n  @media (max-width: 480px) {\n    .metrics {\n      grid-template-columns: 1fr;\n    }\n    .positions {\n      grid-template-columns: repeat(auto-fill, minmax(10px, 1fr));\n      gap: 3px;\n    }\n    .position {\n      width: 10px;\n      height: 10px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Replace optimized positions with substitutes</h2>\n<p class=\"subhead\">The system has 100 positions designed for one component. Swap them out and watch performance degrade.</p>\n\n<div class=\"control\">\n  <label for=\"subs\">Substitutions:</label>\n  <input id=\"subs\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"subs-out\">\n  <output id=\"subs-out\" for=\"subs\">0</output>\n</div>\n\n<div class=\"legend\">\n  <div class=\"legend-item\">\n    <div class=\"legend-box original\"></div>\n    <span>Original</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box substitute\"></div>\n    <span>Substitute</span>\n  </div>\n</div>\n\n<div class=\"system\" aria-hidden=\"true\">\n  <div class=\"positions\" id=\"positions\"></div>\n  <div class=\"output-bar\">\n    <div class=\"bar-label\">System performance</div>\n    <div class=\"bar-track\">\n      <div class=\"bar-fill\" id=\"bar-fill\">100%</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"metrics\">\n  <div class=\"metric\">\n    <div class=\"metric-label\">Slack remaining</div>\n    <div class=\"metric-value\" id=\"slack\">100%</div>\n  </div>\n  <div class=\"metric\">\n    <div class=\"metric-label\">Substituted</div>\n    <div class=\"metric-value\" id=\"subbed\">0</div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">All positions use the original component. The system runs at full capacity with no tolerance burned.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('subs');\n    var subsOut = document.getElementById('subs-out');\n    var barFill = document.getElementById('bar-fill');\n    var slack = document.getElementById('slack');\n    var subbed = document.getElementById('subbed');\n    var caption = document.getElementById('caption');\n    var positionsContainer = document.getElementById('positions');\n    var totalPositions = 100;\n    var positions = [];\n\n    for (var i = 0; i < totalPositions; i++) {\n      var pos = document.createElement('div');\n      pos.className = 'position';\n      positionsContainer.appendChild(pos);\n      positions.push(pos);\n    }\n\n    function performance(subCount) {\n      if (subCount === 0) return 100;\n      if (subCount <= 5) return 100 - subCount * 0.5;\n      if (subCount <= 20) return 97.5 - (subCount - 5) * 1.5;\n      if (subCount <= 50) return 75 - (subCount - 20) * 1.2;\n      return Math.max(10, 39 - (subCount - 50) * 0.58);\n    }\n\n    function slackRemaining(subCount) {\n      if (subCount === 0) return 100;\n      if (subCount <= 5) return 100 - subCount * 2;\n      if (subCount <= 20) return 90 - (subCount - 5) * 3;\n      if (subCount <= 50) return 45 - (subCount - 20) * 1.2;\n      return Math.max(0, 9 - (subCount - 50) * 0.18);\n    }\n\n    function update() {\n      var subCount = +slider.value;\n      subsOut.textContent = subCount;\n      subbed.textContent = subCount;\n\n      for (var i = 0; i < totalPositions; i++) {\n        if (i < subCount) {\n          positions[i].classList.add('substituted');\n        } else {\n          positions[i].classList.remove('substituted');\n        }\n      }\n\n      var perf = performance(subCount);\n      var slackVal = slackRemaining(subCount);\n      \n      barFill.style.width = perf + '%';\n      barFill.textContent = Math.round(perf) + '%';\n      slack.textContent = Math.round(slackVal) + '%';\n\n      if (perf < 75) {\n        barFill.classList.add('degraded');\n      } else {\n        barFill.classList.remove('degraded');\n      }\n\n      if (slackVal < 30) {\n        slack.classList.add('warn');\n      } else {\n        slack.classList.remove('warn');\n      }\n\n      if (subCount === 0) {\n        caption.textContent = 'All positions use the original component. The system runs at full capacity with no tolerance burned.';\n      } else if (subCount <= 5) {\n        caption.textContent = 'A few substitutes barely register. The system absorbs small misfits — performance stays high because tolerance is still deep.';\n      } else if (subCount <= 20) {\n        caption.textContent = 'More substitutes burn through slack faster. Each swap compounds the misfit — the system still works, but margins tighten.';\n      } else if (subCount <= 50) {\n        caption.textContent = 'Half the positions are now substitutes. Compounding misfits degrade performance noticeably. The system survives but operates far below optimal.';\n      } else {\n        caption.textContent = 'Most positions are substituted. Slack is nearly exhausted. The system barely functions — every additional swap pushes closer to collapse.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
