  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Read-Only Versus Transactional Access</title>\n<style>\n* {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nbody {\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  background: #0a0e1a;\n  color: #e4e8f0;\n  padding: 20px;\n  line-height: 1.6;\n}\n\n.container {\n  max-width: 800px;\n  margin: 0 auto;\n}\n\nh1 {\n  font-size: 28px;\n  font-weight: 600;\n  margin-bottom: 12px;\n  color: #fff;\n}\n\n.concept {\n  font-size: 16px;\n  color: #9ca3af;\n  margin-bottom: 32px;\n  line-height: 1.5;\n}\n\n.teaching-label {\n  font-size: 15px;\n  color: #a8b2d1;\n  margin-bottom: 24px;\n  padding: 16px;\n  background: rgba(100, 120, 180, 0.1);\n  border-left: 3px solid #6478b4;\n  border-radius: 4px;\n}\n\n.permission-theater {\n  background: #131720;\n  border-radius: 8px;\n  padding: 24px;\n  margin-bottom: 24px;\n}\n\n.access-toggle {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 32px;\n  background: #1a1f2e;\n  padding: 8px;\n  border-radius: 6px;\n}\n\n.access-btn {\n  flex: 1;\n  padding: 12px;\n  background: #252b3f;\n  border: 2px solid transparent;\n  color: #9ca3af;\n  cursor: pointer;\n  border-radius: 4px;\n  font-size: 15px;\n  font-weight: 500;\n  transition: all 0.2s;\n}\n\n.access-btn:hover {\n  background: #2d3548;\n}\n\n.access-btn.active {\n  background: #1e3a5f;\n  border-color: #3b82f6;\n  color: #fff;\n}\n\n.data-view {\n  background: #0d1117;\n  border-radius: 6px;\n  padding: 20px;\n  margin-bottom: 24px;\n  border: 1px solid #21262d;\n}\n\n.data-header {\n  font-size: 13px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n  color: #6478b4;\n  margin-bottom: 16px;\n  font-weight: 600;\n}\n\n.data-row {\n  display: flex;\n  justify-content: space-between;\n  padding: 10px 0;\n  border-bottom: 1px solid #21262d;\n  font-size: 14px;\n}\n\n.data-row:last-child {\n  border-bottom: none;\n}\n\n.data-label {\n  color: #9ca3af;\n}\n\n.data-value {\n  color: #e4e8f0;\n  font-weight: 500;\n}\n\n.action-zone {\n  background: #1a1f2e;\n  border-radius: 6px;\n  padding: 20px;\n  margin-bottom: 24px;\n}\n\n.action-buttons {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px;\n  margin-top: 16px;\n}\n\n.action-btn {\n  padding: 14px;\n  background: #252b3f;\n  border: 2px solid #3d4554;\n  color: #9ca3af;\n  cursor: not-allowed;\n  border-radius: 4px;\n  font-size: 14px;\n  font-weight: 500;\n  transition: all 0.2s;\n  opacity: 0.5;\n}\n\n.action-btn.enabled {\n  background: #1e3a5f;\n  border-color: #3b82f6;\n  color: #fff;\n  cursor: pointer;\n  opacity: 1;\n}\n\n.action-btn.enabled:hover {\n  background: #2547a8;\n  transform: translateY(-1px);\n}\n\n.action-btn.danger.enabled {\n  background: #5f1e1e;\n  border-color: #dc2626;\n}\n\n.action-btn.danger.enabled:hover {\n  background: #7f1d1d;\n}\n\n.breach-panel {\n  background: #1a0f0f;\n  border: 2px solid #7f1d1d;\n  border-radius: 6px;\n  padding: 20px;\n  margin-top: 16px;\n  display: none;\n}\n\n.breach-panel.visible {\n  display: block;\n  animation: slideIn 0.3s ease-out;\n}\n\n@keyframes slideIn {\n  from {\n    opacity: 0;\n    transform: translateY(-10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.breach-title {\n  color: #dc2626;\n  font-weight: 600;\n  margin-bottom: 12px;\n  font-size: 15px;\n}\n\n.breach-list {\n  list-style: none;\n  padding-left: 0;\n}\n\n.breach-list li {\n  padding: 8px 0;\n  color: #fca5a5;\n  font-size: 14px;\n  border-bottom: 1px solid #3f1515;\n}\n\n.breach-list li:last-child {\n  border-bottom: none;\n}\n\n.breach-list li::before {\n  content: \"→ \";\n  color: #dc2626;\n  font-weight: bold;\n  margin-right: 8px;\n}\n\n.explanation {\n  background: rgba(100, 120, 180, 0.08);\n  border-left: 3px solid #6478b4;\n  padding: 16px;\n  border-radius: 4px;\n  font-size: 15px;\n  color: #d1d5db;\n  line-height: 1.6;\n}\n\n.status-line {\n  text-align: center;\n  padding: 12px;\n  background: #1a1f2e;\n  border-radius: 4px;\n  margin-bottom: 16px;\n  font-size: 14px;\n  font-weight: 500;\n}\n\n.status-line.read-only-mode {\n  color: #60a5fa;\n  border: 1px solid #1e3a5f;\n}\n\n.status-line.transactional-mode {\n  color: #fbbf24;\n  border: 1px solid #78350f;\n}\n\n@media (max-width: 600px) {\n  h1 {\n    font-size: 24px;\n  }\n  \n  .action-buttons {\n    grid-template-columns: 1fr;\n  }\n  \n  .permission-theater {\n    padding: 16px;\n  }\n}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Read-Only Versus Transactional Access</h1>\n  <p class=\"concept\">Software permission systems separate viewing data from acting on it—read-only access lets an application see information but not change it, while transactional access lets the application trigger changes, and the distinction determines which failure modes become possible.</p>\n  \n  <div class=\"teaching-label\">\n    Toggle between permission levels to see what each mode exposes. Try performing actions in read-only mode, then grant transactional access and observe what becomes possible.\n  </div>\n\n  <div class=\"permission-theater\">\n    <div class=\"access-toggle\">\n      <button class=\"access-btn active\" data-mode=\"read-only\">Read-Only Access</button>\n      <button class=\"access-btn\" data-mode=\"transactional\">Transactional Access</button>\n    </div>\n\n    <div class=\"status-line read-only-mode\" id=\"statusLine\">\n      Current mode: Read-Only — Can view data, cannot trigger changes\n    </div>\n\n    <div class=\"data-view\">\n      <div class=\"data-header\">Data the application can see</div>\n      <div class=\"data-row\">\n        <span class=\"data-label\">Balance</span>\n        <span class=\"data-value\">$3,247.18</span>\n      </div>\n      <div class=\"data-row\">\n        <span class=\"data-label\">Last transaction</span>\n        <span class=\"data-value\">Grocery store, $52.34</span>\n      </div>\n      <div class=\"data-row\">\n        <span class=\"data-label\">Recurring charges</span>\n        <span class=\"data-value\">4 active subscriptions</span>\n      </div>\n      <div class=\"data-row\">\n        <span class=\"data-label\">Transaction history</span>\n        <span class=\"data-value\">Last 90 days visible</span>\n      </div>\n    </div>\n\n    <div class=\"action-zone\">\n      <div class=\"data-header\">Actions the application can perform</div>\n      <div class=\"action-buttons\">\n        <button class=\"action-btn\" id=\"transferBtn\">Transfer $500</button>\n        <button class=\"action-btn\" id=\"paymentBtn\">Schedule payment</button>\n        <button class=\"action-btn danger\" id=\"withdrawBtn\">Withdraw funds</button>\n        <button class=\"action-btn\" id=\"subscribeBtn\">Start subscription</button>\n      </div>\n    </div>\n\n    <div class=\"breach-panel\" id=\"breachPanel\">\n      <div class=\"breach-title\">Transactional access enabled these actions:</div>\n      <ul class=\"breach-list\" id=\"breachList\"></ul>\n    </div>\n  </div>\n\n  <div class=\"explanation\">\n    <strong>Why the distinction matters:</strong> Read-only access limits damage from a compromised application to data exposure—someone can see your history but can't move money. Transactional access opens a second failure mode: unauthorized actions. A stolen read-only token leaks information. A stolen transactional token can drain accounts. The convenience of automated payments trades security floor for function. Neither is inherently wrong—the question is whether you understand what you're granting and whether the capability justifies the exposure.\n  </div>\n</div>\n\n<script>\nlet currentMode = 'read-only';\nconst breaches = [];\n\nconst buttons = {\n  readOnly: document.querySelector('[data-mode=\"read-only\"]'),\n  transactional: document.querySelector('[data-mode=\"transactional\"]'),\n  transfer: document.getElementById('transferBtn'),\n  payment: document.getElementById('paymentBtn'),\n  withdraw: document.getElementById('withdrawBtn'),\n  subscribe: document.getElementById('subscribeBtn')\n};\n\nconst statusLine = document.getElementById('statusLine');\nconst breachPanel = document.getElementById('breachPanel');\nconst breachList = document.getElementById('breachList');\n\nfunction setMode(mode) {\n  currentMode = mode;\n  \n  if (mode === 'read-only') {\n    buttons.readOnly.classList.add('active');\n    buttons.transactional.classList.remove('active');\n    statusLine.textContent = 'Current mode: Read-Only — Can view data, cannot trigger changes';\n    statusLine.className = 'status-line read-only-mode';\n    \n    buttons.transfer.classList.remove('enabled');\n    buttons.payment.classList.remove('enabled');\n    buttons.withdraw.classList.remove('enabled');\n    buttons.subscribe.classList.remove('enabled');\n  } else {\n    buttons.readOnly.classList.remove('active');\n    buttons.transactional.classList.add('active');\n    statusLine.textContent = 'Current mode: Transactional — Can view data AND trigger changes';\n    statusLine.className = 'status-line transactional-mode';\n    \n    buttons.transfer.classList.add('enabled');\n    buttons.payment.classList.add('enabled');\n    buttons.withdraw.classList.add('enabled');\n    buttons.subscribe.classList.add('enabled');\n  }\n}\n\nfunction logBreach(action) {\n  if (!breaches.includes(action)) {\n    breaches.push(action);\n    const li = document.createElement('li');\n    li.textContent = action;\n    breachList.appendChild(li);\n    breachPanel.classList.add('visible');\n    \n    if (window.parent) {\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n    }\n  }\n}\n\nbuttons.readOnly.addEventListener('click', () => setMode('read-only'));\nbuttons.transactional.addEventListener('click', () => setMode('transactional'));\n\nbuttons.transfer.addEventListener('click', () => {\n  if (currentMode === 'transactional') {\n    logBreach('Initiated transfer of $500 to external account');\n  }\n});\n\nbuttons.payment.addEventListener('click', () => {\n  if (currentMode === 'transactional') {\n    logBreach('Scheduled recurring payment for $75/month');\n  }\n});\n\nbuttons.withdraw.addEventListener('click', () => {\n  if (currentMode === 'transactional') {\n    logBreach('Withdrew $1,000 to linked external wallet');\n  }\n});\n\nbuttons.subscribe.addEventListener('click', () => {\n  if (currentMode === 'transactional') {\n    logBreach('Enrolled in paid service with automatic billing');\n  }\n});\n</script>\n</body>\n</html>"
  }
}
