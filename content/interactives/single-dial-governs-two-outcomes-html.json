{
  "slug": "single-dial-governs-two-outcomes",
  "type": "html",
  "title": "Measurement Gaming",
  "concept": "When you optimize a system against a measurable proxy for a goal, the system learns to improve the measurement instead of the underlying thing you care about — the metric rises while actual quality stagnates or falls.",
  "interactiveId": "d6138763-2013-4d56-bea0-9deccd1ffdd5",
  "sourcePieceId": "280dc1c7-5a72-4928-aef7-123e19996fb4",
  "publishedAt": 1777582294625,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Measurement Gaming</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --proxy: #1a6b62;\n    --true: #c9a227;\n    --diverge: #b84a3e;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--proxy);\n    min-width: 140px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .chart-container {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 20px;\n    margin: 20px 0;\n  }\n  .chart {\n    position: relative;\n    height: 200px;\n    margin-top: 12px;\n  }\n  .axis {\n    position: absolute;\n    left: 0;\n    bottom: 0;\n    width: 1px;\n    height: 100%;\n    background: var(--line);\n  }\n  .axis-label {\n    position: absolute;\n    font-size: 0.7rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n  .axis-label.y {\n    left: 6px;\n    top: -18px;\n  }\n  .axis-label.x {\n    left: 0;\n    bottom: -20px;\n  }\n  .lines {\n    position: absolute;\n    left: 0;\n    bottom: 0;\n    width: 100%;\n    height: 100%;\n  }\n  svg {\n    width: 100%;\n    height: 100%;\n  }\n  .legend {\n    display: flex;\n    gap: 20px;\n    margin-bottom: 10px;\n    flex-wrap: wrap;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 0.85rem;\n  }\n  .legend-line {\n    width: 24px;\n    height: 3px;\n    border-radius: 2px;\n  }\n  .legend-line.proxy {\n    background: var(--proxy);\n  }\n  .legend-line.true {\n    background: var(--true);\n  }\n  .reading {\n    margin: 20px 0 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 520px) {\n    .chart {\n      height: 180px;\n    }\n    .control {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control label {\n      min-width: 0;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to run optimization cycles</h2>\n<p class=\"subhead\">A system optimizes for a measurable proxy. Watch what happens to the actual quality you care about.</p>\n\n<div class=\"control\">\n  <label for=\"cycles\">Optimization cycles:</label>\n  <input id=\"cycles\" type=\"range\" min=\"0\" max=\"20\" value=\"0\" step=\"1\" aria-describedby=\"cycles-out\">\n  <output id=\"cycles-out\" for=\"cycles\">0</output>\n</div>\n\n<div class=\"chart-container\">\n  <div class=\"legend\">\n    <div class=\"legend-item\">\n      <div class=\"legend-line proxy\"></div>\n      <span>Measured proxy</span>\n    </div>\n    <div class=\"legend-item\">\n      <div class=\"legend-line true\"></div>\n      <span>True quality</span>\n    </div>\n  </div>\n  <div class=\"chart\">\n    <div class=\"axis\"></div>\n    <span class=\"axis-label y\">Value</span>\n    <span class=\"axis-label x\">Cycles</span>\n    <div class=\"lines\">\n      <svg id=\"chart-svg\" viewBox=\"0 0 400 200\" preserveAspectRatio=\"none\">\n        <polyline id=\"proxy-line\" fill=\"none\" stroke=\"#1a6b62\" stroke-width=\"2.5\" vector-effect=\"non-scaling-stroke\"/>\n        <polyline id=\"true-line\" fill=\"none\" stroke=\"#c9a227\" stroke-width=\"2.5\" vector-effect=\"non-scaling-stroke\"/>\n      </svg>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Proxy score: <strong id=\"proxy-score\">50</strong>. \n  True quality: <strong id=\"true-score\">50</strong>. \n  Gap: <strong id=\"gap\">0</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">Before optimization starts, the proxy tracks quality closely.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('cycles');\n    var cyclesOut = document.getElementById('cycles-out');\n    var proxyLine = document.getElementById('proxy-line');\n    var trueLine = document.getElementById('true-line');\n    var proxyScore = document.getElementById('proxy-score');\n    var trueScore = document.getElementById('true-score');\n    var gap = document.getElementById('gap');\n    var caption = document.getElementById('caption');\n\n    function computeProxy(c) {\n      if (c === 0) return 50;\n      return 50 + (c * 3.5);\n    }\n\n    function computeTrue(c) {\n      if (c === 0) return 50;\n      if (c <= 5) return 50 + (c * 2.2);\n      if (c <= 10) return 61 + ((c - 5) * 1.0);\n      if (c <= 15) return 66 + ((c - 10) * 0.3);\n      return 67.5 - ((c - 15) * 0.4);\n    }\n\n    function buildPolyline(fn, maxC) {\n      var points = [];\n      for (var i = 0; i <= maxC; i++) {\n        var x = (i / 20) * 400;\n        var val = fn(i);\n        var y = 200 - ((val / 100) * 200);\n        points.push(x + ',' + y);\n      }\n      return points.join(' ');\n    }\n\n    function update() {\n      var c = +slider.value;\n      cyclesOut.textContent = c;\n\n      var pVal = computeProxy(c);\n      var tVal = computeTrue(c);\n      var gapVal = Math.abs(pVal - tVal);\n\n      proxyScore.textContent = Math.round(pVal);\n      trueScore.textContent = Math.round(tVal);\n      gap.textContent = Math.round(gapVal);\n\n      proxyLine.setAttribute('points', buildPolyline(computeProxy, c));\n      trueLine.setAttribute('points', buildPolyline(computeTrue, c));\n\n      if (c === 0) {\n        caption.textContent = 'Before optimization starts, the proxy tracks quality closely.';\n      } else if (c <= 5) {\n        caption.textContent = 'Early cycles improve both the proxy and true quality. The system is learning.';\n      } else if (c <= 10) {\n        caption.textContent = 'The proxy keeps rising, but true quality gains slow. The system finds cheaper ways to hit the metric.';\n      } else if (c <= 15) {\n        caption.textContent = 'Heavy optimization. The proxy climbs steeply. True quality plateaus — you are gaming the measurement, not improving the thing.';\n      } else {\n        caption.textContent = 'Extreme optimization. The proxy soars. True quality declines — the system has learned to fake the metric while the actual goal degrades.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
