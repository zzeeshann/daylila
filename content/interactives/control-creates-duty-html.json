{
  "slug": "control-creates-duty",
  "type": "html",
  "title": "Duty and Consequence Threshold",
  "concept": "Low-severity failures in duty-holding roles result in civil lawsuits; extreme failures cross into criminal prosecution.",
  "interactiveId": "c6fca09d-c5fd-48d1-86c5-16d7988d53e0",
  "sourcePieceId": "8347b741-20d1-44bf-9d85-f4868d215dd4",
  "publishedAt": 1777560556853,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Duty and Consequence Threshold</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --civil: #c9a227;\n    --criminal: #c9423f;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .role-selector {\n    margin: 20px 0;\n    padding: 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .role-selector label {\n    font-weight: 500;\n    display: block;\n    margin-bottom: 10px;\n  }\n  .role-options {\n    display: flex;\n    gap: 10px;\n    flex-wrap: wrap;\n  }\n  .role-option {\n    flex: 1;\n    min-width: 140px;\n  }\n  .role-option input[type=radio] {\n    position: absolute;\n    opacity: 0;\n  }\n  .role-option label {\n    display: block;\n    padding: 10px;\n    background: var(--bg);\n    border: 2px solid var(--line);\n    border-radius: 4px;\n    cursor: pointer;\n    transition: all 180ms ease-out;\n    text-align: center;\n    font-size: 0.9rem;\n  }\n  .role-option input[type=radio]:checked + label {\n    border-color: var(--fg);\n    background: #fff;\n    font-weight: 500;\n  }\n  .controls {\n    margin: 24px 0;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n  }\n  .control {\n    display: flex;\n    flex-direction: column;\n  }\n  .control-label {\n    display: flex;\n    justify-content: space-between;\n    align-items: baseline;\n    margin-bottom: 10px;\n  }\n  .control-label span:first-child {\n    font-weight: 500;\n    font-size: 0.9rem;\n  }\n  .control-label output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control input[type=range] {\n    width: 100%;\n    accent-color: var(--criminal);\n  }\n  .scale {\n    display: flex;\n    justify-content: space-between;\n    font-size: 0.75rem;\n    color: var(--muted);\n    margin-top: 6px;\n  }\n  .outcome {\n    margin: 24px 0 0;\n    padding: 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    min-height: 80px;\n  }\n  .outcome-line {\n    display: flex;\n    align-items: baseline;\n    gap: 8px;\n    margin-bottom: 8px;\n  }\n  .outcome-line:last-child {\n    margin-bottom: 0;\n  }\n  .outcome-label {\n    font-weight: 600;\n    min-width: 100px;\n  }\n  .outcome-value {\n    color: var(--muted);\n  }\n  .outcome-value.civil {\n    color: var(--civil);\n    font-weight: 500;\n  }\n  .outcome-value.criminal {\n    color: var(--criminal);\n    font-weight: 500;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 600px) {\n    .controls {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n    .role-options {\n      flex-direction: column;\n    }\n    .role-option {\n      min-width: 0;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Select a role, then adjust harm severity and failure pattern</h2>\n<p class=\"subhead\">Some roles create a duty to prevent harm — the combination of severity and pattern determines whether you get sued or go to prison.</p>\n\n<div class=\"role-selector\">\n  <label>Role:</label>\n  <div class=\"role-options\">\n    <div class=\"role-option\">\n      <input type=\"radio\" name=\"role\" id=\"bystander\" value=\"bystander\" checked>\n      <label for=\"bystander\">Bystander</label>\n    </div>\n    <div class=\"role-option\">\n      <input type=\"radio\" name=\"role\" id=\"guardian\" value=\"guardian\">\n      <label for=\"guardian\">Guardian</label>\n    </div>\n    <div class=\"role-option\">\n      <input type=\"radio\" name=\"role\" id=\"supervisor\" value=\"supervisor\">\n      <label for=\"supervisor\">Safety Supervisor</label>\n    </div>\n  </div>\n</div>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <div class=\"control-label\">\n      <span>Harm severity:</span>\n      <output id=\"severity-out\">1</output>\n    </div>\n    <input id=\"severity\" type=\"range\" min=\"1\" max=\"5\" value=\"1\" step=\"1\" aria-describedby=\"severity-out\">\n    <div class=\"scale\">\n      <span>Minor</span>\n      <span>Severe</span>\n    </div>\n  </div>\n  <div class=\"control\">\n    <div class=\"control-label\">\n      <span>Failure pattern:</span>\n      <output id=\"pattern-out\">1</output>\n    </div>\n    <input id=\"pattern\" type=\"range\" min=\"1\" max=\"5\" value=\"1\" step=\"1\" aria-describedby=\"pattern-out\">\n    <div class=\"scale\">\n      <span>Isolated</span>\n      <span>Chronic</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"outcome\" id=\"outcome\">\n  <div class=\"outcome-line\">\n    <span class=\"outcome-label\">Duty exists:</span>\n    <span class=\"outcome-value\" id=\"duty-status\">No</span>\n  </div>\n  <div class=\"outcome-line\">\n    <span class=\"outcome-label\">Consequence:</span>\n    <span class=\"outcome-value\" id=\"consequence\">None</span>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">A bystander has no duty to prevent harm. Inaction carries no legal consequence.</p>\n\n<script>\n  (function () {\n    var roles = document.getElementsByName('role');\n    var severitySlider = document.getElementById('severity');\n    var patternSlider = document.getElementById('pattern');\n    var severityOut = document.getElementById('severity-out');\n    var patternOut = document.getElementById('pattern-out');\n    var dutyStatus = document.getElementById('duty-status');\n    var consequence = document.getElementById('consequence');\n    var caption = document.getElementById('caption');\n\n    var dutyRoles = {\n      bystander: false,\n      guardian: true,\n      supervisor: true\n    };\n\n    function getSelectedRole() {\n      for (var i = 0; i < roles.length; i++) {\n        if (roles[i].checked) return roles[i].value;\n      }\n      return 'bystander';\n    }\n\n    function update() {\n      var role = getSelectedRole();\n      var severity = +severitySlider.value;\n      var pattern = +patternSlider.value;\n      severityOut.textContent = severity;\n      patternOut.textContent = pattern;\n\n      var hasDuty = dutyRoles[role];\n      dutyStatus.textContent = hasDuty ? 'Yes' : 'No';\n      dutyStatus.className = hasDuty ? 'outcome-value' : 'outcome-value';\n\n      if (!hasDuty) {\n        consequence.textContent = 'None';\n        consequence.className = 'outcome-value';\n        caption.textContent = 'A bystander has no duty to prevent harm. Inaction carries no legal consequence.';\n      } else {\n        var combinedScore = severity + pattern;\n        if (combinedScore <= 3) {\n          consequence.textContent = 'Civil lawsuit possible';\n          consequence.className = 'outcome-value civil';\n          caption.textContent = 'Minor harm with an isolated failure means you might get sued, maybe you lose your job.';\n        } else if (combinedScore <= 5) {\n          consequence.textContent = 'Civil lawsuit likely';\n          consequence.className = 'outcome-value civil';\n          caption.textContent = 'Moderate harm or repeated failures make lawsuits likely. Damages get paid, people get fired.';\n        } else if (combinedScore <= 7) {\n          consequence.textContent = 'Criminal charges possible';\n          consequence.className = 'outcome-value criminal';\n          caption.textContent = 'Severe harm plus a pattern of disregard means prosecutors start building a case.';\n        } else {\n          consequence.textContent = 'Criminal charges likely';\n          consequence.className = 'outcome-value criminal';\n          caption.textContent = 'Extreme harm with chronic failure means prison is on the table — inaction becomes a crime.';\n        }\n      }\n    }\n\n    for (var i = 0; i < roles.length; i++) {\n      roles[i].addEventListener('change', function () {\n        update();\n        if (window.parent && window.parent !== window) {\n          window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n        }\n      });\n    }\n\n    severitySlider.addEventListener('input', function () {\n      update();\n      if (window.parent && window.parent !== window) {\n        window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n      }\n    });\n\n    patternSlider.addEventListener('input', function () {\n      update();\n      if (window.parent && window.parent !== window) {\n        window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n      }\n    });\n\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
