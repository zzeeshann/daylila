{
  "slug": "inversion-of-suspicion",
  "type": "html",
  "title": "Scope Before Suspicion",
  "concept": "A system that sets its collection boundary by geography rather than by individual determination gathers data from everyone in a region first, then filters for suspects second — inverting the sequence from 'identify then collect' to 'collect then identify'.",
  "interactiveId": "50701ba0-6944-4865-a113-275f317dbde6",
  "sourcePieceId": "2b084d3c-7401-48a3-b6e2-0f85dc478e1c",
  "publishedAt": 1777324442090,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Scope Before Suspicion</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --collected: #c9a227;\n    --examined: #1a6b62;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--examined);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .models {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 24px;\n    margin: 24px 0;\n  }\n  .model {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n    padding: 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n  }\n  .model-title {\n    font-size: 0.85rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n  }\n  .stage {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n  .stage-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n  .bar-container {\n    width: 100%;\n    height: 32px;\n    background: var(--line);\n    border-radius: 3px;\n    overflow: hidden;\n    position: relative;\n  }\n  .bar {\n    height: 100%;\n    transition: width 220ms ease-out;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.85rem;\n    font-weight: 600;\n    color: #fff;\n  }\n  .bar.collected {\n    background: var(--collected);\n  }\n  .bar.examined {\n    background: var(--examined);\n  }\n  .arrow {\n    text-align: center;\n    color: var(--muted);\n    font-size: 1.2rem;\n    margin: -8px 0;\n  }\n  .sequence {\n    margin-top: 8px;\n    padding: 8px 10px;\n    background: var(--bg);\n    border-radius: 4px;\n    font-size: 0.8rem;\n    font-style: italic;\n    color: var(--muted);\n    min-height: 2.6em;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 600px) {\n    .models {\n      grid-template-columns: 1fr;\n    }\n    .control {\n      flex-wrap: wrap;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to widen the geographic scope</h2>\n<p class=\"subhead\">Two collection strategies respond differently to boundary size.</p>\n\n<div class=\"control\">\n  <label for=\"radius\">Radius:</label>\n  <input id=\"radius\" type=\"range\" min=\"50\" max=\"500\" value=\"100\" step=\"10\" aria-describedby=\"radius-out\">\n  <output id=\"radius-out\" for=\"radius\">100</output>\n</div>\n\n<div class=\"models\">\n  <div class=\"model\">\n    <div class=\"model-title\">Individual-first</div>\n    <div class=\"stage\">\n      <span class=\"stage-label\">Records collected</span>\n      <div class=\"bar-container\">\n        <div class=\"bar collected\" id=\"ind-collected\">\n          <span id=\"ind-collected-count\">5</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"arrow\">↓</div>\n    <div class=\"stage\">\n      <span class=\"stage-label\">Records examined</span>\n      <div class=\"bar-container\">\n        <div class=\"bar examined\" id=\"ind-examined\">\n          <span id=\"ind-examined-count\">5</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"sequence\" id=\"ind-sequence\">Determine individuals. Collect their records.</div>\n  </div>\n\n  <div class=\"model\">\n    <div class=\"model-title\">Geography-first</div>\n    <div class=\"stage\">\n      <span class=\"stage-label\">Records collected</span>\n      <div class=\"bar-container\">\n        <div class=\"bar collected\" id=\"geo-collected\">\n          <span id=\"geo-collected-count\">180</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"arrow\">↓</div>\n    <div class=\"stage\">\n      <span class=\"stage-label\">Records examined</span>\n      <div class=\"bar-container\">\n        <div class=\"bar examined\" id=\"geo-examined\">\n          <span id=\"geo-examined-count\">5</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"sequence\" id=\"geo-sequence\">Collect all records in boundary. Filter to individuals.</div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Geography-first collected <strong id=\"ratio\">36×</strong> more records than individual-first.\n  <br>\n  Examined count: <strong id=\"examined-match\">same</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">Individual-first: collection size tracks determination size. Geography-first: collection size tracks boundary size.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('radius');\n    var radiusOut = document.getElementById('radius-out');\n    \n    var indCollectedBar = document.getElementById('ind-collected');\n    var indExaminedBar = document.getElementById('ind-examined');\n    var indCollectedCount = document.getElementById('ind-collected-count');\n    var indExaminedCount = document.getElementById('ind-examined-count');\n    var indSequence = document.getElementById('ind-sequence');\n    \n    var geoCollectedBar = document.getElementById('geo-collected');\n    var geoExaminedBar = document.getElementById('geo-examined');\n    var geoCollectedCount = document.getElementById('geo-collected-count');\n    var geoExaminedCount = document.getElementById('geo-examined-count');\n    var geoSequence = document.getElementById('geo-sequence');\n    \n    var ratio = document.getElementById('ratio');\n    var examinedMatch = document.getElementById('examined-match');\n    var caption = document.getElementById('caption');\n    \n    var determinedCount = 5;\n    var densityPerUnit = 1.8;\n    var maxCollected = 900;\n\n    function update() {\n      var r = +slider.value;\n      radiusOut.textContent = r;\n      \n      var geoCollected = Math.round(r * densityPerUnit);\n      if (geoCollected > maxCollected) geoCollected = maxCollected;\n      \n      var indPercent = (determinedCount / maxCollected) * 100;\n      var geoCollectedPercent = (geoCollected / maxCollected) * 100;\n      var geoExaminedPercent = (determinedCount / maxCollected) * 100;\n      \n      indCollectedBar.style.width = indPercent + '%';\n      indExaminedBar.style.width = indPercent + '%';\n      indCollectedCount.textContent = determinedCount;\n      indExaminedCount.textContent = determinedCount;\n      \n      geoCollectedBar.style.width = geoCollectedPercent + '%';\n      geoExaminedBar.style.width = geoExaminedPercent + '%';\n      geoCollectedCount.textContent = geoCollected;\n      geoExaminedCount.textContent = determinedCount;\n      \n      var ratioVal = Math.round(geoCollected / determinedCount);\n      ratio.textContent = ratioVal + '×';\n      \n      if (r <= 100) {\n        caption.textContent = 'Individual-first: collection size tracks determination size. Geography-first: collection size tracks boundary size.';\n      } else if (r <= 300) {\n        caption.textContent = 'Widening the boundary expands geography-first collection. Individual-first stays constant — it does not depend on spatial scope.';\n      } else {\n        caption.textContent = 'At wide radius, geography-first collects hundreds of records to examine the same five. The sequence inverts: boundary determines intake, filtering determines output.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
