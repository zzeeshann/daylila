{
  "slug": "dual-optimization-constraint",
  "type": "html",
  "title": "Warmth-Precision Trade-Off",
  "concept": "When a system tries to sound warm and stay accurate, improving one always costs the other—resources go to tone or precision, not both.",
  "interactiveId": "c7debd89-c07e-4b46-9f2c-9d2f1eb2181b",
  "sourcePieceId": "62ae4989-cea9-4abc-8696-f554cd78ad95",
  "publishedAt": 1777687729386,
  "voiceScore": 72,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Warmth-Precision Trade-Off</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --warmth: #c9a227;\n    --precision: #1a6b62;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 80px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--warmth);\n    min-width: 140px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .spectrum {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin: 16px 0 28px;\n    font-size: 0.8rem;\n    color: var(--muted);\n  }\n  .spectrum-bar {\n    flex: 1;\n    height: 6px;\n    background: linear-gradient(to right, var(--precision), var(--warmth));\n    border-radius: 3px;\n    position: relative;\n  }\n  .spectrum-marker {\n    position: absolute;\n    width: 3px;\n    height: 16px;\n    background: var(--fg);\n    top: -5px;\n    border-radius: 2px;\n    transition: left 200ms ease-out;\n  }\n  .outputs {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px;\n    margin: 24px 0;\n  }\n  .output-card {\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .output-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 10px;\n  }\n  .output-value {\n    font-size: 2rem;\n    font-weight: 700;\n    font-variant-numeric: tabular-nums;\n    line-height: 1;\n  }\n  .output-card.warmth .output-value { color: var(--warmth); }\n  .output-card.precision .output-value { color: var(--precision); }\n  .output-bar {\n    height: 8px;\n    background: var(--line);\n    border-radius: 4px;\n    margin-top: 10px;\n    overflow: hidden;\n  }\n  .output-bar-fill {\n    height: 100%;\n    transition: width 200ms ease-out;\n  }\n  .output-card.warmth .output-bar-fill { background: var(--warmth); }\n  .output-card.precision .output-bar-fill { background: var(--precision); }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .outputs {\n      grid-template-columns: 1fr;\n      gap: 12px;\n    }\n    .control label {\n      min-width: 70px;\n      font-size: 0.875rem;\n    }\n    .spectrum {\n      font-size: 0.75rem;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust emphasis toward warmth</h2>\n<p class=\"subhead\">A system balances being kind with being correct. Moving toward one pulls from the other.</p>\n\n<div class=\"control\">\n  <label for=\"emphasis\">Emphasis:</label>\n  <input id=\"emphasis\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"emphasis-out\">\n  <output id=\"emphasis-out\" for=\"emphasis\">50</output>\n</div>\n\n<div class=\"spectrum\">\n  <span>Precision</span>\n  <div class=\"spectrum-bar\">\n    <div class=\"spectrum-marker\" id=\"marker\"></div>\n  </div>\n  <span>Warmth</span>\n</div>\n\n<div class=\"outputs\">\n  <div class=\"output-card precision\">\n    <div class=\"output-label\">Precision Score</div>\n    <div class=\"output-value\" id=\"precision-val\">75</div>\n    <div class=\"output-bar\">\n      <div class=\"output-bar-fill\" id=\"precision-bar\"></div>\n    </div>\n  </div>\n  <div class=\"output-card warmth\">\n    <div class=\"output-label\">Warmth Score</div>\n    <div class=\"output-value\" id=\"warmth-val\">75</div>\n    <div class=\"output-bar\">\n      <div class=\"output-bar-fill\" id=\"warmth-bar\"></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Result: <strong id=\"result\">Balanced split</strong>\n</div>\n\n<p class=\"caption\" id=\"caption\">Both perform okay. Neither excels because each pulls from the same pool.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('emphasis');\n    var emphasisOut = document.getElementById('emphasis-out');\n    var marker = document.getElementById('marker');\n    var precisionVal = document.getElementById('precision-val');\n    var warmthVal = document.getElementById('warmth-val');\n    var precisionBar = document.getElementById('precision-bar');\n    var warmthBar = document.getElementById('warmth-bar');\n    var result = document.getElementById('result');\n    var caption = document.getElementById('caption');\n\n    function computePrecision(emph) {\n      var warmthWeight = emph / 100;\n      var base = 100;\n      var penalty = Math.pow(warmthWeight, 1.4) * 35;\n      return Math.max(0, Math.round(base - penalty));\n    }\n\n    function computeWarmth(emph) {\n      var warmthWeight = emph / 100;\n      var precisionWeight = 1 - warmthWeight;\n      var base = 100;\n      var penalty = Math.pow(precisionWeight, 1.6) * 40;\n      return Math.max(0, Math.round(base - penalty));\n    }\n\n    function update() {\n      var emph = +slider.value;\n      emphasisOut.textContent = emph;\n      marker.style.left = emph + '%';\n\n      var prec = computePrecision(emph);\n      var wrm = computeWarmth(emph);\n\n      precisionVal.textContent = prec;\n      warmthVal.textContent = wrm;\n      precisionBar.style.width = prec + '%';\n      warmthBar.style.width = wrm + '%';\n\n      if (emph <= 10) {\n        result.textContent = 'Pure precision';\n        caption.textContent = 'Warmth is minimal. Precision peaks because all effort goes to getting it right.';\n      } else if (emph <= 35) {\n        result.textContent = 'Precision-heavy';\n        caption.textContent = 'A little warmth costs a few points of precision. The system still focuses on correctness.';\n      } else if (emph >= 90) {\n        result.textContent = 'Pure warmth';\n        caption.textContent = 'Warmth dominates. Precision drops sharply because sounding kind uses what's needed to stay correct.';\n      } else if (emph >= 65) {\n        result.textContent = 'Warmth-heavy';\n        caption.textContent = 'Warmth rises but precision falls faster. Sounding kind requires reframing that competes with getting things right.';\n      } else {\n        result.textContent = 'Balanced split';\n        caption.textContent = 'Both perform okay. Neither excels because each pulls from the same pool.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
