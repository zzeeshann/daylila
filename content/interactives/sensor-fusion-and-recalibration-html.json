{
  "slug": "sensor-fusion-and-recalibration",
  "type": "html",
  "title": "Sensory Fusion and Confidence",
  "concept": "Your brain combines signals from multiple senses to decide how confident it is about which way is up—when one sensor gets noisy, the brain trusts it less and behavior slows to protect against the uncertainty.",
  "interactiveId": "cc8baccd-f519-4b69-949c-9c37c05baa77",
  "sourcePieceId": "b943056e-10e5-4470-86a6-f27f4a10e728",
  "publishedAt": 1778365700643,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Sensory Fusion and Confidence</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --blue: #2563eb;\n    --orange: #ea580c;\n    --green: #16a34a;\n    --red: #dc2626;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 80px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--blue);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3.5ch;\n    text-align: right;\n  }\n  .sensors {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 12px;\n    margin-bottom: 20px;\n  }\n  .sensor {\n    padding: 12px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    text-align: center;\n  }\n  .sensor-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n  }\n  .sensor-bar {\n    height: 80px;\n    background: var(--line);\n    border-radius: 3px;\n    position: relative;\n    overflow: hidden;\n    margin-bottom: 8px;\n  }\n  .sensor-fill {\n    position: absolute;\n    bottom: 0;\n    width: 100%;\n    background: var(--blue);\n    transition: height 180ms ease-out;\n  }\n  .sensor-value {\n    font-weight: 600;\n    font-size: 0.9rem;\n  }\n  .fusion {\n    padding: 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    margin-bottom: 20px;\n  }\n  .fusion-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 10px;\n  }\n  .confidence-bar {\n    height: 40px;\n    background: var(--line);\n    border-radius: 4px;\n    position: relative;\n    overflow: hidden;\n    margin-bottom: 10px;\n  }\n  .confidence-fill {\n    position: absolute;\n    left: 0;\n    top: 0;\n    bottom: 0;\n    background: var(--green);\n    transition: width 180ms ease-out, background 180ms ease-out;\n  }\n  .confidence-value {\n    position: absolute;\n    left: 50%;\n    top: 50%;\n    transform: translate(-50%, -50%);\n    font-weight: 600;\n    font-size: 1.1rem;\n    z-index: 1;\n  }\n  .behavior {\n    padding: 14px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    margin-bottom: 14px;\n  }\n  .behavior strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 540px) {\n    .sensors {\n      grid-template-columns: 1fr;\n    }\n    .control label {\n      min-width: 60px;\n      font-size: 0.9rem;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Add noise to one sensor</h2>\n<p class=\"subhead\">Three sensors report which way is up. When one gets noisy, overall confidence drops.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"sensor1\">Sensor A:</label>\n    <input id=\"sensor1\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"sensor1-out\">\n    <output id=\"sensor1-out\" for=\"sensor1\">0</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"sensor2\">Sensor B:</label>\n    <input id=\"sensor2\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"sensor2-out\">\n    <output id=\"sensor2-out\" for=\"sensor2\">0</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"sensor3\">Sensor C:</label>\n    <input id=\"sensor3\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"sensor3-out\">\n    <output id=\"sensor3-out\" for=\"sensor3\">0</output>\n  </div>\n</div>\n\n<div class=\"sensors\">\n  <div class=\"sensor\">\n    <div class=\"sensor-label\">Sensor A</div>\n    <div class=\"sensor-bar\"><div class=\"sensor-fill\" id=\"bar1\"></div></div>\n    <div class=\"sensor-value\" id=\"val1\">Clean</div>\n  </div>\n  <div class=\"sensor\">\n    <div class=\"sensor-label\">Sensor B</div>\n    <div class=\"sensor-bar\"><div class=\"sensor-fill\" id=\"bar2\"></div></div>\n    <div class=\"sensor-value\" id=\"val2\">Clean</div>\n  </div>\n  <div class=\"sensor\">\n    <div class=\"sensor-label\">Sensor C</div>\n    <div class=\"sensor-bar\"><div class=\"sensor-fill\" id=\"bar3\"></div></div>\n    <div class=\"sensor-value\" id=\"val3\">Clean</div>\n  </div>\n</div>\n\n<div class=\"fusion\">\n  <div class=\"fusion-label\">Combined Confidence</div>\n  <div class=\"confidence-bar\">\n    <div class=\"confidence-fill\" id=\"conf-fill\"></div>\n    <div class=\"confidence-value\" id=\"conf-val\">100%</div>\n  </div>\n</div>\n\n<div class=\"behavior\">\n  Movement speed: <strong id=\"speed\">Normal</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">All sensors agree. The system trusts its orientation sense fully and moves at normal speed.</p>\n\n<script>\n  (function () {\n    var sliders = [\n      { el: document.getElementById('sensor1'), out: document.getElementById('sensor1-out'), bar: document.getElementById('bar1'), val: document.getElementById('val1') },\n      { el: document.getElementById('sensor2'), out: document.getElementById('sensor2-out'), bar: document.getElementById('bar2'), val: document.getElementById('val2') },\n      { el: document.getElementById('sensor3'), out: document.getElementById('sensor3-out'), bar: document.getElementById('bar3'), val: document.getElementById('val3') }\n    ];\n    var confFill = document.getElementById('conf-fill');\n    var confVal = document.getElementById('conf-val');\n    var speed = document.getElementById('speed');\n    var caption = document.getElementById('caption');\n\n    function update() {\n      var noises = sliders.map(function (s) { return +s.el.value; });\n      var maxNoise = Math.max.apply(null, noises);\n      \n      // Update individual sensor displays\n      sliders.forEach(function (s, i) {\n        var n = noises[i];\n        s.out.textContent = n;\n        s.bar.style.height = n + '%';\n        if (n === 0) {\n          s.val.textContent = 'Clean';\n        } else if (n <= 30) {\n          s.val.textContent = 'Slight noise';\n        } else if (n <= 60) {\n          s.val.textContent = 'Noisy';\n        } else {\n          s.val.textContent = 'Very noisy';\n        }\n      });\n\n      // Confidence = 100 minus the worst noise level\n      var confidence = 100 - maxNoise;\n      confVal.textContent = confidence + '%';\n      confFill.style.width = confidence + '%';\n      \n      // Color confidence bar based on level\n      if (confidence >= 80) {\n        confFill.style.background = 'var(--green)';\n      } else if (confidence >= 50) {\n        confFill.style.background = 'var(--orange)';\n      } else {\n        confFill.style.background = 'var(--red)';\n      }\n\n      // Movement speed reflects confidence\n      if (confidence >= 90) {\n        speed.textContent = 'Normal';\n        caption.textContent = 'All sensors agree. The system trusts its orientation sense fully and moves at normal speed.';\n      } else if (confidence >= 70) {\n        speed.textContent = 'Slightly reduced';\n        caption.textContent = 'One sensor is sending noisy signals. Confidence drops a bit, so movement becomes more cautious.';\n      } else if (confidence >= 40) {\n        speed.textContent = 'Reduced';\n        caption.textContent = 'Noisy input from one sensor undermines the combined signal. The system slows down to stay safe.';\n      } else {\n        speed.textContent = 'Very slow';\n        caption.textContent = 'Heavy noise from one sensor collapses overall confidence. Movement slows to a crawl to avoid falling.';\n      }\n    }\n\n    sliders.forEach(function (s) {\n      s.el.addEventListener('input', update);\n    });\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
