{
  "slug": "strict-liability-bright-lines",
  "type": "html",
  "title": "Strict Liability Thresholds",
  "concept": "A rule system can enforce by checking whether a line was crossed or by weighing how much harm occurred—the first method trades precision for speed, the second trades speed for fairness.",
  "interactiveId": "7689cbf8-b060-4a04-8d58-82fdb88b9dbb",
  "sourcePieceId": "ec75ac58-e7b1-4d56-8a00-773de424c954",
  "publishedAt": 1778853973463,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Strict Liability Thresholds</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --blue: #2563eb;\n    --red: #dc2626;\n    --green: #16a34a;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 640px;\n    margin: 0 auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .toggle-group {\n    display: flex;\n    gap: 12px;\n    margin-bottom: 24px;\n    padding: 4px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n    width: fit-content;\n  }\n  .toggle-btn {\n    padding: 8px 16px;\n    border: none;\n    background: transparent;\n    color: var(--muted);\n    font-size: 0.9rem;\n    font-weight: 500;\n    cursor: pointer;\n    border-radius: 6px;\n    transition: all 120ms;\n  }\n  .toggle-btn.active {\n    background: var(--blue);\n    color: #fff;\n  }\n  .control {\n    margin-bottom: 24px;\n  }\n  .control label {\n    display: block;\n    font-weight: 500;\n    margin-bottom: 8px;\n  }\n  .control input[type=range] {\n    width: 100%;\n    accent-color: var(--blue);\n  }\n  .control .value-display {\n    display: flex;\n    justify-content: space-between;\n    font-size: 0.875rem;\n    color: var(--muted);\n    margin-top: 4px;\n  }\n  .control .current-val {\n    font-weight: 600;\n    color: var(--fg);\n  }\n  .visualization {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n  }\n  .threshold-view {\n    position: relative;\n    height: 80px;\n    background: linear-gradient(to right, var(--green) 0%, var(--green) 50%, var(--red) 50%, var(--red) 100%);\n    border-radius: 4px;\n    margin-bottom: 16px;\n  }\n  .threshold-line {\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    left: 50%;\n    width: 2px;\n    background: var(--fg);\n  }\n  .threshold-label {\n    position: absolute;\n    top: -20px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: var(--fg);\n  }\n  .violation-marker {\n    position: absolute;\n    top: 50%;\n    transform: translate(-50%, -50%);\n    width: 16px;\n    height: 16px;\n    background: var(--fg);\n    border: 3px solid #fff;\n    border-radius: 50%;\n    transition: left 180ms ease-out;\n  }\n  .scale-view {\n    position: relative;\n    height: 80px;\n    margin-bottom: 16px;\n  }\n  .scale-bar {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    height: 40px;\n    background: var(--line);\n    border-radius: 4px;\n    overflow: hidden;\n  }\n  .scale-fill {\n    height: 100%;\n    background: var(--blue);\n    transition: width 180ms ease-out;\n  }\n  .scale-marker {\n    position: absolute;\n    bottom: 40px;\n    transform: translateX(-50%);\n    width: 16px;\n    height: 16px;\n    background: var(--fg);\n    border: 3px solid #fff;\n    border-radius: 50%;\n    transition: left 180ms ease-out;\n  }\n  .result {\n    padding: 12px 16px;\n    border-radius: 6px;\n    font-size: 0.9rem;\n    font-weight: 500;\n  }\n  .result.pass {\n    background: #dcfce7;\n    color: #166534;\n  }\n  .result.fail {\n    background: #fee2e2;\n    color: #991b1b;\n  }\n  .explanation {\n    margin-top: 20px;\n    padding-top: 20px;\n    border-top: 1px solid var(--line);\n    font-size: 0.875rem;\n    color: var(--muted);\n  }\n  .explanation strong {\n    color: var(--fg);\n    font-weight: 600;\n  }\n  @media (max-width: 480px) {\n    body {\n      padding: 16px;\n    }\n    .toggle-group {\n      flex-direction: column;\n      width: 100%;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Choose how the system judges violations</h2>\n<p class=\"subhead\">One method checks if you crossed the line. The other weighs how far over you went.</p>\n\n<div class=\"toggle-group\">\n  <button class=\"toggle-btn active\" data-mode=\"threshold\">Line-crossing</button>\n  <button class=\"toggle-btn\" data-mode=\"scale\">Harm-weighing</button>\n</div>\n\n<div class=\"control\">\n  <label for=\"violation\">Violation severity:</label>\n  <input id=\"violation\" type=\"range\" min=\"0\" max=\"100\" value=\"15\" aria-describedby=\"violation-display\">\n  <div class=\"value-display\">\n    <span>None</span>\n    <span class=\"current-val\" id=\"violation-display\">15%</span>\n    <span>Severe</span>\n  </div>\n</div>\n\n<div class=\"visualization\">\n  <div id=\"threshold-view\" class=\"threshold-view\" style=\"display: block;\">\n    <div class=\"threshold-line\"></div>\n    <div class=\"threshold-label\">Line</div>\n    <div class=\"violation-marker\" id=\"threshold-marker\"></div>\n  </div>\n  <div id=\"scale-view\" class=\"scale-view\" style=\"display: none;\">\n    <div class=\"scale-marker\" id=\"scale-marker\"></div>\n    <div class=\"scale-bar\">\n      <div class=\"scale-fill\" id=\"scale-fill\"></div>\n    </div>\n  </div>\n  <div class=\"result\" id=\"result\"></div>\n</div>\n\n<div class=\"explanation\" id=\"explanation\"></div>\n\n<script>\n  (function () {\n    var mode = 'threshold';\n    var slider = document.getElementById('violation');\n    var display = document.getElementById('violation-display');\n    var thresholdView = document.getElementById('threshold-view');\n    var scaleView = document.getElementById('scale-view');\n    var thresholdMarker = document.getElementById('threshold-marker');\n    var scaleMarker = document.getElementById('scale-marker');\n    var scaleFill = document.getElementById('scale-fill');\n    var result = document.getElementById('result');\n    var explanation = document.getElementById('explanation');\n    var buttons = document.querySelectorAll('.toggle-btn');\n\n    var THRESHOLD = 50;\n\n    function setMode(newMode) {\n      mode = newMode;\n      for (var i = 0; i < buttons.length; i++) {\n        buttons[i].classList.toggle('active', buttons[i].dataset.mode === mode);\n      }\n      thresholdView.style.display = mode === 'threshold' ? 'block' : 'none';\n      scaleView.style.display = mode === 'scale' ? 'block' : 'none';\n      update();\n    }\n\n    function update() {\n      var val = +slider.value;\n      display.textContent = val + '%';\n\n      if (mode === 'threshold') {\n        thresholdMarker.style.left = val + '%';\n        if (val >= THRESHOLD) {\n          result.className = 'result fail';\n          result.textContent = 'Penalty applies';\n          explanation.innerHTML = '<strong>Line-crossing</strong> checks one thing: did you cross the line? You did. Penalty applies. The system doesn\\'t care if you went over by 1% or 50%—both get the same outcome. Fast, uniform, mechanical.';\n        } else {\n          result.className = 'result pass';\n          result.textContent = 'No penalty';\n          explanation.innerHTML = '<strong>Line-crossing</strong> checks one thing: did you cross the line? You didn\\'t. No penalty. The severity of what you did doesn\\'t matter—the line is the only thing the system looks at.';\n        }\n      } else {\n        scaleMarker.style.left = val + '%';\n        scaleFill.style.width = val + '%';\n        if (val === 0) {\n          result.className = 'result pass';\n          result.textContent = 'No penalty';\n          explanation.innerHTML = '<strong>Harm-weighing</strong> measures how much damage occurred, then scales the penalty to match. Zero harm means no penalty, regardless of whether a technical rule was broken.';\n        } else if (val < 25) {\n          result.className = 'result pass';\n          result.textContent = 'Warning issued';\n          explanation.innerHTML = '<strong>Harm-weighing</strong> sees minor harm and applies a minor consequence. The penalty fits what happened. This takes longer—someone has to measure and judge—but it feels fair.';\n        } else if (val < 60) {\n          result.className = 'result fail';\n          result.textContent = 'Moderate penalty';\n          explanation.innerHTML = '<strong>Harm-weighing</strong> scales the penalty to the harm. Moderate damage gets a moderate consequence. The system spends time measuring, but the outcome matches the severity.';\n        } else {\n          result.className = 'result fail';\n          result.textContent = 'Severe penalty';\n          explanation.innerHTML = '<strong>Harm-weighing</strong> sees serious harm and applies a serious penalty. The scale reflects the damage. This feels proportional, but it requires judgment calls—who decides how bad \"serious\" is?';\n        }\n      }\n    }\n\n    for (var i = 0; i < buttons.length; i++) {\n      buttons[i].addEventListener('click', function () {\n        setMode(this.dataset.mode);\n      });\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
