---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  bundleFromEntries,
  groupBySlug,
  isLowQuality,
  LOW_QUALITY_NOTE,
  type InteractiveEntry,
} from '../../lib/interactives';
import { wrapWithResizeProbe } from '../../lib/interactive-html';
import '../../styles/quiz.css';
import '../../styles/interactive-frame.css';

/**
 * One static path per slug, regardless of how many artefact types
 * (quiz / html) ship for that slug. A piece's quiz + html SHARE the
 * slug as of Phase 2 sub-task 2.5 (migration 0026 relaxed slug
 * uniqueness to per-(slug, type)). Group entries by slug so each
 * URL renders both artefacts when both exist, OR just whichever
 * one shipped if only one did.
 */
export async function getStaticPaths() {
  const all = await getCollection('interactives');
  const bySlug = groupBySlug(all);
  return Array.from(bySlug.entries()).map(([slug, entries]) => ({
    params: { slug },
    props: { entries },
  }));
}

const { entries } = Astro.props as { entries: InteractiveEntry[] };
const bundle = bundleFromEntries(entries);
if (!bundle) {
  // Empty group — shouldn't happen given the static-paths grouping,
  // but Astro's type narrowing wants this guard.
  throw new Error(`No interactive entries for slug ${Astro.params.slug}`);
}
const { primary, quizEntry, htmlEntry, quizContentJson } = bundle;
---

<BaseLayout title={primary.data.title} description={primary.data.concept} ogType="article">
  <article class="mx-auto">
    <p class="text-xs uppercase tracking-wider text-zee-muted mb-2">
      Interactive
    </p>
    <h1 class="text-3xl font-bold text-zee-primary mb-3">{primary.data.title}</h1>
    {primary.data.concept && (
      <p class="text-lg text-zee-text/80 mb-6 leading-relaxed">{primary.data.concept}</p>
    )}

    {/* HTML interactive renders FIRST when present — manipulation before recall.
        The reader feels the mechanism via the slider/scrubber/etc., then the
        quiz checks pattern recognition. Order chosen for pedagogical layering;
        spec leaves it open. */}
    {htmlEntry && htmlEntry.data.content.type === 'html' && (
      <section class="mb-12">
        <h2 class="text-sm uppercase tracking-wider text-zee-muted mb-3">Try the model</h2>
        {isLowQuality(htmlEntry) && (
          <div class="text-xs text-zee-muted border border-zee-border/50 rounded-md px-3 py-2 mb-3">
            {LOW_QUALITY_NOTE}
          </div>
        )}
        <interactive-frame
          data-interactive-id={htmlEntry.data.interactiveId}
          data-concept={htmlEntry.data.concept}
        >
          <iframe
            class="interactive-frame-iframe"
            sandbox="allow-scripts"
            loading="lazy"
            referrerpolicy="no-referrer"
            scrolling="no"
            title={htmlEntry.data.concept}
            srcdoc={wrapWithResizeProbe(htmlEntry.data.content.html)}
          ></iframe>
        </interactive-frame>
      </section>
    )}

    {/* Quiz renders second — pattern recognition after manipulation. */}
    {quizEntry && quizEntry.data.content.type === 'quiz' && quizContentJson && (
      <section>
        {htmlEntry && (
          <h2 class="text-sm uppercase tracking-wider text-zee-muted mb-3">Then check the pattern</h2>
        )}
        {isLowQuality(quizEntry) && (
          <div class="text-xs text-zee-muted border border-zee-border/50 rounded-md px-3 py-2 mb-3">
            {LOW_QUALITY_NOTE}
          </div>
        )}
        <quiz-card data-interactive-id={quizEntry.data.interactiveId}>
          <script type="application/json" data-quiz-content set:html={quizContentJson} />
          <noscript>
            <ol class="space-y-6 list-decimal list-inside">
              {quizEntry.data.content.questions.map((q) => (
                <li class="leading-relaxed">
                  <p class="font-medium mb-2">{q.question}</p>
                  <ul class="list-disc list-inside pl-4 text-zee-text/80 space-y-1">
                    {q.options.map((opt) => (
                      <li>{opt}</li>
                    ))}
                  </ul>
                  <p class="text-xs text-zee-muted mt-2">
                    Answer: {q.options[q.correctIndex]}. {q.explanation}
                  </p>
                </li>
              ))}
            </ol>
          </noscript>
        </quiz-card>
      </section>
    )}

    <p class="text-xs text-zee-muted mt-10">
      <a href="/library/" class="hover:text-zee-primary transition-colors">← Back to library</a>
    </p>
  </article>

  <script>
    import '../../interactive/quiz-card';
    import '../../interactive/interactive-frame';
  </script>
</BaseLayout>
