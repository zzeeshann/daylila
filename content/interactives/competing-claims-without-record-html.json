{
  "slug": "competing-claims-without-record",
  "type": "html",
  "title": "Competing Claims Without Record",
  "concept": "When two parties in a mutual agreement both claim the other defected first and no neutral record exists to verify the sequence, both justifications become equally defensible—neither can be falsified.",
  "interactiveId": "6a0482b7-aaeb-4a85-a563-686818016c34",
  "sourcePieceId": "6e55caab-d026-4286-944f-03f30d4bdf76",
  "publishedAt": 1777601669445,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Competing Claims Without Record</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --entity-x: #c9a227;\n    --entity-y: #1a6b62;\n    --neutral: #9b9b9b;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .toggle-box {\n    margin: 24px 0;\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .toggle-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 20px;\n  }\n  .toggle-row label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .toggle-switch {\n    position: relative;\n    display: inline-block;\n    width: 52px;\n    height: 28px;\n  }\n  .toggle-switch input {\n    opacity: 0;\n    width: 0;\n    height: 0;\n  }\n  .toggle-slider {\n    position: absolute;\n    cursor: pointer;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background-color: #ccc;\n    transition: 0.3s;\n    border-radius: 28px;\n  }\n  .toggle-slider:before {\n    position: absolute;\n    content: \"\";\n    height: 20px;\n    width: 20px;\n    left: 4px;\n    bottom: 4px;\n    background-color: white;\n    transition: 0.3s;\n    border-radius: 50%;\n  }\n  input:checked + .toggle-slider {\n    background-color: var(--neutral);\n  }\n  input:checked + .toggle-slider:before {\n    transform: translateX(24px);\n  }\n  .toggle-state {\n    font-weight: 600;\n    color: var(--muted);\n  }\n  .sequence {\n    margin: 20px 0;\n  }\n  .action {\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n    margin-bottom: 12px;\n    padding: 10px;\n    border-radius: 4px;\n    font-size: 0.9rem;\n  }\n  .action.entity-x {\n    background: rgba(201, 162, 39, 0.08);\n  }\n  .action.entity-y {\n    background: rgba(26, 107, 98, 0.08);\n  }\n  .action .dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    margin-top: 6px;\n    flex-shrink: 0;\n  }\n  .action.entity-x .dot {\n    background: var(--entity-x);\n  }\n  .action.entity-y .dot {\n    background: var(--entity-y);\n  }\n  .action .content {\n    flex: 1;\n  }\n  .action .timestamp {\n    font-family: monospace;\n    font-size: 0.75rem;\n    color: var(--muted);\n    margin-top: 4px;\n    padding: 2px 6px;\n    background: rgba(0,0,0,0.04);\n    border-radius: 3px;\n    display: inline-block;\n  }\n  .action .timestamp.hidden {\n    opacity: 0.2;\n    text-decoration: line-through;\n  }\n  .narratives {\n    margin: 20px 0;\n  }\n  .narrative {\n    padding: 12px;\n    margin-bottom: 10px;\n    border-left: 3px solid;\n    background: rgba(0,0,0,0.02);\n    font-size: 0.875rem;\n  }\n  .narrative.entity-x {\n    border-color: var(--entity-x);\n  }\n  .narrative.entity-y {\n    border-color: var(--entity-y);\n  }\n  .narrative .speaker {\n    font-weight: 600;\n    margin-bottom: 4px;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .toggle-row {\n      flex-direction: column;\n      align-items: flex-start;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Toggle whether a neutral record exists</h2>\n<p class=\"subhead\">Both entities take the same actions. The record changes what each claim can prove.</p>\n\n<div class=\"toggle-box\">\n  <div class=\"toggle-row\">\n    <label for=\"record\">Neutral record:</label>\n    <label class=\"toggle-switch\">\n      <input type=\"checkbox\" id=\"record\" checked>\n      <span class=\"toggle-slider\"></span>\n    </label>\n    <span class=\"toggle-state\" id=\"state\">Available</span>\n  </div>\n\n  <div class=\"sequence\">\n    <div class=\"action entity-x\">\n      <div class=\"dot\"></div>\n      <div class=\"content\">\n        <div>Entity X stops delivery.</div>\n        <div class=\"timestamp\" id=\"ts1\">14:22</div>\n      </div>\n    </div>\n    <div class=\"action entity-y\">\n      <div class=\"dot\"></div>\n      <div class=\"content\">\n        <div>Entity Y withholds payment.</div>\n        <div class=\"timestamp\" id=\"ts2\">14:47</div>\n      </div>\n    </div>\n    <div class=\"action entity-x\">\n      <div class=\"dot\"></div>\n      <div class=\"content\">\n        <div>Entity X withholds further service.</div>\n        <div class=\"timestamp\" id=\"ts3\">15:03</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"narratives\">\n  <div class=\"narrative entity-x\">\n    <div class=\"speaker\">Entity X claims:</div>\n    <div id=\"claim-x\">\"We stopped delivery after they withheld payment. Our action was a response to their breach.\"</div>\n  </div>\n  <div class=\"narrative entity-y\">\n    <div class=\"speaker\">Entity Y claims:</div>\n    <div id=\"claim-y\">\"We withheld payment after they stopped delivery. Our action was a response to their breach.\"</div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Testable: <strong id=\"testable\">both</strong>.<br>\n  Result: <strong id=\"result\">Entity X defected first</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">With timestamps, the record shows Entity X acted at 14:22, Entity Y at 14:47. Entity X's claim is falsified. Entity Y's claim holds.</p>\n\n<script>\n  (function () {\n    var toggle = document.getElementById('record');\n    var state = document.getElementById('state');\n    var ts1 = document.getElementById('ts1');\n    var ts2 = document.getElementById('ts2');\n    var ts3 = document.getElementById('ts3');\n    var claimX = document.getElementById('claim-x');\n    var claimY = document.getElementById('claim-y');\n    var testable = document.getElementById('testable');\n    var result = document.getElementById('result');\n    var caption = document.getElementById('caption');\n\n    function update() {\n      var hasRecord = toggle.checked;\n      \n      if (hasRecord) {\n        state.textContent = 'Available';\n        ts1.classList.remove('hidden');\n        ts2.classList.remove('hidden');\n        ts3.classList.remove('hidden');\n        claimX.textContent = '\"We stopped delivery after they withheld payment. Our action was a response to their breach.\"';\n        claimY.textContent = '\"We withheld payment after they stopped delivery. Our action was a response to their breach.\"';\n        testable.textContent = 'both';\n        result.textContent = 'Entity X defected first';\n        caption.textContent = 'With timestamps, the record shows Entity X acted at 14:22, Entity Y at 14:47. Entity X\\'s claim is falsified. Entity Y\\'s claim holds.';\n      } else {\n        state.textContent = 'Absent';\n        ts1.classList.add('hidden');\n        ts2.classList.add('hidden');\n        ts3.classList.add('hidden');\n        claimX.textContent = '\"We stopped delivery after they withheld payment. Our action was a response to their breach.\"';\n        claimY.textContent = '\"We withheld payment after they stopped delivery. Our action was a response to their breach.\"';\n        testable.textContent = 'neither';\n        result.textContent = 'both claims are defensible';\n        caption.textContent = 'Without timestamps, both stories explain the same observations. Neither claim can be falsified. Each defection becomes defensible as retaliation.';\n      }\n    }\n\n    toggle.addEventListener('change', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
