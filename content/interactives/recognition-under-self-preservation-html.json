{
  "slug": "recognition-under-self-preservation",
  "type": "html",
  "title": "Signal Filtering Under Ambiguity",
  "concept": "A filter that removes noise also removes signal when the two look similar—aggressive filtering catches more noise but destroys more of what you need to keep.",
  "interactiveId": "474c0898-c753-4fec-964a-3c1f3e9c3d28",
  "sourcePieceId": "1837d250-d1bb-4002-9160-40ac0500d673",
  "publishedAt": 1777774620536,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Signal Filtering Under Ambiguity</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --signal: #1a6b62;\n    --noise: #d32f2f;\n    --ambiguous: #c9a227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--noise);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .views {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px;\n    margin: 24px 0 12px;\n  }\n  .view {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 16px;\n  }\n  .view-title {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 12px;\n  }\n  .stream {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 4px;\n    min-height: 120px;\n  }\n  .packet {\n    width: 16px;\n    height: 16px;\n    border-radius: 2px;\n    transition: opacity 180ms ease-out;\n  }\n  .packet.signal {\n    background: var(--signal);\n  }\n  .packet.noise {\n    background: var(--noise);\n  }\n  .packet.ambiguous {\n    background: var(--ambiguous);\n  }\n  .packet.filtered {\n    opacity: 0.2;\n  }\n  .legend {\n    display: flex;\n    gap: 16px;\n    margin: 16px 0;\n    font-size: 0.85rem;\n    flex-wrap: wrap;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-box {\n    width: 20px;\n    height: 20px;\n    border-radius: 3px;\n    flex-shrink: 0;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .stat-row {\n    display: flex;\n    justify-content: space-between;\n    margin-top: 6px;\n    padding-top: 6px;\n    border-top: 1px solid var(--line);\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .views {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust filter threshold</h2>\n<p class=\"subhead\">Higher thresholds remove more noise. They also remove signal that looks like noise.</p>\n\n<div class=\"control\">\n  <label for=\"threshold\">Threshold:</label>\n  <input id=\"threshold\" type=\"range\" min=\"0\" max=\"100\" value=\"30\" aria-describedby=\"threshold-out\">\n  <output id=\"threshold-out\" for=\"threshold\">30</output>\n</div>\n\n<div class=\"legend\">\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--signal);\"></div>\n    <span>Clean signal</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--ambiguous);\"></div>\n    <span>Signal near noise</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--noise);\"></div>\n    <span>Noise</span>\n  </div>\n</div>\n\n<div class=\"views\">\n  <div class=\"view\">\n    <div class=\"view-title\">Raw stream</div>\n    <div class=\"stream\" id=\"raw-stream\" role=\"img\" aria-label=\"Unfiltered data stream\"></div>\n  </div>\n  <div class=\"view\">\n    <div class=\"view-title\">After filter</div>\n    <div class=\"stream\" id=\"filtered-stream\" role=\"img\" aria-label=\"Filtered data stream\"></div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  <div>Noise removed: <strong id=\"noise-removed\">0</strong> of <strong id=\"total-noise\">40</strong></div>\n  <div class=\"stat-row\">\n    <span>Signal lost: <strong id=\"signal-lost\">0</strong> of <strong id=\"total-signal\">60</strong></span>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Low threshold passes most noise through. Signal stays intact.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('threshold');\n    var thresholdOut = document.getElementById('threshold-out');\n    var rawStream = document.getElementById('raw-stream');\n    var filteredStream = document.getElementById('filtered-stream');\n    var noiseRemovedEl = document.getElementById('noise-removed');\n    var totalNoiseEl = document.getElementById('total-noise');\n    var signalLostEl = document.getElementById('signal-lost');\n    var totalSignalEl = document.getElementById('total-signal');\n    var caption = document.getElementById('caption');\n\n    var packets = [];\n    var totalCleanSignal = 30;\n    var totalAmbiguous = 30;\n    var totalNoise = 40;\n\n    for (var i = 0; i < totalCleanSignal; i++) {\n      packets.push({type: 'signal', ambiguity: Math.random() * 20});\n    }\n    for (var i = 0; i < totalAmbiguous; i++) {\n      packets.push({type: 'ambiguous', ambiguity: 40 + Math.random() * 40});\n    }\n    for (var i = 0; i < totalNoise; i++) {\n      packets.push({type: 'noise', ambiguity: 70 + Math.random() * 30});\n    }\n\n    for (var i = packets.length - 1; i > 0; i--) {\n      var j = Math.floor(Math.random() * (i + 1));\n      var temp = packets[i];\n      packets[i] = packets[j];\n      packets[j] = temp;\n    }\n\n    rawStream.innerHTML = '';\n    filteredStream.innerHTML = '';\n    for (var i = 0; i < packets.length; i++) {\n      var rawDiv = document.createElement('div');\n      rawDiv.className = 'packet ' + packets[i].type;\n      rawDiv.dataset.index = i;\n      rawStream.appendChild(rawDiv);\n\n      var filteredDiv = document.createElement('div');\n      filteredDiv.className = 'packet ' + packets[i].type;\n      filteredDiv.dataset.index = i;\n      filteredStream.appendChild(filteredDiv);\n    }\n\n    var rawPackets = rawStream.querySelectorAll('.packet');\n    var filteredPackets = filteredStream.querySelectorAll('.packet');\n\n    function update() {\n      var thresh = +slider.value;\n      thresholdOut.textContent = thresh;\n\n      var noiseRemoved = 0;\n      var signalLost = 0;\n\n      for (var i = 0; i < packets.length; i++) {\n        var packet = packets[i];\n        var filtered = thresh >= packet.ambiguity;\n\n        if (filtered) {\n          filteredPackets[i].classList.add('filtered');\n          if (packet.type === 'noise') {\n            noiseRemoved++;\n          }\n          if (packet.type === 'signal' || packet.type === 'ambiguous') {\n            signalLost++;\n          }\n        } else {\n          filteredPackets[i].classList.remove('filtered');\n        }\n      }\n\n      noiseRemovedEl.textContent = noiseRemoved;\n      totalNoiseEl.textContent = totalNoise;\n      signalLostEl.textContent = signalLost;\n      totalSignalEl.textContent = totalCleanSignal + totalAmbiguous;\n\n      if (thresh < 30) {\n        caption.textContent = 'Low threshold passes most noise through. Signal stays intact.';\n      } else if (thresh < 50) {\n        caption.textContent = 'Moderate threshold removes some noise. A few ambiguous signals drop out.';\n      } else if (thresh < 75) {\n        caption.textContent = 'High threshold removes most noise. Many ambiguous signals lost as collateral.';\n      } else {\n        caption.textContent = 'Maximum threshold removes nearly all noise and most ambiguous signal. Clean transmission costs half the data.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
