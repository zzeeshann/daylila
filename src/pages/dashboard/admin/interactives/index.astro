---
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getUser } from '../../../../lib/db';
import { deriveSlug } from '../../../../lib/slug';

const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = userId ? await getUser(db, userId) : null;
const ADMIN_EMAIL = (Astro.locals.runtime.env as Record<string, string>).ADMIN_EMAIL;

if (!user?.email || user.email !== ADMIN_EMAIL) {
  return Astro.redirect('/login/?redirect=/dashboard/admin/interactives/');
}

type InteractiveRow = {
  id: string;
  slug: string;
  type: 'quiz' | 'html';
  title: string;
  voice_score: number | null;
  quality_flag: 'low' | null;
  quality_tier: 'polished' | 'solid' | 'rough' | null;
  revision_count: number;
  published_at: number | null;
  created_at: number;
  source_piece_id: string | null;
  source_piece_date: string | null;
  source_piece_headline: string | null;
};

type AuditRow = {
  interactive_id: string;
  round: number;
  dimension: 'voice' | 'structure' | 'essence' | 'factual';
  passed: number;
  score: number | null;
};

type Dimension = AuditRow['dimension'];
const DIMENSION_ORDER: Dimension[] = ['voice', 'structure', 'essence', 'factual'];

interface RowData extends InteractiveRow {
  /** Latest round's pass/fail per dimension. Empty when no audit rows
   *  exist (legacy interactives pre-migration 0023). */
  latestAudit: Record<Dimension, { passed: boolean; score: number | null }> | null;
  /** Number of the latest audit round, or null when no audit rows. */
  latestRound: number | null;
}

/** A piece that is missing at least one of (quiz, html). One row per
 *  piece — the per-type flags tell the operator which interactives
 *  exist. Single deep-link to the per-piece admin page where the
 *  Generate buttons live. */
type GapPiece = {
  id: string;
  date: string;
  headline: string;
  published_at: number | null;
  has_quiz: boolean;
  has_html: boolean;
  slug: string | null;
};

let rows: RowData[] = [];
let pieceWithoutQuizCount = 0;
let pieceWithoutHtmlCount = 0;
let gapPieces: GapPiece[] = [];

// Slug map from the dailyPieces content collection. Authoritative —
// the MDX filename is what Director wrote at publish time, including
// the 60-char truncation. Falling back to a re-derived slug from the
// headline risks mid-word truncation mismatches.
const dailyEntries = await getCollection('dailyPieces');
const slugByPieceId = new Map<string, string>();
for (const entry of dailyEntries) {
  if (entry.data.pieceId) {
    slugByPieceId.set(entry.data.pieceId, deriveSlug(entry.id));
  }
}

try {
  // Pull every interactive with its source piece headline.
  const interactiveRows = await db
    .prepare(`
      SELECT
        i.id, i.slug, i.type, i.title, i.voice_score, i.quality_flag,
        i.quality_tier, i.revision_count, i.published_at, i.created_at,
        i.source_piece_id,
        p.date AS source_piece_date,
        p.headline AS source_piece_headline
      FROM interactives i
      LEFT JOIN daily_pieces p ON p.id = i.source_piece_id
      ORDER BY
        CASE WHEN i.quality_flag = 'low' THEN 0 ELSE 1 END,
        CASE WHEN i.published_at IS NULL THEN 1 ELSE 0 END,
        i.published_at DESC,
        i.created_at DESC
    `)
    .all<InteractiveRow>();

  const interactives = interactiveRows.results ?? [];

  // Per-row latest-round audit fetch. One query covering every
  // interactive's max round, then join to dimension rows. Two queries
  // total — clean and avoids a correlated subquery per row.
  let auditByInteractive = new Map<string, { round: number; dims: Map<Dimension, { passed: boolean; score: number | null }> }>();
  if (interactives.length > 0) {
    const placeholders = interactives.map(() => '?').join(',');
    const ids = interactives.map((i) => i.id);
    const auditRows = await db
      .prepare(`
        SELECT interactive_id, round, dimension, passed, score
        FROM interactive_audit_results
        WHERE interactive_id IN (${placeholders})
      `)
      .bind(...ids)
      .all<AuditRow>();

    // Group by interactive_id, then keep only the highest round.
    const byInt = new Map<string, AuditRow[]>();
    for (const r of auditRows.results ?? []) {
      if (!byInt.has(r.interactive_id)) byInt.set(r.interactive_id, []);
      byInt.get(r.interactive_id)!.push(r);
    }
    for (const [intId, rs] of byInt.entries()) {
      let maxRound = -1;
      for (const r of rs) if (r.round > maxRound) maxRound = r.round;
      const dims = new Map<Dimension, { passed: boolean; score: number | null }>();
      for (const r of rs) {
        if (r.round === maxRound) {
          dims.set(r.dimension as Dimension, { passed: r.passed === 1, score: r.score });
        }
      }
      auditByInteractive.set(intId, { round: maxRound, dims });
    }
  }

  rows = interactives.map((i) => {
    const audit = auditByInteractive.get(i.id);
    let latestAudit: RowData['latestAudit'] = null;
    if (audit) {
      latestAudit = {
        voice: audit.dims.get('voice') ?? { passed: true, score: null },
        structure: audit.dims.get('structure') ?? { passed: true, score: null },
        essence: audit.dims.get('essence') ?? { passed: true, score: null },
        factual: audit.dims.get('factual') ?? { passed: true, score: null },
      };
    }
    return {
      ...i,
      latestAudit,
      latestRound: audit?.round ?? null,
    };
  });

  // Count published pieces missing each interactive type, AND pull
  // the most-recent N missing pieces per type for the deep-link
  // subsection below. Two queries each — counts are cheap, the
  // bounded SELECT is for the visible subsection.
  const piecesMissingQuiz = await db
    .prepare(`
      SELECT COUNT(*) AS n FROM daily_pieces p
      WHERE NOT EXISTS (
        SELECT 1 FROM interactives i
        WHERE i.source_piece_id = p.id AND i.type = 'quiz'
      )
    `)
    .first<{ n: number }>();
  pieceWithoutQuizCount = piecesMissingQuiz?.n ?? 0;

  const piecesMissingHtml = await db
    .prepare(`
      SELECT COUNT(*) AS n FROM daily_pieces p
      WHERE NOT EXISTS (
        SELECT 1 FROM interactives i
        WHERE i.source_piece_id = p.id AND i.type = 'html'
      )
    `)
    .first<{ n: number }>();
  pieceWithoutHtmlCount = piecesMissingHtml?.n ?? 0;

  // One unified query for "pieces missing at least one interactive".
  // Returns BOTH per-type flags so a single row can render
  // `quiz ✓ · html ✗` (or any other combination) inline. Newest first,
  // capped at 30 unique pieces — the cap is on rows the operator will
  // actually scroll, not on the count line above which is exact.
  const gapRows = await db
    .prepare(`
      SELECT
        p.id, p.date, p.headline, p.published_at,
        EXISTS (SELECT 1 FROM interactives i WHERE i.source_piece_id = p.id AND i.type = 'quiz') AS has_quiz_int,
        EXISTS (SELECT 1 FROM interactives i WHERE i.source_piece_id = p.id AND i.type = 'html') AS has_html_int
      FROM daily_pieces p
      WHERE
        NOT EXISTS (SELECT 1 FROM interactives i WHERE i.source_piece_id = p.id AND i.type = 'quiz')
        OR NOT EXISTS (SELECT 1 FROM interactives i WHERE i.source_piece_id = p.id AND i.type = 'html')
      ORDER BY p.published_at DESC, p.created_at DESC
      LIMIT 30
    `)
    .all<{ id: string; date: string; headline: string; published_at: number | null; has_quiz_int: number; has_html_int: number }>();
  gapPieces = (gapRows.results ?? []).map((r) => ({
    id: r.id,
    date: r.date,
    headline: r.headline,
    published_at: r.published_at,
    has_quiz: r.has_quiz_int === 1,
    has_html: r.has_html_int === 1,
    slug: slugByPieceId.get(r.id) ?? null,
  }));
} catch { /* fall through with empty rows */ }

// ─── Cost telemetry (MTD) ─────────────────────────────────────────
//
// Aggregates token totals from `observer_events` rows whose context
// JSON carries the InteractiveGenerator metering shape. `quiz` and
// `html` keys both have tokensIn/tokensOut/cacheCreateTokens/cacheReadTokens
// since Phase 3.4 (commit ref ddb5cdd's successor). Older events
// have only tokensIn/tokensOut — cache fields are coalesced to 0.
//
// Pricing is Sonnet 4.5 published rates as of 2026-04. Cache write =
// 1.25× input, cache read = 0.1× input. If Anthropic changes rates,
// update SONNET_RATES here.
const SONNET_RATES = {
  input_per_million_usd: 3,
  output_per_million_usd: 15,
  cache_write_multiplier: 1.25, // applied to input_per_million
  cache_read_multiplier: 0.1,   // applied to input_per_million
} as const;

interface ArtefactMetric {
  tokensIn?: number;
  tokensOut?: number;
  cacheCreateTokens?: number;
  cacheReadTokens?: number;
}

interface MeteredContext {
  quiz?: ArtefactMetric;
  html?: ArtefactMetric | null;
}

let mtdTokensIn = 0;
let mtdTokensOut = 0;
let mtdCacheCreate = 0;
let mtdCacheRead = 0;
let mtdRunCount = 0;
let mtdCacheBreakdownAvailable = true; // becomes false if any row lacks cache fields

try {
  // Start of current calendar month (UTC). The site cron + agents
  // worker run UTC, so MTD is also UTC.
  const now = new Date();
  const monthStartMs = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 1, 0, 0, 0);

  const meteredRows = await db
    .prepare(`
      SELECT context FROM observer_events
      WHERE title LIKE 'Interactive(s)%'
        AND created_at >= ?
        AND context IS NOT NULL
    `)
    .bind(monthStartMs)
    .all<{ context: string }>();

  for (const r of meteredRows.results ?? []) {
    let ctx: MeteredContext;
    try {
      ctx = JSON.parse(r.context) as MeteredContext;
    } catch { continue; }

    // Only count events that actually metered a Generator run.
    // The interactive_regenerated event uses a different shape and
    // shouldn't double-count (its corresponding metered event from
    // the fresh-generation alarm is what we want here).
    if (!ctx.quiz && !ctx.html) continue;

    mtdRunCount += 1;
    const quizMetric = ctx.quiz ?? {};
    const htmlMetric = ctx.html ?? {};

    mtdTokensIn += (quizMetric.tokensIn ?? 0) + (htmlMetric.tokensIn ?? 0);
    mtdTokensOut += (quizMetric.tokensOut ?? 0) + (htmlMetric.tokensOut ?? 0);
    mtdCacheCreate += (quizMetric.cacheCreateTokens ?? 0) + (htmlMetric.cacheCreateTokens ?? 0);
    mtdCacheRead += (quizMetric.cacheReadTokens ?? 0) + (htmlMetric.cacheReadTokens ?? 0);

    // If both cache fields are missing on either artefact, the event
    // pre-dates the cache-capture work — flag the breakdown as
    // partial so the surface can footnote it.
    const quizMissing =
      ('quiz' in ctx) &&
      quizMetric.cacheCreateTokens === undefined &&
      quizMetric.cacheReadTokens === undefined;
    const htmlMissing =
      ('html' in ctx) && ctx.html != null &&
      htmlMetric.cacheCreateTokens === undefined &&
      htmlMetric.cacheReadTokens === undefined;
    if (quizMissing || htmlMissing) mtdCacheBreakdownAvailable = false;
  }
} catch { /* fall through with zero totals */ }

const inputCost = (mtdTokensIn / 1_000_000) * SONNET_RATES.input_per_million_usd;
const outputCost = (mtdTokensOut / 1_000_000) * SONNET_RATES.output_per_million_usd;
const cacheWriteCost = (mtdCacheCreate / 1_000_000) * SONNET_RATES.input_per_million_usd * SONNET_RATES.cache_write_multiplier;
const cacheReadCost = (mtdCacheRead / 1_000_000) * SONNET_RATES.input_per_million_usd * SONNET_RATES.cache_read_multiplier;
const mtdCostUsd = inputCost + outputCost + cacheWriteCost + cacheReadCost;

function fmtUsd(n: number): string {
  if (n < 0.01 && n > 0) return '<$0.01';
  return `$${n.toFixed(2)}`;
}
function fmtTokens(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(2)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return n.toLocaleString();
}
const mtdMonthLabel = new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });

// ─── Stats ────────────────────────────────────────────────────────
const totalCount = rows.length;
const cleanCount = rows.filter((r) => r.quality_flag === null).length;
const roughCount = rows.filter((r) => r.quality_flag === 'low').length;
const quizCount = rows.filter((r) => r.type === 'quiz').length;
const htmlCount = rows.filter((r) => r.type === 'html').length;

// ─── Helpers ──────────────────────────────────────────────────────
function fmtTs(ms: number | null): string {
  if (!ms) return '—';
  return new Date(ms).toISOString().slice(0, 10);
}

function adminPieceHref(date: string | null, pieceId: string | null): string | null {
  if (!date || !pieceId) return null;
  return `/dashboard/admin/piece/${date}/`;
}

/** Slug-inclusive variant. Used by the gap-piece list where multi-per-day
 *  ambiguity matters — date-only links land on a disambiguation page
 *  for any 2026-04-22-era piece (interval_hours=12), which surprises the
 *  operator. Falls back to the date-only form when slug is null. */
function adminPieceHrefSlug(date: string | null, pieceId: string | null, slug: string | null): string | null {
  if (!date || !pieceId) return null;
  if (slug) return `/dashboard/admin/piece/${date}/${slug}/`;
  return `/dashboard/admin/piece/${date}/`;
}

function statusLabel(r: RowData): { text: string; cls: string } {
  if (r.quality_flag === 'low') return { text: 'Rough', cls: 'bg-amber-50 text-amber-800 border-amber-200' };
  if (r.published_at === null) return { text: 'Pending', cls: 'bg-zee-bg text-zee-muted border-zee-border' };
  return { text: 'Clean', cls: 'bg-emerald-50 text-emerald-800 border-emerald-200' };
}

function tierLabel(tier: RowData['quality_tier']): string {
  if (tier === 'polished') return 'Polished';
  if (tier === 'solid') return 'Solid';
  if (tier === 'rough') return 'Rough';
  return '—';
}

function typeLabel(type: RowData['type']): { text: string; cls: string } {
  if (type === 'quiz') return { text: 'quiz', cls: 'bg-violet-50 text-violet-800 border-violet-200' };
  return { text: 'html', cls: 'bg-sky-50 text-sky-800 border-sky-200' };
}
---

<BaseLayout title="Interactives — Zeemish admin" description="Quizzes and HTML interactives, sortable by quality.">
  <div class="pt-6 pb-10 flex items-start justify-between gap-6 flex-wrap">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
        The control room
      </p>
      <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight tracking-tight">
        Interactives
      </h1>
      <p class="text-lg text-zee-muted">
        Every quiz and HTML interactive shipped from a daily piece. Rough ones bubble to the top.
      </p>
    </div>
    <div class="flex flex-col items-end gap-1 mt-2 text-sm whitespace-nowrap">
      <a href="/dashboard/admin/" class="text-zee-muted hover:text-zee-primary">← Admin</a>
    </div>
  </div>

  <section class="rounded-xl border border-zee-border p-6 mb-8">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
      Catalogue
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-5">
      <div>
        <p class="text-xs text-zee-muted mb-1">Total</p>
        <p class="text-2xl font-bold">{totalCount}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Clean</p>
        <p class="text-2xl font-bold text-emerald-700">{cleanCount}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Rough</p>
        <p class="text-2xl font-bold text-amber-700">{roughCount}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Quiz</p>
        <p class="text-2xl font-bold">{quizCount}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">HTML</p>
        <p class="text-2xl font-bold">{htmlCount}</p>
      </div>
    </div>
    <p class="text-xs text-zee-muted leading-relaxed">
      {pieceWithoutQuizCount} {pieceWithoutQuizCount === 1 ? 'piece has' : 'pieces have'} no quiz · {pieceWithoutHtmlCount} {pieceWithoutHtmlCount === 1 ? 'piece has' : 'pieces have'} no HTML interactive.
      See the gap list below to open any piece's admin page where Generate buttons live; the toggle on
      <a href="/dashboard/admin/settings/" class="text-zee-primary hover:underline">settings</a>
      gates the HTML path.
    </p>
  </section>

  {gapPieces.length > 0 && (
    <section class="rounded-xl border border-zee-border p-6 mb-8">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
        Pieces missing interactives <span class="text-zee-text tabular-nums">({gapPieces.length})</span>
      </h2>
      <p class="text-xs text-zee-muted mb-5 leading-relaxed">
        One row per piece, newest first, capped at 30. Each row shows which interactive types exist; click through to the per-piece admin page where Generate / Regenerate buttons live in the Interactive section.
      </p>
      <ul class="divide-y divide-zee-border/60">
        {gapPieces.map((p) => {
          const href = adminPieceHrefSlug(p.date, p.id, p.slug);
          const QuizPill = p.has_quiz
            ? <span class="text-emerald-700">quiz ✓</span>
            : <span class="text-amber-700">quiz ✗</span>;
          const HtmlPill = p.has_html
            ? <span class="text-emerald-700">html ✓</span>
            : <span class="text-amber-700">html ✗</span>;
          return (
            <li class="py-2.5 flex items-center gap-4">
              <div class="min-w-0 flex-1">
                <p class="text-sm leading-snug truncate">
                  {href ? (
                    <a href={href} class="hover:text-zee-primary transition-colors">{p.headline}</a>
                  ) : p.headline}
                </p>
                <p class="text-[11px] text-zee-muted tabular-nums">{p.date}</p>
              </div>
              <div class="text-xs tabular-nums shrink-0 flex items-center gap-2">
                {QuizPill}
                <span class="text-zee-muted/40">·</span>
                {HtmlPill}
              </div>
              {href && (
                <a href={href} class="text-xs text-zee-primary hover:underline shrink-0" aria-label={`Open admin for ${p.headline}`}>
                  Open →
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <section class="rounded-xl border border-zee-border p-6 mb-8">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
      Cost (month-to-date · {mtdMonthLabel})
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-4">
      <div>
        <p class="text-xs text-zee-muted mb-1">MTD spend</p>
        <p class="text-2xl font-bold">{fmtUsd(mtdCostUsd)}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Generator runs</p>
        <p class="text-2xl font-bold">{mtdRunCount}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Uncached input</p>
        <p class="text-base font-semibold">{fmtTokens(mtdTokensIn)}</p>
        <p class="text-xs text-zee-muted">{fmtUsd(inputCost)}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Cache write · read</p>
        <p class="text-base font-semibold">{fmtTokens(mtdCacheCreate)} · {fmtTokens(mtdCacheRead)}</p>
        <p class="text-xs text-zee-muted">{fmtUsd(cacheWriteCost + cacheReadCost)}</p>
      </div>
      <div>
        <p class="text-xs text-zee-muted mb-1">Output</p>
        <p class="text-base font-semibold">{fmtTokens(mtdTokensOut)}</p>
        <p class="text-xs text-zee-muted">{fmtUsd(outputCost)}</p>
      </div>
    </div>
    <p class="text-xs text-zee-muted leading-relaxed">
      Sonnet 4.5 rates: ${SONNET_RATES.input_per_million_usd}/M input, ${SONNET_RATES.output_per_million_usd}/M output, cache write at {SONNET_RATES.cache_write_multiplier}× input, cache read at {SONNET_RATES.cache_read_multiplier}× input. Covers InteractiveGenerator + InteractiveAuditor only — Drafter, Voice/Structure/Fact, Curator, Categoriser, Learner, Reflector aren't surfaced yet.
      {!mtdCacheBreakdownAvailable && (
        <span class="block mt-1 italic">
          Some events this month pre-date cache capture (Phase 3.4); their cache breakdown shows as 0 and the input/output totals undercount the system-prompt portion. Events written after the 3.4 deploy carry full cache numbers.
        </span>
      )}
    </p>
  </section>

  <nav class="mb-4" aria-label="Filter interactives by type">
    <ul class="flex flex-wrap gap-2">
      <li>
        <button
          type="button"
          data-type-chip="all"
          class="type-chip inline-flex items-center gap-1.5 min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-zee-primary text-white border-zee-primary"
          aria-pressed="true"
        >
          All<span class="opacity-80">{totalCount}</span>
        </button>
      </li>
      <li>
        <button
          type="button"
          data-type-chip="quiz"
          class="type-chip inline-flex items-center gap-1.5 min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-transparent text-zee-text border-zee-border/80 hover:border-zee-primary/50 hover:text-zee-primary"
          aria-pressed="false"
        >
          Quiz<span class="text-zee-muted">{quizCount}</span>
        </button>
      </li>
      <li>
        <button
          type="button"
          data-type-chip="html"
          class="type-chip inline-flex items-center gap-1.5 min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-transparent text-zee-text border-zee-border/80 hover:border-zee-primary/50 hover:text-zee-primary"
          aria-pressed="false"
        >
          HTML<span class="text-zee-muted">{htmlCount}</span>
        </button>
      </li>
    </ul>
  </nav>

  <p
    id="type-empty-state"
    class="text-zee-muted italic text-sm py-6 hidden"
  >
    No interactives match this filter.
  </p>

  {totalCount === 0 && (
    <p class="text-zee-muted italic text-sm py-6">
      No interactives shipped yet. The <a href="/dashboard/admin/" class="text-zee-primary hover:underline">admin home</a>'s All Pieces list is the place to trigger generation per piece.
    </p>
  )}

  {totalCount > 0 && (
    <div id="interactives-list" class="space-y-3">
      {rows.map((r) => {
        const typ = typeLabel(r.type);
        const status = statusLabel(r);
        const pieceHref = adminPieceHref(r.source_piece_date, r.source_piece_id);
        return (
          <article
            data-int-row
            data-type={r.type}
            class="p-4 rounded-xl border border-zee-border hover:border-zee-primary/40 transition-colors"
          >
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-mono border ${typ.cls}`}>
                    {typ.text}
                  </span>
                  <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${status.cls}`}>
                    {status.text}
                  </span>
                  {r.quality_tier && r.quality_tier !== 'rough' && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border bg-zee-bg text-zee-muted border-zee-border">
                      {tierLabel(r.quality_tier)}
                    </span>
                  )}
                </div>
                <h3 class="text-base font-semibold leading-snug mb-1">
                  <a href={`/interactives/${r.slug}/`} class="hover:text-zee-primary">
                    {r.title}
                  </a>
                </h3>
                <p class="text-xs text-zee-muted truncate">
                  <code class="font-mono">{r.slug}</code>
                  {r.source_piece_headline && (
                    <span> · from
                      {pieceHref ? (
                        <a href={pieceHref} class="text-zee-primary hover:underline ml-1">
                          {r.source_piece_headline}
                        </a>
                      ) : (
                        <span class="ml-1">{r.source_piece_headline}</span>
                      )}
                    </span>
                  )}
                </p>
              </div>
              <div class="text-right text-xs text-zee-muted whitespace-nowrap">
                <p>{fmtTs(r.published_at)}</p>
                <p class="mt-1">
                  {r.revision_count} {r.revision_count === 1 ? 'revision' : 'revisions'}
                </p>
              </div>
            </div>

            <div class="mt-3 flex items-center gap-3 flex-wrap text-xs">
              <span class="text-zee-muted">Audit (latest round):</span>
              {r.latestAudit ? (
                DIMENSION_ORDER.map((dim) => {
                  const d = r.latestAudit![dim];
                  const isVoice = dim === 'voice';
                  const passCls = d.passed ? 'text-emerald-700 border-emerald-200 bg-emerald-50' : 'text-amber-800 border-amber-300 bg-amber-50';
                  return (
                    <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded border ${passCls}`}>
                      <span class="font-medium">{dim}</span>
                      {isVoice && d.score != null && <span class="font-mono">{d.score}</span>}
                      <span aria-hidden="true">{d.passed ? '✓' : '✗'}</span>
                    </span>
                  );
                })
              ) : (
                <span class="italic text-zee-muted">no audit rows (pre-migration 0023)</span>
              )}
              {r.latestAudit && r.latestRound !== null && (
                <span class="text-zee-muted ml-auto">round {r.latestRound + 1}</span>
              )}
            </div>

            <div class="mt-3 pt-3 border-t border-zee-border/50 flex items-center justify-between gap-3 flex-wrap text-xs">
              <span class="text-zee-muted">
                {r.voice_score != null ? <>voice score <span class="font-mono">{r.voice_score}/100</span></> : 'no voice score'}
              </span>
              <button
                type="button"
                data-regen-btn
                data-piece-id={r.source_piece_id ?? ''}
                data-type={r.type}
                data-slug={r.slug}
                disabled={!r.source_piece_id}
                class="px-3 py-1.5 rounded-lg border border-zee-border text-zee-text bg-zee-bg hover:border-zee-primary/50 hover:text-zee-primary disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
              >
                Regenerate
              </button>
            </div>
            <p data-regen-status class="mt-2 text-xs hidden" aria-live="polite"></p>
          </article>
        );
      })}
    </div>
  )}
</BaseLayout>

<script>
  (() => {
    const chipActiveClass = ['bg-zee-primary', 'text-white', 'border-zee-primary'];
    const chipIdleClass = ['bg-transparent', 'text-zee-text', 'border-zee-border/80', 'hover:border-zee-primary/50', 'hover:text-zee-primary'];
    const typeChips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-type-chip]'));
    const intRows = Array.from(document.querySelectorAll<HTMLElement>('[data-int-row]'));
    const emptyState = document.getElementById('type-empty-state');

    function applyTypeFilter(active: string) {
      let anyVisible = false;
      for (const row of intRows) {
        const show = active === 'all' || row.dataset.type === active;
        row.style.display = show ? '' : 'none';
        if (show) anyVisible = true;
      }
      if (emptyState) {
        emptyState.classList.toggle('hidden', anyVisible || intRows.length === 0);
      }
      for (const chip of typeChips) {
        const isActive = chip.dataset.typeChip === active;
        chip.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        chip.classList.remove(...chipActiveClass, ...chipIdleClass);
        chip.classList.add(...(isActive ? chipActiveClass : chipIdleClass));
      }
    }
    for (const chip of typeChips) {
      chip.addEventListener('click', () => applyTypeFilter(chip.dataset.typeChip ?? 'all'));
    }

    // Per-row destructive regenerate button. Confirm dialog spells out
    // exactly what gets wiped (file + D1 row + audit rows). On success,
    // disable the button + show a "regenerating…" hint until the user
    // refreshes — the fresh-generation alarm runs in the background and
    // the next page reload will show its result row.
    const regenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-regen-btn]'));
    for (const btn of regenButtons) {
      btn.addEventListener('click', async () => {
        const pieceId = btn.dataset.pieceId ?? '';
        const type = btn.dataset.type ?? '';
        const slug = btn.dataset.slug ?? '';
        if (!pieceId) return;

        const confirmMsg =
          `Regenerate the ${type} for "${slug}"?\n\n` +
          `This will:\n` +
          `  • delete content/interactives/${slug}${type === 'html' ? '-html' : ''}.json from git (one commit)\n` +
          `  • delete the interactives row + every audit_results row\n` +
          (type === 'quiz' ? `  • clear daily_pieces.interactive_id\n` : '') +
          `  • schedule a fresh produce → audit → revise loop\n\n` +
          `The generation runs in the background — refresh in a minute or two to see the result.`;
        if (!window.confirm(confirmMsg)) return;

        const status = btn.parentElement?.parentElement?.querySelector<HTMLElement>('[data-regen-status]');
        const setStatus = (text: string, cls: string) => {
          if (!status) return;
          status.textContent = text;
          status.className = `mt-2 text-xs ${cls}`;
        };

        btn.disabled = true;
        const originalLabel = btn.textContent;
        btn.textContent = 'Regenerating…';
        setStatus('Wiping old artefact + scheduling fresh generation…', 'text-zee-muted');

        try {
          const qs = new URLSearchParams({ piece_id: pieceId, type });
          const res = await fetch(`/api/agents/interactive-regenerate?${qs.toString()}`, {
            method: 'POST',
          });
          const body = await res.json() as { ok?: boolean; error?: string; deletedSlug?: string };
          if (!res.ok || !body.ok) {
            setStatus(body.error ?? `Regenerate failed (${res.status})`, 'text-red-600');
            btn.disabled = false;
            btn.textContent = originalLabel ?? 'Regenerate';
            return;
          }
          setStatus(
            `Wiped slug "${body.deletedSlug ?? slug}". Fresh generation running in the background — reload this page in a minute or two.`,
            'text-emerald-700',
          );
          // Leave button disabled until reload to discourage accidental
          // re-clicks. The alarm is async; clicking again would race a
          // fresh row that doesn't yet exist.
        } catch (err) {
          const msg = err instanceof Error ? err.message : 'Network error';
          setStatus(msg, 'text-red-600');
          btn.disabled = false;
          btn.textContent = originalLabel ?? 'Regenerate';
        }
      });
    }
  })();
</script>
</content>
</invoke>