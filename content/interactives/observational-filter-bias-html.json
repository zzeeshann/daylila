{
  "slug": "observational-filter-bias",
  "type": "html",
  "title": "Model Boundary Blindness",
  "concept": "When a model declares a region impossible, search stops there—but if the model boundary is drawn wrong, real cases sitting outside it never get checked.",
  "interactiveId": "8aedfbad-b0bf-47c2-9874-6dce3bae22c5",
  "sourcePieceId": "088db2c2-9b0b-4f9e-a0d3-6f7492b6a108",
  "publishedAt": 1777969311158,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Model Boundary Blindness</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c73e1d;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .chart-container {\n    position: relative;\n    margin: 24px 0 16px;\n    max-width: 500px;\n  }\n  svg {\n    display: block;\n    width: 100%;\n    height: auto;\n  }\n  .axis-label {\n    font-size: 0.75rem;\n    fill: var(--muted);\n  }\n  .model-region {\n    fill: var(--teal);\n    opacity: 0.15;\n    transition: d 250ms ease-out;\n  }\n  .model-boundary {\n    fill: none;\n    stroke: var(--teal);\n    stroke-width: 2;\n    transition: d 250ms ease-out;\n  }\n  .search-dot {\n    fill: var(--teal);\n    opacity: 0.6;\n  }\n  .case {\n    fill: var(--red);\n    stroke: #fff;\n    stroke-width: 1.5;\n  }\n  .skipped-region {\n    fill: var(--muted);\n    opacity: 0.08;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .stats {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 12px;\n    margin: 16px 0;\n  }\n  .stat {\n    padding: 8px 12px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    font-size: 0.85rem;\n  }\n  .stat-label {\n    color: var(--muted);\n    font-size: 0.75rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 2px;\n  }\n  .stat-value {\n    font-weight: 600;\n    font-size: 1.1rem;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .stats {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to tighten the model's prediction of what's possible</h2>\n<p class=\"subhead\">Your model draws a boundary. You only check cases inside it. The red dot is a real case.</p>\n\n<div class=\"control\">\n  <label for=\"strictness\">Model strictness:</label>\n  <input id=\"strictness\" type=\"range\" min=\"10\" max=\"90\" value=\"45\" step=\"5\" aria-describedby=\"strictness-out\">\n  <output id=\"strictness-out\" for=\"strictness\">45</output>\n</div>\n\n<div class=\"chart-container\">\n  <svg viewBox=\"0 0 400 300\" role=\"img\" aria-label=\"Chart showing model boundary and search space\">\n    <defs>\n      <clipPath id=\"chart-clip\">\n        <rect x=\"40\" y=\"20\" width=\"340\" height=\"260\"></rect>\n      </clipPath>\n    </defs>\n    \n    <!-- Axes -->\n    <line x1=\"40\" y1=\"280\" x2=\"380\" y2=\"280\" stroke=\"var(--line)\" stroke-width=\"1\"></line>\n    <line x1=\"40\" y1=\"20\" x2=\"40\" y2=\"280\" stroke=\"var(--line)\" stroke-width=\"1\"></line>\n    \n    <text x=\"210\" y=\"298\" class=\"axis-label\" text-anchor=\"middle\">Object size →</text>\n    <text x=\"15\" y=\"150\" class=\"axis-label\" text-anchor=\"middle\" transform=\"rotate(-90 15 150)\">Distance from heat source →</text>\n    \n    <!-- Skipped region (everything outside model boundary) -->\n    <rect x=\"40\" y=\"20\" width=\"340\" height=\"260\" class=\"skipped-region\" clip-path=\"url(#chart-clip)\"></rect>\n    \n    <!-- Model allowed region -->\n    <path id=\"model-region\" class=\"model-region\" clip-path=\"url(#chart-clip)\"></path>\n    <path id=\"model-boundary\" class=\"model-boundary\" clip-path=\"url(#chart-clip)\"></path>\n    \n    <!-- Search dots (cases inside boundary that get checked) -->\n    <g id=\"search-dots\" clip-path=\"url(#chart-clip)\"></g>\n    \n    <!-- The real case (red dot) - fixed position outside strict boundaries -->\n    <circle cx=\"320\" cy=\"210\" r=\"5\" class=\"case\"></circle>\n  </svg>\n</div>\n\n<div class=\"stats\">\n  <div class=\"stat\">\n    <div class=\"stat-label\">Cases checked</div>\n    <div class=\"stat-value\" id=\"checked\">24</div>\n  </div>\n  <div class=\"stat\">\n    <div class=\"stat-label\">Case detected</div>\n    <div class=\"stat-value\" id=\"detected\">Yes</div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Your model allows a wide region. The case sits inside it, so you check there and find it.</p>\n\n<script>\n(function() {\n  var slider = document.getElementById('strictness');\n  var strictnessOut = document.getElementById('strictness-out');\n  var modelRegion = document.getElementById('model-region');\n  var modelBoundary = document.getElementById('model-boundary');\n  var searchDots = document.getElementById('search-dots');\n  var checkedEl = document.getElementById('checked');\n  var detectedEl = document.getElementById('detected');\n  var caption = document.getElementById('caption');\n  \n  var CHART_X = 40;\n  var CHART_Y = 20;\n  var CHART_W = 340;\n  var CHART_H = 260;\n  var CASE_X = 320;\n  var CASE_Y = 210;\n  \n  function generateBoundary(strictness) {\n    // Model boundary: objects below a size-distance threshold can't hold atmosphere\n    // Lower strictness = model allows more (boundary extends further)\n    // Higher strictness = model restricts more (boundary shrinks)\n    \n    // Boundary is a curve: small+close OR large+far can hold atmosphere\n    // strictness controls how much of each dimension is required\n    \n    var maxX = CHART_X + CHART_W;\n    var maxY = CHART_Y + CHART_H;\n    var centerX = CHART_X + CHART_W * 0.5;\n    var centerY = CHART_Y + CHART_H * 0.5;\n    \n    // Width and height of allowed ellipse\n    var widthFactor = 1.1 - (strictness / 100);\n    var heightFactor = 1.1 - (strictness / 100);\n    \n    var radiusX = (CHART_W / 2) * widthFactor;\n    var radiusY = (CHART_H / 2) * heightFactor;\n    \n    // Draw ellipse from bottom-left, curve up and right\n    var path = 'M ' + CHART_X + ' ' + maxY;\n    path += ' Q ' + CHART_X + ' ' + (centerY + radiusY * 0.7);\n    path += ' ' + (centerX - radiusX * 0.7) + ' ' + (centerY + radiusY * 0.3);\n    path += ' T ' + (centerX - radiusX * 0.3) + ' ' + centerY;\n    path += ' Q ' + centerX + ' ' + (centerY - radiusY * 0.5);\n    path += ' ' + (centerX + radiusX * 0.5) + ' ' + (centerY - radiusY * 0.3);\n    path += ' T ' + (centerX + radiusX) + ' ' + CHART_Y;\n    path += ' L ' + maxX + ' ' + CHART_Y;\n    path += ' L ' + maxX + ' ' + maxY;\n    path += ' Z';\n    \n    return path;\n  }\n  \n  function isInsideBoundary(x, y, strictness) {\n    var centerX = CHART_X + CHART_W * 0.5;\n    var centerY = CHART_Y + CHART_H * 0.5;\n    var widthFactor = 1.1 - (strictness / 100);\n    var heightFactor = 1.1 - (strictness / 100);\n    var radiusX = (CHART_W / 2) * widthFactor;\n    var radiusY = (CHART_H / 2) * heightFactor;\n    \n    var dx = (x - centerX) / radiusX;\n    var dy = (y - centerY) / radiusY;\n    return (dx * dx + dy * dy) <= 1.15;\n  }\n  \n  function update() {\n    var strictness = +slider.value;\n    strictnessOut.textContent = strictness;\n    \n    var boundaryPath = generateBoundary(strictness);\n    modelRegion.setAttribute('d', boundaryPath);\n    modelBoundary.setAttribute('d', boundaryPath);\n    \n    // Generate search dots\n    searchDots.innerHTML = '';\n    var checked = 0;\n    var gridSize = 15;\n    for (var i = 0; i < gridSize; i++) {\n      for (var j = 0; j < gridSize; j++) {\n        var x = CHART_X + (CHART_W / (gridSize - 1)) * i + (Math.random() - 0.5) * 8;\n        var y = CHART_Y + (CHART_H / (gridSize - 1)) * j + (Math.random() - 0.5) * 8;\n        \n        if (isInsideBoundary(x, y, strictness)) {\n          // Skip if too close to the case dot to avoid visual overlap\n          if (Math.abs(x - CASE_X) > 10 || Math.abs(y - CASE_Y) > 10) {\n            var dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n            dot.setAttribute('cx', x);\n            dot.setAttribute('cy', y);\n            dot.setAttribute('r', '2.5');\n            dot.setAttribute('class', 'search-dot');\n            searchDots.appendChild(dot);\n            checked++;\n          }\n        }\n      }\n    }\n    \n    var caseInside = isInsideBoundary(CASE_X, CASE_Y, strictness);\n    \n    checkedEl.textContent = checked;\n    detectedEl.textContent = caseInside ? 'Yes' : 'No';\n    \n    if (caseInside) {\n      if (strictness <= 30) {\n        caption.textContent = 'Your model allows a wide region. The case sits inside it, so you check there and find it.';\n      } else if (strictness <= 50) {\n        caption.textContent = 'Your model is tightening but still includes where the case is. You find it.';\n      } else {\n        caption.textContent = 'Your model is quite strict but the boundary still reaches the case. You find it.';\n      }\n    } else {\n      if (strictness <= 60) {\n        caption.textContent = 'Your model just excluded the case. It sits outside the boundary now—you never check there.';\n      } else if (strictness <= 75) {\n        caption.textContent = 'Your model declares that region impossible. The case is real, but you don\\'t look where your model says nothing can be.';\n      } else {\n        caption.textContent = 'Your model is very restrictive. The case sits far outside what you think is possible. It stays invisible.';\n      }\n    }\n  }\n  \n  slider.addEventListener('input', update);\n  update();\n})();\n</script>\n</body>\n</html>"
  }
}
