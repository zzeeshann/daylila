{
  "slug": "proximity-as-inference",
  "type": "html",
  "title": "Proximity as Predictor",
  "concept": "When a system records everyone present in a bounded space-time region, proximity to an event becomes a candidate signal for involvement — filtering by location generates a suspect pool before any individual action is observed.",
  "interactiveId": "4f4f8fa9-6c9b-4fcc-881e-19f0d1dc4e84",
  "sourcePieceId": "cfd3f570-cab3-4283-ae6d-9d23cbd40cee",
  "publishedAt": 1777302333458,
  "voiceScore": 94,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Proximity as Predictor</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c92727;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .scene {\n    position: relative;\n    width: 100%;\n    height: 320px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    margin: 24px 0 12px;\n    overflow: hidden;\n  }\n  .boundary {\n    position: absolute;\n    border: 2px dashed var(--teal);\n    border-radius: 50%;\n    pointer-events: none;\n    transition: all 220ms ease-out;\n  }\n  .entity {\n    position: absolute;\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n    background: var(--muted);\n    transition: background 180ms ease-out, transform 180ms ease-out;\n  }\n  .entity.inside {\n    background: var(--gold);\n    transform: scale(1.3);\n  }\n  .entity.event {\n    background: var(--red);\n    transform: scale(1.6);\n    z-index: 10;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .scene {\n      height: 280px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to expand the boundary</h2>\n<p class=\"subhead\">One entity triggers an event. Entities within the boundary become candidates.</p>\n\n<div class=\"control\">\n  <label for=\"radius\">Radius:</label>\n  <input id=\"radius\" type=\"range\" min=\"30\" max=\"150\" value=\"60\" aria-describedby=\"radius-out\">\n  <output id=\"radius-out\" for=\"radius\">60</output>\n</div>\n\n<div class=\"scene\" id=\"scene\" aria-hidden=\"true\">\n  <div class=\"boundary\" id=\"boundary\"></div>\n</div>\n\n<div class=\"reading\">\n  Entities in boundary: <strong id=\"count\">0</strong>.\n  Precision: <strong id=\"precision\">0%</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">No entities captured yet.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('radius');\n    var radiusOut = document.getElementById('radius-out');\n    var scene = document.getElementById('scene');\n    var boundary = document.getElementById('boundary');\n    var countEl = document.getElementById('count');\n    var precisionEl = document.getElementById('precision');\n    var caption = document.getElementById('caption');\n\n    var entities = [];\n    var eventIndex = -1;\n    var centerX = 0;\n    var centerY = 0;\n\n    function initEntities() {\n      var rect = scene.getBoundingClientRect();\n      centerX = rect.width / 2;\n      centerY = rect.height / 2;\n\n      var positions = [\n        {x: 0.5, y: 0.5, isEvent: true},\n        {x: 0.3, y: 0.4}, {x: 0.6, y: 0.35}, {x: 0.45, y: 0.6},\n        {x: 0.7, y: 0.5}, {x: 0.25, y: 0.55}, {x: 0.55, y: 0.7},\n        {x: 0.8, y: 0.3}, {x: 0.2, y: 0.7}, {x: 0.65, y: 0.25},\n        {x: 0.35, y: 0.75}, {x: 0.75, y: 0.65}, {x: 0.4, y: 0.25},\n        {x: 0.15, y: 0.35}, {x: 0.85, y: 0.55}, {x: 0.5, y: 0.85},\n        {x: 0.3, y: 0.15}, {x: 0.9, y: 0.4}, {x: 0.1, y: 0.6},\n        {x: 0.6, y: 0.15}, {x: 0.45, y: 0.9}\n      ];\n\n      entities = positions.map(function (p, i) {\n        var el = document.createElement('div');\n        el.className = 'entity';\n        var px = p.x * rect.width;\n        var py = p.y * rect.height;\n        el.style.left = (px - 5) + 'px';\n        el.style.top = (py - 5) + 'px';\n        if (p.isEvent) {\n          el.classList.add('event');\n          eventIndex = i;\n        }\n        scene.appendChild(el);\n        return {el: el, x: px, y: py, isEvent: !!p.isEvent};\n      });\n\n      boundary.style.left = (centerX - 60) + 'px';\n      boundary.style.top = (centerY - 60) + 'px';\n      boundary.style.width = '120px';\n      boundary.style.height = '120px';\n    }\n\n    function update() {\n      var r = +slider.value;\n      radiusOut.textContent = r;\n\n      boundary.style.left = (centerX - r) + 'px';\n      boundary.style.top = (centerY - r) + 'px';\n      boundary.style.width = (r * 2) + 'px';\n      boundary.style.height = (r * 2) + 'px';\n\n      var inside = 0;\n      var eventCaptured = false;\n\n      for (var i = 0; i < entities.length; i++) {\n        var e = entities[i];\n        var dx = e.x - centerX;\n        var dy = e.y - centerY;\n        var dist = Math.sqrt(dx * dx + dy * dy);\n        if (dist <= r) {\n          if (!e.el.classList.contains('event')) {\n            e.el.classList.add('inside');\n          }\n          inside++;\n          if (e.isEvent) eventCaptured = true;\n        } else {\n          e.el.classList.remove('inside');\n        }\n      }\n\n      countEl.textContent = inside;\n\n      var precision = eventCaptured ? Math.round((1 / inside) * 100) : 0;\n      precisionEl.textContent = precision + '%';\n\n      if (inside === 0) {\n        caption.textContent = 'No entities captured yet.';\n      } else if (!eventCaptured) {\n        caption.textContent = 'Boundary contains ' + inside + ' entities, but not the event entity. All are false positives.';\n      } else if (inside === 1) {\n        caption.textContent = 'Boundary captures only the event entity. Precision is perfect.';\n      } else if (inside <= 3) {\n        caption.textContent = 'Narrow boundary yields high precision. Few candidates, event entity included.';\n      } else if (inside <= 8) {\n        caption.textContent = 'Moderate boundary captures the event entity alongside several others. Precision declines as pool grows.';\n      } else {\n        caption.textContent = 'Wide boundary captures many entities. Event entity is present, but precision is low — most candidates uninvolved.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n\n    if (scene.getBoundingClientRect().width > 0) {\n      initEntities();\n      update();\n    } else {\n      setTimeout(function () {\n        initEntities();\n        update();\n      }, 50);\n    }\n  })();\n</script>\n</body>\n</html>"
  }
}
