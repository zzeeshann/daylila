{
  "slug": "trust-without-verification",
  "type": "html",
  "title": "Verification Depth and Cost",
  "concept": "Deeper verification catches more fraud but costs more per check—so a system must choose between shallow checks that miss fraud or thorough checks it can't afford to run on everything.",
  "interactiveId": "0d06720e-4533-4c25-97d4-9ee5964a1c75",
  "sourcePieceId": "955100a7-9500-4f26-87a8-cfd02c20789e",
  "publishedAt": 1778335944264,
  "voiceScore": 68,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Verification Depth and Cost</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c94227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    margin-bottom: 20px;\n  }\n  .control label {\n    display: block;\n    font-weight: 500;\n    margin-bottom: 8px;\n  }\n  .slider-group {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .slider-group input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .slider-group output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 8ch;\n    text-align: right;\n    font-size: 0.9rem;\n  }\n  .depth-labels {\n    display: flex;\n    justify-content: space-between;\n    font-size: 0.75rem;\n    color: var(--muted);\n    margin-top: 4px;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n  .items {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    margin: 20px 0;\n  }\n  .item {\n    padding: 12px 14px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    transition: all 180ms ease;\n    min-height: 56px;\n  }\n  .item-label {\n    font-size: 0.9rem;\n    flex: 1;\n    margin-right: 12px;\n  }\n  .item-status {\n    font-size: 0.8rem;\n    font-weight: 600;\n    padding: 4px 10px;\n    border-radius: 4px;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    transition: all 180ms ease;\n  }\n  .item-status.pass {\n    background: rgba(26, 107, 98, 0.15);\n    color: var(--teal);\n  }\n  .item-status.fail {\n    background: rgba(201, 66, 39, 0.15);\n    color: var(--red);\n  }\n  .item.flagged {\n    border-color: var(--red);\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 14px;\n  }\n  .reading-item {\n    display: flex;\n    align-items: baseline;\n    gap: 6px;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .reading {\n      flex-direction: column;\n      gap: 8px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to set verification depth</h2>\n<p class=\"subhead\">Six items pass through review. Deeper checks catch more fraud but cost more per item.</p>\n\n<div class=\"control\">\n  <label for=\"depth\">Verification depth:</label>\n  <div class=\"slider-group\">\n    <input id=\"depth\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" step=\"1\" aria-describedby=\"depth-out\">\n    <output id=\"depth-out\" for=\"depth\">Format</output>\n  </div>\n  <div class=\"depth-labels\">\n    <span>Format</span>\n    <span>Metadata</span>\n    <span>Content</span>\n  </div>\n</div>\n\n<div class=\"items\" id=\"items\"></div>\n\n<div class=\"reading\">\n  <div class=\"reading-item\">\n    <span>Passed:</span>\n    <strong id=\"passed\">6</strong>\n  </div>\n  <div class=\"reading-item\">\n    <span>Flagged:</span>\n    <strong id=\"flagged\">0</strong>\n  </div>\n  <div class=\"reading-item\">\n    <span>Cost per item:</span>\n    <strong id=\"cost\">$1</strong>\n  </div>\n  <div class=\"reading-item\">\n    <span>Total spent:</span>\n    <strong id=\"total\">$6</strong>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">At format-only depth, every item passes. Cost is low but fraud slips through.</p>\n\n<script>\n  (function () {\n    var items = [\n      { label: \"Reference with author, year, journal — structure looks correct\", threshold: 0 },\n      { label: \"Email address with plausible domain and correct @ symbol\", threshold: 0 },\n      { label: \"DOI with correct prefix format and check digit\", threshold: 33 },\n      { label: \"Institutional affiliation with proper department naming\", threshold: 33 },\n      { label: \"Journal name matching a real publication database entry\", threshold: 66 },\n      { label: \"Author name cross-referenced against institutional records\", threshold: 66 }\n    ];\n\n    var depthSlider = document.getElementById('depth');\n    var depthOut = document.getElementById('depth-out');\n    var itemsEl = document.getElementById('items');\n    var passedEl = document.getElementById('passed');\n    var flaggedEl = document.getElementById('flagged');\n    var costEl = document.getElementById('cost');\n    var totalEl = document.getElementById('total');\n    var captionEl = document.getElementById('caption');\n\n    function getDepthLabel(val) {\n      if (val < 33) return 'Format';\n      if (val < 66) return 'Metadata';\n      return 'Content';\n    }\n\n    function getCost(val) {\n      if (val < 33) return 1;\n      if (val < 66) return 4;\n      return 12;\n    }\n\n    function render() {\n      var depth = +depthSlider.value;\n      depthOut.textContent = getDepthLabel(depth);\n\n      itemsEl.innerHTML = '';\n      var passed = 0;\n      var flagged = 0;\n\n      items.forEach(function (item) {\n        var passes = depth < item.threshold;\n        if (passes) {\n          passed++;\n        } else {\n          flagged++;\n        }\n\n        var div = document.createElement('div');\n        div.className = 'item' + (passes ? '' : ' flagged');\n        div.innerHTML =\n          '<span class=\"item-label\">' + item.label + '</span>' +\n          '<span class=\"item-status ' + (passes ? 'pass' : 'fail') + '\">' + (passes ? 'Pass' : 'Fail') + '</span>';\n        itemsEl.appendChild(div);\n      });\n\n      var cost = getCost(depth);\n      var total = cost * items.length;\n\n      passedEl.textContent = passed;\n      flaggedEl.textContent = flagged;\n      costEl.textContent = '$' + cost;\n      totalEl.textContent = '$' + total;\n\n      if (depth < 33) {\n        captionEl.textContent = 'At format-only depth, every item passes. Cost is low but fraud slips through.';\n      } else if (depth < 66) {\n        captionEl.textContent = 'Metadata checks catch items with broken links and fake domains. Cost rises to $4 per item.';\n      } else {\n        captionEl.textContent = 'Content verification flags all fraudulent items. Cost hits $12 per item—checking everything at this depth is expensive.';\n      }\n    }\n\n    depthSlider.addEventListener('input', render);\n    render();\n  })();\n</script>\n</body>\n</html>"
  }
}
