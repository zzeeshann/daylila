  "title": "Threshold Crossing Through Accumulation",
  "concept": "Individual data points that fall below a protective threshold can, when accumulated over time, cross into a different category that triggers protection — the aggregate transforms what the parts were not.",
  "interactiveId": "46571a52-6f67-4bea-9382-447d21b2ed3c",
  "sourcePieceId": "923402b1-c39f-4118-b93b-01b9c88fb7a9",
  "publishedAt": 1777344751464,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Threshold Crossing Through Accumulation</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --below: #c9a227;\n    --above: #c72735;\n    --threshold: #1a6b62;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--threshold);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .diagram {\n    margin: 24px 0;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 30px 20px;\n    position: relative;\n  }\n  .scale {\n    position: relative;\n    height: 280px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n  }\n  .threshold-line {\n    position: absolute;\n    left: 0;\n    right: 0;\n    top: 50%;\n    height: 2px;\n    background: var(--threshold);\n    z-index: 1;\n  }\n  .threshold-line::after {\n    content: 'PROTECTION THRESHOLD';\n    position: absolute;\n    right: 8px;\n    top: -22px;\n    font-size: 0.7rem;\n    font-weight: 600;\n    color: var(--threshold);\n    letter-spacing: 0.05em;\n  }\n  .zone {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    padding: 0 20px;\n    position: relative;\n  }\n  .zone-label {\n    position: absolute;\n    left: 8px;\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n  }\n  .zone.top {\n    border-bottom: 2px solid var(--threshold);\n  }\n  .zone.top .zone-label {\n    top: 8px;\n  }\n  .zone.bottom .zone-label {\n    bottom: 8px;\n  }\n  .items-container {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    justify-content: center;\n    align-items: center;\n    padding: 10px 0;\n  }\n  .item {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: var(--below);\n    transition: all 300ms ease-out;\n  }\n  .aggregate {\n    padding: 16px 20px;\n    background: var(--above);\n    color: white;\n    border-radius: 8px;\n    font-weight: 600;\n    font-size: 1rem;\n    text-align: center;\n    transition: all 300ms ease-out;\n    opacity: 0;\n    transform: scale(0.8);\n  }\n  .aggregate.visible {\n    opacity: 1;\n    transform: scale(1);\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control output {\n      text-align: left;\n    }\n    .threshold-line::after {\n      font-size: 0.65rem;\n      right: 4px;\n      top: -20px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Add individual records</h2>\n<p class=\"subhead\">Each record falls below the threshold. Watch what happens when they combine.</p>\n\n<div class=\"control\">\n  <label for=\"records\">Records collected:</label>\n  <input id=\"records\" type=\"range\" min=\"1\" max=\"120\" value=\"1\" aria-describedby=\"rec-out\">\n  <output id=\"rec-out\" for=\"records\">1</output>\n</div>\n\n<div class=\"diagram\">\n  <div class=\"scale\">\n    <div class=\"zone top\">\n      <span class=\"zone-label\">Protected category</span>\n      <div class=\"items-container\" id=\"top-zone\"></div>\n    </div>\n    <div class=\"zone bottom\">\n      <span class=\"zone-label\">Unprotected category</span>\n      <div class=\"items-container\" id=\"bottom-zone\"></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Individual status: <strong id=\"individual-status\">unprotected</strong>.<br>\n  Aggregate status: <strong id=\"aggregate-status\">does not exist</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">One record sits below the threshold. No protection applies.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('records');\n    var recOut = document.getElementById('rec-out');\n    var topZone = document.getElementById('top-zone');\n    var bottomZone = document.getElementById('bottom-zone');\n    var individualStatus = document.getElementById('individual-status');\n    var aggregateStatus = document.getElementById('aggregate-status');\n    var caption = document.getElementById('caption');\n\n    var THRESHOLD = 30;\n\n    function render(n) {\n      recOut.textContent = n;\n      bottomZone.innerHTML = '';\n      topZone.innerHTML = '';\n\n      if (n < THRESHOLD) {\n        for (var i = 0; i < n; i++) {\n          var dot = document.createElement('div');\n          dot.className = 'item';\n          bottomZone.appendChild(dot);\n        }\n        individualStatus.textContent = 'unprotected';\n        aggregateStatus.textContent = 'does not exist';\n\n        if (n === 1) {\n          caption.textContent = 'One record sits below the threshold. No protection applies.';\n        } else if (n < 10) {\n          caption.textContent = 'A few records remain unprotected. Each stays in the lower category.';\n        } else if (n < 20) {\n          caption.textContent = 'More records accumulate, still below threshold. The category has not changed.';\n        } else {\n          caption.textContent = 'Many records pile up. Each one unprotected, but accumulation nears the line.';\n        }\n      } else {\n        var agg = document.createElement('div');\n        agg.className = 'aggregate visible';\n        agg.textContent = 'AGGREGATE (' + n + ' records)';\n        topZone.appendChild(agg);\n\n        individualStatus.textContent = 'unprotected';\n        aggregateStatus.textContent = 'protected';\n\n        if (n < 50) {\n          caption.textContent = 'Threshold crossed. The aggregate now occupies the protected category — what the individual records were not.';\n        } else if (n < 80) {\n          caption.textContent = 'The composite grows. Protection applies to the whole, though each part remains unprotected in isolation.';\n        } else {\n          caption.textContent = 'Dense accumulation cements the transformation. The aggregate is categorically distinct from its components.';\n        }\n      }\n    }\n\n    slider.addEventListener('input', function () {\n      render(+slider.value);\n    });\n\n    render(1);\n  })();\n</script>\n</body>\n</html>"
  }
}
