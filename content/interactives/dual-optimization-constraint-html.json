  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Zero-Sum Capacity Split</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --goal-a: #1a6b62;\n    --goal-b: #c9a227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 80px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--goal-b);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .chart {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .bars {\n    display: flex;\n    gap: 24px;\n    margin-bottom: 16px;\n  }\n  .bar-group {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n  }\n  .bar-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n    text-align: center;\n  }\n  .bar-track {\n    height: 160px;\n    background: var(--line);\n    border-radius: 4px;\n    position: relative;\n    overflow: hidden;\n    display: flex;\n    flex-direction: column-reverse;\n  }\n  .bar-fill {\n    width: 100%;\n    transition: height 180ms ease-out;\n    border-radius: 4px 4px 0 0;\n  }\n  .bar-fill[data-metric=\"goal-a\"] {\n    background: var(--goal-a);\n  }\n  .bar-fill[data-metric=\"goal-b\"] {\n    background: var(--goal-b);\n  }\n  .bar-value {\n    margin-top: 8px;\n    text-align: center;\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    font-size: 0.9rem;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .bars {\n      flex-direction: column;\n      gap: 20px;\n    }\n    .bar-track {\n      height: 120px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag the slider. One goal rises as the other drops.</h2>\n<p class=\"subhead\">Total capacity is fixed.</p>\n\n<div class=\"control\">\n  <label for=\"split\">Split:</label>\n  <input id=\"split\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"split-out\">\n  <output id=\"split-out\" for=\"split\">50</output>\n</div>\n\n<div class=\"chart\">\n  <div class=\"bars\">\n    <div class=\"bar-group\">\n      <div class=\"bar-label\">Goal A</div>\n      <div class=\"bar-track\">\n        <div class=\"bar-fill\" data-metric=\"goal-a\" id=\"barGoalA\"></div>\n      </div>\n      <div class=\"bar-value\" id=\"valueGoalA\">50</div>\n    </div>\n    <div class=\"bar-group\">\n      <div class=\"bar-label\">Goal B</div>\n      <div class=\"bar-track\">\n        <div class=\"bar-fill\" data-metric=\"goal-b\" id=\"barGoalB\"></div>\n      </div>\n      <div class=\"bar-value\" id=\"valueGoalB\">50</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Total used: <strong id=\"totalUsed\">100</strong>%.\n  Current priority: <strong id=\"priority\">balanced</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">Both goals split capacity equally. Neither dominates.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('split');\n    var splitOut = document.getElementById('split-out');\n    var barGoalA = document.getElementById('barGoalA');\n    var barGoalB = document.getElementById('barGoalB');\n    var valueGoalA = document.getElementById('valueGoalA');\n    var valueGoalB = document.getElementById('valueGoalB');\n    var totalUsed = document.getElementById('totalUsed');\n    var priority = document.getElementById('priority');\n    var caption = document.getElementById('caption');\n\n    function update() {\n      var t = +slider.value;\n      splitOut.textContent = t;\n      \n      var scoreB = Math.round(t);\n      var scoreA = Math.round(100 - t);\n      \n      barGoalA.style.height = scoreA + '%';\n      barGoalB.style.height = scoreB + '%';\n      valueGoalA.textContent = scoreA;\n      valueGoalB.textContent = scoreB;\n      \n      totalUsed.textContent = '100';\n      \n      if (t >= 80) {\n        priority.textContent = 'Goal B';\n        caption.textContent = 'Goal B dominates. Goal A drops as capacity shifts.';\n      } else if (t >= 60) {\n        priority.textContent = 'Goal B, leaning';\n        caption.textContent = 'Goal B gets priority. Goal A still functions but drops.';\n      } else if (t >= 40) {\n        priority.textContent = 'balanced';\n        caption.textContent = 'Both goals split capacity equally. Neither dominates.';\n      } else if (t >= 20) {\n        priority.textContent = 'Goal A, leaning';\n        caption.textContent = 'Goal A gets priority. Goal B still functions but drops.';\n      } else {\n        priority.textContent = 'Goal A';\n        caption.textContent = 'Goal A dominates. Goal B drops as capacity shifts.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
