{
  "slug": "symbol-to-sound-transition",
  "type": "html",
  "title": "Symbol-to-Sound Mapping",
  "concept": "Phonetic writing requires treating a familiar symbol as a pure sound rather than as the thing it depicts—a conceptual leap that converts visible marks into units of speech.",
  "interactiveId": "7d0c1049-23cc-4018-870b-6fbb28f26531",
  "sourcePieceId": "d0504385-5ffc-4dde-9dcc-8b3b3d1ae73f",
  "publishedAt": 1778292583544,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Symbol-to-Sound Mapping</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --inactive: #d0d0d0;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 600px;\n    margin: 0 auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 24px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .mode-toggle {\n    display: flex;\n    gap: 12px;\n    margin-bottom: 28px;\n    padding: 8px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .mode-toggle button {\n    flex: 1;\n    padding: 10px 16px;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    background: var(--bg);\n    color: var(--fg);\n    font-weight: 500;\n    font-size: 0.9rem;\n    cursor: pointer;\n    transition: all 150ms ease;\n  }\n  .mode-toggle button:hover {\n    background: #fff;\n  }\n  .mode-toggle button.active {\n    background: var(--teal);\n    color: #fff;\n    border-color: var(--teal);\n  }\n  .symbol-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .symbol-card {\n    aspect-ratio: 1;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    background: #fff;\n    padding: 16px;\n    cursor: pointer;\n    transition: all 150ms ease;\n    position: relative;\n  }\n  .symbol-card:hover {\n    border-color: var(--teal);\n    transform: translateY(-2px);\n  }\n  .symbol-card.selected {\n    border-color: var(--gold);\n    border-width: 3px;\n    background: #fffef8;\n  }\n  .symbol-icon {\n    font-size: 3rem;\n    margin-bottom: 8px;\n    user-select: none;\n  }\n  .symbol-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-align: center;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n  .output-area {\n    min-height: 100px;\n    padding: 20px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    margin-bottom: 20px;\n  }\n  .output-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 12px;\n  }\n  .output-sequence {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n    align-items: center;\n    min-height: 40px;\n  }\n  .output-item {\n    padding: 8px 14px;\n    background: var(--bg);\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    font-size: 1.1rem;\n    font-weight: 500;\n  }\n  .output-item.sound {\n    background: #e8f4f2;\n    border-color: var(--teal);\n    color: var(--teal);\n  }\n  .controls {\n    display: flex;\n    gap: 12px;\n    margin-bottom: 20px;\n  }\n  .controls button {\n    padding: 10px 20px;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    background: var(--bg);\n    color: var(--fg);\n    font-weight: 500;\n    font-size: 0.9rem;\n    cursor: pointer;\n    transition: all 150ms ease;\n  }\n  .controls button:hover {\n    background: #fff;\n    border-color: var(--teal);\n  }\n  .reading {\n    padding: 14px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    margin-bottom: 12px;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .symbol-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n    .symbol-icon {\n      font-size: 2.5rem;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Choose a mode, then tap symbols to build a sequence</h2>\n<p class=\"subhead\">Picture mode reads symbols as objects. Sound mode treats them as pure sounds.</p>\n\n<div class=\"mode-toggle\">\n  <button id=\"mode-picture\" class=\"active\">Picture Mode</button>\n  <button id=\"mode-sound\">Sound Mode</button>\n</div>\n\n<div class=\"symbol-grid\">\n  <div class=\"symbol-card\" data-picture=\"water\" data-sound=\"wuh\">\n    <div class=\"symbol-icon\">💧</div>\n    <div class=\"symbol-label\" data-mode-label>water</div>\n  </div>\n  <div class=\"symbol-card\" data-picture=\"house\" data-sound=\"huh\">\n    <div class=\"symbol-icon\">🏠</div>\n    <div class=\"symbol-label\" data-mode-label>house</div>\n  </div>\n  <div class=\"symbol-card\" data-picture=\"eye\" data-sound=\"ah\">\n    <div class=\"symbol-icon\">👁️</div>\n    <div class=\"symbol-label\" data-mode-label>eye</div>\n  </div>\n  <div class=\"symbol-card\" data-picture=\"hand\" data-sound=\"yuh\">\n    <div class=\"symbol-icon\">✋</div>\n    <div class=\"symbol-label\" data-mode-label>hand</div>\n  </div>\n  <div class=\"symbol-card\" data-picture=\"tree\" data-sound=\"tuh\">\n    <div class=\"symbol-icon\">🌳</div>\n    <div class=\"symbol-label\" data-mode-label>tree</div>\n  </div>\n  <div class=\"symbol-card\" data-picture=\"mouth\" data-sound=\"muh\">\n    <div class=\"symbol-icon\">👄</div>\n    <div class=\"symbol-label\" data-mode-label>mouth</div>\n  </div>\n</div>\n\n<div class=\"output-area\">\n  <div class=\"output-label\" id=\"output-label\">You're building:</div>\n  <div class=\"output-sequence\" id=\"sequence\"></div>\n</div>\n\n<div class=\"controls\">\n  <button id=\"clear\">Clear Sequence</button>\n</div>\n\n<div class=\"reading\">\n  Current mode: <strong id=\"mode-display\">Picture</strong>.<br>\n  Sequence length: <strong id=\"length-display\">0</strong>.\n</div>\n\n<p class=\"caption\" id=\"caption\">In picture mode, each symbol means what it depicts. A list of objects.</p>\n\n<script>\n  (function () {\n    var modePicture = document.getElementById('mode-picture');\n    var modeSound = document.getElementById('mode-sound');\n    var cards = document.querySelectorAll('.symbol-card');\n    var sequence = document.getElementById('sequence');\n    var clearBtn = document.getElementById('clear');\n    var modeDisplay = document.getElementById('mode-display');\n    var lengthDisplay = document.getElementById('length-display');\n    var caption = document.getElementById('caption');\n    var outputLabel = document.getElementById('output-label');\n\n    var currentMode = 'picture';\n    var items = [];\n\n    function setMode(mode) {\n      currentMode = mode;\n      if (mode === 'picture') {\n        modePicture.classList.add('active');\n        modeSound.classList.remove('active');\n        modeDisplay.textContent = 'Picture';\n        outputLabel.textContent = \"You're building:\";\n        updateCaption();\n        updateLabels();\n      } else {\n        modeSound.classList.add('active');\n        modePicture.classList.remove('active');\n        modeDisplay.textContent = 'Sound';\n        outputLabel.textContent = \"You're spelling:\";\n        updateCaption();\n        updateLabels();\n      }\n      clearSequence();\n    }\n\n    function updateLabels() {\n      cards.forEach(function(card) {\n        var label = card.querySelector('[data-mode-label]');\n        if (currentMode === 'picture') {\n          label.textContent = card.dataset.picture;\n        } else {\n          label.textContent = card.dataset.sound;\n        }\n      });\n    }\n\n    function addSymbol(card) {\n      var value = currentMode === 'picture' ? card.dataset.picture : card.dataset.sound;\n      items.push(value);\n      renderSequence();\n      updateCaption();\n    }\n\n    function renderSequence() {\n      sequence.innerHTML = '';\n      items.forEach(function(item) {\n        var el = document.createElement('span');\n        el.className = currentMode === 'sound' ? 'output-item sound' : 'output-item';\n        el.textContent = item;\n        sequence.appendChild(el);\n      });\n      lengthDisplay.textContent = items.length;\n    }\n\n    function clearSequence() {\n      items = [];\n      renderSequence();\n      updateCaption();\n    }\n\n    function updateCaption() {\n      if (items.length === 0) {\n        if (currentMode === 'picture') {\n          caption.textContent = 'In picture mode, each symbol means what it depicts. A list of objects.';\n        } else {\n          caption.textContent = 'In sound mode, symbols become building blocks for speech. The picture no longer matters.';\n        }\n      } else if (currentMode === 'picture') {\n        if (items.length === 1) {\n          caption.textContent = 'One symbol, one object. The meaning is direct.';\n        } else if (items.length === 2) {\n          caption.textContent = 'Two symbols, two objects. Still a list of things you can point at.';\n        } else {\n          caption.textContent = 'A sequence of objects. To read this as speech, you'd need to ignore what each symbol depicts and treat it as a sound instead—a conceptual leap that took centuries to invent.';\n        }\n      } else {\n        if (items.length === 1) {\n          caption.textContent = 'One sound. Not enough to make a word yet.';\n        } else if (items.length === 2) {\n          caption.textContent = 'Two sounds strung together. You're encoding speech, not listing objects.';\n        } else if (items.length === 3) {\n          caption.textContent = 'Three sounds make a pronounceable chunk. This is how names and words get written when symbols break free from meaning.';\n        } else {\n          caption.textContent = 'A sound sequence. Each symbol contributes a piece of speech. The original picture is just a memory aid for the sound it represents.';\n        }\n      }\n    }\n\n    modePicture.addEventListener('click', function() { setMode('picture'); });\n    modeSound.addEventListener('click', function() { setMode('sound'); });\n\n    cards.forEach(function(card) {\n      card.addEventListener('click', function() {\n        addSymbol(card);\n        card.classList.add('selected');\n        setTimeout(function() {\n          card.classList.remove('selected');\n        }, 200);\n      });\n    });\n\n    clearBtn.addEventListener('click', clearSequence);\n\n    setMode('picture');\n  })();\n</script>\n</body>\n</html>"
  }
}
