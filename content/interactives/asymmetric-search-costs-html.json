{
  "slug": "asymmetric-search-costs",
  "type": "html",
  "title": "Attack Surface Asymmetry",
  "concept": "Defenders must secure every entry point in a system; attackers need to find just one weakness—the imbalance in required coverage creates structural advantage for offense over defense.",
  "interactiveId": "3fd6c85a-d751-4380-880f-b8f6ae523a29",
  "sourcePieceId": "e6c58cad-9a9d-41ab-9c30-74a250a1914b",
  "publishedAt": 1778594728544,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Attack Surface Asymmetry</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --defender: #1a6b62;\n    --attacker: #c94227;\n    --vulnerable: #f4a259;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--defender);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(28px, 1fr));\n    gap: 6px;\n    margin: 24px 0;\n    max-width: 600px;\n  }\n  .entry {\n    aspect-ratio: 1;\n    border-radius: 3px;\n    border: 2px solid var(--line);\n    background: #fff;\n    transition: all 200ms ease-out;\n    position: relative;\n  }\n  .entry.secured {\n    background: var(--defender);\n    border-color: var(--defender);\n  }\n  .entry.vulnerable {\n    background: var(--vulnerable);\n    border-color: var(--vulnerable);\n    animation: pulse 1.2s ease-in-out infinite;\n  }\n  .entry.breached {\n    background: var(--attacker);\n    border-color: var(--attacker);\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.5; }\n  }\n  .stats {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin: 20px 0;\n    max-width: 600px;\n  }\n  .stat {\n    padding: 12px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .stat strong {\n    font-weight: 600;\n    font-size: 1.1rem;\n    display: block;\n    margin-top: 4px;\n  }\n  .stat.defender strong { color: var(--defender); }\n  .stat.attacker strong { color: var(--attacker); }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n    max-width: 600px;\n  }\n  .legend {\n    display: flex;\n    gap: 16px;\n    margin: 16px 0;\n    font-size: 0.85rem;\n    flex-wrap: wrap;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-box {\n    width: 16px;\n    height: 16px;\n    border-radius: 2px;\n    border: 2px solid currentColor;\n  }\n  @media (max-width: 480px) {\n    .grid {\n      grid-template-columns: repeat(auto-fill, minmax(24px, 1fr));\n      gap: 4px;\n    }\n    .stats {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to increase defensive coverage</h2>\n<p class=\"subhead\">Each square is an entry point. Secured ones are locked. Vulnerable ones flash. One breach is enough.</p>\n\n<div class=\"control\">\n  <label for=\"coverage\">Coverage:</label>\n  <input id=\"coverage\" type=\"range\" min=\"0\" max=\"100\" value=\"60\" aria-describedby=\"coverage-out\">\n  <output id=\"coverage-out\" for=\"coverage\">60</output>%\n</div>\n\n<div class=\"legend\">\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--defender); border-color: var(--defender);\"></div>\n    <span>Secured</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--vulnerable); border-color: var(--vulnerable);\"></div>\n    <span>Vulnerable</span>\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-box\" style=\"background: var(--attacker); border-color: var(--attacker);\"></div>\n    <span>Breached</span>\n  </div>\n</div>\n\n<div class=\"grid\" id=\"grid\"></div>\n\n<div class=\"stats\">\n  <div class=\"stat defender\">\n    <div>Defender must secure</div>\n    <strong id=\"def-count\">100</strong>\n  </div>\n  <div class=\"stat attacker\">\n    <div>Attacker needs</div>\n    <strong id=\"atk-count\">1</strong>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">The defender's job scales with every entry point. The attacker's job stays constant.</p>\n\n<script>\n  (function () {\n    var TOTAL = 100;\n    var slider = document.getElementById('coverage');\n    var coverageOut = document.getElementById('coverage-out');\n    var grid = document.getElementById('grid');\n    var defCount = document.getElementById('def-count');\n    var atkCount = document.getElementById('atk-count');\n    var caption = document.getElementById('caption');\n    var entries = [];\n    var breachedIndex = null;\n\n    function init() {\n      for (var i = 0; i < TOTAL; i++) {\n        var div = document.createElement('div');\n        div.className = 'entry';\n        grid.appendChild(div);\n        entries.push(div);\n      }\n    }\n\n    function update() {\n      var cov = +slider.value;\n      coverageOut.textContent = cov;\n      var secured = Math.floor((cov / 100) * TOTAL);\n      var vulnerable = TOTAL - secured;\n\n      defCount.textContent = TOTAL;\n      atkCount.textContent = '1';\n\n      // Shuffle which ones are secured vs vulnerable each update\n      // to avoid user seeing a simple left-to-right fill pattern\n      var indices = [];\n      for (var i = 0; i < TOTAL; i++) indices.push(i);\n      for (var j = indices.length - 1; j > 0; j--) {\n        var k = Math.floor(Math.random() * (j + 1));\n        var temp = indices[j];\n        indices[j] = indices[k];\n        indices[k] = temp;\n      }\n\n      var securedIndices = indices.slice(0, secured);\n      var vulnerableIndices = indices.slice(secured);\n\n      for (var m = 0; m < entries.length; m++) {\n        entries[m].className = 'entry';\n      }\n\n      for (var n = 0; n < securedIndices.length; n++) {\n        entries[securedIndices[n]].classList.add('secured');\n      }\n\n      for (var p = 0; p < vulnerableIndices.length; p++) {\n        entries[vulnerableIndices[p]].classList.add('vulnerable');\n      }\n\n      // Pick one vulnerable to breach if any exist\n      if (vulnerableIndices.length > 0) {\n        breachedIndex = vulnerableIndices[Math.floor(Math.random() * vulnerableIndices.length)];\n        entries[breachedIndex].classList.remove('vulnerable');\n        entries[breachedIndex].classList.add('breached');\n      } else {\n        breachedIndex = null;\n      }\n\n      if (cov === 100) {\n        caption.textContent = 'Perfect coverage. No vulnerable entry points remain. The attacker is locked out.';\n      } else if (cov >= 80) {\n        caption.textContent = 'High coverage, but the attacker only needs one gap. Still an imbalance.';\n      } else if (cov >= 50) {\n        caption.textContent = 'The defender must secure all ' + TOTAL + ' points. The attacker exploits any single weakness.';\n      } else {\n        caption.textContent = 'Low coverage. Many vulnerabilities available. The attacker has easy targets.';\n      }\n\n      // Post engagement event on user manipulation\n      if (window.parent && typeof window.parent.postMessage === 'function') {\n        window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n      }\n    }\n\n    slider.addEventListener('input', update);\n    init();\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
