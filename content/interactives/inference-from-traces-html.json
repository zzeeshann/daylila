{
  "slug": "inference-from-traces",
  "type": "html",
  "title": "Reading Action from Marks",
  "concept": "When you can't see the action directly, you reconstruct what happened by reading the pattern of marks left behind—arrangement and type reveal intent.",
  "interactiveId": "de70a42d-7a13-48ab-9556-d5f0aae5b203",
  "sourcePieceId": "fec7fcc3-8e7c-4afa-b6e9-5c031773d395",
  "publishedAt": 1778458390803,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Reading Action from Marks</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c94227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 24px;\n    max-width: 500px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  .control-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .control-row label {\n    font-weight: 500;\n    min-width: 80px;\n    flex-shrink: 0;\n  }\n  .control-row input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control-row output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .button-group {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n  }\n  .button-group button {\n    padding: 6px 12px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 0.85rem;\n    transition: all 0.15s;\n  }\n  .button-group button:hover {\n    background: var(--bg);\n  }\n  .button-group button.active {\n    background: var(--teal);\n    color: #fff;\n    border-color: var(--teal);\n  }\n  .surface {\n    position: relative;\n    width: 100%;\n    max-width: 500px;\n    margin: 0 auto;\n  }\n  svg {\n    display: block;\n    width: 100%;\n    height: auto;\n    border: 1px solid var(--line);\n    background: #fff;\n    border-radius: 6px;\n  }\n  .mark {\n    transition: all 0.2s ease-out;\n  }\n  .reading {\n    margin: 18px auto 6px;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    max-width: 500px;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .reading .detail {\n    margin-top: 8px;\n    padding-top: 8px;\n    border-top: 1px solid var(--line);\n    color: var(--muted);\n    font-size: 0.85rem;\n  }\n  p.caption {\n    margin: 14px auto 0;\n    max-width: 500px;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    body { padding: 16px; }\n    h2 { font-size: 1rem; }\n    .control-row {\n      flex-direction: column;\n      align-items: flex-start;\n    }\n    .control-row label {\n      min-width: auto;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust mark properties to see what action they reveal</h2>\n<p class=\"subhead\">Angle, depth, and arrangement tell you what happened even when you can't see it directly.</p>\n\n<div class=\"controls\">\n  <div class=\"control-row\">\n    <label for=\"angle\">Angle:</label>\n    <input id=\"angle\" type=\"range\" min=\"0\" max=\"90\" value=\"15\" aria-describedby=\"angle-out\">\n    <output id=\"angle-out\" for=\"angle\">15°</output>\n  </div>\n  <div class=\"control-row\">\n    <label for=\"depth\">Depth:</label>\n    <input id=\"depth\" type=\"range\" min=\"1\" max=\"5\" value=\"2\" aria-describedby=\"depth-out\">\n    <output id=\"depth-out\" for=\"depth\">2</output>\n  </div>\n  <div class=\"control-row\">\n    <label>Pattern:</label>\n    <div class=\"button-group\">\n      <button data-pattern=\"aligned\" class=\"active\">Aligned</button>\n      <button data-pattern=\"crossing\">Crossing</button>\n      <button data-pattern=\"scattered\">Scattered</button>\n    </div>\n  </div>\n</div>\n\n<div class=\"surface\">\n  <svg id=\"canvas\" viewBox=\"0 0 400 200\" aria-label=\"Surface with marks\">\n    <rect x=\"50\" y=\"60\" width=\"300\" height=\"80\" rx=\"8\" fill=\"#f4ede0\" stroke=\"#a89f8f\" stroke-width=\"2\"/>\n    <text x=\"200\" y=\"35\" text-anchor=\"middle\" font-size=\"12\" fill=\"var(--muted)\">Object surface</text>\n  </svg>\n</div>\n\n<div class=\"reading\">\n  <strong id=\"inference\">Removing material along the structure</strong>\n  <div class=\"detail\" id=\"detail\">Low-angle marks running parallel to the object's length mean the tool moved with the grain—working along natural lines to strip away the outer layer efficiently.</div>\n</div>\n\n<p class=\"caption\" id=\"caption\">When marks run parallel at shallow angles, the person worked methodically along the object's length—a deliberate pattern, not random damage.</p>\n\n<script>\n  (function () {\n    var angleSlider = document.getElementById('angle');\n    var depthSlider = document.getElementById('depth');\n    var angleOut = document.getElementById('angle-out');\n    var depthOut = document.getElementById('depth-out');\n    var patternButtons = document.querySelectorAll('[data-pattern]');\n    var inference = document.getElementById('inference');\n    var detail = document.getElementById('detail');\n    var caption = document.getElementById('caption');\n    var canvas = document.getElementById('canvas');\n    var currentPattern = 'aligned';\n\n    var states = {\n      'low-shallow-aligned': {\n        inference: 'Removing material along the structure',\n        detail: 'Low-angle marks running parallel to the object\\'s length mean the tool moved with the grain—working along natural lines to strip away the outer layer efficiently.',\n        caption: 'When marks run parallel at shallow angles, the person worked methodically along the object\\'s length—a deliberate pattern, not random damage.'\n      },\n      'low-shallow-crossing': {\n        inference: 'Testing or repositioning the tool',\n        detail: 'Shallow marks crossing at low angles suggest tentative movements—the person was finding the right grip or working around an obstacle, not executing a main task.',\n        caption: 'Crossing shallow marks at low angles = exploratory movements. The main work hasn\\'t started yet.'\n      },\n      'low-shallow-scattered': {\n        inference: 'Incidental contact or cleanup',\n        detail: 'Scattered shallow marks with no alignment suggest the tool scraped the surface during transport, storage, or after the main work—background noise, not purposeful action.',\n        caption: 'Random shallow marks = no clear intent. Not every mark comes from deliberate work.'\n      },\n      'low-deep-aligned': {\n        inference: 'Cutting through the outer layer',\n        detail: 'Deep marks aligned along the object mean the tool cut into the material while following its structure—removing a thick layer or scoring for later separation.',\n        caption: 'Aligned deep cuts = working with the structure but penetrating far. The person knew where to apply force.'\n      },\n      'low-deep-crossing': {\n        inference: 'Carving or shaping detail',\n        detail: 'Deep marks crossing at low angles suggest controlled shaping—the person was modifying the surface deliberately, creating a specific form or texture.',\n        caption: 'Crossing deep marks at low angles = intentional shaping. This is craft, not just removal.'\n      },\n      'low-deep-scattered': {\n        inference: 'Heavy damage or forceful strikes',\n        detail: 'Scattered deep marks suggest impacts from multiple directions—either the object was struck repeatedly without care, or something heavy fell on it.',\n        caption: 'Random deep marks = uncontrolled force. The pattern suggests damage, not skilled work.'\n      },\n      'high-shallow-aligned': {\n        inference: 'Scraping across the grain',\n        detail: 'High-angle shallow marks aligned perpendicular to the object\\'s length mean the tool scraped across the structure—less efficient than working with it, but useful for reaching recesses.',\n        caption: 'Perpendicular shallow marks = working against the grain. Slower, but sometimes necessary.'\n      },\n      'high-shallow-crossing': {\n        inference: 'Surface cleanup or smoothing',\n        detail: 'Shallow marks crossing at high angles suggest the person was evening out the surface—light strokes in multiple directions to remove irregularities.',\n        caption: 'Crossing shallow marks at high angles = finishing work. The main task is done; this is refinement.'\n      },\n      'high-shallow-scattered': {\n        inference: 'Light abrasion from handling',\n        detail: 'Scattered shallow marks at varied angles suggest the object rubbed against other surfaces during use or storage—wear, not deliberate marking.',\n        caption: 'Random shallow high-angle marks = passive wear. The object moved around, but no one was working it.'\n      },\n      'high-deep-aligned': {\n        inference: 'Separating parts at connection points',\n        detail: 'Deep marks cutting perpendicular to the object at high angles mean the tool targeted structural weak points—separating segments where they naturally join.',\n        caption: 'Perpendicular deep cuts = breaking the object into parts. The person knew where connections were and cut through them.'\n      },\n      'high-deep-crossing': {\n        inference: 'Breaking through resistant material',\n        detail: 'Deep marks crossing at high angles suggest the person attacked a tough section from multiple directions—no single cut worked, so they used several.',\n        caption: 'Crossing deep marks at high angles = forcing through resistance. The material fought back.'\n      },\n      'high-deep-scattered': {\n        inference: 'Violent breakage or destruction',\n        detail: 'Scattered deep marks at high angles suggest the object was broken apart without care—smashed, not carefully separated.',\n        caption: 'Random deep high-angle marks = destruction. This wasn\\'t controlled separation—it was breaking.'\n      }\n    };\n\n    function getState() {\n      var angle = +angleSlider.value;\n      var depth = +depthSlider.value;\n      var angleKey = angle <= 45 ? 'low' : 'high';\n      var depthKey = depth <= 2 ? 'shallow' : 'deep';\n      return angleKey + '-' + depthKey + '-' + currentPattern;\n    }\n\n    function drawMarks() {\n      var existing = canvas.querySelectorAll('.mark');\n      existing.forEach(function (el) { el.remove(); });\n\n      var angle = +angleSlider.value;\n      var depth = +depthSlider.value;\n      var baseX = 100;\n      var baseY = 100;\n      var length = 40;\n      var count = currentPattern === 'scattered' ? 8 : 5;\n      var strokeWidth = 1 + (depth - 1) * 0.8;\n      var color = depth <= 2 ? 'var(--teal)' : 'var(--gold)';\n\n      for (var i = 0; i < count; i++) {\n        var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n        line.setAttribute('class', 'mark');\n        line.setAttribute('stroke', color);\n        line.setAttribute('stroke-width', strokeWidth);\n\n        var x, y, x2, y2;\n        if (currentPattern === 'aligned') {\n          var offset = i * 18;\n          x = baseX + offset;\n          y = baseY;\n          var rad = (angle * Math.PI) / 180;\n          x2 = x + length * Math.cos(rad);\n          y2 = y + length * Math.sin(rad);\n        } else if (currentPattern === 'crossing') {\n          var offsetX = (i % 3) * 25;\n          var offsetY = Math.floor(i / 3) * 25;\n          x = baseX + offsetX;\n          y = baseY - 10 + offsetY;\n          var rad = ((angle + (i % 2 === 0 ? 0 : 90)) * Math.PI) / 180;\n          x2 = x + length * 0.7 * Math.cos(rad);\n          y2 = y + length * 0.7 * Math.sin(rad);\n        } else {\n          x = baseX + Math.random() * 200;\n          y = baseY - 20 + Math.random() * 40;\n          var randomAngle = Math.random() * 180;\n          var rad = (randomAngle * Math.PI) / 180;\n          x2 = x + (length * 0.6) * Math.cos(rad);\n          y2 = y + (length * 0.6) * Math.sin(rad);\n        }\n\n        line.setAttribute('x1', x);\n        line.setAttribute('y1', y);\n        line.setAttribute('x2', x2);\n        line.setAttribute('y2', y2);\n        canvas.appendChild(line);\n      }\n    }\n\n    function update() {\n      var angle = +angleSlider.value;\n      var depth = +depthSlider.value;\n      angleOut.textContent = angle + '°';\n      depthOut.textContent = depth;\n\n      drawMarks();\n\n      var stateKey = getState();\n      var state = states[stateKey];\n      if (state) {\n        inference.textContent = state.inference;\n        detail.textContent = state.detail;\n        caption.textContent = state.caption;\n      }\n    }\n\n    angleSlider.addEventListener('input', update);\n    depthSlider.addEventListener('input', update);\n\n    patternButtons.forEach(function (btn) {\n      btn.addEventListener('click', function () {\n        patternButtons.forEach(function (b) { b.classList.remove('active'); });\n        btn.classList.add('active');\n        currentPattern = btn.getAttribute('data-pattern');\n        update();\n      });\n    });\n\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
