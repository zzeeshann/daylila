{
  "slug": "collective-property-emergence",
  "type": "html",
  "title": "Emergent Properties from Scale",
  "concept": "Some properties only exist when you zoom out from individual components to their collective behavior—they're real and measurable at one scale but absent at another.",
  "interactiveId": "98f8a703-298f-4b7c-930c-00fa34c42280",
  "sourcePieceId": "bb305ff6-936e-4d4f-a0fa-7200787ae669",
  "publishedAt": 1777989858958,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Emergent Properties from Scale</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c74440;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .container {\n    position: relative;\n    width: 100%;\n    height: 320px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    overflow: hidden;\n    margin: 24px 0 12px;\n  }\n  .particle {\n    position: absolute;\n    width: 6px;\n    height: 6px;\n    background: var(--gold);\n    border-radius: 50%;\n    transition: opacity 150ms ease-out;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .property-indicator {\n    display: inline-block;\n    width: 12px;\n    height: 12px;\n    border-radius: 2px;\n    vertical-align: middle;\n    margin-left: 6px;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .container {\n      height: 280px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Add components to watch a property emerge</h2>\n<p class=\"subhead\">Individual parts don't have the property. Collective behavior creates it.</p>\n\n<div class=\"control\">\n  <label for=\"count\">Count:</label>\n  <input id=\"count\" type=\"range\" min=\"1\" max=\"500\" value=\"1\" aria-describedby=\"count-out\">\n  <output id=\"count-out\" for=\"count\">1</output>\n</div>\n\n<div class=\"container\" id=\"container\" aria-hidden=\"true\"></div>\n\n<div class=\"reading\">\n  Property status: <strong id=\"status\">absent</strong><span class=\"property-indicator\" id=\"indicator\"></span>\n</div>\n\n<p class=\"caption\" id=\"caption\">With one component, there's nothing to average. The property doesn't exist yet.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('count');\n    var countOut = document.getElementById('count-out');\n    var container = document.getElementById('container');\n    var status = document.getElementById('status');\n    var indicator = document.getElementById('indicator');\n    var caption = document.getElementById('caption');\n    \n    var particles = [];\n    var animationFrame = null;\n    var containerWidth = 0;\n    var containerHeight = 0;\n    \n    function initContainer() {\n      containerWidth = container.clientWidth;\n      containerHeight = container.clientHeight;\n    }\n    \n    function createParticle() {\n      var particle = {\n        x: Math.random() * containerWidth,\n        y: Math.random() * containerHeight,\n        vx: (Math.random() - 0.5) * 2,\n        vy: (Math.random() - 0.5) * 2,\n        element: document.createElement('div')\n      };\n      particle.element.className = 'particle';\n      particle.element.style.left = particle.x + 'px';\n      particle.element.style.top = particle.y + 'px';\n      container.appendChild(particle.element);\n      return particle;\n    }\n    \n    function removeParticle(particle) {\n      container.removeChild(particle.element);\n    }\n    \n    function updateParticle(particle) {\n      particle.x += particle.vx;\n      particle.y += particle.vy;\n      \n      if (particle.x < 0 || particle.x > containerWidth) {\n        particle.vx *= -1;\n        particle.x = Math.max(0, Math.min(containerWidth, particle.x));\n      }\n      if (particle.y < 0 || particle.y > containerHeight) {\n        particle.vy *= -1;\n        particle.y = Math.max(0, Math.min(containerHeight, particle.y));\n      }\n      \n      particle.element.style.left = particle.x + 'px';\n      particle.element.style.top = particle.y + 'px';\n    }\n    \n    function animate() {\n      for (var i = 0; i < particles.length; i++) {\n        updateParticle(particles[i]);\n      }\n      animationFrame = requestAnimationFrame(animate);\n    }\n    \n    function updateDisplay(count) {\n      countOut.textContent = count;\n      \n      while (particles.length < count) {\n        particles.push(createParticle());\n      }\n      while (particles.length > count) {\n        removeParticle(particles.pop());\n      }\n      \n      if (count === 1) {\n        status.textContent = 'absent';\n        indicator.style.background = 'transparent';\n        indicator.style.border = '1px solid var(--line)';\n        caption.textContent = \"With one component, there's nothing to average. The property doesn't exist yet.\";\n      } else if (count < 20) {\n        status.textContent = 'flickering';\n        indicator.style.background = 'linear-gradient(90deg, transparent 50%, var(--gold) 50%)';\n        indicator.style.border = '1px solid var(--gold)';\n        caption.textContent = 'A handful of components show hints of collective behavior, but the pattern is noisy and unstable.';\n      } else if (count < 100) {\n        status.textContent = 'forming';\n        indicator.style.background = 'var(--gold)';\n        indicator.style.border = 'none';\n        caption.textContent = 'With dozens of components, a stable pattern emerges. The collective property is measurable now.';\n      } else if (count < 300) {\n        status.textContent = 'established';\n        indicator.style.background = 'var(--teal)';\n        indicator.style.border = 'none';\n        caption.textContent = 'At this scale, the property is robust. Individual variations average out. The system has a trait the parts lack.';\n      } else {\n        status.textContent = 'dominant';\n        indicator.style.background = 'var(--teal)';\n        indicator.style.border = 'none';\n        caption.textContent = 'The collective property completely dominates. You can predict system behavior without tracking individual components.';\n      }\n      \n      if (particles.length > 0 && animationFrame === null) {\n        animate();\n      } else if (particles.length === 0 && animationFrame !== null) {\n        cancelAnimationFrame(animationFrame);\n        animationFrame = null;\n      }\n    }\n    \n    slider.addEventListener('input', function() {\n      updateDisplay(+slider.value);\n    });\n    \n    window.addEventListener('resize', function() {\n      initContainer();\n    });\n    \n    initContainer();\n    updateDisplay(1);\n  })();\n</script>\n</body>\n</html>"
  }
}
