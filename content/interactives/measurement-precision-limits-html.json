{
  "slug": "measurement-precision-limits",
  "type": "html",
  "title": "Signal Extraction from Noise",
  "concept": "When a true signal is vastly weaker than surrounding interference, measurement precision depends on both isolation techniques and the number of independent observations you can average together.",
  "interactiveId": "b00223e2-7bea-41d8-aaa0-9dc131b884a0",
  "sourcePieceId": "376094d7-409c-4433-a244-74da50e043ac",
  "publishedAt": 1778230955688,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Signal Extraction from Noise</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --signal: #1a6b62;\n    --noise: #c9a227;\n    --combined: #8b6f47;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n    min-width: 140px;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--signal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .visualization {\n    margin: 24px 0;\n    padding: 20px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .chart-container {\n    width: 100%;\n    height: 200px;\n    position: relative;\n    margin-bottom: 16px;\n  }\n  canvas {\n    width: 100%;\n    height: 100%;\n    display: block;\n  }\n  .legend {\n    display: flex;\n    gap: 20px;\n    flex-wrap: wrap;\n    margin-top: 12px;\n    font-size: 0.85rem;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-color {\n    width: 16px;\n    height: 16px;\n    border-radius: 2px;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 14px;\n    background: var(--bg);\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .metric-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 12px;\n    margin-top: 12px;\n  }\n  .metric {\n    padding: 10px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n  }\n  .metric-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 4px;\n  }\n  .metric-value {\n    font-size: 1.1rem;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control label {\n      min-width: 100px;\n      font-size: 0.9rem;\n    }\n    .chart-container {\n      height: 160px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Adjust noise level and sample count</h2>\n<p class=\"subhead\">A weak signal buried in strong interference becomes measurable only through isolation and averaging.</p>\n\n<div class=\"controls\">\n  <div class=\"control\">\n    <label for=\"noise-ratio\">Noise strength:</label>\n    <input id=\"noise-ratio\" type=\"range\" min=\"0\" max=\"100\" value=\"80\" aria-describedby=\"noise-out\">\n    <output id=\"noise-out\" for=\"noise-ratio\">80×</output>\n  </div>\n  <div class=\"control\">\n    <label for=\"samples\">Sample count:</label>\n    <input id=\"samples\" type=\"range\" min=\"1\" max=\"100\" value=\"1\" aria-describedby=\"samples-out\">\n    <output id=\"samples-out\" for=\"samples\">1</output>\n  </div>\n</div>\n\n<div class=\"visualization\">\n  <div class=\"chart-container\">\n    <canvas id=\"waveform\" width=\"800\" height=\"200\"></canvas>\n  </div>\n  <div class=\"legend\">\n    <div class=\"legend-item\">\n      <div class=\"legend-color\" style=\"background: var(--signal);\"></div>\n      <span>True signal</span>\n    </div>\n    <div class=\"legend-item\">\n      <div class=\"legend-color\" style=\"background: var(--noise);\"></div>\n      <span>Interference</span>\n    </div>\n    <div class=\"legend-item\">\n      <div class=\"legend-color\" style=\"background: var(--combined);\"></div>\n      <span>Measured value</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"reading\">\n  <div class=\"metric-grid\">\n    <div class=\"metric\">\n      <div class=\"metric-label\">True signal</div>\n      <div class=\"metric-value\" id=\"true-signal\">10.0</div>\n    </div>\n    <div class=\"metric\">\n      <div class=\"metric-value\" id=\"measured-value\">—</div>\n      <div class=\"metric-label\">Measured (averaged)</div>\n    </div>\n    <div class=\"metric\">\n      <div class=\"metric-label\">Error</div>\n      <div class=\"metric-value\" id=\"error\">—</div>\n    </div>\n    <div class=\"metric\">\n      <div class=\"metric-label\">Uncertainty</div>\n      <div class=\"metric-value\" id=\"uncertainty\">—</div>\n    </div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Single measurements drown in interference. The signal is there, but you can't see it yet.</p>\n\n<script>\n  (function () {\n    var noiseSlider = document.getElementById('noise-ratio');\n    var samplesSlider = document.getElementById('samples');\n    var noiseOut = document.getElementById('noise-out');\n    var samplesOut = document.getElementById('samples-out');\n    var canvas = document.getElementById('waveform');\n    var ctx = canvas.getContext('2d');\n    var trueSignalEl = document.getElementById('true-signal');\n    var measuredEl = document.getElementById('measured-value');\n    var errorEl = document.getElementById('error');\n    var uncertaintyEl = document.getElementById('uncertainty');\n    var caption = document.getElementById('caption');\n\n    var TRUE_SIGNAL = 10.0;\n    var measurements = [];\n\n    function generateMeasurements(noiseRatio, count) {\n      measurements = [];\n      var noiseStdDev = noiseRatio / 10;\n      for (var i = 0; i < count; i++) {\n        var noise = (Math.random() - 0.5) * 2 * noiseStdDev * 2.5;\n        measurements.push(TRUE_SIGNAL + noise);\n      }\n    }\n\n    function average(arr) {\n      var sum = 0;\n      for (var i = 0; i < arr.length; i++) sum += arr[i];\n      return sum / arr.length;\n    }\n\n    function stdDev(arr, mean) {\n      var sumSq = 0;\n      for (var i = 0; i < arr.length; i++) {\n        var diff = arr[i] - mean;\n        sumSq += diff * diff;\n      }\n      return Math.sqrt(sumSq / arr.length);\n    }\n\n    function drawWaveform() {\n      var width = canvas.width;\n      var height = canvas.height;\n      ctx.clearRect(0, 0, width, height);\n\n      var centerY = height / 2;\n      var scaleY = height / 50;\n\n      ctx.lineWidth = 2;\n\n      // Draw true signal (flat line)\n      ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--signal').trim();\n      ctx.beginPath();\n      ctx.moveTo(0, centerY - TRUE_SIGNAL * scaleY);\n      ctx.lineTo(width, centerY - TRUE_SIGNAL * scaleY);\n      ctx.stroke();\n\n      // Draw measurements as discrete points\n      var pointSpacing = width / Math.max(measurements.length, 10);\n      ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--combined').trim();\n      for (var i = 0; i < Math.min(measurements.length, 50); i++) {\n        var x = i * pointSpacing + pointSpacing / 2;\n        var y = centerY - measurements[i] * scaleY;\n        ctx.beginPath();\n        ctx.arc(x, y, 3, 0, 2 * Math.PI);\n        ctx.fill();\n      }\n\n      // Draw averaged measurement as dashed line if we have samples\n      if (measurements.length > 0) {\n        var avg = average(measurements);\n        ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--combined').trim();\n        ctx.setLineDash([5, 5]);\n        ctx.beginPath();\n        ctx.moveTo(0, centerY - avg * scaleY);\n        ctx.lineTo(width, centerY - avg * scaleY);\n        ctx.stroke();\n        ctx.setLineDash([]);\n      }\n    }\n\n    function update() {\n      var noiseRatio = +noiseSlider.value;\n      var sampleCount = +samplesSlider.value;\n\n      noiseOut.textContent = noiseRatio + '×';\n      samplesOut.textContent = sampleCount;\n\n      generateMeasurements(noiseRatio, sampleCount);\n      drawWaveform();\n\n      trueSignalEl.textContent = TRUE_SIGNAL.toFixed(1);\n\n      if (measurements.length > 0) {\n        var avg = average(measurements);\n        var error = Math.abs(avg - TRUE_SIGNAL);\n        var unc = stdDev(measurements, avg) / Math.sqrt(measurements.length);\n\n        measuredEl.textContent = avg.toFixed(1);\n        errorEl.textContent = error.toFixed(1);\n        uncertaintyEl.textContent = '±' + unc.toFixed(1);\n\n        // Update caption based on state\n        if (sampleCount === 1) {\n          if (noiseRatio >= 60) {\n            caption.textContent = 'Single measurements drown in interference. The signal is there, but you can\\'t see it yet.';\n          } else {\n            caption.textContent = 'With weak interference, even one measurement gets close to the true value.';\n          }\n        } else if (sampleCount < 20) {\n          if (noiseRatio >= 60) {\n            caption.textContent = 'A few samples help, but strong interference still dominates. The average wanders.';\n          } else {\n            caption.textContent = 'Multiple measurements reveal the signal even through moderate noise.';\n          }\n        } else {\n          if (noiseRatio >= 60) {\n            caption.textContent = 'Many samples beat down the noise. Random interference cancels out; the signal emerges.';\n          } else {\n            caption.textContent = 'With many samples and low noise, the measurement locks onto the true value.';\n          }\n        }\n      }\n    }\n\n    noiseSlider.addEventListener('input', update);\n    samplesSlider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
