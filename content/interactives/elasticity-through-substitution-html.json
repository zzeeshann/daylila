{
  "slug": "elasticity-through-substitution",
  "type": "html",
  "title": "Stigma as Friction Cost",
  "concept": "Social norms impose a cost on behavior separate from money—when enough people cross the threshold simultaneously, the friction dissolves because visibility shifts faster than values.",
  "interactiveId": "ba29ecdd-41cc-4fbc-a4dd-38d4b2229568",
  "sourcePieceId": "8cda1afc-48fb-4ad3-94d2-1ee3d77e3edc",
  "publishedAt": 1778502084008,
  "voiceScore": 88,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Stigma as Friction Cost</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c23b22;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n    max-width: 640px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .population {\n    margin: 24px 0;\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .dots-grid {\n    display: grid;\n    grid-template-columns: repeat(10, 1fr);\n    gap: 6px;\n    margin: 16px 0;\n  }\n  .dot {\n    width: 100%;\n    aspect-ratio: 1;\n    border-radius: 50%;\n    background: var(--line);\n    transition: background 200ms ease-out;\n  }\n  .dot.acting {\n    background: var(--gold);\n  }\n  .readings {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    margin-top: 16px;\n  }\n  .reading {\n    padding: 10px 12px;\n    background: var(--bg);\n    border-radius: 4px;\n    font-size: 0.875rem;\n  }\n  .reading strong {\n    font-weight: 600;\n    display: block;\n    margin-top: 2px;\n    font-size: 1.1rem;\n  }\n  .cost-display {\n    margin: 20px 0;\n    padding: 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .cost-bar {\n    display: flex;\n    height: 32px;\n    border-radius: 4px;\n    overflow: hidden;\n    margin: 8px 0;\n  }\n  .cost-segment {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: #fff;\n    transition: flex 200ms ease-out;\n  }\n  .cost-segment.money {\n    background: var(--teal);\n  }\n  .cost-segment.stigma {\n    background: var(--red);\n  }\n  .cost-legend {\n    display: flex;\n    gap: 16px;\n    font-size: 0.8rem;\n    margin-top: 10px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-swatch {\n    width: 14px;\n    height: 14px;\n    border-radius: 2px;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .dots-grid {\n      grid-template-columns: repeat(5, 1fr);\n    }\n    .readings {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to change how many people do the behavior</h2>\n<p class=\"subhead\">Watch what happens to the friction cost when the crowd shifts.</p>\n\n<div class=\"control\">\n  <label for=\"adoption\">Adoption rate:</label>\n  <input id=\"adoption\" type=\"range\" min=\"0\" max=\"100\" value=\"8\" step=\"1\" aria-describedby=\"adoption-out\">\n  <output id=\"adoption-out\" for=\"adoption\">8%</output>\n</div>\n\n<div class=\"population\">\n  <div class=\"dots-grid\" id=\"dots\" aria-hidden=\"true\"></div>\n  <div class=\"readings\">\n    <div class=\"reading\">\n      <span>People doing it:</span>\n      <strong id=\"acting-count\">8</strong>\n    </div>\n    <div class=\"reading\">\n      <span>Friction cost:</span>\n      <strong id=\"friction-level\">High</strong>\n    </div>\n  </div>\n</div>\n\n<div class=\"cost-display\">\n  <div style=\"font-size: 0.875rem; margin-bottom: 6px; color: var(--muted);\">Total cost to act:</div>\n  <div class=\"cost-bar\" id=\"cost-bar\" aria-hidden=\"true\">\n    <div class=\"cost-segment money\" id=\"money-cost\">Money</div>\n    <div class=\"cost-segment stigma\" id=\"stigma-cost\">Stigma</div>\n  </div>\n  <div class=\"cost-legend\">\n    <div class=\"legend-item\">\n      <div class=\"legend-swatch\" style=\"background: var(--teal);\"></div>\n      <span>Money cost (fixed)</span>\n    </div>\n    <div class=\"legend-item\">\n      <div class=\"legend-swatch\" style=\"background: var(--red);\"></div>\n      <span>Stigma cost (varies)</span>\n    </div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">At low adoption, stigma dominates the cost. Most people won't cross the threshold.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('adoption');\n    var adoptionOut = document.getElementById('adoption-out');\n    var dotsContainer = document.getElementById('dots');\n    var actingCount = document.getElementById('acting-count');\n    var frictionLevel = document.getElementById('friction-level');\n    var moneyCost = document.getElementById('money-cost');\n    var stigmaCost = document.getElementById('stigma-cost');\n    var caption = document.getElementById('caption');\n\n    var dots = [];\n    for (var i = 0; i < 100; i++) {\n      var dot = document.createElement('div');\n      dot.className = 'dot';\n      dotsContainer.appendChild(dot);\n      dots.push(dot);\n    }\n\n    function update() {\n      var rate = +slider.value;\n      adoptionOut.textContent = rate + '%';\n      actingCount.textContent = rate;\n\n      // Update dots — first `rate` dots are acting\n      for (var i = 0; i < dots.length; i++) {\n        if (i < rate) {\n          dots[i].classList.add('acting');\n        } else {\n          dots[i].classList.remove('acting');\n        }\n      }\n\n      // Stigma cost decreases as adoption increases\n      // Model: stigma drops sharply after ~20%, flattens near zero at ~60%\n      var stigmaFraction;\n      if (rate < 20) {\n        stigmaFraction = 0.8 - (rate / 20) * 0.3; // 0.8 → 0.5\n      } else if (rate < 60) {\n        stigmaFraction = 0.5 - ((rate - 20) / 40) * 0.45; // 0.5 → 0.05\n      } else {\n        stigmaFraction = Math.max(0, 0.05 - ((rate - 60) / 40) * 0.05); // 0.05 → 0\n      }\n\n      var moneyFraction = 0.2; // fixed at 20% of total cost\n      var total = moneyFraction + stigmaFraction;\n      var moneyPct = (moneyFraction / total) * 100;\n      var stigmaPct = (stigmaFraction / total) * 100;\n\n      moneyCost.style.flex = moneyPct;\n      stigmaCost.style.flex = stigmaPct;\n\n      // Update friction label\n      if (rate < 15) {\n        frictionLevel.textContent = 'High';\n        caption.textContent = 'At low adoption, stigma dominates the cost. Most people won't cross the threshold.';\n      } else if (rate < 40) {\n        frictionLevel.textContent = 'Falling';\n        caption.textContent = 'As more people act, stigma drops. The same behavior costs less than it did.';\n      } else if (rate < 65) {\n        frictionLevel.textContent = 'Low';\n        caption.textContent = 'Past a tipping point, stigma nearly disappears. Visibility shifted faster than values.';\n      } else {\n        frictionLevel.textContent = 'Gone';\n        caption.textContent = 'When most people do it, the friction is gone. The behavior is now normal.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
