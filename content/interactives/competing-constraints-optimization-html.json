{
  "slug": "competing-constraints-optimization",
  "type": "html",
  "title": "Dual-Constraint Envelope",
  "concept": "When two opposing needs define safe boundaries, the viable region is where both thresholds are met—not where either need is maximized.",
  "interactiveId": "a9edab91-8421-45a5-b668-55b5f5ca887e",
  "sourcePieceId": "ee3a82fd-c06a-4557-bfb2-f6b261e6ba07",
  "publishedAt": 1777913776002,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Dual-Constraint Envelope</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --safe: #2d7a4f;\n    --danger: #c9332e;\n    --gold: #c9a227;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 24px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--gold);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 2.5ch;\n    text-align: right;\n  }\n  .chart-container {\n    margin: 20px 0;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 20px;\n    position: relative;\n  }\n  svg {\n    display: block;\n    width: 100%;\n    height: auto;\n  }\n  .axis-label {\n    font-size: 0.75rem;\n    fill: var(--muted);\n  }\n  .threshold-line {\n    stroke-width: 2.5;\n    fill: none;\n  }\n  .safe-region {\n    fill: var(--safe);\n    opacity: 0.12;\n  }\n  .danger-region {\n    fill: var(--danger);\n    opacity: 0.12;\n  }\n  .current-point {\n    fill: var(--gold);\n    stroke: var(--fg);\n    stroke-width: 2;\n  }\n  .grid-line {\n    stroke: var(--line);\n    stroke-width: 1;\n    stroke-dasharray: 2 3;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .status {\n    display: inline-block;\n    padding: 2px 8px;\n    border-radius: 3px;\n    font-size: 0.85rem;\n    font-weight: 600;\n  }\n  .status.viable {\n    background: rgba(45, 122, 79, 0.2);\n    color: #1f5438;\n  }\n  .status.violation {\n    background: rgba(201, 51, 46, 0.2);\n    color: #9d2826;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 480px) {\n    .control {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control output {\n      text-align: left;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to adjust exposure level</h2>\n<p class=\"subhead\">Two thresholds define where a system can operate without violating either limit.</p>\n\n<div class=\"control\">\n  <label for=\"exposure\">Exposure:</label>\n  <input id=\"exposure\" type=\"range\" min=\"0\" max=\"100\" value=\"50\" aria-describedby=\"exposure-out\">\n  <output id=\"exposure-out\" for=\"exposure\">50</output>\n</div>\n\n<div class=\"chart-container\">\n  <svg id=\"chart\" viewBox=\"0 0 400 320\" xmlns=\"http://www.w3.org/2000/svg\">\n    <!-- Grid lines -->\n    <line class=\"grid-line\" x1=\"40\" y1=\"80\" x2=\"360\" y2=\"80\" />\n    <line class=\"grid-line\" x1=\"40\" y1=\"160\" x2=\"360\" y2=\"160\" />\n    <line class=\"grid-line\" x1=\"40\" y1=\"240\" x2=\"360\" y2=\"240\" />\n    <line class=\"grid-line\" x1=\"120\" y1=\"20\" x2=\"120\" y2=\"280\" />\n    <line class=\"grid-line\" x1=\"200\" y1=\"20\" x2=\"200\" y2=\"280\" />\n    <line class=\"grid-line\" x1=\"280\" y1=\"20\" x2=\"280\" y2=\"280\" />\n    \n    <!-- Danger regions -->\n    <rect class=\"danger-region\" x=\"40\" y=\"20\" width=\"320\" height=\"70\" />\n    <rect class=\"danger-region\" x=\"40\" y=\"230\" width=\"320\" height=\"50\" />\n    \n    <!-- Safe region -->\n    <rect class=\"safe-region\" x=\"40\" y=\"90\" width=\"320\" height=\"140\" />\n    \n    <!-- Upper threshold (damage limit) -->\n    <path id=\"upper-threshold\" class=\"threshold-line\" stroke=\"var(--danger)\" />\n    \n    <!-- Lower threshold (starvation limit) -->\n    <path id=\"lower-threshold\" class=\"threshold-line\" stroke=\"var(--danger)\" />\n    \n    <!-- Axes -->\n    <line x1=\"40\" y1=\"20\" x2=\"40\" y2=\"280\" stroke=\"var(--fg)\" stroke-width=\"2\" />\n    <line x1=\"40\" y1=\"280\" x2=\"360\" y2=\"280\" stroke=\"var(--fg)\" stroke-width=\"2\" />\n    \n    <!-- Axis labels -->\n    <text class=\"axis-label\" x=\"200\" y=\"300\" text-anchor=\"middle\">Exposure</text>\n    <text class=\"axis-label\" x=\"10\" y=\"150\" text-anchor=\"middle\" transform=\"rotate(-90 10 150)\">Load per unit</text>\n    \n    <!-- Threshold labels -->\n    <text class=\"axis-label\" x=\"365\" y=\"85\" text-anchor=\"start\">damage</text>\n    <text class=\"axis-label\" x=\"365\" y=\"235\" text-anchor=\"start\">starvation</text>\n    \n    <!-- Current position marker -->\n    <circle id=\"marker\" class=\"current-point\" cx=\"200\" cy=\"150\" r=\"7\" />\n  </svg>\n</div>\n\n<div class=\"reading\">\n  Status: <span class=\"status\" id=\"status\">viable</span><br>\n  <strong id=\"description\">Within the envelope. Both limits satisfied.</strong>\n</div>\n\n<p class=\"caption\" id=\"caption\">At moderate exposure, load per unit stays between the two thresholds. The system operates safely.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('exposure');\n    var exposureOut = document.getElementById('exposure-out');\n    var marker = document.getElementById('marker');\n    var upperPath = document.getElementById('upper-threshold');\n    var lowerPath = document.getElementById('lower-threshold');\n    var status = document.getElementById('status');\n    var description = document.getElementById('description');\n    var caption = document.getElementById('caption');\n\n    // Chart dimensions: x from 40 to 360, y from 20 to 280.\n    // At low exposure: units spread out → load per unit is LOW (risk: starvation).\n    // At high exposure: units cluster → load per unit is HIGH (risk: damage).\n    // Upper threshold (damage): load must stay BELOW this.\n    // Lower threshold (starvation): load must stay ABOVE this.\n    // Both thresholds move with exposure, narrowing the envelope at extremes.\n\n    function exposureToX(e) {\n      return 40 + (e / 100) * 320;\n    }\n\n    function exposureToLoadPerUnit(e) {\n      // Load per unit increases with exposure (clustering).\n      // At e=0: load=20 (too low, starves).\n      // At e=50: load=150 (safe zone center).\n      // At e=100: load=260 (too high, damages).\n      // Linear rise: load = 20 + 2.4 * e.\n      return 280 - (20 + 2.4 * e);\n    }\n\n    function upperThreshold(e) {\n      // Damage threshold: FALLS as exposure increases (clustering reduces margin).\n      // At e=0: y=60 (plenty of headroom).\n      // At e=50: y=90 (threshold lowering).\n      // At e=100: y=140 (very tight).\n      // Exponential fall: y = 60 + 0.8 * e.\n      return 60 + 0.6 * e;\n    }\n\n    function lowerThreshold(e) {\n      // Starvation threshold: RISES as exposure increases (spreading margin shrinks).\n      // At e=0: y=250 (very tight).\n      // At e=50: y=230.\n      // At e=100: y=210 (plenty of headroom).\n      // Linear rise: y = 250 - 0.4 * e.\n      return 250 - 0.4 * e;\n    }\n\n    function update() {\n      var e = +slider.value;\n      exposureOut.textContent = e;\n\n      var x = exposureToX(e);\n      var y = exposureToLoadPerUnit(e);\n      marker.setAttribute('cx', x);\n      marker.setAttribute('cy', y);\n\n      // Draw threshold lines across the chart.\n      var upperY = upperThreshold(e);\n      var lowerY = lowerThreshold(e);\n      upperPath.setAttribute('d', 'M 40 ' + upperY + ' L 360 ' + upperY);\n      lowerPath.setAttribute('d', 'M 40 ' + lowerY + ' L 360 ' + lowerY);\n\n      // Check violations.\n      var aboveDamage = y < upperY;\n      var belowStarvation = y > lowerY;\n\n      if (aboveDamage) {\n        status.className = 'status violation';\n        status.textContent = 'violation';\n        description.textContent = 'Load per unit exceeds the damage threshold. Units fail under the burden.';\n        caption.textContent = 'High exposure pushes load above the safe ceiling. The damage limit is breached.';\n      } else if (belowStarvation) {\n        status.className = 'status violation';\n        status.textContent = 'violation';\n        description.textContent = 'Load per unit falls below the starvation threshold. Units cannot sustain operation.';\n        caption.textContent = 'Low exposure drops load below the safe floor. The starvation limit is breached.';\n      } else {\n        status.className = 'status viable';\n        status.textContent = 'viable';\n        var margin = Math.min(y - upperY, lowerY - y);\n        if (margin > 40) {\n          description.textContent = 'Within the envelope. Both limits satisfied.';\n          caption.textContent = 'At moderate exposure, load per unit stays between the two thresholds. The system operates safely.';\n        } else if (y - upperY < lowerY - y) {\n          description.textContent = 'Safe, but nearing the damage ceiling. A bit more exposure and units overload.';\n          caption.textContent = 'Close to the upper threshold. Still viable, but margin is thin.';\n        } else {\n          description.textContent = 'Safe, but nearing the starvation floor. A bit less exposure and units fail.';\n          caption.textContent = 'Close to the lower threshold. Still viable, but margin is thin.';\n        }\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
