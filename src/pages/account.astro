---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getUser } from '../lib/db';
import { formatDate, formatShortDate } from '../lib/format';
import { getCollection } from 'astro:content';
import { deriveSlug, pieceUrl } from '../lib/slug';
import { FALLBACK_SLUG } from '../lib/categories';

const db = Astro.locals.runtime.env.DB;
const userId = Astro.locals.userId;
const user = await getUser(db, userId);

const hasEmail = !!user?.email;

let memberSince = '';
if (hasEmail && user?.created_at) {
  const iso = new Date(user.created_at).toISOString().slice(0, 10);
  memberSince = formatDate(iso);
}

// ── Resume: most recent in-progress read ──────────────────────────
interface ResumeRow {
  piece_id: string;
  current_beat: string | null;
  started_at: number;
  last_seen_at: number;
}

let resumeRow: ResumeRow | null = null;
try {
  resumeRow = await db
    .prepare(
      `SELECT piece_id, current_beat, started_at, last_seen_at
       FROM user_piece_reads
       WHERE user_id = ? AND completed_at IS NULL
       ORDER BY last_seen_at DESC
       LIMIT 1`,
    )
    .bind(userId)
    .first<ResumeRow>();
} catch { /* table may not exist in dev */ }

// ── Recently read: latest 10 completed pieces ─────────────────────
interface RecentRow {
  piece_id: string;
  completed_at: number;
}

let recentRows: RecentRow[] = [];
let recentTotal = 0;
try {
  const result = await db
    .prepare(
      `SELECT piece_id, completed_at
       FROM user_piece_reads
       WHERE user_id = ? AND completed_at IS NOT NULL
       ORDER BY completed_at DESC
       LIMIT 10`,
    )
    .bind(userId)
    .all<RecentRow>();
  recentRows = result.results ?? [];

  const totalRow = await db
    .prepare(
      `SELECT COUNT(*) AS n
       FROM user_piece_reads
       WHERE user_id = ? AND completed_at IS NOT NULL`,
    )
    .bind(userId)
    .first<{ n: number }>();
  recentTotal = totalRow?.n ?? 0;
} catch { /* fall through to empty list */ }

// ── Streak: distinct days of activity in last 14 days ─────────────
const fourteenDaysAgo = Date.now() - 14 * 24 * 60 * 60 * 1000;
let streakDays = 0;
try {
  const row = await db
    .prepare(
      `SELECT COUNT(DISTINCT date(last_seen_at / 1000, 'unixepoch')) AS n
       FROM user_piece_reads
       WHERE user_id = ? AND last_seen_at >= ?`,
    )
    .bind(userId, fourteenDaysAgo)
    .first<{ n: number }>();
  streakDays = row?.n ?? 0;
} catch { /* fall through to 0 */ }

// ── Subjects: top categories among the user's completed pieces ────
interface SubjectRow { slug: string; name: string; n: number }
let subjects: SubjectRow[] = [];
try {
  const result = await db
    .prepare(
      `SELECT c.slug, c.name, COUNT(*) AS n
       FROM user_piece_reads upr
       JOIN piece_categories pc ON pc.piece_id = upr.piece_id
       JOIN categories c ON c.id = pc.category_id
       WHERE upr.user_id = ? AND upr.completed_at IS NOT NULL AND c.slug != ?
       GROUP BY c.id
       ORDER BY n DESC
       LIMIT 5`,
    )
    .bind(userId, FALLBACK_SLUG)
    .all<SubjectRow>();
  subjects = result.results ?? [];
} catch { /* fall through */ }

const totalCompleted = recentTotal; // alias for the threshold check below

// ── Quizzes: completed interactive_engagement rows ────────────────
interface QuizRow {
  score: number | null;
  per_question_correctness: string | null;
  created_at: number;
  slug: string;
  title: string;
}

let quizRows: QuizRow[] = [];
try {
  const result = await db
    .prepare(
      `SELECT ie.score, ie.per_question_correctness, ie.created_at, i.slug, i.title
       FROM interactive_engagement ie
       JOIN interactives i ON i.id = ie.interactive_id
       WHERE ie.user_id = ? AND ie.event_type = 'completed'
       ORDER BY ie.created_at DESC`,
    )
    .bind(userId)
    .all<QuizRow>();
  quizRows = result.results ?? [];
} catch { /* fall through */ }

// Aggregate + parse per_question_correctness JSON arrays.
const quizzes = quizRows.map((r) => {
  let total = 0;
  if (r.per_question_correctness) {
    try {
      const arr = JSON.parse(r.per_question_correctness);
      if (Array.isArray(arr)) total = arr.length;
    } catch { /* malformed JSON, skip */ }
  }
  return { ...r, total };
});

const quizCount = quizzes.length;
const quizScoreSum = quizzes.reduce((acc, q) => acc + (q.score ?? 0), 0);
const quizTotalSum = quizzes.reduce((acc, q) => acc + q.total, 0);
const quizPct = quizTotalSum > 0 ? Math.round((quizScoreSum / quizTotalSum) * 100) : 0;
const recentQuizzes = quizzes.slice(0, 5);

// ── Zita conversations: grouped by piece_id (or piece_date for older
//    rows with null piece_id, until those age out post-Step-10). ───
interface ZitaRow {
  piece_id: string | null;
  piece_date: string | null;
  messages: number;
  last_at: number;
}
let zitaRows: ZitaRow[] = [];
try {
  const result = await db
    .prepare(
      `SELECT piece_id, piece_date, COUNT(*) AS messages, MAX(created_at) AS last_at
       FROM zita_messages
       WHERE user_id = ? AND role = 'user'
       GROUP BY COALESCE(piece_id, piece_date)
       ORDER BY last_at DESC
       LIMIT 5`,
    )
    .bind(userId)
    .all<ZitaRow>();
  zitaRows = result.results ?? [];
} catch { /* fall through */ }

// ── Build a piece_id → entry map for the rows we'll render ────────
const piecesNeeded = new Set<string>();
if (resumeRow) piecesNeeded.add(resumeRow.piece_id);
for (const r of recentRows) piecesNeeded.add(r.piece_id);

const datesNeeded = new Set<string>();
for (const z of zitaRows) {
  if (z.piece_id) piecesNeeded.add(z.piece_id);
  else if (z.piece_date) datesNeeded.add(z.piece_date);
}

const allPieces = await getCollection('dailyPieces');
const pieceMap = new Map<string, (typeof allPieces)[number]>();
const dateMap = new Map<string, (typeof allPieces)[number]>();
for (const entry of allPieces) {
  if (piecesNeeded.has(entry.data.pieceId)) {
    pieceMap.set(entry.data.pieceId, entry);
  }
  if (datesNeeded.has(entry.data.date) && !dateMap.has(entry.data.date)) {
    dateMap.set(entry.data.date, entry);
  }
}

// Resolve the resume card data; null if entry missing (orphan piece_id).
let resume: {
  headline: string;
  url: string;
  startedDisplay: string;
  beatLabel: string | null;
} | null = null;
if (resumeRow) {
  const entry = pieceMap.get(resumeRow.piece_id);
  if (entry) {
    const slug = deriveSlug(entry.id);
    const baseUrl = pieceUrl(entry.data.date, slug);
    const url = resumeRow.current_beat ? `${baseUrl}#${resumeRow.current_beat}` : baseUrl;
    const startedIso = new Date(resumeRow.started_at).toISOString().slice(0, 10);
    const startedDisplay = formatDate(startedIso);
    const beatLabel = resumeRow.current_beat
      ? humanise(entry.data.beatTitles?.[resumeRow.current_beat] ?? resumeRow.current_beat)
      : null;
    resume = {
      headline: entry.data.title,
      url,
      startedDisplay,
      beatLabel,
    };
  }
}

// Resolve the recently-read list. Skip rows with no matching collection
// entry (orphan piece_ids).
const recent: { headline: string; url: string; subject: string | null; dateDisplay: string }[] = [];
for (const r of recentRows) {
  const entry = pieceMap.get(r.piece_id);
  if (!entry) continue;
  recent.push({
    headline: entry.data.title,
    url: pieceUrl(entry.data.date, deriveSlug(entry.id)),
    subject: entry.data.underlyingSubject ?? null,
    dateDisplay: formatShortDate(r.completed_at),
  });
}

// Resolve Zita conversations into renderable rows.
const zitaConversations: { headline: string; url: string; messages: number; lastDisplay: string }[] = [];
for (const z of zitaRows) {
  const entry = z.piece_id ? pieceMap.get(z.piece_id) : z.piece_date ? dateMap.get(z.piece_date) : null;
  if (!entry) continue;
  zitaConversations.push({
    headline: entry.data.title,
    url: pieceUrl(entry.data.date, deriveSlug(entry.id)),
    messages: z.messages,
    lastDisplay: formatShortDate(z.last_at),
  });
}

function humanise(s: string): string {
  // If it already contains spaces or capitals, treat as already-human.
  if (/[A-Z\s]/.test(s)) return s;
  return s
    .split('-')
    .filter(Boolean)
    .map((w) => w[0].toUpperCase() + w.slice(1))
    .join(' ');
}
---

<BaseLayout title="Account — Zeemish">

  <header class="pt-6 pb-10">
    {memberSince && (
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-gold mb-2">
        Member since {memberSince}
      </p>
    )}
    <h1 class="text-3xl md:text-4xl font-bold leading-tight tracking-tight">Account</h1>
  </header>

  {resume ? (
    <section class="mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-3">
        Continue reading
      </p>
      <a href={resume.url} class="block p-5 rounded-xl border border-zee-border hover:border-zee-primary/40 transition-colors no-underline">
        <h2 class="text-xl md:text-2xl font-bold text-zee-text leading-snug mb-2">
          {resume.headline}
        </h2>
        <p class="text-sm text-zee-muted mb-4">
          {resume.beatLabel && <>On: <span class="text-zee-text">{resume.beatLabel}</span> · </>}
          Started {resume.startedDisplay}
        </p>
        <span class="text-sm text-zee-primary font-medium">Continue <span aria-hidden="true">→</span></span>
      </a>
      {streakDays >= 2 && (
        <p class="mt-3 text-sm text-zee-muted">
          You've read {streakDays} of the last 14 days.
        </p>
      )}
    </section>
  ) : (
    <section class="mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-3">
        Today's piece
      </p>
      <a href="/daily/" class="block p-5 rounded-xl border border-zee-border hover:border-zee-primary/40 transition-colors no-underline">
        <p class="text-base text-zee-text mb-1">Read today's piece</p>
        <span class="text-sm text-zee-primary font-medium">Go to Daily <span aria-hidden="true">→</span></span>
      </a>
      {streakDays >= 2 && (
        <p class="mt-3 text-sm text-zee-muted">
          You've read {streakDays} of the last 14 days.
        </p>
      )}
    </section>
  )}

  {recent.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
        Recently read
      </h2>
      <ul class="space-y-4">
        {recent.map((r) => (
          <li>
            <p class="text-xs text-zee-muted mb-1">{r.dateDisplay}</p>
            <a href={r.url} class="text-base text-zee-text hover:text-zee-primary transition-colors leading-snug">
              {r.headline}
            </a>
            {r.subject && (
              <p class="text-xs text-zee-muted mt-1">{r.subject}</p>
            )}
          </li>
        ))}
      </ul>
      {recentTotal > recent.length && (
        <a href="/library/" class="mt-5 inline-block text-sm text-zee-primary hover:underline underline-offset-2">
          See all in library <span aria-hidden="true">→</span>
        </a>
      )}
    </section>
  )}

  {totalCompleted >= 3 && subjects.length >= 2 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
        Subjects you've been reading
      </h2>
      <p class="text-base text-zee-text leading-relaxed" set:html={
        "You've read " + subjects.map((s, i) => {
          const sep = i === 0 ? '' : i === subjects.length - 1 ? ', and ' : ', ';
          const count = `${s.n} ${s.n === 1 ? 'piece' : 'pieces'} in `;
          const safeName = s.name.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          return `${sep}${count}<a href="/library/${s.slug}/" class="font-bold text-zee-text hover:text-zee-primary transition-colors underline-offset-2 hover:underline">${safeName}</a>`;
        }).join('') + '.'
      } />
    </section>
  )}

  {quizCount > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
        Quizzes you've taken
      </h2>
      <p class="text-base text-zee-text mb-4">
        You've taken {quizCount} {quizCount === 1 ? 'quiz' : 'quizzes'}.
        {quizTotalSum > 0 && (
          <> Overall: {quizScoreSum} of {quizTotalSum} correct ({quizPct}%).</>
        )}
      </p>
      <ul class="space-y-3">
        {recentQuizzes.map((q) => (
          <li class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <span class="text-xs text-zee-muted">{formatShortDate(q.created_at)}</span>
            <a href={`/interactives/${q.slug}/`} class="text-base text-zee-text hover:text-zee-primary transition-colors">
              {q.title}
            </a>
            {q.total > 0 && (
              <span class="text-sm text-zee-muted">{q.score ?? 0} of {q.total}</span>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  {zitaConversations.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zee-muted mb-4">
        Your questions
      </h2>
      <ul class="space-y-3">
        {zitaConversations.map((z) => (
          <li class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <a href={z.url} class="text-base text-zee-text hover:text-zee-primary transition-colors">
              {z.headline}
            </a>
            <span class="text-sm text-zee-muted">
              {z.messages} {z.messages === 1 ? 'message' : 'messages'} · {z.lastDisplay}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="pb-10 text-zee-text">
    {hasEmail ? (
      <>
        <p class="text-sm text-zee-muted">Signed in as <span class="text-zee-text">{user!.email}</span>.</p>
        <button
          id="logout-btn"
          class="mt-3 text-sm text-zee-muted hover:text-zee-text transition-colors underline-offset-2 hover:underline"
        >
          Log out
        </button>
      </>
    ) : (
      <>
        <p class="text-sm text-zee-muted">Reading anonymously on this device.</p>
        <a
          href="/login/?upgrade=1"
          class="mt-3 inline-block text-sm text-zee-primary hover:underline underline-offset-2"
        >
          Sign in to sync <span aria-hidden="true">→</span>
        </a>
      </>
    )}
  </section>

</BaseLayout>

<script>
  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });
</script>
