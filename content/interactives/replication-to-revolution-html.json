{
  "slug": "replication-to-revolution",
  "type": "html",
  "title": "Replication, Prediction, Validation",
  "concept": "A surprising measurement crosses three thresholds to become established knowledge: replication confirms the pattern is real, prediction tests whether you understand the mechanism, and validation confirms the mechanism holds.",
  "interactiveId": "ad471170-bc65-4101-9afc-30e23f774bc5",
  "sourcePieceId": "cf1dca3e-8b79-4ad8-915a-0bb911755cbd",
  "publishedAt": 1778249502853,
  "voiceScore": 94,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Replication, Prediction, Validation</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c93b27;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .findings {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    margin: 24px 0;\n  }\n  .finding {\n    padding: 12px 14px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 6px;\n    cursor: pointer;\n    transition: border-color 150ms ease-out, background 150ms ease-out;\n    user-select: none;\n  }\n  .finding:hover {\n    border-color: var(--teal);\n  }\n  .finding.selected {\n    border-color: var(--teal);\n    background: #f0f8f7;\n  }\n  .finding-title {\n    font-weight: 600;\n    font-size: 0.95rem;\n    margin-bottom: 4px;\n  }\n  .finding-props {\n    font-size: 0.8rem;\n    color: var(--muted);\n    display: flex;\n    gap: 14px;\n    flex-wrap: wrap;\n  }\n  .prop {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n  .prop-label {\n    font-weight: 500;\n  }\n  .gates {\n    margin: 28px 0;\n    display: flex;\n    gap: 20px;\n    align-items: stretch;\n  }\n  .gate {\n    flex: 1;\n    padding: 16px;\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    position: relative;\n    transition: border-color 200ms ease-out, background 200ms ease-out;\n  }\n  .gate.pass {\n    border-color: var(--teal);\n    background: #f0f8f7;\n  }\n  .gate.fail {\n    border-color: var(--red);\n    background: #fdf3f2;\n  }\n  .gate-number {\n    position: absolute;\n    top: -12px;\n    left: 14px;\n    width: 24px;\n    height: 24px;\n    border-radius: 50%;\n    background: var(--line);\n    color: var(--muted);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    font-size: 0.85rem;\n    transition: background 200ms ease-out, color 200ms ease-out;\n  }\n  .gate.pass .gate-number {\n    background: var(--teal);\n    color: #fff;\n  }\n  .gate.fail .gate-number {\n    background: var(--red);\n    color: #fff;\n  }\n  .gate-title {\n    font-weight: 600;\n    font-size: 0.9rem;\n    margin: 6px 0 8px;\n  }\n  .gate-desc {\n    font-size: 0.8rem;\n    color: var(--muted);\n    line-height: 1.4;\n    margin-bottom: 10px;\n  }\n  .gate-result {\n    font-size: 0.85rem;\n    font-weight: 500;\n    padding-top: 8px;\n    border-top: 1px solid var(--line);\n    min-height: 2.5em;\n  }\n  .gate.pass .gate-result {\n    color: var(--teal);\n  }\n  .gate.fail .gate-result {\n    color: var(--red);\n  }\n  .status {\n    margin: 20px 0 0;\n    padding: 12px 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .status strong {\n    font-weight: 600;\n  }\n  .status.established {\n    border-color: var(--gold);\n    background: #fffbf0;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n    line-height: 1.4;\n  }\n  @media (max-width: 600px) {\n    .gates {\n      flex-direction: column;\n    }\n    .finding-props {\n      flex-direction: column;\n      gap: 6px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Pick a measurement and watch it pass through the three gates</h2>\n<p class=\"subhead\">Each finding has different properties. The gates test those properties.</p>\n\n<div class=\"findings\">\n  <div class=\"finding\" data-index=\"0\">\n    <div class=\"finding-title\">Finding A</div>\n    <div class=\"finding-props\">\n      <span class=\"prop\"><span class=\"prop-label\">Convergence:</span> high</span>\n      <span class=\"prop\"><span class=\"prop-label\">Predictions:</span> yes</span>\n      <span class=\"prop\"><span class=\"prop-label\">Match:</span> 94%</span>\n    </div>\n  </div>\n  <div class=\"finding\" data-index=\"1\">\n    <div class=\"finding-title\">Finding B</div>\n    <div class=\"finding-props\">\n      <span class=\"prop\"><span class=\"prop-label\">Convergence:</span> low</span>\n      <span class=\"prop\"><span class=\"prop-label\">Predictions:</span> yes</span>\n      <span class=\"prop\"><span class=\"prop-label\">Match:</span> 87%</span>\n    </div>\n  </div>\n  <div class=\"finding\" data-index=\"2\">\n    <div class=\"finding-title\">Finding C</div>\n    <div class=\"finding-props\">\n      <span class=\"prop\"><span class=\"prop-label\">Convergence:</span> high</span>\n      <span class=\"prop\"><span class=\"prop-label\">Predictions:</span> no</span>\n      <span class=\"prop\"><span class=\"prop-label\">Match:</span> —</span>\n    </div>\n  </div>\n  <div class=\"finding\" data-index=\"3\">\n    <div class=\"finding-title\">Finding D</div>\n    <div class=\"finding-props\">\n      <span class=\"prop\"><span class=\"prop-label\">Convergence:</span> high</span>\n      <span class=\"prop\"><span class=\"prop-label\">Predictions:</span> yes</span>\n      <span class=\"prop\"><span class=\"prop-label\">Match:</span> 42%</span>\n    </div>\n  </div>\n  <div class=\"finding\" data-index=\"4\">\n    <div class=\"finding-title\">Finding E</div>\n    <div class=\"finding-props\">\n      <span class=\"prop\"><span class=\"prop-label\">Convergence:</span> high</span>\n      <span class=\"prop\"><span class=\"prop-label\">Predictions:</span> yes</span>\n      <span class=\"prop\"><span class=\"prop-label\">Match:</span> 91%</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"gates\">\n  <div class=\"gate\" id=\"gate-1\">\n    <div class=\"gate-number\">1</div>\n    <div class=\"gate-title\">Replication</div>\n    <div class=\"gate-desc\">Do independent teams see the same pattern?</div>\n    <div class=\"gate-result\" id=\"result-1\"></div>\n  </div>\n  <div class=\"gate\" id=\"gate-2\">\n    <div class=\"gate-number\">2</div>\n    <div class=\"gate-title\">Prediction</div>\n    <div class=\"gate-desc\">Does it predict something new we can test?</div>\n    <div class=\"gate-result\" id=\"result-2\"></div>\n  </div>\n  <div class=\"gate\" id=\"gate-3\">\n    <div class=\"gate-number\">3</div>\n    <div class=\"gate-title\">Validation</div>\n    <div class=\"gate-desc\">Do the predictions hold when checked?</div>\n    <div class=\"gate-result\" id=\"result-3\"></div>\n  </div>\n</div>\n\n<div class=\"status\" id=\"status\">\n  <strong>Status:</strong> <span id=\"status-text\">Select a finding to test.</span>\n</div>\n\n<p class=\"caption\" id=\"caption\">Convergence measures whether different instruments agree. Predictions test whether you understand the mechanism. Match measures how well predictions align with observations.</p>\n\n<script>\n  (function () {\n    var findings = [\n      {conv: 'high', pred: true, match: 94},\n      {conv: 'low', pred: true, match: 87},\n      {conv: 'high', pred: false, match: null},\n      {conv: 'high', pred: true, match: 42},\n      {conv: 'high', pred: true, match: 91}\n    ];\n\n    var findingEls = document.querySelectorAll('.finding');\n    var gate1 = document.getElementById('gate-1');\n    var gate2 = document.getElementById('gate-2');\n    var gate3 = document.getElementById('gate-3');\n    var result1 = document.getElementById('result-1');\n    var result2 = document.getElementById('result-2');\n    var result3 = document.getElementById('result-3');\n    var statusEl = document.getElementById('status');\n    var statusText = document.getElementById('status-text');\n    var caption = document.getElementById('caption');\n\n    function reset() {\n      gate1.classList.remove('pass', 'fail');\n      gate2.classList.remove('pass', 'fail');\n      gate3.classList.remove('pass', 'fail');\n      result1.textContent = '';\n      result2.textContent = '';\n      result3.textContent = '';\n      statusEl.classList.remove('established');\n    }\n\n    function test(index) {\n      reset();\n      var f = findings[index];\n      var passed = 0;\n\n      // Gate 1: replication\n      if (f.conv === 'high') {\n        gate1.classList.add('pass');\n        result1.textContent = 'Pass — independent teams agree.';\n        passed++;\n      } else {\n        gate1.classList.add('fail');\n        result1.textContent = 'Fail — measurements differ across instruments.';\n        statusText.textContent = 'Stopped at gate 1. Different teams see different patterns. This is noise or instrument error, not a real signal.';\n        caption.textContent = 'Low convergence means the measurement does not replicate. Without replication, there is no pattern to explain.';\n        return;\n      }\n\n      // Gate 2: prediction\n      if (f.pred) {\n        gate2.classList.add('pass');\n        result2.textContent = 'Pass — generates testable predictions.';\n        passed++;\n      } else {\n        gate2.classList.add('fail');\n        result2.textContent = 'Fail — no testable predictions.';\n        statusText.textContent = 'Stopped at gate 2. The pattern replicates but generates no predictions. A curiosity without a mechanism.';\n        caption.textContent = 'Replication confirms the pattern is real. But without predictions, we have no way to test whether we understand it.';\n        return;\n      }\n\n      // Gate 3: validation\n      if (f.match >= 80) {\n        gate3.classList.add('pass');\n        result3.textContent = 'Pass — predictions match observations (' + f.match + '%).';\n        passed++;\n        statusEl.classList.add('established');\n        statusText.textContent = 'All three gates passed. The measurement is real, the mechanism is understood, and the predictions hold. Established knowledge.';\n        caption.textContent = 'Replication ruled out noise. Predictions tested the mechanism. Validation confirmed the mechanism is real. This finding becomes a foundation.';\n      } else {\n        gate3.classList.add('fail');\n        result3.textContent = 'Fail — predictions mismatch observations (' + f.match + '%).';\n        statusText.textContent = 'Stopped at gate 3. The pattern replicates and makes predictions, but the predictions do not hold. The explanation is wrong.';\n        caption.textContent = 'A low match means the mechanism we proposed does not fit reality. The measurement is real, but our understanding is incomplete.';\n      }\n    }\n\n    findingEls.forEach(function (el) {\n      el.addEventListener('click', function () {\n        findingEls.forEach(function (e) { e.classList.remove('selected'); });\n        el.classList.add('selected');\n        var idx = +el.getAttribute('data-index');\n        test(idx);\n      });\n    });\n  })();\n</script>\n</body>\n</html>"
  }
}
