  "title": "Activation-Dependent Survival",
  "concept": "Connections you activate regularly survive; connections you neglect fade and eventually disappear—individual use history determines which links persist.",
  "interactiveId": "f0b4a97f-8677-4bb7-b369-f1ba6bed0a2d",
  "sourcePieceId": "9536b2c6-35aa-461c-9748-68ad2a73685e",
  "publishedAt": 1778508423912,
  "voiceScore": 88,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Activation-Dependent Survival</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --strong: #1a6b62;\n    --fading: #c9a227;\n    --gone: #d4d4d4;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .network {\n    margin: 24px auto;\n    max-width: 500px;\n    height: 320px;\n    position: relative;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    background: #fff;\n    cursor: crosshair;\n  }\n  svg {\n    width: 100%;\n    height: 100%;\n  }\n  .link {\n    stroke-width: 3;\n    transition: stroke 200ms ease-out, opacity 200ms ease-out;\n    pointer-events: stroke;\n    cursor: pointer;\n  }\n  .link:hover {\n    stroke-width: 5;\n  }\n  .node {\n    transition: fill 200ms ease-out;\n    pointer-events: none;\n  }\n  .controls {\n    display: flex;\n    justify-content: center;\n    gap: 12px;\n    margin: 16px 0;\n  }\n  button {\n    padding: 8px 16px;\n    font-size: 0.9rem;\n    font-weight: 500;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    background: #fff;\n    color: var(--fg);\n    cursor: pointer;\n    transition: all 150ms ease-out;\n  }\n  button:hover {\n    background: var(--strong);\n    color: #fff;\n    border-color: var(--strong);\n  }\n  button:active {\n    transform: scale(0.96);\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  .stat-row {\n    display: flex;\n    justify-content: space-between;\n    margin-top: 8px;\n    gap: 12px;\n  }\n  .stat {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 0.85rem;\n  }\n  .stat .dot {\n    width: 10px;\n    height: 10px;\n    border-radius: 50%;\n  }\n  .stat .dot.strong { background: var(--strong); }\n  .stat .dot.fading { background: var(--fading); }\n  .stat .dot.gone { background: var(--gone); }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  .instruction {\n    text-align: center;\n    margin: 12px 0;\n    font-size: 0.9rem;\n    color: var(--muted);\n  }\n  .instruction strong {\n    color: var(--fg);\n  }\n  @media (max-width: 480px) {\n    .network {\n      height: 280px;\n    }\n    .stat-row {\n      flex-direction: column;\n      gap: 6px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Click connections to keep them alive</h2>\n<p class=\"subhead\">A network where links survive only if you activate them regularly.</p>\n\n<div class=\"network\" role=\"application\" aria-label=\"Interactive network where clicking connections keeps them alive\">\n  <svg id=\"svg\"></svg>\n</div>\n\n<p class=\"instruction\"><strong>Click any line</strong> to activate that connection. Each tick, unused connections fade.</p>\n\n<div class=\"controls\">\n  <button id=\"tick-btn\">Advance one tick</button>\n  <button id=\"reset-btn\">Reset</button>\n</div>\n\n<div class=\"reading\">\n  Active connections: <strong id=\"strong-count\">12</strong> | \n  Fading: <strong id=\"fading-count\">0</strong> | \n  Lost: <strong id=\"gone-count\">0</strong>\n  <div class=\"stat-row\">\n    <div class=\"stat\"><span class=\"dot strong\"></span>Strong (used recently)</div>\n    <div class=\"stat\"><span class=\"dot fading\"></span>Fading (not used in 2+ ticks)</div>\n    <div class=\"stat\"><span class=\"dot gone\"></span>Gone (not used in 4+ ticks)</div>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">All connections start strong. Click them to keep them alive as time passes.</p>\n\n<script>\n(function() {\n  var svg = document.getElementById('svg');\n  var tickBtn = document.getElementById('tick-btn');\n  var resetBtn = document.getElementById('reset-btn');\n  var strongCountEl = document.getElementById('strong-count');\n  var fadingCountEl = document.getElementById('fading-count');\n  var goneCountEl = document.getElementById('gone-count');\n  var caption = document.getElementById('caption');\n  \n  var nodes = [\n    {x: 0.15, y: 0.25},\n    {x: 0.5, y: 0.15},\n    {x: 0.85, y: 0.25},\n    {x: 0.15, y: 0.5},\n    {x: 0.5, y: 0.5},\n    {x: 0.85, y: 0.5},\n    {x: 0.15, y: 0.75},\n    {x: 0.5, y: 0.85},\n    {x: 0.85, y: 0.75}\n  ];\n  \n  var linkDefs = [\n    {source: 0, target: 1},\n    {source: 1, target: 2},\n    {source: 0, target: 3},\n    {source: 1, target: 4},\n    {source: 2, target: 5},\n    {source: 3, target: 4},\n    {source: 4, target: 5},\n    {source: 3, target: 6},\n    {source: 4, target: 7},\n    {source: 5, target: 8},\n    {source: 6, target: 7},\n    {source: 7, target: 8}\n  ];\n  \n  var links = [];\n  var tickCount = 0;\n  \n  function init() {\n    links = linkDefs.map(function(def) {\n      return {\n        source: def.source,\n        target: def.target,\n        lastUsed: 0,\n        element: null\n      };\n    });\n    tickCount = 0;\n    render();\n    updateStats();\n  }\n  \n  function toCoords(node, width, height) {\n    return {\n      x: node.x * width,\n      y: node.y * height\n    };\n  }\n  \n  function getState(link) {\n    var age = tickCount - link.lastUsed;\n    if (age >= 4) return 'gone';\n    if (age >= 2) return 'fading';\n    return 'strong';\n  }\n  \n  function getColor(state) {\n    if (state === 'strong') return '#1a6b62';\n    if (state === 'fading') return '#c9a227';\n    return '#d4d4d4';\n  }\n  \n  function getOpacity(state) {\n    if (state === 'strong') return 0.9;\n    if (state === 'fading') return 0.5;\n    return 0.2;\n  }\n  \n  function render() {\n    var rect = svg.getBoundingClientRect();\n    var width = rect.width;\n    var height = rect.height;\n    \n    svg.innerHTML = '';\n    \n    links.forEach(function(link) {\n      var src = toCoords(nodes[link.source], width, height);\n      var tgt = toCoords(nodes[link.target], width, height);\n      var state = getState(link);\n      \n      var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n      line.setAttribute('x1', src.x);\n      line.setAttribute('y1', src.y);\n      line.setAttribute('x2', tgt.x);\n      line.setAttribute('y2', tgt.y);\n      line.setAttribute('class', 'link');\n      line.setAttribute('stroke', getColor(state));\n      line.setAttribute('opacity', getOpacity(state));\n      line.setAttribute('data-link-id', links.indexOf(link));\n      \n      line.addEventListener('click', function(e) {\n        e.stopPropagation();\n        link.lastUsed = tickCount;\n        render();\n        updateStats();\n        if (window.parent) {\n          window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n        }\n      });\n      \n      svg.appendChild(line);\n      link.element = line;\n    });\n    \n    nodes.forEach(function(node) {\n      var coords = toCoords(node, width, height);\n      var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('cx', coords.x);\n      circle.setAttribute('cy', coords.y);\n      circle.setAttribute('r', 5);\n      circle.setAttribute('class', 'node');\n      circle.setAttribute('fill', '#1a1a1a');\n      svg.appendChild(circle);\n    });\n  }\n  \n  function updateStats() {\n    var strong = 0;\n    var fading = 0;\n    var gone = 0;\n    \n    links.forEach(function(link) {\n      var state = getState(link);\n      if (state === 'strong') strong++;\n      else if (state === 'fading') fading++;\n      else gone++;\n    });\n    \n    strongCountEl.textContent = strong;\n    fadingCountEl.textContent = fading;\n    goneCountEl.textContent = gone;\n    \n    if (gone === 0 && fading === 0) {\n      caption.textContent = 'All connections start strong. Click them to keep them alive as time passes.';\n    } else if (gone === 0) {\n      caption.textContent = 'Some connections are fading. Click them to restore their strength before they disappear.';\n    } else if (strong > 6) {\n      caption.textContent = 'Connections you activate regularly survive. Neglected connections have started disappearing.';\n    } else if (strong > 3) {\n      caption.textContent = 'The network is shrinking. Only the connections you actively maintain remain strong.';\n    } else {\n      caption.textContent = 'Most connections are gone. The network retains only what you choose to keep alive.';\n    }\n  }\n  \n  function tick() {\n    tickCount++;\n    render();\n    updateStats();\n  }\n  \n  tickBtn.addEventListener('click', function() {\n    tick();\n    if (window.parent) {\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n    }\n  });\n  \n  resetBtn.addEventListener('click', function() {\n    init();\n    if (window.parent) {\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n    }\n  });\n  \n  window.addEventListener('resize', render);\n  init();\n})();\n</script>\n</body>\n</html>"
  }
}
