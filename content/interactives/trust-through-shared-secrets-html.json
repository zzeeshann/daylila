{
  "slug": "trust-through-shared-secrets",
  "type": "html",
  "title": "Lock-and-Key Pairing",
  "concept": "A message encrypted with one key can only be decrypted by its paired key—the sender scrambles with a public key that anyone can see, but only the recipient's private key can unscramble it.",
  "interactiveId": "f5a34a22-c22f-4816-af14-7d2c9e947f2a",
  "sourcePieceId": "e772ca93-49fc-448e-92ad-8eeeddf4b597",
  "publishedAt": 1778551630679,
  "voiceScore": 90,
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Lock-and-Key Pairing</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #d63031;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .demo {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    gap: 20px;\n    align-items: center;\n    margin: 24px 0;\n  }\n  .party {\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 8px;\n  }\n  .party-label {\n    font-weight: 600;\n    margin-bottom: 10px;\n    font-size: 0.9rem;\n  }\n  .key-display {\n    font-family: \"Courier New\", monospace;\n    font-size: 0.75rem;\n    padding: 8px;\n    background: var(--bg);\n    border-radius: 4px;\n    margin: 6px 0;\n    word-break: break-all;\n    color: var(--muted);\n  }\n  .key-type {\n    font-size: 0.7rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n    margin-bottom: 4px;\n  }\n  .message-box {\n    margin-top: 12px;\n  }\n  .message-box textarea {\n    width: 100%;\n    min-height: 60px;\n    padding: 8px;\n    border: 1px solid var(--line);\n    border-radius: 4px;\n    font-family: inherit;\n    font-size: 0.875rem;\n    resize: vertical;\n  }\n  .message-box textarea:focus {\n    outline: 2px solid var(--teal);\n    outline-offset: 1px;\n  }\n  .transit {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n  }\n  .arrow {\n    width: 40px;\n    height: 2px;\n    background: var(--muted);\n    position: relative;\n  }\n  .arrow::after {\n    content: \"\";\n    position: absolute;\n    right: -6px;\n    top: -3px;\n    width: 0;\n    height: 0;\n    border-left: 8px solid var(--muted);\n    border-top: 4px solid transparent;\n    border-bottom: 4px solid transparent;\n  }\n  .encrypted-blob {\n    padding: 10px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-family: \"Courier New\", monospace;\n    font-size: 0.7rem;\n    word-break: break-all;\n    max-width: 120px;\n    text-align: center;\n    color: var(--teal);\n    font-weight: 600;\n  }\n  .status {\n    margin: 18px 0;\n    padding: 12px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .status strong {\n    font-weight: 600;\n  }\n  .status.success {\n    border-color: var(--teal);\n    background: #f0f9f8;\n  }\n  .status.error {\n    border-color: var(--red);\n    background: #fff5f5;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  button {\n    padding: 8px 16px;\n    background: var(--teal);\n    color: #fff;\n    border: none;\n    border-radius: 4px;\n    font-weight: 500;\n    cursor: pointer;\n    font-size: 0.875rem;\n    margin-top: 8px;\n  }\n  button:hover {\n    background: #145650;\n  }\n  button:active {\n    transform: translateY(1px);\n  }\n  .try-section {\n    margin-top: 24px;\n    padding-top: 24px;\n    border-top: 1px solid var(--line);\n  }\n  .try-section h3 {\n    font-size: 0.95rem;\n    font-weight: 600;\n    margin: 0 0 12px;\n  }\n  .wrong-key-demo {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px;\n    margin-top: 12px;\n  }\n  .wrong-key-box {\n    padding: 12px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .wrong-key-box h4 {\n    font-size: 0.85rem;\n    font-weight: 600;\n    margin: 0 0 8px;\n  }\n  @media (max-width: 640px) {\n    .demo {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n    .transit {\n      flex-direction: row;\n    }\n    .arrow {\n      transform: rotate(90deg);\n    }\n    .wrong-key-demo {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Type a message and watch it encrypt</h2>\n<p class=\"subhead\">The sender scrambles with the recipient's public key. Only the recipient's private key can unscramble it.</p>\n\n<div class=\"demo\">\n  <div class=\"party\">\n    <div class=\"party-label\">Sender</div>\n    <div class=\"message-box\">\n      <textarea id=\"plaintext\" placeholder=\"Type your message here...\">Hello</textarea>\n    </div>\n    <button id=\"encrypt-btn\">Encrypt and send</button>\n  </div>\n\n  <div class=\"transit\">\n    <div class=\"arrow\" aria-hidden=\"true\"></div>\n    <div class=\"encrypted-blob\" id=\"encrypted-display\">—</div>\n    <div class=\"arrow\" aria-hidden=\"true\"></div>\n  </div>\n\n  <div class=\"party\">\n    <div class=\"party-label\">Recipient</div>\n    <div class=\"key-type\">Public key (anyone can see)</div>\n    <div class=\"key-display\" id=\"public-key\">—</div>\n    <div class=\"key-type\">Private key (only recipient has)</div>\n    <div class=\"key-display\" id=\"private-key\">—</div>\n    <div class=\"message-box\">\n      <textarea id=\"decrypted\" placeholder=\"Decrypted message appears here...\" readonly></textarea>\n    </div>\n  </div>\n</div>\n\n<div class=\"status\" id=\"status\" style=\"display:none;\">\n  <strong id=\"status-label\">Status:</strong> <span id=\"status-text\"></span>\n</div>\n\n<p class=\"caption\" id=\"caption\">The encrypted blob is unreadable noise. Only the paired private key can turn it back into the original message.</p>\n\n<div class=\"try-section\">\n  <h3>What happens with the wrong key?</h3>\n  <div class=\"wrong-key-demo\">\n    <div class=\"wrong-key-box\">\n      <h4>With the correct private key</h4>\n      <div class=\"key-display\" style=\"font-size: 0.7rem; margin-bottom: 8px;\" id=\"correct-key-display\">—</div>\n      <div style=\"padding: 8px; background: var(--bg); border-radius: 4px; font-size: 0.85rem;\" id=\"correct-decrypt\">—</div>\n    </div>\n    <div class=\"wrong-key-box\">\n      <h4>With a different private key</h4>\n      <div class=\"key-display\" style=\"font-size: 0.7rem; margin-bottom: 8px;\" id=\"wrong-key-display\">—</div>\n      <div style=\"padding: 8px; background: var(--bg); border-radius: 4px; font-size: 0.85rem; color: var(--red); font-weight: 500;\" id=\"wrong-decrypt\">Decryption failed: noise</div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  // Simplified RSA-like demo using basic modular arithmetic.\n  // NOT cryptographically secure—purely pedagogical.\n\n  function generateKeyPair() {\n    // Small primes for demo clarity\n    var p = 61;\n    var q = 53;\n    var n = p * q; // 3233\n    var phi = (p - 1) * (q - 1); // 3120\n    var e = 17; // public exponent\n    var d = modInverse(e, phi); // private exponent\n    return {\n      publicKey: { e: e, n: n },\n      privateKey: { d: d, n: n }\n    };\n  }\n\n  function modInverse(a, m) {\n    // Extended Euclidean algorithm\n    var m0 = m, x0 = 0, x1 = 1;\n    if (m === 1) return 0;\n    while (a > 1) {\n      var q = Math.floor(a / m);\n      var t = m;\n      m = a % m;\n      a = t;\n      t = x0;\n      x0 = x1 - q * x0;\n      x1 = t;\n    }\n    if (x1 < 0) x1 += m0;\n    return x1;\n  }\n\n  function modPow(base, exp, mod) {\n    var result = 1;\n    base = base % mod;\n    while (exp > 0) {\n      if (exp % 2 === 1) result = (result * base) % mod;\n      exp = Math.floor(exp / 2);\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  function encrypt(plaintext, publicKey) {\n    var encrypted = [];\n    for (var i = 0; i < plaintext.length; i++) {\n      var charCode = plaintext.charCodeAt(i);\n      var enc = modPow(charCode, publicKey.e, publicKey.n);\n      encrypted.push(enc);\n    }\n    return encrypted;\n  }\n\n  function decrypt(encrypted, privateKey) {\n    var decrypted = \"\";\n    for (var i = 0; i < encrypted.length; i++) {\n      var dec = modPow(encrypted[i], privateKey.d, privateKey.n);\n      decrypted += String.fromCharCode(dec);\n    }\n    return decrypted;\n  }\n\n  function toHex(arr) {\n    return arr.map(function(n) { return n.toString(16).toUpperCase(); }).join(\"\");\n  }\n\n  var recipientKeys = generateKeyPair();\n  var wrongKeys = generateKeyPair(); // different key pair for comparison\n\n  var plaintextEl = document.getElementById(\"plaintext\");\n  var encryptedDisplayEl = document.getElementById(\"encrypted-display\");\n  var decryptedEl = document.getElementById(\"decrypted\");\n  var publicKeyEl = document.getElementById(\"public-key\");\n  var privateKeyEl = document.getElementById(\"private-key\");\n  var statusEl = document.getElementById(\"status\");\n  var statusLabelEl = document.getElementById(\"status-label\");\n  var statusTextEl = document.getElementById(\"status-text\");\n  var captionEl = document.getElementById(\"caption\");\n  var encryptBtn = document.getElementById(\"encrypt-btn\");\n\n  var correctKeyDisplayEl = document.getElementById(\"correct-key-display\");\n  var wrongKeyDisplayEl = document.getElementById(\"wrong-key-display\");\n  var correctDecryptEl = document.getElementById(\"correct-decrypt\");\n  var wrongDecryptEl = document.getElementById(\"wrong-decrypt\");\n\n  publicKeyEl.textContent = \"e=\" + recipientKeys.publicKey.e + \", n=\" + recipientKeys.publicKey.n;\n  privateKeyEl.textContent = \"d=\" + recipientKeys.privateKey.d + \", n=\" + recipientKeys.privateKey.n;\n\n  correctKeyDisplayEl.textContent = \"d=\" + recipientKeys.privateKey.d + \", n=\" + recipientKeys.privateKey.n;\n  wrongKeyDisplayEl.textContent = \"d=\" + wrongKeys.privateKey.d + \", n=\" + wrongKeys.privateKey.n;\n\n  var currentEncrypted = null;\n\n  function runEncryption() {\n    var plaintext = plaintextEl.value;\n    if (plaintext.length === 0) {\n      statusEl.style.display = \"block\";\n      statusEl.className = \"status error\";\n      statusTextEl.textContent = \"Type a message first.\";\n      return;\n    }\n\n    currentEncrypted = encrypt(plaintext, recipientKeys.publicKey);\n    var encHex = toHex(currentEncrypted);\n    encryptedDisplayEl.textContent = encHex.substring(0, 16) + \"...\";\n\n    var decrypted = decrypt(currentEncrypted, recipientKeys.privateKey);\n    decryptedEl.value = decrypted;\n\n    statusEl.style.display = \"block\";\n    statusEl.className = \"status success\";\n    statusTextEl.textContent = \"Message encrypted and decrypted successfully.\";\n\n    captionEl.textContent = \"The encrypted blob is unreadable noise. Only the paired private key turns it back into \\\"\" + plaintext + \"\\\".\";\n\n    // Update the comparison boxes\n    correctDecryptEl.textContent = decrypted;\n    try {\n      var wrongDecrypted = decrypt(currentEncrypted, wrongKeys.privateKey);\n      // It will likely produce garbage characters\n      var displayWrong = \"\";\n      for (var i = 0; i < wrongDecrypted.length; i++) {\n        var code = wrongDecrypted.charCodeAt(i);\n        if (code < 32 || code > 126) {\n          displayWrong += \"�\";\n        } else {\n          displayWrong += wrongDecrypted[i];\n        }\n      }\n      wrongDecryptEl.textContent = \"Decryption failed: \" + displayWrong;\n    } catch (e) {\n      wrongDecryptEl.textContent = \"Decryption failed: noise\";\n    }\n  }\n\n  encryptBtn.addEventListener(\"click\", runEncryption);\n\n  // Initial state\n  runEncryption();\n})();\n</script>\n</body>\n</html>"
  }
}
