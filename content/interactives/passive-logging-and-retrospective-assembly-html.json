  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Passive Accumulation, Active Query</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --pale-gold: #fef9e7;\n    --pale-teal: #e8f4f2;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .timeline-container {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 20px;\n    margin: 24px 0;\n  }\n  .timeline-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 12px;\n  }\n  .timeline {\n    position: relative;\n    height: 60px;\n    background: var(--pale-teal);\n    border-radius: 4px;\n    overflow: visible;\n    margin-bottom: 20px;\n  }\n  .tick {\n    position: absolute;\n    width: 2px;\n    height: 100%;\n    background: var(--muted);\n    top: 0;\n    opacity: 0.3;\n  }\n  .event {\n    position: absolute;\n    width: 4px;\n    height: 100%;\n    background: var(--gold);\n    top: 0;\n    opacity: 0;\n    transition: opacity 200ms ease-out;\n  }\n  .event.accumulated {\n    opacity: 0.8;\n  }\n  .retrieval-window {\n    position: absolute;\n    top: -4px;\n    bottom: -4px;\n    background: rgba(26, 107, 98, 0.12);\n    border-left: 3px solid var(--teal);\n    border-right: 3px solid var(--teal);\n    pointer-events: none;\n    transition: all 200ms ease-out;\n  }\n  .window-label {\n    position: absolute;\n    top: -24px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 0.7rem;\n    color: var(--teal);\n    font-weight: 600;\n    white-space: nowrap;\n  }\n  .control-group {\n    margin: 20px 0;\n  }\n  .control-row {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 14px;\n  }\n  .control-row label {\n    font-weight: 500;\n    min-width: 100px;\n    flex-shrink: 0;\n  }\n  .control-row input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control-row output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 6ch;\n    text-align: right;\n  }\n  .time-axis {\n    display: flex;\n    justify-content: space-between;\n    font-size: 0.7rem;\n    color: var(--muted);\n    margin-top: 6px;\n  }\n  .reading {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n  }\n  .reading strong {\n    font-weight: 600;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 520px) {\n    .control-row {\n      flex-direction: column;\n      align-items: stretch;\n    }\n    .control-row label {\n      min-width: auto;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag the window to query the archive</h2>\n<p class=\"subhead\">Events accumulate continuously. Retrieval is a separate action that defines what becomes visible.</p>\n\n<div class=\"timeline-container\">\n  <div class=\"timeline-label\">Event Archive (accumulating)</div>\n  <div class=\"timeline\" id=\"timeline\" aria-label=\"Event timeline\">\n    <div class=\"retrieval-window\" id=\"window\">\n      <span class=\"window-label\" id=\"window-label\">Query window</span>\n    </div>\n  </div>\n  <div class=\"time-axis\">\n    <span>Day 0</span>\n    <span>Day 30</span>\n    <span>Day 60</span>\n    <span>Day 90</span>\n  </div>\n</div>\n\n<div class=\"control-group\">\n  <div class=\"control-row\">\n    <label for=\"start\">Window start:</label>\n    <input id=\"start\" type=\"range\" min=\"0\" max=\"80\" value=\"20\" step=\"1\" aria-describedby=\"start-out\">\n    <output id=\"start-out\" for=\"start\">Day 20</output>\n  </div>\n  <div class=\"control-row\">\n    <label for=\"end\">Window end:</label>\n    <input id=\"end\" type=\"range\" min=\"20\" max=\"90\" value=\"50\" step=\"1\" aria-describedby=\"end-out\">\n    <output id=\"end-out\" for=\"end\">Day 50</output>\n  </div>\n</div>\n\n<div class=\"reading\">\n  Archive holds <strong id=\"total-events\">0</strong> events.\n  Query window captures <strong id=\"retrieved-events\">0</strong> events.\n</div>\n\n<p class=\"caption\" id=\"caption\">Events accumulate as routine operation. The query window determines what becomes a retrievable record.</p>\n\n<script>\n  (function () {\n    var timeline = document.getElementById('timeline');\n    var windowEl = document.getElementById('window');\n    var windowLabel = document.getElementById('window-label');\n    var startSlider = document.getElementById('start');\n    var endSlider = document.getElementById('end');\n    var startOut = document.getElementById('start-out');\n    var endOut = document.getElementById('end-out');\n    var totalEventsEl = document.getElementById('total-events');\n    var retrievedEventsEl = document.getElementById('retrieved-events');\n    var caption = document.getElementById('caption');\n\n    var totalDays = 90;\n    var events = [];\n    var eventElements = [];\n    var accumulationInterval = null;\n    var dayCounter = 0;\n\n    function initTimeline() {\n      for (var i = 0; i <= totalDays; i += 10) {\n        var tick = document.createElement('div');\n        tick.className = 'tick';\n        tick.style.left = (i / totalDays * 100) + '%';\n        timeline.appendChild(tick);\n      }\n      timeline.appendChild(windowEl);\n    }\n\n    function addEvent(day) {\n      events.push(day);\n      var eventEl = document.createElement('div');\n      eventEl.className = 'event';\n      eventEl.style.left = (day / totalDays * 100) + '%';\n      timeline.insertBefore(eventEl, windowEl);\n      eventElements.push(eventEl);\n      setTimeout(function() {\n        eventEl.classList.add('accumulated');\n      }, 50);\n    }\n\n    function startAccumulation() {\n      accumulationInterval = setInterval(function() {\n        if (dayCounter > totalDays) {\n          clearInterval(accumulationInterval);\n          return;\n        }\n        if (Math.random() < 0.7) {\n          addEvent(dayCounter);\n        }\n        dayCounter++;\n        updateReadout();\n      }, 150);\n    }\n\n    function updateWindow() {\n      var startVal = +startSlider.value;\n      var endVal = +endSlider.value;\n      \n      if (startVal >= endVal) {\n        startVal = endVal - 5;\n        startSlider.value = startVal;\n      }\n      if (endVal <= startVal) {\n        endVal = startVal + 5;\n        endSlider.value = endVal;\n      }\n\n      startOut.textContent = 'Day ' + startVal;\n      endOut.textContent = 'Day ' + endVal;\n\n      var startPercent = (startVal / totalDays) * 100;\n      var endPercent = (endVal / totalDays) * 100;\n      windowEl.style.left = startPercent + '%';\n      windowEl.style.width = (endPercent - startPercent) + '%';\n\n      updateReadout();\n    }\n\n    function updateReadout() {\n      var startVal = +startSlider.value;\n      var endVal = +endSlider.value;\n      var retrieved = 0;\n      for (var i = 0; i < events.length; i++) {\n        if (events[i] >= startVal && events[i] <= endVal) {\n          retrieved++;\n        }\n      }\n      totalEventsEl.textContent = events.length;\n      retrievedEventsEl.textContent = retrieved;\n\n      var span = endVal - startVal;\n      if (retrieved === 0) {\n        caption.textContent = 'The archive contains events outside this window. Moving the window does not change what was recorded.';\n      } else if (span < 15) {\n        caption.textContent = 'A narrow window retrieves a small slice. The full archive remains intact.';\n      } else if (span < 40) {\n        caption.textContent = 'Widening the window captures more events. All were logged before the query.';\n      } else {\n        caption.textContent = 'A wide window retrieves most of the archive. Retrieval is reconstruction, not observation.';\n      }\n    }\n\n    startSlider.addEventListener('input', updateWindow);\n    endSlider.addEventListener('input', updateWindow);\n\n    initTimeline();\n    updateWindow();\n    startAccumulation();\n  })();\n</script>\n</body>\n</html>"
  }
