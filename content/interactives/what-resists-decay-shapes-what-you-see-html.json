{
  "slug": "what-resists-decay-shapes-what-you-see",
  "type": "html",
  "title": "Decay Filters the Record",
  "concept": "When preservation depends on durability, fragile evidence decays faster than stable evidence—what survives teaches you about the filter's selectivity as much as the original population.",
  "interactiveId": "16f9910b-0f6d-4a21-8268-5e81ebf14db6",
  "sourcePieceId": "13ba1f76-4494-464f-80e9-59e716541419",
  "publishedAt": 1777762110287,
  "voiceScore": 78,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Decay Filters the Record</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --durable: #1a6b62;\n    --fragile: #c9a227;\n    --lost: #e8e8e8;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--durable);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 4ch;\n    text-align: right;\n  }\n  .visualization {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 24px;\n    margin: 24px 0;\n  }\n  .panel {\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    padding: 16px;\n  }\n  .panel-title {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin: 0 0 12px;\n  }\n  .population {\n    display: grid;\n    grid-template-columns: repeat(10, 1fr);\n    gap: 4px;\n    margin-bottom: 12px;\n  }\n  .item {\n    aspect-ratio: 1;\n    border-radius: 2px;\n  }\n  .item.durable {\n    background: var(--durable);\n  }\n  .item.fragile {\n    background: var(--fragile);\n  }\n  .item.lost {\n    background: var(--lost);\n    opacity: 0.3;\n  }\n  .legend {\n    display: flex;\n    gap: 16px;\n    margin-top: 12px;\n    font-size: 0.85rem;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-swatch {\n    width: 14px;\n    height: 14px;\n    border-radius: 2px;\n  }\n  .stats {\n    margin: 18px 0 6px;\n    padding: 10px 14px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n    font-size: 0.9rem;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n  }\n  .stat {\n    display: flex;\n    flex-direction: column;\n  }\n  .stat-label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n  }\n  .stat-value {\n    font-weight: 600;\n    font-size: 1.1rem;\n    margin-top: 2px;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  @media (max-width: 600px) {\n    .visualization {\n      grid-template-columns: 1fr;\n    }\n    .stats {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Set burial speed</h2>\n<p class=\"subhead\">Two types of material exist in equal numbers. One resists decay. The other doesn't.</p>\n\n<div class=\"control\">\n  <label for=\"burial\">Burial speed:</label>\n  <input id=\"burial\" type=\"range\" min=\"0\" max=\"100\" value=\"20\" aria-describedby=\"burial-out\">\n  <output id=\"burial-out\" for=\"burial\">20%</output>\n</div>\n\n<div class=\"visualization\">\n  <div class=\"panel\">\n    <div class=\"panel-title\">Living Population</div>\n    <div class=\"population\" id=\"true-pop\"></div>\n    <div class=\"legend\">\n      <div class=\"legend-item\">\n        <div class=\"legend-swatch\" style=\"background: var(--durable);\"></div>\n        <span>Durable</span>\n      </div>\n      <div class=\"legend-item\">\n        <div class=\"legend-swatch\" style=\"background: var(--fragile);\"></div>\n        <span>Fragile</span>\n      </div>\n    </div>\n  </div>\n  <div class=\"panel\">\n    <div class=\"panel-title\">Preserved Record</div>\n    <div class=\"population\" id=\"archive-pop\"></div>\n    <div class=\"legend\">\n      <div class=\"legend-item\">\n        <div class=\"legend-swatch\" style=\"background: var(--durable);\"></div>\n        <span>Durable</span>\n      </div>\n      <div class=\"legend-item\">\n        <div class=\"legend-swatch\" style=\"background: var(--fragile);\"></div>\n        <span>Fragile</span>\n      </div>\n      <div class=\"legend-item\">\n        <div class=\"legend-swatch\" style=\"background: var(--lost);\"></div>\n        <span>Lost</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"stats\">\n  <div class=\"stat\">\n    <span class=\"stat-label\">Durable in record</span>\n    <span class=\"stat-value\" id=\"durable-pct\">83%</span>\n  </div>\n  <div class=\"stat\">\n    <span class=\"stat-label\">Fragile in record</span>\n    <span class=\"stat-value\" id=\"fragile-pct\">17%</span>\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Slow burial gives decay time to work. The record overrepresents durable forms.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('burial');\n    var burialOut = document.getElementById('burial-out');\n    var truePop = document.getElementById('true-pop');\n    var archivePop = document.getElementById('archive-pop');\n    var durablePct = document.getElementById('durable-pct');\n    var fragilePct = document.getElementById('fragile-pct');\n    var caption = document.getElementById('caption');\n\n    var trueComposition = [];\n    for (var i = 0; i < 50; i++) {\n      trueComposition.push(i < 25 ? 'durable' : 'fragile');\n    }\n\n    function shuffle(arr) {\n      var copy = arr.slice();\n      for (var i = copy.length - 1; i > 0; i--) {\n        var j = Math.floor(Math.random() * (i + 1));\n        var temp = copy[i];\n        copy[i] = copy[j];\n        copy[j] = temp;\n      }\n      return copy;\n    }\n\n    var shuffledTrue = shuffle(trueComposition);\n\n    function renderPopulation(container, items) {\n      container.innerHTML = '';\n      for (var i = 0; i < items.length; i++) {\n        var div = document.createElement('div');\n        div.className = 'item ' + items[i];\n        container.appendChild(div);\n      }\n    }\n\n    function update() {\n      var burialSpeed = +slider.value;\n      burialOut.textContent = burialSpeed + '%';\n\n      renderPopulation(truePop, shuffledTrue);\n\n      var archive = [];\n      for (var i = 0; i < shuffledTrue.length; i++) {\n        var type = shuffledTrue[i];\n        if (type === 'durable') {\n          archive.push('durable');\n        } else {\n          if (Math.random() * 100 < burialSpeed) {\n            archive.push('fragile');\n          } else {\n            archive.push('lost');\n          }\n        }\n      }\n\n      renderPopulation(archivePop, archive);\n\n      var durableCount = 0;\n      var fragileCount = 0;\n      for (var j = 0; j < archive.length; j++) {\n        if (archive[j] === 'durable') durableCount++;\n        if (archive[j] === 'fragile') fragileCount++;\n      }\n      var total = durableCount + fragileCount;\n      var durablePercent = total > 0 ? Math.round((durableCount / total) * 100) : 0;\n      var fragilePercent = total > 0 ? Math.round((fragileCount / total) * 100) : 0;\n\n      durablePct.textContent = durablePercent + '%';\n      fragilePct.textContent = fragilePercent + '%';\n\n      if (burialSpeed === 0) {\n        caption.textContent = 'All fragile material lost. The record contains only durable forms.';\n      } else if (burialSpeed < 30) {\n        caption.textContent = 'Slow burial gives decay time to work. The record overrepresents durable forms.';\n      } else if (burialSpeed < 70) {\n        caption.textContent = 'Faster burial traps more fragile material before decay finishes. The record shifts closer to the living mix.';\n      } else {\n        caption.textContent = 'Rapid burial seals fragile material quickly. The preserved record nearly matches the living population.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
