---
import { getCollection, render } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';
import { deriveSlug } from '../../../lib/slug';
import { bundleByPieceId, type InteractiveBundle } from '../../../lib/interactives';
import '../../../styles/made.css';
import '../../../styles/quiz.css';
import '../../../styles/interactive-frame.css';
import '../../../styles/lesson-finish.css';

export async function getStaticPaths() {
  const pieces = await getCollection('dailyPieces');
  // Cross-collection self-join — for each daily piece, find all
  // interactives whose sourcePieceId matches (Area 4 sub-task 4.6,
  // widened to multiple-per-piece in Phase 2 sub-task 2.5: a piece can
  // have BOTH a quiz AND an html artefact).
  const interactives = await getCollection('interactives');
  const bundleByPiece = bundleByPieceId(interactives);
  return pieces.map((piece) => {
    const bundle = bundleByPiece.get(piece.data.pieceId) ?? null;
    return {
      params: { date: piece.data.date, slug: deriveSlug(piece.id) },
      props: { piece, bundle },
    };
  });
}

const { piece, bundle } = Astro.props as {
  piece: Awaited<ReturnType<typeof getCollection<'dailyPieces'>>>[number];
  bundle: InteractiveBundle | null;
};
const { Content } = await render(piece);
---

<LessonLayout
  title={piece.data.title}
  estimatedTime={piece.data.estimatedTime}
  audioBeats={piece.data.audioBeats}
  audioSrc={piece.data.audioSrc}
  beatCount={piece.data.beatCount}
  subject={piece.data.underlyingSubject}
  date={piece.data.date}
  pieceId={piece.data.pieceId}
  publishedAt={piece.data.publishedAt}
  voiceScore={piece.data.voiceScore}
  qualityFlag={piece.data.qualityFlag}
  description={piece.data.description}
  sourceUrl={piece.data.sourceUrl}
  newsSource={piece.data.newsSource}
  interactiveBundle={bundle}
>
  <Content />
</LessonLayout>

<script>
  import '../../../interactive/register';
</script>
