  "title": "Category Elimination",
  "concept": "Each measurement rules out entire classes of possibility by identifying properties incompatible with broad categories; identification emerges as the intersection of what survives successive filters.",
  "interactiveId": "9bdcac0b-57c0-490a-b1f7-5a1b0695ebcd",
  "sourcePieceId": "e55021d2-da15-4aec-a21b-3c691e62372d",
  "publishedAt": 1777350630132,
  "voiceScore": 90,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Category Elimination</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --red: #c94a27;\n    --blue: #275fc9;\n    --purple: #7c27c9;\n    --eliminated: #d4cfc4;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .controls {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    margin-bottom: 24px;\n  }\n  .test-row {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    padding: 10px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .test-row.disabled {\n    opacity: 0.4;\n    pointer-events: none;\n  }\n  .test-row.done {\n    opacity: 0.6;\n  }\n  .test-row label {\n    flex: 1;\n    font-size: 0.9rem;\n    font-weight: 500;\n  }\n  .test-row .eliminates {\n    font-size: 0.8rem;\n    color: var(--muted);\n    margin-right: 8px;\n  }\n  .test-row button {\n    padding: 6px 16px;\n    background: var(--teal);\n    color: white;\n    border: none;\n    border-radius: 4px;\n    font-size: 0.85rem;\n    font-weight: 500;\n    cursor: pointer;\n    transition: background 120ms;\n  }\n  .test-row button:hover {\n    background: #155a52;\n  }\n  .space {\n    margin: 20px 0;\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .space-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: baseline;\n    margin-bottom: 12px;\n  }\n  .space-header strong {\n    font-size: 0.95rem;\n    font-weight: 600;\n  }\n  .space-header .count {\n    font-size: 0.85rem;\n    color: var(--muted);\n    font-variant-numeric: tabular-nums;\n  }\n  .grid {\n    display: grid;\n    grid-template-columns: repeat(25, 1fr);\n    gap: 2px;\n    max-width: 100%;\n  }\n  .cell {\n    aspect-ratio: 1;\n    border-radius: 2px;\n    transition: opacity 400ms ease-out;\n  }\n  .cell.cat-a { background: var(--gold); }\n  .cell.cat-b { background: var(--red); }\n  .cell.cat-c { background: var(--blue); }\n  .cell.cat-d { background: var(--purple); }\n  .cell.eliminated {\n    opacity: 0.15;\n  }\n  .legend {\n    display: flex;\n    gap: 16px;\n    margin-top: 10px;\n    font-size: 0.8rem;\n    flex-wrap: wrap;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .legend-item .swatch {\n    width: 12px;\n    height: 12px;\n    border-radius: 2px;\n  }\n  .legend-item.eliminated {\n    opacity: 0.4;\n    text-decoration: line-through;\n  }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n  }\n  .reset-row {\n    margin-top: 16px;\n    text-align: center;\n  }\n  .reset-row button {\n    padding: 8px 20px;\n    background: var(--line);\n    color: var(--fg);\n    border: none;\n    border-radius: 4px;\n    font-size: 0.85rem;\n    font-weight: 500;\n    cursor: pointer;\n  }\n  .reset-row button:hover {\n    background: #d4cfc4;\n  }\n  @media (max-width: 480px) {\n    .grid {\n      grid-template-columns: repeat(20, 1fr);\n    }\n    .test-row {\n      flex-direction: column;\n      align-items: flex-start;\n    }\n    .test-row .eliminates {\n      margin-right: 0;\n      margin-bottom: 4px;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Apply filters to eliminate entire categories</h2>\n<p class=\"subhead\">Each filter removes all candidates incompatible with one observed property.</p>\n\n<div class=\"controls\">\n  <div class=\"test-row\" data-test=\"0\">\n    <label>Filter Alpha</label>\n    <span class=\"eliminates\">Eliminates: Category A</span>\n    <button onclick=\"runTest(0)\">Apply</button>\n  </div>\n  <div class=\"test-row\" data-test=\"1\">\n    <label>Filter Beta</label>\n    <span class=\"eliminates\">Eliminates: Category B</span>\n    <button onclick=\"runTest(1)\">Apply</button>\n  </div>\n  <div class=\"test-row\" data-test=\"2\">\n    <label>Filter Gamma</label>\n    <span class=\"eliminates\">Eliminates: Category C</span>\n    <button onclick=\"runTest(2)\">Apply</button>\n  </div>\n  <div class=\"test-row\" data-test=\"3\">\n    <label>Filter Delta</label>\n    <span class=\"eliminates\">Eliminates: Category D</span>\n    <button onclick=\"runTest(3)\">Apply</button>\n  </div>\n</div>\n\n<div class=\"space\">\n  <div class=\"space-header\">\n    <strong>Candidate space</strong>\n    <span class=\"count\"><span id=\"remaining\">1000</span> of 1000 remain</span>\n  </div>\n  <div class=\"grid\" id=\"grid\" aria-hidden=\"true\"></div>\n  <div class=\"legend\" id=\"legend\"></div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Four categories, 250 candidates each. Apply the first filter to eliminate an entire category.</p>\n\n<div class=\"reset-row\">\n  <button onclick=\"reset()\">Reset</button>\n</div>\n\n<script>\n(function() {\n  var total = 1000;\n  var perCat = 250;\n  var categories = ['a', 'b', 'c', 'd'];\n  var catNames = ['Category A', 'Category B', 'Category C', 'Category D'];\n  var catColors = ['var(--gold)', 'var(--red)', 'var(--blue)', 'var(--purple)'];\n  var state = [];\n  var currentTest = 0;\n  var grid = document.getElementById('grid');\n  var remaining = document.getElementById('remaining');\n  var caption = document.getElementById('caption');\n  var legend = document.getElementById('legend');\n  var eliminated = [];\n  \n  var captions = [\n    'Four categories, 250 candidates each. Apply the first filter to eliminate an entire category.',\n    'Filter Alpha eliminated Category A. 750 candidates remain across three categories.',\n    'Filter Beta eliminated Category B. 500 candidates remain across two categories.',\n    'Filter Gamma eliminated Category C. 250 candidates remain in one category.',\n    'Filter Delta eliminated Category D. Zero candidates remain — all possibilities ruled out by successive filters.'\n  ];\n\n  function init() {\n    state = [];\n    eliminated = [];\n    for (var i = 0; i < total; i++) {\n      var cat = categories[Math.floor(i / perCat)];\n      state.push({ cat: cat, eliminated: false });\n    }\n    currentTest = 0;\n    renderGrid();\n    renderLegend();\n    updateUI();\n  }\n\n  function renderGrid() {\n    grid.innerHTML = '';\n    for (var i = 0; i < state.length; i++) {\n      var cell = document.createElement('div');\n      cell.className = 'cell cat-' + state[i].cat;\n      if (state[i].eliminated) {\n        cell.classList.add('eliminated');\n      }\n      grid.appendChild(cell);\n    }\n  }\n\n  function renderLegend() {\n    legend.innerHTML = '';\n    for (var i = 0; i < categories.length; i++) {\n      var item = document.createElement('div');\n      item.className = 'legend-item';\n      if (eliminated.indexOf(categories[i]) !== -1) {\n        item.classList.add('eliminated');\n      }\n      var swatch = document.createElement('div');\n      swatch.className = 'swatch cat-' + categories[i];\n      var label = document.createElement('span');\n      label.textContent = catNames[i];\n      item.appendChild(swatch);\n      item.appendChild(label);\n      legend.appendChild(item);\n    }\n  }\n\n  function countRemaining() {\n    var count = 0;\n    for (var i = 0; i < state.length; i++) {\n      if (!state[i].eliminated) count++;\n    }\n    return count;\n  }\n\n  function updateUI() {\n    var rem = countRemaining();\n    remaining.textContent = rem;\n    caption.textContent = captions[currentTest];\n    \n    var rows = document.querySelectorAll('.test-row');\n    for (var i = 0; i < rows.length; i++) {\n      if (i < currentTest) {\n        rows[i].classList.add('done');\n        rows[i].classList.add('disabled');\n      } else if (i === currentTest) {\n        rows[i].classList.remove('disabled');\n        rows[i].classList.remove('done');\n      } else {\n        rows[i].classList.add('disabled');\n      }\n    }\n  }\n\n  window.runTest = function(idx) {\n    if (idx !== currentTest || currentTest >= categories.length) return;\n    \n    var targetCat = categories[currentTest];\n    eliminated.push(targetCat);\n    \n    for (var i = 0; i < state.length; i++) {\n      if (state[i].cat === targetCat) {\n        state[i].eliminated = true;\n      }\n    }\n    \n    renderGrid();\n    renderLegend();\n    currentTest++;\n    updateUI();\n    \n    if (typeof window.parent !== 'undefined' && window.parent !== window) {\n      window.parent.postMessage({type: 'interactive_engagement', event: 'manipulated'}, '*');\n    }\n  };\n\n  window.reset = function() {\n    init();\n  };\n\n  init();\n})();\n</script>\n</body>\n</html>"
  }
}
