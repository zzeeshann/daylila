{
  "slug": "tacit-knowledge-transmission",
  "type": "html",
  "title": "Practice Environment Match",
  "concept": "When training conditions match performance conditions, you acquire skills the test will actually demand—training in controlled conditions optimizes what you can measure but may miss what the real task requires.",
  "interactiveId": "1a2d6f3e-b020-4326-86e7-9d3d19ebe0da",
  "sourcePieceId": "7b1cddee-d352-4664-a204-f6e49ff966bf",
  "publishedAt": 1777860495498,
  "voiceScore": 88,
  "qualityFlag": "low",
  "content": {
    "type": "html",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Practice Environment Match</title>\n<style>\n  :root {\n    --bg: #faf7f1;\n    --fg: #1a1a1a;\n    --muted: #6b6b6b;\n    --line: #e5e0d6;\n    --gold: #c9a227;\n    --teal: #1a6b62;\n    --blue: #4a90e2;\n  }\n  * { box-sizing: border-box; }\n  body {\n    font-family: system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    margin: 0;\n    padding: 20px;\n    color: var(--fg);\n    background: var(--bg);\n    line-height: 1.5;\n  }\n  h2 {\n    font-size: 1.05rem;\n    font-weight: 600;\n    margin: 0 0 4px;\n  }\n  p.subhead {\n    margin: 0 0 20px;\n    color: var(--muted);\n    font-size: 0.9rem;\n  }\n  .control {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 20px;\n  }\n  .control label {\n    font-weight: 500;\n    flex-shrink: 0;\n  }\n  .control input[type=range] {\n    flex: 1;\n    accent-color: var(--teal);\n    min-width: 120px;\n  }\n  .control output {\n    font-variant-numeric: tabular-nums;\n    font-weight: 600;\n    min-width: 3ch;\n    text-align: right;\n  }\n  .environments {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin: 24px 0;\n  }\n  .env-card {\n    background: #fff;\n    border: 2px solid var(--line);\n    border-radius: 8px;\n    padding: 16px;\n  }\n  .env-card h3 {\n    margin: 0 0 12px;\n    font-size: 0.95rem;\n    font-weight: 600;\n  }\n  .env-card.practice { border-color: var(--blue); }\n  .env-card.performance { border-color: var(--gold); }\n  .condition-list {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n  .condition {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 0.85rem;\n  }\n  .condition-icon {\n    width: 16px;\n    height: 16px;\n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n  .condition-icon.present { background: var(--teal); }\n  .condition-icon.absent { background: var(--line); }\n  .results {\n    margin: 24px 0;\n    padding: 16px;\n    background: #fff;\n    border: 1px solid var(--line);\n    border-radius: 6px;\n  }\n  .results h3 {\n    margin: 0 0 12px;\n    font-size: 0.95rem;\n    font-weight: 600;\n  }\n  .skill-bars {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n  .skill-bar {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n  .skill-label {\n    font-size: 0.8rem;\n    color: var(--muted);\n    display: flex;\n    justify-content: space-between;\n  }\n  .bar-track {\n    height: 24px;\n    background: var(--line);\n    border-radius: 4px;\n    overflow: hidden;\n    position: relative;\n  }\n  .bar-fill {\n    height: 100%;\n    transition: width 300ms ease-out;\n  }\n  .bar-fill.measured { background: var(--blue); }\n  .bar-fill.unmeasured { background: var(--gold); }\n  .bar-fill.combined { background: linear-gradient(to right, var(--blue) 0%, var(--blue) var(--measured-pct), var(--gold) var(--measured-pct), var(--gold) 100%); }\n  p.caption {\n    margin: 14px 0 0;\n    color: var(--muted);\n    font-size: 0.875rem;\n    line-height: 1.4;\n  }\n  .score {\n    margin: 16px 0 0;\n    padding: 12px;\n    background: var(--bg);\n    border-radius: 4px;\n    font-size: 0.9rem;\n  }\n  .score strong {\n    font-weight: 600;\n  }\n  @media (max-width: 580px) {\n    .environments {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n<h2>Drag to shift practice toward performance conditions</h2>\n<p class=\"subhead\">Training can happen in controlled settings or in conditions that match the real task.</p>\n\n<div class=\"control\">\n  <label for=\"match\">Environment match:</label>\n  <input id=\"match\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" aria-describedby=\"match-out\">\n  <output id=\"match-out\" for=\"match\">0%</output>\n</div>\n\n<div class=\"environments\">\n  <div class=\"env-card practice\">\n    <h3>Practice Setting</h3>\n    <div class=\"condition-list\" id=\"practice-conditions\"></div>\n  </div>\n  <div class=\"env-card performance\">\n    <h3>Performance Setting</h3>\n    <div class=\"condition-list\" id=\"performance-conditions\"></div>\n  </div>\n</div>\n\n<div class=\"results\">\n  <h3>Skills Acquired</h3>\n  <div class=\"skill-bars\">\n    <div class=\"skill-bar\">\n      <div class=\"skill-label\">\n        <span>Measurable skills (heart rate control, pacing consistency)</span>\n        <span id=\"measured-val\">100%</span>\n      </div>\n      <div class=\"bar-track\">\n        <div class=\"bar-fill measured\" id=\"measured-bar\"></div>\n      </div>\n    </div>\n    <div class=\"skill-bar\">\n      <div class=\"skill-label\">\n        <span>Context skills (responding to surges, uneven terrain navigation)</span>\n        <span id=\"unmeasured-val\">0%</span>\n      </div>\n      <div class=\"bar-track\">\n        <div class=\"bar-fill unmeasured\" id=\"unmeasured-bar\"></div>\n      </div>\n    </div>\n  </div>\n  <div class=\"score\">\n    Performance score: <strong id=\"perf-score\">50</strong> / 100\n  </div>\n</div>\n\n<p class=\"caption\" id=\"caption\">Controlled practice optimizes what you can measure. Performance demands both measured and contextual skills.</p>\n\n<script>\n  (function () {\n    var slider = document.getElementById('match');\n    var matchOut = document.getElementById('match-out');\n    var practiceList = document.getElementById('practice-conditions');\n    var performanceList = document.getElementById('performance-conditions');\n    var measuredBar = document.getElementById('measured-bar');\n    var unmeasuredBar = document.getElementById('unmeasured-bar');\n    var measuredVal = document.getElementById('measured-val');\n    var unmeasuredVal = document.getElementById('unmeasured-val');\n    var perfScore = document.getElementById('perf-score');\n    var caption = document.getElementById('caption');\n\n    var practiceConditions = [\n      { name: 'Controlled temperature', needsMatch: false },\n      { name: 'Flat, even surface', needsMatch: false },\n      { name: 'Solo runs with monitor', needsMatch: false },\n      { name: 'Variable terrain', needsMatch: true },\n      { name: 'Group dynamics', needsMatch: true },\n      { name: 'Weather exposure', needsMatch: true }\n    ];\n\n    var performanceConditions = [\n      { name: 'Variable terrain', present: true },\n      { name: 'Tactical racing (responding to others)', present: true },\n      { name: 'Weather shifts', present: true },\n      { name: 'Altitude or heat', present: true }\n    ];\n\n    function renderConditions(list, conditions, matchPct) {\n      list.innerHTML = '';\n      conditions.forEach(function (c) {\n        var div = document.createElement('div');\n        div.className = 'condition';\n        var icon = document.createElement('div');\n        icon.className = 'condition-icon';\n        var present = c.present !== undefined ? c.present : (c.needsMatch ? matchPct >= 30 : true);\n        icon.classList.add(present ? 'present' : 'absent');\n        var label = document.createElement('span');\n        label.textContent = c.name;\n        div.appendChild(icon);\n        div.appendChild(label);\n        list.appendChild(div);\n      });\n    }\n\n    function update() {\n      var match = +slider.value;\n      matchOut.textContent = match + '%';\n\n      // As match increases, practice conditions shift toward performance conditions\n      renderConditions(practiceList, practiceConditions, match);\n      renderConditions(performanceList, performanceConditions, match);\n\n      // Measurable skills: high when match is low (controlled practice optimizes these)\n      // They don't disappear, but priority shifts\n      var measuredSkill = Math.max(50, 100 - match * 0.5);\n      \n      // Context skills: low when match is low, high when match is high\n      var unmeasuredSkill = match;\n\n      measuredBar.style.width = measuredSkill + '%';\n      unmeasuredBar.style.width = unmeasuredSkill + '%';\n      measuredVal.textContent = Math.round(measuredSkill) + '%';\n      unmeasuredVal.textContent = Math.round(unmeasuredSkill) + '%';\n\n      // Performance score: weighted combination\n      // Real performance needs both, but context skills matter more (60/40 split)\n      var score = Math.round(measuredSkill * 0.4 + unmeasuredSkill * 0.6);\n      perfScore.textContent = score;\n\n      if (match === 0) {\n        caption.textContent = 'Controlled practice optimizes what you can measure. Performance demands both measured and contextual skills.';\n      } else if (match < 40) {\n        caption.textContent = 'Some real conditions enter practice. Measurable skills remain strong while context skills begin developing.';\n      } else if (match < 70) {\n        caption.textContent = 'Practice now includes most performance conditions. Context skills grow; measured skills stay present but share focus.';\n      } else {\n        caption.textContent = 'Practice matches performance closely. Context skills reach high levels. Performance score peaks when training includes the conditions the task will demand.';\n      }\n    }\n\n    slider.addEventListener('input', update);\n    update();\n  })();\n</script>\n</body>\n</html>"
  }
}
