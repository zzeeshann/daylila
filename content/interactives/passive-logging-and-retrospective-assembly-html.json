  "title": "Passive Accumulation, Active Query",
  "concept": "A system that records continuously creates a complete archive without anyone watching—the difference between accumulation and surveillance appears only when someone decides what window to retrieve.",
  "interactiveId": "62f0de33-c9a5-4d19-abfb-ab6504307045",
  "sourcePieceId": "923402b1-c39f-4118-b93b-01b9c88fb7a9",
